---
interface Props {
  name?: string
  value?: string
  rows?: number
}
const { name = 'formula', value = '', rows = 5 } = Astro.props
---

<div class="formula-editor-wrap">
  <!-- Toolbar: operators & functions -->
  <div class="fe-toolbar">
    {
      [
        { label: '+', insert: '+' },
        { label: '−', insert: '-' },
        { label: '×', insert: '*' },
        { label: '÷', insert: '/' },
        { label: '( )', insert: '()' },
        { label: 'IF', insert: 'IF(condicion, valor_si, valor_no)' },
        { label: 'ROUND', insert: 'ROUND(valor, 2)' },
        { label: 'MIN', insert: 'MIN(a, b)' },
        { label: 'MAX', insert: 'MAX(a, b)' },
        { label: 'ABS', insert: 'ABS(valor)' },
      ].map((op) => (
        <button
          type="button"
          class="fe-op"
          data-insert={op.insert}
          title={op.insert}
        >
          {op.label}
        </button>
      ))
    }
  </div>

  <!-- Textarea -->
  <textarea
    id="formula-textarea"
    name={name}
    class="fe-textarea"
    rows={rows}
    spellcheck="false"
    autocomplete="off"
    placeholder="SALARIO * DIAS_TRABAJADOS / DIAS_PERIODO"
  >{value}</textarea>

  <!-- Variable reference panel -->
  <div class="fe-vars-panel">
    <p class="fe-vars-title">Variables disponibles — clic para insertar</p>
    <div class="fe-vars-grid">
      {
        [
          { name: 'SALARIO', desc: 'Salario base' },
          { name: 'SALARIO_DIARIO', desc: 'Salario base ÷ 30' },
          { name: 'DIAS_PERIODO', desc: 'Total días del período' },
          { name: 'DIAS_TRABAJADOS', desc: 'Días trabajados' },
          { name: 'DIAS_HABILES', desc: 'Días hábiles del período' },
          { name: 'DIAS_AUSENCIA', desc: 'Días de ausencia' },
          { name: 'HORAS_EXTRA', desc: 'Horas extra trabajadas' },
          { name: 'MINUTOS_EXTRA', desc: 'Minutos extra trabajados' },
          { name: 'MINUTOS_TARDANZA', desc: 'Minutos de tardanza' },
          { name: 'HORAS', desc: 'Horas trabajadas (días × 8)' },
          { name: 'ANTIGUEDAD', desc: 'Antigüedad en años' },
          { name: 'ANTIGUEDAD_DIAS', desc: 'Antigüedad en días' },
          { name: 'FECHAINICIO', desc: 'Inicio período (YYYYMMDD)' },
          { name: 'FECHAFIN', desc: 'Fin período (YYYYMMDD)' },
          { name: 'FECHAPAGO', desc: 'Fecha de pago (YYYYMMDD)' },
          { name: 'GASTOS_REP', desc: 'Gastos de representación' },
          { name: 'FICHA', desc: 'Código del empleado' },
          { name: 'DIAS_HABILES_XIII', desc: 'Días trabajados en período XIII' },
        ].map((v) => (
          <button
            type="button"
            class="fe-var"
            data-insert={v.name}
            title={v.desc}
          >
            <span class="fe-var-name">{v.name}</span>
            <span class="fe-var-desc">{v.desc}</span>
          </button>
        ))
      }
    </div>
  </div>
</div>

<script>
  function initFormulaEditor(wrap: HTMLElement) {
    const ta = wrap.querySelector<HTMLTextAreaElement>('#formula-textarea')
    if (!ta) return

    wrap.querySelectorAll<HTMLButtonElement>('[data-insert]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const snippet = btn.dataset.insert ?? ''
        const start = ta.selectionStart
        const end = ta.selectionEnd
        const before = ta.value.slice(0, start)
        const after = ta.value.slice(end)

        // Smart spacing: add space before if previous char is word char
        const needSpaceBefore =
          before.length > 0 && /[\w\d]$/.test(before) && /^\w/.test(snippet)
        const needSpaceAfter =
          after.length > 0 && /^\w/.test(after) && /[\w\d]$/.test(snippet)

        const inserted =
          (needSpaceBefore ? ' ' : '') + snippet + (needSpaceAfter ? ' ' : '')
        ta.value = before + inserted + after

        // Position cursor inside parens if snippet ends with ()
        const cursor = start + inserted.length
        const parenPos = before.length + (needSpaceBefore ? 1 : 0) + snippet.indexOf('(')
        if (snippet.includes('(') && snippet.includes(')')) {
          ta.setSelectionRange(parenPos + 1, parenPos + 1)
        } else {
          ta.setSelectionRange(cursor, cursor)
        }
        ta.focus()
      })
    })
  }

  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll<HTMLElement>('.formula-editor-wrap').forEach(initFormulaEditor)
  })
</script>

<style>
  /*
   * Editor de fórmulas — usa las CSS custom properties del sistema
   * para integrarse al tema activo. Antes las clases tailwind fijas
   * (`bg-gray-50`, `bg-white`, `hover:bg-blue-50`) dejaban el panel
   * casi blanco sobre el fondo oscuro, sin contraste razonable.
   */
  .formula-editor-wrap {
    border-radius: 0.5rem;
    border: 1px solid var(--rule);
    overflow: hidden;
    background: var(--ink-2);
    transition: border-color 120ms, box-shadow 120ms;
  }
  .formula-editor-wrap:focus-within {
    border-color: transparent;
    box-shadow: 0 0 0 2px var(--navy, #2563eb);
  }

  .fe-toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    padding: 0.5rem 0.75rem;
    background: var(--ink-3);
    border-bottom: 1px solid var(--rule);
  }

  .fe-op {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.6rem;
    border-radius: 0.25rem;
    font-family: var(--f-mono, ui-monospace, monospace);
    font-size: 0.75rem;
    font-weight: 600;
    background: var(--ink-2);
    border: 1px solid var(--rule);
    color: var(--fore-dim);
    cursor: pointer;
    user-select: none;
    transition: background-color 120ms, border-color 120ms, color 120ms;
  }
  .fe-op:hover,
  .fe-op:focus-visible {
    background: var(--ink-4);
    border-color: var(--rule-hi);
    color: var(--fore);
  }

  .fe-textarea {
    width: 100%;
    padding: 0.75rem;
    font-family: var(--f-mono, ui-monospace, monospace);
    font-size: 0.75rem;
    line-height: 1.6;
    color: var(--fore);
    background: var(--ink-2);
    resize: none;
    border: none;
    outline: none;
  }
  .fe-textarea::placeholder {
    color: var(--mute);
  }

  .fe-vars-panel {
    border-top: 1px solid var(--rule);
    background: var(--ink-3);
    padding: 0.75rem;
  }

  .fe-vars-title {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--mute-2);
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .fe-vars-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .fe-var {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 0.25rem 0.6rem;
    border-radius: 0.375rem;
    border: 1px solid var(--rule);
    background: var(--ink-2);
    color: var(--fore-dim);
    cursor: pointer;
    user-select: none;
    text-align: left;
    transition: background-color 120ms, border-color 120ms, color 120ms;
  }
  .fe-var:hover,
  .fe-var:focus-visible {
    background: var(--ink-4);
    border-color: var(--navy, #2563eb);
    color: var(--fore);
  }

  .fe-var-name {
    font-family: var(--f-mono, ui-monospace, monospace);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--navy-hi, #60a5fa);
    line-height: 1;
  }
  [data-theme='light'] .fe-var-name {
    color: #1d4ed8;
  }

  .fe-var-desc {
    font-size: 0.625rem;
    color: var(--mute);
    line-height: 1.2;
    margin-top: 0.125rem;
  }
</style>

---
// Inputs de campos adicionales (custom_field_definitions) para los
// formularios de empleado. Cada input usa name="cf_<code>" y un valor
// ya resuelto (almacenado o valor por defecto) pasado en `values`.
interface CustomFieldDef {
  code: string
  name: string
  description: string | null
  fieldType: 'text' | 'integer' | 'float' | 'date'
  isRequired: boolean
}
interface Props {
  defs: CustomFieldDef[]
  values: Record<string, string>
}
const { defs, values } = Astro.props
const baseClass =
  'w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent'
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
  {defs.map((cf) => {
    const inputName = `cf_${cf.code}`
    const value = values[cf.code] ?? ''
    return (
      <div data-cf-row={cf.code}>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          {cf.name}
          {cf.isRequired && <span class="text-red-500 ml-0.5">*</span>}
        </label>
        {cf.fieldType === 'integer' && (
          <input type="number" step="1" name={inputName} value={value} required={cf.isRequired} class={baseClass} />
        )}
        {cf.fieldType === 'float' && (
          <input type="number" step="0.01" name={inputName} value={value} required={cf.isRequired} class={baseClass} />
        )}
        {cf.fieldType === 'date' && (
          <input type="date" name={inputName} value={value} required={cf.isRequired} class={baseClass} />
        )}
        {cf.fieldType === 'text' && (
          <input type="text" name={inputName} value={value} required={cf.isRequired} maxlength="255" class={baseClass} />
        )}
        <p class="mt-1 text-xs text-gray-400 font-mono">
          {cf.code}
          {cf.description && <span class="text-gray-500"> · {cf.description}</span>}
        </p>
      </div>
    )
  })}
</div>

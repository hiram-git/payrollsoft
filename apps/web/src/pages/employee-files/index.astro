    [data-theme='light'] .ef-input          { background: #ffffff; }
    [data-theme='light'] .ef-input:disabled,
    [data-theme='light'] .ef-input-readonly { background: #f3f4f6; }
    [data-theme='light'] .ef-btn-secondary  { background: #ffffff; }
    [data-theme='light'] .ef-btn-secondary:hover { background: #f3f4f6; }
    [data-theme='light'] .ef-dropdown       { background: #ffffff; }

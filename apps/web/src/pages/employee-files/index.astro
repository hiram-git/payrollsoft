---
import ServerToastBridge from '../../components/ServerToastBridge.astro'
import AppLayout from '../../layouts/AppLayout.astro'
import { can, getIdentity } from '../../lib/auth'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'

const identity = getIdentity(Astro.cookies)
if (!identity) return Astro.redirect('/login')
if (!can(identity, 'employee_files:read')) return Astro.redirect('/dashboard')

const tenantSlug = identity.tenantSlug ?? 'demo'
const headers = { Cookie: `auth=${identity.raw}`, 'X-Tenant': tenantSlug }
const canWrite = can(identity, 'employee_files:write')
const canDelete = can(identity, 'employee_files:delete')

type Employee = {
  id: string
  code: string
  firstName: string
  lastName: string
  idNumber: string | null
  isActive: boolean
}
type FileRow = {
  id: string
  employeeId: string
  typeId: number
  subtypeId: number
  documentDate: string
  documentNumber: string
  observations: string | null
  extraFields: Record<string, unknown>
  approvalStatus: 'pending' | 'approved' | 'rejected'
  rejectionReason: string | null
  createdAt: string
}
type TypeRow = { id: number; code: string; name: string }
type SubtypeRow = { id: number; code: string; name: string; typeId: number }

const employeeId = (Astro.url.searchParams.get('employeeId') ?? '').trim()

let employees: Employee[] = []
try {
  const res = await fetch(`${API_URL}/employees?limit=5000&isActive=true`, { headers })
  if (res.status === 401) return Astro.redirect('/login')
  if (res.ok) {
    employees = ((await res.json()) as { data: Employee[] }).data ?? []
  }
} catch {
  /* tabla queda vacía si el listado falla */
}

let selectedEmployee: Employee | null = null
let files: FileRow[] = []
let types: TypeRow[] = []
const subtypes: SubtypeRow[] = []

if (employeeId) {
  try {
    const [empRes, listRes, typesRes] = await Promise.all([
      fetch(`${API_URL}/employees/${employeeId}`, { headers }),
      fetch(`${API_URL}/employee-files?employeeId=${employeeId}`, { headers }),
      fetch(`${API_URL}/employee-files/types`, { headers }),
    ])
    if (empRes.ok) selectedEmployee = ((await empRes.json()) as { data: Employee }).data
    if (listRes.ok) files = ((await listRes.json()) as { data: FileRow[] }).data ?? []
    if (typesRes.ok) types = ((await typesRes.json()) as { data: TypeRow[] }).data ?? []

    const distinctTypeIds = Array.from(new Set(files.map((f) => f.typeId)))
    for (const tid of distinctTypeIds) {
      try {
        const sres = await fetch(`${API_URL}/employee-files/types/${tid}/subtypes`, { headers })
        if (sres.ok) {
          const subs = ((await sres.json()) as { data: SubtypeRow[] }).data ?? []
          subtypes.push(...subs.map((s) => ({ ...s, typeId: tid })))
        }
      } catch {
        /* best-effort */
      }
    }
  } catch {
    /* listado vacío */
  }
}

const typeById = new Map(types.map((t) => [t.id, t]))
const subtypeById = new Map(subtypes.map((s) => [s.id, s]))

function fmtDate(s: string): string {
  if (!s) return '—'
  const [y, m, d] = s.slice(0, 10).split('-')
  return `${d}-${m}-${y}`
}

// Agrupar expedientes por tipo para mostrar categorizados en el listado.
const filesByType = new Map<number, FileRow[]>()
for (const f of files) {
  const arr = filesByType.get(f.typeId) ?? []
  arr.push(f)
  filesByType.set(f.typeId, arr)
}
const typesWithFiles = Array.from(filesByType.keys())
  .map((tid) => ({ type: typeById.get(tid), rows: filesByType.get(tid) ?? [] }))
  .filter((g): g is { type: TypeRow; rows: FileRow[] } => Boolean(g.type))
  .sort((a, b) => a.type.name.localeCompare(b.type.name, 'es'))

const today = new Date().toISOString().slice(0, 10)
const flash = Astro.url.searchParams.get('flash')
const errorMsg = Astro.url.searchParams.get('error') ?? ''
---

<AppLayout title="Expedientes de empleados">
  <div class="mx-auto w-full max-w-7xl p-8 lg:w-3/4">
    <div class="mb-6">
      <h1 class="text-xl font-semibold tracking-tight ef-title">Expedientes de empleados</h1>
      <p class="text-sm mt-0.5 ef-subtitle">
        Busca un empleado y registra sus expedientes (estudios, permisos, licencias, etc.)
        directamente en esta vista, categorizados por tipo y subtipo.
      </p>
    </div>

    {flash === 'created' && (
      <div class="mb-4 rounded-md bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700" data-server-toast="success">Expediente creado.</div>
    )}
    {flash === 'updated' && (
      <div class="mb-4 rounded-md bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700" data-server-toast="success">Expediente actualizado.</div>
    )}
    {flash === 'deleted' && (
      <div class="mb-4 rounded-md bg-amber-50 border border-amber-200 px-4 py-3 text-sm text-amber-800" data-server-toast="success">Expediente eliminado.</div>
    )}
    {errorMsg && (
      <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700" data-server-toast="error">{errorMsg}</div>
    )}

    <form method="GET" action="/employee-files" class="ef-card border rounded-lg p-4 mb-6">
      <label class="block text-xs font-medium ef-label mb-1.5" for="emp-search">Empleado</label>
      <div class="flex items-center gap-2">
        <div class="relative flex-1">
          <input
            type="text"
            id="emp-search"
            placeholder="Buscar por nombre, apellido o código…"
            autocomplete="off"
            value={selectedEmployee
              ? `${selectedEmployee.lastName}, ${selectedEmployee.firstName} (${selectedEmployee.code})`
              : ''}
            class="ef-input w-full px-3 py-2 text-sm rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900"
          />
          <input type="hidden" name="employeeId" id="emp-id" value={selectedEmployee?.id ?? ''} />
          <ul
            id="emp-dropdown"
            class="ef-dropdown hidden absolute z-20 left-0 right-0 mt-1 rounded-md shadow-lg max-h-56 overflow-y-auto text-sm"
            role="listbox"
          ></ul>
        </div>
        <button type="submit" class="px-3.5 py-2 rounded-md bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 transition-colors">
          Seleccionar
        </button>
        {selectedEmployee && (
          <a href="/employee-files" class="ef-btn-secondary px-3.5 py-2 rounded-md border text-sm font-medium transition-colors">
            Limpiar
          </a>
        )}
      </div>
      <p class="mt-2 text-xs ef-hint">Solo empleados activos. Tipea para filtrar y elige uno de la lista.</p>
    </form>

    {!selectedEmployee && (
      <div class="ef-card border rounded-lg p-10 text-center">
        <p class="text-sm ef-subtitle">Selecciona un empleado arriba para registrar y consultar expedientes.</p>
      </div>
    )}

    {selectedEmployee && (
      <div class="space-y-6">

        <!-- ── Crear nuevo expediente — inline ─────────────────────────────── -->
        {canWrite && (
          <section class="ef-card border rounded-lg overflow-hidden">
            <header class="ef-section-header px-5 py-3 border-b flex items-center justify-between gap-2">
              <div>
                <h2 class="text-sm font-semibold ef-heading">Registrar nuevo expediente</h2>
                <p class="text-xs ef-hint mt-0.5">
                  Para {selectedEmployee.lastName}, {selectedEmployee.firstName}
                  <span class="ml-1 ef-mute font-mono">{selectedEmployee.code}</span>
                </p>
              </div>
            </header>

            <form
              id="ef-form"
              method="POST"
              action="/api/employee-files/save"
              enctype="multipart/form-data"
              class="p-5 space-y-4"
            >
              <input type="hidden" name="employeeId" value={selectedEmployee.id} />

              <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                  <label class="block text-xs font-medium ef-label mb-1.5">Tipo</label>
                  <select id="ef-type" name="typeId" required class="ef-input w-full px-3 py-2 text-sm rounded-md">
                    <option value="">Selecciona…</option>
                    {types.map((t) => (
                      <option value={t.id}>{t.name}</option>
                    ))}
                  </select>
                </div>
                <div>
                  <label class="block text-xs font-medium ef-label mb-1.5">Subtipo</label>
                  <select id="ef-subtype" name="subtypeId" required disabled class="ef-input w-full px-3 py-2 text-sm rounded-md">
                    <option value="">Selecciona un tipo primero</option>
                  </select>
                </div>
                <div>
                  <label class="block text-xs font-medium ef-label mb-1.5">Fecha</label>
                  <input type="date" id="ef-date" name="documentDate" required value={today} class="ef-input w-full px-3 py-2 text-sm rounded-md" />
                </div>
              </div>

              <div>
                <label class="block text-xs font-medium ef-label mb-1.5">Número (vista previa)</label>
                <input type="text" id="ef-number-preview" value="Se asigna automáticamente" disabled class="ef-input ef-input-readonly w-full px-3 py-2 text-sm rounded-md font-mono" />
              </div>

              <div>
                <label class="block text-xs font-medium ef-label mb-1.5">Observaciones</label>
                <textarea name="observations" rows="2" class="ef-input w-full px-3 py-2 text-sm rounded-md" placeholder="Notas adicionales (opcional)"></textarea>
              </div>

              <!-- Campos dinámicos del tipo+subtipo elegido -->
              <div id="ef-dynamic-wrap" class="hidden ef-divider pt-4">
                <p class="text-xs font-medium ef-label mb-2">Datos específicos del tipo seleccionado</p>
                <div id="ef-dynamic-fields" class="grid grid-cols-1 md:grid-cols-2 gap-4"></div>
              </div>

              <div class="ef-divider pt-4">
                <label class="block text-xs font-medium ef-label mb-1.5">Adjuntos adicionales</label>
                <input
                  type="file"
                  name="attachments"
                  multiple
                  accept="application/pdf,image/jpeg,image/png,image/gif"
                  class="ef-file block w-full text-sm file:mr-4 file:py-1.5 file:px-3 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100"
                />
                <p class="mt-1 text-[11px] ef-hint">PDFs o imágenes hasta 5 MB cada uno.</p>
              </div>

              <div id="ef-error" class="hidden text-xs text-red-700 bg-red-50 border border-red-200 rounded px-3 py-2"></div>

              <div class="flex items-center justify-end gap-2 pt-2">
                <button type="button" id="ef-cancel" class="ef-btn-link px-3.5 py-2 text-sm">
                  Limpiar
                </button>
                <button type="submit" id="ef-submit" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-md bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 disabled:opacity-70 disabled:cursor-wait">
                  <span data-label>Crear expediente</span>
                </button>
              </div>
            </form>
          </section>
        )}

        <!-- ── Listado existente — agrupado por tipo ───────────────────────── -->
        <section class="ef-card border rounded-lg overflow-hidden">
          <header class="ef-section-header px-5 py-3 border-b flex items-center justify-between gap-2">
            <h2 class="text-sm font-semibold ef-heading">Expedientes registrados</h2>
            <span class="text-xs ef-hint">
              {files.length} {files.length === 1 ? 'registro' : 'registros'}
            </span>
          </header>

          {files.length === 0 ? (
            <div class="py-12 text-center">
              <p class="text-sm ef-mute">Sin expedientes para este empleado todavía.</p>
              {canWrite && (
                <p class="text-xs ef-mute mt-1">Usa el formulario de arriba para crear el primero.</p>
              )}
            </div>
          ) : (
            <div class="ef-divide">
              {typesWithFiles.map((g) => (
                <div>
                  <div class="ef-group-header px-5 py-2.5 border-b">
                    <h3 class="text-xs font-semibold ef-heading uppercase tracking-wide">
                      {g.type.name}
                      <span class="ml-2 ef-mute normal-case">
                        · {g.rows.length} {g.rows.length === 1 ? 'expediente' : 'expedientes'}
                      </span>
                    </h3>
                  </div>
                  <table class="ef-table w-full text-sm">
                    <tbody>
                      {g.rows.map((f) => {
                        const s = subtypeById.get(f.subtypeId)
                        const status = f.approvalStatus ?? 'approved'
                        return (
                          <tr class="border-b last:border-0 transition-colors">
                            <td class="px-5 py-3 font-mono text-xs ef-cell-mono whitespace-nowrap w-44">{f.documentNumber}</td>
                            <td class="px-5 py-3 ef-cell whitespace-nowrap w-28">{fmtDate(f.documentDate)}</td>
                            <td class="px-5 py-3 ef-cell">{s?.name ?? '—'}</td>
                            <td class="px-5 py-3 whitespace-nowrap">
                              <span class={`ef-status-badge ef-status-${status}`}>
                                {status === 'pending' ? 'Pendiente' : status === 'approved' ? 'Aprobado' : 'Rechazado'}
                              </span>
                              {status === 'rejected' && f.rejectionReason && (
                                <span class="ml-2 text-[11px] ef-cell-mute" title={f.rejectionReason}>
                                  ({f.rejectionReason.length > 30 ? `${f.rejectionReason.slice(0, 30)}…` : f.rejectionReason})
                                </span>
                              )}
                            </td>
                            <td class="px-5 py-3 text-xs ef-cell-mute truncate max-w-xs" title={f.observations ?? ''}>
                              {f.observations ?? '—'}
                            </td>
                            <td class="px-5 py-3 text-right whitespace-nowrap">
                              <a href={`/employee-files/${f.id}`} class="ef-action mr-3">Ver</a>
                              {canWrite && (
                                <a href={`/employee-files/${f.id}/edit`} class="ef-action mr-3">Editar</a>
                              )}
                              {canDelete && (
                                <form
                                  method="POST"
                                  action="/api/employee-files/delete"
                                  data-saconfirm
                                  data-sa-title="Eliminar expediente"
                                  data-sa-message={`Vas a eliminar el expediente ${f.documentNumber}. Esta acción no se puede deshacer.`}
                                  data-sa-confirm-label="Eliminar"
                                  data-sa-tone="danger"
                                  data-sa-loading-title="Eliminando"
                                  data-sa-success-title="Expediente eliminado"
                                  data-sa-error-title="No se pudo eliminar"
                                  style="display:inline"
                                >
                                  <input type="hidden" name="id" value={f.id} />
                                  <input type="hidden" name="employeeId" value={selectedEmployee.id} />
                                  <button type="submit" class="text-xs text-red-600 hover:underline">Eliminar</button>
                                </form>
                              )}
                            </td>
                          </tr>
                        )
                      })}
                    </tbody>
                  </table>
                </div>
              ))}
            </div>
          )}
        </section>
      </div>
    )}
  </div>

  <ServerToastBridge />

  <script type="application/json" id="emp-catalog" set:html={JSON.stringify(employees)}></script>

  <script is:inline>
    ;(function () {
      const catalogEl = document.getElementById('emp-catalog')
      const input = document.getElementById('emp-search')
      const hidden = document.getElementById('emp-id')
      const dropdown = document.getElementById('emp-dropdown')
      if (!catalogEl || !input || !hidden || !dropdown) return
      const employees = JSON.parse(catalogEl.textContent || '[]')

      function show(items) {
        if (items.length === 0) { dropdown.classList.add('hidden'); return }
        dropdown.innerHTML = items.slice(0, 30).map((e) => (
          '<li class="ef-dropdown-item px-3 py-2 cursor-pointer" role="option" ' +
          'data-id="' + e.id + '" data-label="' + e.lastName + ', ' + e.firstName + ' (' + e.code + ')">' +
          '<div class="ef-dropdown-primary">' + e.lastName + ', ' + e.firstName + '</div>' +
          '<div class="text-xs ef-dropdown-secondary font-mono">' + e.code + ' · ' + (e.idNumber || '—') + '</div>' +
          '</li>'
        )).join('')
        dropdown.classList.remove('hidden')
      }
      input.addEventListener('focus', () => { if (input.value.length === 0) show(employees) })
      input.addEventListener('input', () => {
        hidden.value = ''
        const q = input.value.trim().toLowerCase()
        const filtered = q.length === 0
          ? employees
          : employees.filter((e) => (e.lastName + ' ' + e.firstName + ' ' + e.code + ' ' + (e.idNumber || '')).toLowerCase().includes(q))
        show(filtered)
      })
      dropdown.addEventListener('mousedown', (e) => {
        const li = e.target.closest('li[data-id]')
        if (!li) return
        hidden.value = li.dataset.id
        input.value = li.dataset.label
        dropdown.classList.add('hidden')
      })
      document.addEventListener('click', (e) => {
        if (!dropdown.contains(e.target) && e.target !== input) dropdown.classList.add('hidden')
      })
    })()
  </script>

  <!-- Lógica del formulario de creación inline -->
  <script is:inline>
    ;(function () {
      const form = document.getElementById('ef-form')
      const cancel = document.getElementById('ef-cancel')
      if (!form || !cancel) return

      const typeSel = document.getElementById('ef-type')
      const subtypeSel = document.getElementById('ef-subtype')
      const dateEl = document.getElementById('ef-date')
      const numberPreview = document.getElementById('ef-number-preview')
      const dynWrap = document.getElementById('ef-dynamic-wrap')
      const dynFields = document.getElementById('ef-dynamic-fields')
      const errorEl = document.getElementById('ef-error')
      const submitBtn = document.getElementById('ef-submit')

      cancel.addEventListener('click', () => {
        form.reset()
        dynWrap.classList.add('hidden')
        dynFields.innerHTML = ''
        subtypeSel.innerHTML = '<option value="">Selecciona un tipo primero</option>'
        subtypeSel.disabled = true
        numberPreview.value = 'Se asigna automáticamente'
        errorEl.classList.add('hidden')
      })

      const subtypesCache = new Map()
      const fieldsCache = new Map()

      async function loadSubtypes(typeId) {
        if (!typeId) {
          subtypeSel.innerHTML = '<option value="">Selecciona un tipo primero</option>'
          subtypeSel.disabled = true
          return
        }
        if (!subtypesCache.has(typeId)) {
          const res = await fetch('/api/employee-files/proxy?path=' + encodeURIComponent('types/' + typeId + '/subtypes'))
          const json = await res.json().catch(() => ({}))
          subtypesCache.set(typeId, json.data || [])
        }
        const subs = subtypesCache.get(typeId)
        subtypeSel.innerHTML = '<option value="">Selecciona…</option>' +
          subs.map((s) => '<option value="' + s.id + '">' + s.name + '</option>').join('')
        subtypeSel.disabled = false
      }

      function renderField(def, prefix) {
        const id = 'ef-fld-' + def.name
        const name = prefix + '_' + def.name
        const req = def.required ? 'required' : ''
        const ro = def.readonly ? 'readonly' : ''
        const placeholder = def.placeholder ? 'placeholder="' + def.placeholder + '"' : ''
        const value = def.default != null ? String(def.default) : ''
        const wrap = (inner, full) =>
          '<div' + (full ? ' class="md:col-span-2"' : '') + '>' +
          '<label class="block text-xs font-medium ef-label mb-1.5" for="' + id + '">' +
          def.label + (def.required ? ' <span class="text-red-500">*</span>' : '') +
          '</label>' + inner + '</div>'
        const cls = 'ef-input w-full px-3 py-2 text-sm rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900'
        switch (def.type) {
          case 'textarea':
            return wrap('<textarea id="' + id + '" name="' + name + '" rows="2" ' + req + ' ' + ro + ' ' + placeholder + ' class="' + cls + '">' + value + '</textarea>', true)
          case 'select': {
            const opts = (def.options || []).map((o) =>
              '<option value="' + o.value + '"' + (value === o.value ? ' selected' : '') + '>' + o.label + '</option>'
            ).join('')
            return wrap('<select id="' + id + '" name="' + name + '" ' + req + ' ' + ro + ' class="' + cls + '"><option value="">Selecciona…</option>' + opts + '</select>', false)
          }
          case 'file':
            return wrap('<input id="' + id + '" type="file" name="' + name + '" ' + req + ' accept="' + (def.accept || '') + '" class="ef-file block w-full text-sm file:mr-4 file:py-1.5 file:px-3 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" />', true)
          case 'number': {
            const step = def.step != null ? 'step="' + def.step + '"' : ''
            return wrap('<input id="' + id + '" type="number" name="' + name + '" ' + req + ' ' + ro + ' ' + step + ' ' + placeholder + ' value="' + value + '" class="' + cls + '" />', false)
          }
          case 'datetime':
            return wrap('<input id="' + id + '" type="datetime-local" name="' + name + '" ' + req + ' ' + ro + ' value="' + value + '" class="' + cls + '" />', false)
          case 'date':
            return wrap('<input id="' + id + '" type="date" name="' + name + '" ' + req + ' ' + ro + ' value="' + value + '" class="' + cls + '" />', false)
          default:
            return wrap('<input id="' + id + '" type="text" name="' + name + '" ' + req + ' ' + ro + ' ' + placeholder + ' value="' + value + '" class="' + cls + '" />', false)
        }
      }

      async function loadFields(typeId, subtypeId) {
        if (!typeId || !subtypeId) {
          dynWrap.classList.add('hidden')
          dynFields.innerHTML = ''
          return
        }
        const key = typeId + '/' + subtypeId
        if (!fieldsCache.has(key)) {
          const res = await fetch('/api/employee-files/proxy?path=' + encodeURIComponent('fields?typeId=' + typeId + '&subtypeId=' + subtypeId))
          const json = await res.json().catch(() => ({}))
          fieldsCache.set(key, json.data?.fields || [])
        }
        const fields = fieldsCache.get(key)
        if (fields.length === 0) {
          dynWrap.classList.add('hidden')
          dynFields.innerHTML = ''
          return
        }
        dynFields.innerHTML = fields.map((f) => renderField(f, f.type === 'file' ? 'file' : 'extra')).join('')
        dynWrap.classList.remove('hidden')
      }

      async function refreshNumberPreview() {
        const typeId = typeSel.value, subtypeId = subtypeSel.value, date = dateEl.value
        if (!typeId || !subtypeId || !date) {
          numberPreview.value = 'Se asigna automáticamente'
          return
        }
        try {
          const res = await fetch('/api/employee-files/proxy?path=' + encodeURIComponent('next-number?typeId=' + typeId + '&subtypeId=' + subtypeId + '&documentDate=' + date))
          const json = await res.json().catch(() => ({}))
          numberPreview.value = json.data?.documentNumber || '—'
        } catch { numberPreview.value = '—' }
      }

      typeSel.addEventListener('change', async () => {
        await loadSubtypes(typeSel.value)
        await loadFields(typeSel.value, subtypeSel.value)
        await refreshNumberPreview()
      })
      subtypeSel.addEventListener('change', async () => {
        await loadFields(typeSel.value, subtypeSel.value)
        await refreshNumberPreview()
      })
      dateEl.addEventListener('change', refreshNumberPreview)

      // Submit con flujo saModal: confirmar → loading → resultado.
      // El helper global `window.saModal` está definido en Modals.astro
      // del AppLayout. Devuelve true si el usuario confirma.
      form.addEventListener('submit', async (e) => {
        e.preventDefault()
        errorEl.classList.add('hidden')
        const data = new FormData(form)
        const typeSel2 = document.getElementById('ef-type')
        const subSel2 = document.getElementById('ef-subtype')
        const typeLabel = typeSel2.selectedOptions[0]?.text || ''
        const subLabel = subSel2.selectedOptions[0]?.text || ''
        const sa = window.saModal
        // Confirmar primero.
        if (sa && typeof sa.confirm === 'function') {
          const okConfirm = await sa.confirm({
            title: 'Registrar expediente',
            message: 'Vas a crear un expediente' +
              (typeLabel ? ' de tipo "' + typeLabel + '"' : '') +
              (subLabel ? ' / "' + subLabel + '"' : '') +
              '. ¿Continuar?',
            confirmLabel: 'Registrar',
            tone: 'primary',
          })
          if (!okConfirm) return
          sa.loading({ title: 'Guardando expediente', message: 'Procesando datos y adjuntos…' })
        } else {
          // Fallback si Modals.astro no está montado por alguna razón.
          submitBtn.disabled = true
          const labelEl = submitBtn.querySelector('[data-label]')
          if (labelEl) labelEl.textContent = 'Guardando…'
        }
        try {
          const res = await fetch('/api/employee-files/save', {
            method: 'POST',
            body: data,
            headers: { 'X-SA-Modal': '1' },
          })
          const json = await res.json().catch(() => ({}))
          if (!res.ok || json.ok === false) {
            const msg = json.error || 'HTTP ' + res.status
            if (sa && typeof sa.error === 'function') {
              await sa.error({ title: 'No se pudo registrar', message: msg })
            }
            errorEl.textContent = msg
            errorEl.classList.remove('hidden')
          } else {
            const redirectUrl =
              json.redirect ||
              '/employee-files?employeeId=' + data.get('employeeId') + '&flash=created'
            if (sa && typeof sa.success === 'function') {
              await sa.success({
                title: 'Expediente registrado',
                message: json.message || 'El expediente se guardó correctamente.',
                redirect: redirectUrl,
              })
            } else {
              window.location.href = redirectUrl
            }
          }
        } catch (err) {
          const msg = err && err.message ? err.message : String(err)
          if (sa && typeof sa.error === 'function') {
            await sa.error({ title: 'Error de red', message: msg })
          }
          errorEl.textContent = msg
          errorEl.classList.remove('hidden')
        } finally {
          submitBtn.disabled = false
          const labelEl = submitBtn.querySelector('[data-label]')
          if (labelEl) labelEl.textContent = 'Crear expediente'
        }
      })
    })()
  </script>

  <style>

      letter-spacing: 0.04em;
    }
    .ef-status-pending  { background: rgba(245, 158, 11, 0.18); color: #fbbf24; }
    .ef-status-approved { background: rgba(16, 185, 129, 0.18); color: #34d399; }
    .ef-status-rejected { background: rgba(239, 68, 68, 0.18);  color: #f87171; }
    [data-theme='light'] .ef-status-pending  { background: #fef3c7; color: #92400e; }
    [data-theme='light'] .ef-status-approved { background: #d1fae5; color: #065f46; }
    [data-theme='light'] .ef-status-rejected { background: #fee2e2; color: #991b1b; }

    /* Modo claro — override de la paleta blanca para tarjetas/encabezados. */
    [data-theme='light'] .ef-card           { background: #ffffff; }

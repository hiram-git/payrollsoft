<script type="application/json" id="cfDefs" set:html={JSON.stringify(customFieldDefs)}></script>

<script is:inline>
  ;(function () {
    const defsEl = document.getElementById('cfDefs')
    if (!defsEl) return
    let defs
    try {
      defs = JSON.parse(defsEl.textContent || '[]')
    } catch {
      return
    }
    if (!Array.isArray(defs) || defs.length === 0) return

    function readDeps(def) {
      const rules = def.validationRules && Array.isArray(def.validationRules.dependsOn)
        ? def.validationRules.dependsOn
        : []
      return rules.filter((r) => r && typeof r === 'object' && r.field && r.op && r.effect)
    }
    function isEmpty(v) {
      if (v == null) return true
      if (typeof v === 'string') return v.trim() === ''
      return false
    }
    function toNum(v) {
      if (v == null || v === '') return null
      const n = Number(v)
      return Number.isFinite(n) ? n : null
    }
    function evalRule(r, values) {
      const v = values[r.field]
      switch (r.op) {
        case 'eq': return String(v ?? '') === String(r.value ?? '')
        case 'ne': return String(v ?? '') !== String(r.value ?? '')
        case 'gt': { const a = toNum(v), b = toNum(r.value); return a != null && b != null && a > b }
        case 'lt': { const a = toNum(v), b = toNum(r.value); return a != null && b != null && a < b }
        case 'gte': { const a = toNum(v), b = toNum(r.value); return a != null && b != null && a >= b }
        case 'lte': { const a = toNum(v), b = toNum(r.value); return a != null && b != null && a <= b }
        case 'in': return Array.isArray(r.values) && r.values.some((x) => String(x) === String(v ?? ''))
        case 'empty': return isEmpty(v)
        case 'notEmpty': return !isEmpty(v)
        default: return false
      }
    }
    function readValues() {
      const out = {}
      for (const def of defs) {
        const el = document.querySelector('[name="cf_' + def.code + '"]')
        out[def.code] = el ? el.value : ''
      }
      return out
    }
    function applyState() {
      const values = readValues()
      for (const def of defs) {
        const rules = readDeps(def)
        const row = document.querySelector('[data-cf-row="' + def.code + '"]')
        const input = document.querySelector('[name="cf_' + def.code + '"]')
        if (!row || !input) continue
        const visRules = rules.filter((r) => r.effect === 'visible')
        const reqRules = rules.filter((r) => r.effect === 'required')
        const roRules = rules.filter((r) => r.effect === 'readonly')
        const visible = visRules.length === 0 ? true : visRules.every((r) => evalRule(r, values))
        const required = !!def.isRequired || (reqRules.length > 0 && reqRules.every((r) => evalRule(r, values)))
        const readonly = roRules.length > 0 && roRules.every((r) => evalRule(r, values))
        row.style.display = visible ? '' : 'none'
        if (required && visible) input.setAttribute('required', 'required')
        else input.removeAttribute('required')
        if (readonly) input.setAttribute('readonly', 'readonly')
        else input.removeAttribute('readonly')
        if (!visible) input.value = ''
        // Toggle the asterisk on the label so the user sees state changes.
        const lbl = row.querySelector('label')
        if (lbl) {
          const star = lbl.querySelector('.cf-required-star')
          if (required && !star) {
            const sp = document.createElement('span')
            sp.className = 'cf-required-star text-red-500 ml-0.5'
            sp.textContent = '*'
            lbl.appendChild(sp)
          } else if (!required && star) {
            star.remove()
          }
        }
      }
    }
    for (const def of defs) {
      const el = document.querySelector('[name="cf_' + def.code + '"]')
      if (el) el.addEventListener('input', applyState)
      if (el) el.addEventListener('change', applyState)
    }
    applyState()
  })()
</script>

<script is:inline>
  function switchTab(tab, btn) {
    document.querySelectorAll('[id^="tab-"]').forEach(el => el.style.display = 'none')
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'))
    document.getElementById('tab-' + tab).style.display = ''
    btn.classList.add('active')
  }

  // ─── Bancario: ocultar campos cuando es Efectivo ───────────────────────
  ;(function() {
    var bankFields = document.getElementById('bank-fields');
    var radios = document.querySelectorAll('input[name="paymentMethod"]');
    if (!bankFields || !radios.length) return;
    radios.forEach(function(r) {
      r.addEventListener('change', function() { bankFields.style.display = this.value === 'cash' ? 'none' : ''; });
    });
  })();

  // ─── Vacaciones: modal de solicitud + cancelación ──────────────────────
  ;(function () {
    const modal = document.getElementById('vac-modal')
    const openBtn = document.getElementById('vac-request-btn')
    const closeBtn = document.getElementById('vac-modal-close')
    const cancelBtn = document.getElementById('vac-modal-cancel')
    const form = document.getElementById('vac-form')
    const errBox = document.getElementById('vac-form-error')

    function openModal() {
      if (!modal) return
      modal.classList.remove('hidden')
      modal.classList.add('flex')
      errBox.classList.add('hidden')
      applyTypeVisibility()
    }
    function closeModal() {
      if (!modal) return
      modal.classList.add('hidden')
      modal.classList.remove('flex')
      form.reset()
    }
    function applyTypeVisibility() {
      const selectedType = form.querySelector('input[name="requestType"]:checked')?.value || 'enjoy'
      form.querySelectorAll('[data-show-when]').forEach((el) => {
        const allowed = (el.getAttribute('data-show-when') || '').split(' ')
        el.style.display = allowed.includes(selectedType) ? '' : 'none'
      })
    }

    openBtn?.addEventListener('click', openModal)
    closeBtn?.addEventListener('click', closeModal)
    cancelBtn?.addEventListener('click', closeModal)
    modal?.addEventListener('click', (e) => { if (e.target === modal) closeModal() })
    form?.querySelectorAll('input[name="requestType"]').forEach((r) => r.addEventListener('change', applyTypeVisibility))

    form?.addEventListener('submit', async (e) => {
      e.preventDefault()
      errBox.classList.add('hidden')
      const fd = new FormData(form)
      const payload = {
        employeeId: fd.get('employeeId'),
        requestType: fd.get('requestType'),
        startDate: fd.get('startDate') || null,
        endDate: fd.get('endDate') || null,
        enjoyDays: parseInt(fd.get('enjoyDays') || '0', 10),
        paidDays: parseInt(fd.get('paidDays') || '0', 10),
        reason: fd.get('reason') || null,
      }
      try {
        const res = await fetch('/api/vacations/action?op=create', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-SA-Modal': '1' },
          body: JSON.stringify(payload),
        })
        const json = await res.json().catch(() => ({}))
        if (!json.ok) {
          errBox.textContent = json.error || ('HTTP ' + res.status)
          errBox.classList.remove('hidden')
          return
        }
        const sa = window.saModal
        if (sa) {
          await sa.success({
            title: 'Solicitud enviada',
            message: `Solicitud ${json.data?.requestNumber || ''} creada. El saldo quedó reservado hasta la aprobación.`,
            redirect: window.location.pathname,
          })
        } else {
          window.location.reload()
        }
      } catch (err) {
        errBox.textContent = 'Error de red: ' + String(err)
        errBox.classList.remove('hidden')
      }
    })

    // Cancelar solicitud pendiente
    document.querySelectorAll('[data-cancel-vac]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = btn.getAttribute('data-cancel-vac')
        const num = btn.getAttribute('data-num')
        const sa = window.saModal
        if (!sa) return
        const ok = await sa.confirm({
          title: 'Cancelar solicitud',
          message: `Vas a cancelar la solicitud ${num}. Los días reservados se devolverán al saldo.`,
          confirmLabel: 'Cancelar solicitud',
          tone: 'danger',
        })
        if (!ok) return
        sa.loading({ title: 'Cancelando', message: 'Procesando…' })
        const res = await fetch('/api/vacations/action?op=cancel&id=' + id, {
          method: 'POST',
          headers: { 'X-SA-Modal': '1' },
        })
        const json = await res.json().catch(() => ({}))
        if (!json.ok) {
          await sa.error({ title: 'No se pudo cancelar', message: json.error })
        } else {
          await sa.success({ title: 'Solicitud cancelada', redirect: window.location.pathname })
        }
      })
    })
  })()

  // Auto-fill cargo/depto/funcion/salary from selected position (empresa pública)
  const posSelect = document.getElementById('positionSelect')
  if (posSelect) {
    posSelect.addEventListener('change', function () {
      const opt = this.options[this.selectedIndex]
      document.getElementById('hiddenCargoId').value = opt.dataset.cargo || ''
      document.getElementById('hiddenDepartamentoId').value = opt.dataset.depto || ''
      document.getElementById('hiddenFuncionId').value = opt.dataset.funcion || ''
      document.getElementById('baseSalaryInput').value = opt.dataset.salary || ''
    })
  }
</script>

<script is:inline>
function togglePortalCb(id) {
  var cb = document.getElementById(id);
  if (!cb) return;
  cb.checked = !cb.checked;
  syncToggleUI(id, cb.checked);
}
function syncToggleUI(id, val) {
  var cb = document.getElementById(id);
  var track = document.getElementById(id + '-track');
  var knob = document.getElementById(id + '-knob');
  if (cb) cb.checked = val;
  if (track) {
    track.classList.remove('toggle-on', 'toggle-off');
    track.classList.add(val ? 'toggle-on' : 'toggle-off');
  }
  if (knob) {
    knob.classList.remove('knob-on', 'knob-off');
    knob.classList.add(val ? 'knob-on' : 'knob-off');
  }
}

;(function() {
  var empId = window.location.pathname.split('/employees/')[1]?.split('/')[0] || '';
  if (!empId) return;
  var badge = document.getElementById('portal-status-badge');
  var enabledCb = document.getElementById('portal-enabled');
  var approverCb = document.getElementById('portal-approver');
  var modChecks = document.querySelectorAll('.portal-mod');
  var saveBtn = document.getElementById('portal-save');
  var resetBtn = document.getElementById('portal-reset-pw');
  var pwHint = document.getElementById('portal-pw-hint');
  var sa = window.saModal;
  if (!badge || !enabledCb || !saveBtn) return;

  function loadPortalData() {
    fetch('/api/employees/' + empId + '/portal')
      .then(function(r) { return r.json(); })
      .then(function(res) {
        if (!res.success) { badge.textContent = 'Error'; return; }
        var d = res.data;
        var isOn = false;
        if (!d.hasCredentials) {
          badge.textContent = 'Sin acceso';
          badge.className = 'text-xs font-medium px-2.5 py-0.5 rounded bg-gray-100 text-gray-500';
        } else if (d.credentials.isLocked) {
          badge.textContent = 'Bloqueado';
          badge.className = 'text-xs font-medium px-2.5 py-0.5 rounded bg-red-100 text-red-700';
          isOn = d.credentials.isActive;
        } else if (!d.credentials.isActive) {
          badge.textContent = 'Desactivado';
          badge.className = 'text-xs font-medium px-2.5 py-0.5 rounded bg-amber-100 text-amber-700';
        } else {
          badge.textContent = 'Activo';
          badge.className = 'text-xs font-medium px-2.5 py-0.5 rounded bg-green-100 text-green-700';
          isOn = true;
        }
        syncToggleUI('portal-enabled', isOn);
        syncToggleUI('portal-approver', d.credentials?.isApprover || false);
        var mods = {};
        (d.modules || []).forEach(function(m) { mods[m.module] = m.isEnabled; });
        modChecks.forEach(function(cb) { cb.checked = mods[cb.dataset.module] !== false; });
        if (d.credentials?.lastLoginAt) {
          pwHint.textContent = 'Último acceso: ' + new Date(d.credentials.lastLoginAt).toLocaleDateString('es-PA');
        }
      })
      .catch(function() { badge.textContent = 'Error de conexión'; });
  }

  saveBtn.addEventListener('click', function() {
    saveBtn.disabled = true;
    saveBtn.textContent = 'Guardando...';
    var modules = [];
    modChecks.forEach(function(cb) { modules.push({ module: cb.dataset.module, isEnabled: cb.checked }); });
    fetch('/api/employees/' + empId + '/portal', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ portalEnabled: enabledCb.checked, isApprover: approverCb.checked, modules: modules })
    })
    .then(function(r) { return r.json(); })
    .then(function(res) {
      saveBtn.disabled = false;
      saveBtn.textContent = 'Guardar configuración del portal';
      if (res.success) {
        loadPortalData();
        if (sa) sa.success({ title: 'Guardado', message: 'Configuración del portal actualizada.' });
      } else {
        if (sa) sa.error({ title: 'Error', message: res.error || 'No se pudo guardar.' });
      }
    })
    .catch(function() {
      saveBtn.disabled = false;
      saveBtn.textContent = 'Guardar configuración del portal';
      if (sa) sa.error({ title: 'Error', message: 'Error de conexión.' });
    });
  });

  resetBtn.addEventListener('click', async function() {
    if (!sa) return;
    var ok = await sa.confirm({
      title: 'Resetear contraseña',
      message: 'La contraseña se reseteará a 172839. El empleado deberá cambiarla en su próximo acceso.',
      confirmLabel: 'Resetear',
      tone: 'warning',
    });
    if (!ok) return;
    sa.loading({ title: 'Reseteando', message: 'Procesando…' });
    fetch('/api/employees/' + empId + '/portal', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ resetPassword: true })
    })
    .then(function(r) { return r.json(); })
    .then(function(res) {
      if (res.success) sa.success({ title: 'Listo', message: 'Contraseña reseteada a 172839.' });
      else sa.error({ title: 'Error', message: res.error || 'No se pudo resetear.' });
    })
    .catch(function() { sa.error({ title: 'Error', message: 'Error de conexión.' }); });
  });

  loadPortalData();
})();
</script>

<script is:inline>
;(function() {
  var empId = window.location.pathname.split('/employees/')[1]?.split('/')[0] || '';
  if (!empId) return;
  var listEl = document.getElementById('dep-list');
  var formEl = document.getElementById('dep-form');
  var addBtn = document.getElementById('dep-add-btn');
  var cancelBtn = document.getElementById('dep-cancel-btn');
  var saveBtn = document.getElementById('dep-save-btn');
  var hasDis = document.getElementById('dep-hasDisability');
  var disRow = document.getElementById('dep-disability-row');
  if (!listEl || !formEl || !addBtn) return;

  var REL_LABELS = { spouse:'Cónyuge', child:'Hijo(a)', parent:'Padre/Madre', sibling:'Hermano(a)', other:'Otro' };
  var editingId = null;

  hasDis?.addEventListener('change', function() {
    disRow.style.display = hasDis.checked ? '' : 'none';
  });
  addBtn.addEventListener('click', function() { editingId = null; clearForm(); formEl.classList.remove('hidden'); });
  cancelBtn?.addEventListener('click', function() { formEl.classList.add('hidden'); });

  function clearForm() {
    ['dep-firstName','dep-lastName','dep-idNumber','dep-birthDate','dep-disabilityDesc'].forEach(function(id) {
      var el = document.getElementById(id); if (el) el.value = '';
    });
    document.getElementById('dep-relationship').value = 'spouse';
    document.getElementById('dep-sex').value = '';
    hasDis.checked = false; disRow.style.display = 'none';
  }

  function loadDeps() {
    fetch('/api/employees/' + empId + '/dependents')
      .then(function(r) { return r.json(); })
      .then(function(res) {
        var deps = (res.data || []).filter(function(d) { return d.isActive !== false; });
        if (deps.length === 0) { listEl.innerHTML = '<div class="py-8 text-center text-sm text-gray-400">Sin dependientes registrados.</div>'; return; }
        var html = '<table class="w-full text-sm"><thead><tr class="border-b border-gray-200 bg-gray-50">' +
          '<th class="text-left px-3 py-2 text-xs font-medium text-gray-500 uppercase">Nombre</th>' +
          '<th class="text-left px-3 py-2 text-xs font-medium text-gray-500 uppercase">Cédula</th>' +
          '<th class="text-left px-3 py-2 text-xs font-medium text-gray-500 uppercase">Parentesco</th>' +
          '<th class="text-left px-3 py-2 text-xs font-medium text-gray-500 uppercase">Discapacidad</th>' +
          '<th class="px-3 py-2"></th></tr></thead><tbody>';
        deps.forEach(function(d) {
          html += '<tr class="border-b border-gray-100">' +
            '<td class="px-3 py-2.5 font-medium text-gray-900">' + d.firstName + ' ' + d.lastName + '</td>' +
            '<td class="px-3 py-2.5 text-gray-600 font-mono text-xs">' + (d.idNumber || '—') + '</td>' +
            '<td class="px-3 py-2.5 text-gray-600 text-xs">' + (REL_LABELS[d.relationship] || d.relationship) + '</td>' +
            '<td class="px-3 py-2.5">' + (d.hasDisability ? '<span class="text-xs font-medium px-1.5 py-0.5 rounded bg-amber-50 text-amber-700">Sí</span>' : '<span class="text-xs text-gray-400">No</span>') + '</td>' +
            '<td class="px-3 py-2.5 text-right"><button class="text-xs text-red-500 hover:underline" onclick="window.__depDel(\'' + d.id + '\')">Eliminar</button></td></tr>';
        });
        html += '</tbody></table>';
        listEl.innerHTML = html;
      })
      .catch(function() { listEl.innerHTML = '<div class="py-8 text-center text-sm text-red-400">Error al cargar.</div>'; });
  }

  saveBtn?.addEventListener('click', function() {
    var fn = document.getElementById('dep-firstName').value.trim();
    var ln = document.getElementById('dep-lastName').value.trim();
    if (!fn || !ln) return;
    var body = {
      firstName: fn, lastName: ln,
      idNumber: document.getElementById('dep-idNumber').value.trim() || null,
      relationship: document.getElementById('dep-relationship').value,
      birthDate: document.getElementById('dep-birthDate').value || null,
      sex: document.getElementById('dep-sex').value || null,
      hasDisability: hasDis.checked,
      disabilityDescription: document.getElementById('dep-disabilityDesc').value.trim() || null,
    };
    if (editingId) body._id = editingId;
    saveBtn.disabled = true;
    fetch('/api/employees/' + empId + '/dependents', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
    })
    .then(function(r) { return r.json(); })
    .then(function(res) {
      saveBtn.disabled = false;
      if (res.success) { formEl.classList.add('hidden'); loadDeps(); }
    })
    .catch(function() { saveBtn.disabled = false; });
  });

  window.__depDel = function(depId) {
    if (!confirm('¿Eliminar este dependiente?')) return;
    fetch('/api/employees/' + empId + '/dependents', {
      method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ dependentId: depId }),
    }).then(function() { loadDeps(); });
  };

  loadDeps();
})();
</script>

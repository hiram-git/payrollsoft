---
import AppLayout from '../../layouts/AppLayout.astro'
import PositionSelect from '../../components/PositionSelect.astro'
import CustomFieldInputs from '../../components/CustomFieldInputs.astro'
import { customFieldValueToString } from '../../lib/custom-fields'
import { resolveTenantSlugFromCookie } from '../../lib/tenant-slug'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'

const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')
const tenantSlug = resolveTenantSlugFromCookie(authCookie)

const { id } = Astro.params

type Employee = {
  id: string
  code: string
  firstName: string
  secondName: string | null
  lastName: string
  secondSurname: string | null
  marriedSurname: string | null
  idNumber: string
  idPrefix: string | null
  idProvince: string | null
  idVolume: string | null
  idFolio: string | null
  socialSecurityNumber: string | null
  sex: string | null
  maritalStatus: string | null
  nationality: string | null
  birthDate: string | null
  birthPlace: string | null
  email: string | null
  personalEmail: string | null
  phone: string | null
  addressProvince: string | null
  addressDistrict: string | null
  addressTownship: string | null
  address: string | null
  otherAddress: string | null
  jobTitleId: string | null
  jobFunctionId: string | null
  departmentId: string | null
  positionId: string | null
  position: string | null
  department: string | null
  hireDate: string
  baseSalary: string
  payFrequency: string
  decreeNumber: string | null
  resolutionNumber: string | null
  decreeDate: string | null
  resolutionDate: string | null
  collaboratorNumber: string | null
  externalUserRef: string | null
  contractType: string | null
  irKey: string | null
  shiftId: string | null
  weeklyBaseHours: string | null
  observations: string | null
  terminationDate: string | null
  terminationDecree: string | null
  terminationResolution: string | null
  terminationDecreeDate: string | null
  terminationResolutionDate: string | null
  terminationReason: string | null
  siacapPct: string | null
  hasOwnDisability?: boolean
  requiresAttendanceMarking?: boolean
  canRead?: boolean
  canWrite?: boolean
  photo?: string | null
  scannedId?: string | null
  isActive: boolean
  payrollTypeIds?: string[]
  bankId?: string | null
  accountNumber?: string | null
  accountType?: 'savings' | 'checking' | null
  paymentMethod?: 'ach' | 'check' | 'cash'
}
type Bank = { id: string; name: string; isActive: number }
type PayrollType = { id: string; code: string; name: string; sortOrder: number }

type CatalogItem = { id: string; code: string; name: string; isActive: boolean }
type Departamento = CatalogItem & { parentId: string | null }
type Position = {
  id: string
  code: string
  name: string
  salary: string
  overtimeAmount: string | null
  representationAmount: string | null
  jobTitleId: string | null
  departmentId: string | null
  jobFunctionId: string | null
  isActive: boolean
  status: 'en_uso' | 'vacante' | string
}
type CompanyConfig = { tipoInstitucion?: string | null }
type Loan = {
  id: string
  employeeId: string
  amount: string
  balance: string
  installment: string
  startDate: string
  endDate: string | null
  isActive: boolean
  createdAt: string
}
type CustomFieldDefinition = {
  id: string
  code: string
  name: string
  description: string | null
  fieldType: 'text' | 'integer' | 'float' | 'date'
  isRequired: boolean
  isActive: boolean
  defaultValue: unknown
  sortOrder: number
  validationRules?: {
    dependsOn?: Array<{
      field: string
      op: string
      value?: unknown
      values?: unknown[]
      effect: 'required' | 'visible' | 'readonly'
    }>
    readPermission?: string | null
    writePermission?: string | null
  } | null
}
type CustomFieldHistoryEntry = {
  id: string
  employeeId: string
  fieldCode: string
  oldValue: unknown
  newValue: unknown
  changedBy: string | null
  changedAt: string
}
type UserRow = { id: string; name: string | null; email: string }

let emp: Employee | null = null
let cargos: CatalogItem[] = []
let funciones: CatalogItem[] = []
let departamentos: Departamento[] = []
let positions: Position[] = []
let loans: Loan[] = []
let payrollTypes: PayrollType[] = []
let customFieldDefs: CustomFieldDefinition[] = []
let cfHistory: CustomFieldHistoryEntry[] = []
const userNameMap = new Map<string, string>()
let tipoInstitucion = 'privada'
let banksCatalog: Bank[] = []

type FileRow = {
  id: string
  typeId: number
  subtypeId: number
  documentNumber: string
  documentDate: string
  observations: string | null
  approvalStatus: 'pending' | 'approved' | 'rejected'
  rejectionReason: string | null
  approvedAt: string | null
  createdAt: string
}
type FileType = { id: number; code: string; name: string }
type FileSubtype = { id: number; code: string; name: string; typeId: number }
let efFiles: FileRow[] = []
let efTypes: FileType[] = []
const efSubtypes: FileSubtype[] = []

type VacationBalance = {
  enjoy: { earned: number; used: number; reserved: number; available: number }
  paid: { earned: number; used: number; reserved: number; available: number }
  lastAccrualDate: string | null
}
type VacationRequest = {
  id: string
  requestNumber: string
  requestType: 'enjoy' | 'pay' | 'mixed'
  startDate: string | null
  endDate: string | null
  enjoyDays: number
  paidDays: number
  reason: string | null
  status: 'pending' | 'approved' | 'rejected' | 'processed' | 'cancelled'
  rejectionReason: string | null
  approvedAt: string | null
  payrollId: string | null
  createdAt: string
}
let vacBalance: VacationBalance | null = null
let vacRequests: VacationRequest[] = []

try {
  const headers = { Cookie: `auth=${authCookie}`, 'X-Tenant': tenantSlug }
  const [empRes, cRes, fRes, dRes, compRes, cfgRes] = await Promise.all([
    fetch(`${API_URL}/employees/${id}`, { headers }),
    fetch(`${API_URL}/job-titles`, { headers }),
    fetch(`${API_URL}/job-functions`, { headers }),
    fetch(`${API_URL}/departments`, { headers }),
    fetch(`${API_URL}/company`, { headers }),
    fetch(`${API_URL}/concepts/config`, { headers }),
  ])

  if (empRes.status === 401) return Astro.redirect('/login')
  if (empRes.status === 404) return Astro.redirect('/employees')
  if (empRes.ok) emp = ((await empRes.json()) as { data: Employee }).data

  if (cRes.ok) cargos = ((await cRes.json()) as { data: CatalogItem[] }).data ?? []
  if (fRes.ok) funciones = ((await fRes.json()) as { data: CatalogItem[] }).data ?? []
  if (dRes.ok) departamentos = ((await dRes.json()) as { data: Departamento[] }).data ?? []
  if (compRes.ok) {
    const cfg = ((await compRes.json()) as { data: CompanyConfig }).data
    tipoInstitucion = cfg?.institutionType ?? 'privada'
  }
  if (cfgRes.ok) {
    const cfgData = (await cfgRes.json()) as { data?: { payrollTypes?: PayrollType[] } }
    payrollTypes = (cfgData.data?.payrollTypes ?? []).sort((a, b) => a.sortOrder - b.sortOrder)
  }

  if (tipoInstitucion === 'publica') {
    const pRes = await fetch(`${API_URL}/positions?isActive=true`, { headers })
    if (pRes.ok) positions = ((await pRes.json()) as { data: Position[] }).data ?? []
  }

  // Load loans after we have the employee id confirmed
  if (emp) {
    const lRes = await fetch(`${API_URL}/loans?employeeId=${emp.id}`, { headers })
    if (lRes.ok) loans = ((await lRes.json()) as { data: Loan[] }).data ?? []
  }

  // Active custom field definitions, ordered by the catalog's sortOrder.
  // Inactive ones se ocultan del formulario pero no se borran del jsonb,
  // así que valores históricos quedan disponibles vía CAMPOADICIONAL().
  const cfRes = await fetch(`${API_URL}/custom-fields`, { headers })
  if (cfRes.ok) {
    const cfJson = (await cfRes.json()) as { data: CustomFieldDefinition[] }
    customFieldDefs = (cfJson.data ?? []).filter((d) => d.isActive)
  }

  // Historial de cambios de campos adicionales (más reciente primero).
  if (emp) {
    const histRes = await fetch(`${API_URL}/employees/${emp.id}/custom-fields/history?limit=200`, {
      headers,
    })
    if (histRes.ok) {
      cfHistory = ((await histRes.json()) as { data: CustomFieldHistoryEntry[] }).data ?? []
    }
    if (cfHistory.length > 0) {
      const usersRes = await fetch(`${API_URL}/tenant-users`, { headers }).catch(() => null)
      if (usersRes?.ok) {
        const users = ((await usersRes.json()) as { data: UserRow[] }).data ?? []
        for (const u of users) userNameMap.set(u.id, u.name || u.email)
      }
    }
  }

  // Vacaciones — saldo + últimas solicitudes.
  if (emp) {
    const [balRes, reqRes] = await Promise.all([
      fetch(`${API_URL}/vacations/balance/${emp.id}`, { headers }),
      fetch(`${API_URL}/vacations?employeeId=${emp.id}`, { headers }),
    ])
    if (balRes.ok) vacBalance = ((await balRes.json()) as { data: VacationBalance }).data
    if (reqRes.ok) vacRequests = ((await reqRes.json()) as { data: VacationRequest[] }).data ?? []
  }

  // Catálogo de bancos (tab Bancario)
  const banksRes = await fetch(`${API_URL}/banks`, { headers }).catch(() => null)
  if (banksRes?.ok) {
    banksCatalog = ((await banksRes.json()) as { data: Bank[] }).data ?? []
  }

  // Expedientes del empleado — agrupados por tipo en el tab.
  if (emp) {
    const [efRes, tRes] = await Promise.all([
      fetch(`${API_URL}/employee-files?employeeId=${emp.id}`, { headers }),
      fetch(`${API_URL}/employee-files/types`, { headers }),
    ])
    if (efRes.ok) efFiles = ((await efRes.json()) as { data: FileRow[] }).data ?? []
    if (tRes.ok) efTypes = ((await tRes.json()) as { data: FileType[] }).data ?? []
    // Subtipos para mapear nombres — solo para los tipos que el empleado tiene.
    const distinctTypeIds = Array.from(new Set(efFiles.map((f) => f.typeId)))
    for (const tid of distinctTypeIds) {
      try {
        const sres = await fetch(`${API_URL}/employee-files/types/${tid}/subtypes`, { headers })
        if (sres.ok) {
          const subs = ((await sres.json()) as { data: FileSubtype[] }).data ?? []
          efSubtypes.push(...subs.map((s) => ({ ...s, typeId: tid })))
        }
      } catch {
        /* best-effort */
      }
    }
  }
} catch {
  return Astro.redirect('/employees')
}

const efTypeById = new Map(efTypes.map((t) => [t.id, t]))
const efSubtypeById = new Map(efSubtypes.map((s) => [s.id, s]))
const efFilesByType = new Map<number, FileRow[]>()
for (const f of efFiles) {
  const arr = efFilesByType.get(f.typeId) ?? []
  arr.push(f)
  efFilesByType.set(f.typeId, arr)
}
const efTypesWithFiles = Array.from(efFilesByType.keys())
  .map((tid) => ({ type: efTypeById.get(tid), rows: efFilesByType.get(tid) ?? [] }))
  .filter((g): g is { type: FileType; rows: FileRow[] } => Boolean(g.type))
  .sort((a, b) => a.type.name.localeCompare(b.type.name, 'es'))

function fmtFileDate(s: string): string {
  if (!s) return '—'
  const [y, m, d] = s.slice(0, 10).split('-')
  return `${d}-${m}-${y}`
}

// `customFields` jsonb del empleado — diccionario code→valor.
const empCustomFields = ((emp as unknown as { customFields?: Record<string, unknown> } | null)
  ?.customFields ?? {}) as Record<string, unknown>
function cfValue(code: string): string {
  const v = empCustomFields[code]
  if (v == null) return ''
  if (v instanceof Date) return v.toISOString().slice(0, 10)
  return String(v)
}
// Valor a mostrar: el almacenado para el empleado; si nunca se ha
// establecido, se precarga el valor por defecto de la definición.
function cfDisplayValue(cf: { code: string; fieldType: string; defaultValue: unknown }): string {
  if (Object.prototype.hasOwnProperty.call(empCustomFields, cf.code)) return cfValue(cf.code)
  return customFieldValueToString(cf.defaultValue, cf.fieldType)
}
const cfValues: Record<string, string> = {}
for (const cf of customFieldDefs) cfValues[cf.code] = cfDisplayValue(cf)

if (!emp) return Astro.redirect('/employees')

const isPublica = tipoInstitucion === 'publica'

// For each dropdown: show active items + currently selected one (even if inactive)
function buildOptions<T extends CatalogItem>(items: T[], currentId: string | null) {
  const active = items.filter((i) => i.isActive)
  if (currentId && !active.find((i) => i.id === currentId)) {
    const current = items.find((i) => i.id === currentId)
    if (current) active.unshift(current)
  }
  return active
}

const cargoOptions = buildOptions(cargos, emp.jobTitleId)
const funcionOptions = buildOptions(funciones, emp.jobFunctionId)
const deptOptions = buildOptions(departamentos, emp.departmentId)

const positionOptions = isPublica ? positions.filter((p) => p.isActive) : []
// Currently assigned position drives the salary ceiling and the read-only
// info block shown for institutions with positions.
const currentPosition = isPublica ? (positions.find((p) => p.id === emp.positionId) ?? null) : null
const jobTitleNameById = new Map(cargos.map((c) => [c.id, c.name]))

const positionSelectOptions = positionOptions.map((p) => ({
  id: p.id,
  name: p.name,
  code: p.code,
  salary: p.salary,
  status: p.status,
  jobTitleId: p.jobTitleId,
  cargoName: p.jobTitleId ? (jobTitleNameById.get(p.jobTitleId) ?? '') : '',
  departmentId: p.departmentId,
  overtimeAmount: p.overtimeAmount ?? '0',
  representationAmount: p.representationAmount ?? '0',
}))

const error = Astro.url.searchParams.get('error') ?? ''
const success = Astro.url.searchParams.get('success') === '1'
const errorMessages: Record<string, string> = {
  code_taken: 'El código de empleado ya está en uso.',
  id_taken: 'La cédula ya está registrada.',
  no_payroll_type: 'El empleado debe pertenecer a al menos un tipo de planilla.',
  salary_max: 'El salario base no puede superar el salario de la posición.',
  position_occupied: 'La posición seleccionada ya está ocupada por otro empleado.',
  'server-error': 'Error del servidor. Intenta de nuevo.',
  'missing-fields': 'Completa todos los campos requeridos.',
}

const freqLabel: Record<string, string> = {
  biweekly: 'Quincenal',
  monthly: 'Mensual',
  weekly: 'Semanal',
}
---

<AppLayout title={`${emp.firstName} ${emp.lastName}`}>
  <div class="p-8">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">{emp.firstName} {emp.lastName}</h1>
        <p class="text-sm text-gray-500 mt-0.5">Código: {emp.code}</p>
      </div>
      <div class="flex items-center gap-3">
        {!emp.isActive && (
          <span class="px-3 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-500">
            Inactivo
          </span>
        )}
        <a href="/employees" class="text-sm text-gray-500 hover:text-gray-700">← Volver</a>
      </div>
    </div>

    {success && (
      <div id="serverSuccess" class="mb-6 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">
        Empleado actualizado correctamente.
      </div>
    )}
    {error && (
      <div id="serverError" class="mb-6 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
        {errorMessages[error] ?? 'Ocurrió un error inesperado.'}
      </div>
    )}

    <form method="POST" action={`/api/employees/${id}`} id="empForm" novalidate>
      <input type="hidden" name="_method" value="PUT" />
      <div id="reqError" class="hidden mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700"></div>

      <!-- Tabs -->
      <div class="flex gap-0 border-b-2 border-gray-200 mb-6">
        <button type="button" class="tab-btn active" data-tab="personal" onclick="switchTab('personal', this)">
          Datos Personales
        </button>
        <button type="button" class="tab-btn" data-tab="laboral" onclick="switchTab('laboral', this)">
          Datos Laborales
        </button>
        <button type="button" class="tab-btn" data-tab="bancario" onclick="switchTab('bancario', this)">
          Bancario
        </button>
        <button type="button" class="tab-btn" data-tab="prestamos" onclick="switchTab('prestamos', this)">
          Préstamos
        </button>
        {payrollTypes.length > 0 && (
          <button type="button" class="tab-btn" data-tab="nomina" onclick="switchTab('nomina', this)">
            Tipos de Planilla
          </button>
        )}
        {customFieldDefs.length > 0 && (
          <button type="button" class="tab-btn" data-tab="adicionales" onclick="switchTab('adicionales', this)">
            Campos adicionales
          </button>
        )}
        <button type="button" class="tab-btn" data-tab="expedientes" onclick="switchTab('expedientes', this)">
          Expedientes{efFiles.length > 0 ? ` (${efFiles.length})` : ''}
        </button>
        <button type="button" class="tab-btn" data-tab="saldos" onclick="switchTab('saldos', this)">
          Saldos
        </button>
        <button type="button" class="tab-btn" data-tab="dependientes" onclick="switchTab('dependientes', this)">
          Dependientes
        </button>
        <button type="button" class="tab-btn" data-tab="portal" onclick="switchTab('portal', this)">
          Portal
        </button>
      </div>

      <!-- TAB: Datos Personales -->
      <div id="tab-personal">
        <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
          <h3 class="font-semibold text-gray-800 mb-4">Nombres</h3>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Primer nombre *</label>
              <input type="text" name="firstName" class="input" required value={emp.firstName} />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Segundo nombre</label>
              <input type="text" name="secondName" class="input" value={emp.secondName ?? ''} />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Primer apellido *</label>
              <input type="text" name="lastName" class="input" required value={emp.lastName} />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Segundo apellido</label>
              <input type="text" name="secondSurname" class="input" value={emp.secondSurname ?? ''} />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Apellido de casada</label>
              <input type="text" name="marriedSurname" class="input" value={emp.marriedSurname ?? ''} />
            </div>
          </div>
        </div>

        <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
          <h3 class="font-semibold text-gray-800 mb-4">Identificación</h3>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="col-span-2 md:col-span-1">
              <label class="block text-sm font-medium text-gray-700 mb-1">Cédula *</label>
              <input type="text" name="idNumber" class="input" required value={emp.idNumber} />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Sigla</label>
              <input type="text" name="idPrefix" class="input" maxlength="5" value={emp.idPrefix ?? ''} />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Provincia</label>
              <input type="text" name="idProvince" class="input" maxlength="5" value={emp.idProvince ?? ''} />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Tomo</label>
              <input type="text" name="idVolume" class="input" maxlength="10" value={emp.idVolume ?? ''} />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Folio</label>
              <input type="text" name="idFolio" class="input" maxlength="10" value={emp.idFolio ?? ''} />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Seguro social</label>
              <input type="text" name="socialSecurityNumber" class="input" value={emp.socialSecurityNumber ?? ''} />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Sexo *</label>
              <select name="sex" class="input" required>
                <option value="">—</option>
                <option value="M" selected={emp.sex === 'M'}>Masculino</option>
                <option value="F" selected={emp.sex === 'F'}>Femenino</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Estado civil</label>
              <select name="maritalStatus" class="input">
                <option value="">—</option>
                <option value="single" selected={emp.maritalStatus === 'single'}>Soltero(a)</option>
                <option value="married" selected={emp.maritalStatus === 'married'}>Casado(a)</option>
                <option value="divorced" selected={emp.maritalStatus === 'divorced'}>Divorciado(a)</option>
                <option value="widowed" selected={emp.maritalStatus === 'widowed'}>Viudo(a)</option>
                <option value="union" selected={emp.maritalStatus === 'union'}>Unión libre</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Nacionalidad *</label>
              <select name="nationality" class="input" required>
                <option value="">—</option>
                <option value="panamanian" selected={emp.nationality === 'panamanian'}>Panameño(a)</option>
                <option value="foreign" selected={emp.nationality === 'foreign'}>Extranjero(a)</option>
                <option value="naturalized" selected={emp.nationality === 'naturalized'}>Nacionalizado(a)</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Fecha de nacimiento</label>
              <input type="date" name="birthDate" class="input" value={emp.birthDate ?? ''} />
            </div>
            <div class="col-span-2">
              <label class="block text-sm font-medium text-gray-700 mb-1">Lugar de nacimiento</label>
              <input type="text" name="birthPlace" class="input" value={emp.birthPlace ?? ''} />
            </div>
          </div>
        </div>

        <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
          <h3 class="font-semibold text-gray-800 mb-4">Contacto y dirección</h3>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Email institucional</label>
              <input type="email" name="email" class="input" value={emp.email ?? ''} />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Email personal</label>
              <input type="email" name="personalEmail" class="input" value={emp.personalEmail ?? ''} />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Teléfono</label>
              <input type="text" name="phone" class="input" value={emp.phone ?? ''} />
            </div>
            <div></div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Provincia</label>
              <input type="text" name="addressProvince" class="input" value={emp.addressProvince ?? ''} />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Distrito</label>
              <input type="text" name="addressDistrict" class="input" value={emp.addressDistrict ?? ''} />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Corregimiento</label>
              <input type="text" name="addressTownship" class="input" value={emp.addressTownship ?? ''} />
            </div>
            <div></div>
            <div class="col-span-2">
              <label class="block text-sm font-medium text-gray-700 mb-1">Dirección</label>
              <input type="text" name="address" class="input" value={emp.address ?? ''} />
            </div>
            <div class="col-span-2">
              <label class="block text-sm font-medium text-gray-700 mb-1">Otra dirección</label>
              <input type="text" name="otherAddress" class="input" value={emp.otherAddress ?? ''} />
            </div>
          </div>
        </div>

        <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
          <h3 class="font-semibold text-gray-800 mb-1">Condición y registro</h3>
          <p class="text-xs text-gray-500 mb-4">
            Marque las casillas que apliquen a este colaborador. La discapacidad propia
            habilita su saldo de incapacidad.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            <label class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:bg-gray-50 cursor-pointer">
              <input type="checkbox" name="hasOwnDisability" class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" checked={emp.hasOwnDisability ?? false} />
              <span class="text-sm text-gray-700">Tiene discapacidad propia</span>
            </label>
            <label class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:bg-gray-50 cursor-pointer">
              <input type="checkbox" name="requiresAttendanceMarking" class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" checked={emp.requiresAttendanceMarking ?? true} />
              <span class="text-sm text-gray-700">Marca reloj (registra asistencia)</span>
            </label>
            <label class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:bg-gray-50 cursor-pointer">
              <input type="checkbox" name="canRead" class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" checked={emp.canRead ?? false} />
              <span class="text-sm text-gray-700">Sabe leer</span>
            </label>
            <label class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:bg-gray-50 cursor-pointer">
              <input type="checkbox" name="canWrite" class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" checked={emp.canWrite ?? false} />
              <span class="text-sm text-gray-700">Sabe escribir</span>
            </label>
          </div>
        </div>

        <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
          <h3 class="font-semibold text-gray-800 mb-1">Foto y cédula</h3>
          <p class="text-xs text-gray-500 mb-4">
            Imágenes en formato PNG, JPEG o WEBP, hasta 500 KB cada una. La foto se
            guarda como referencia visual y puede usarse para enrolar el rostro.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Foto del colaborador</label>
              <img id="photoPreview" src={emp.photo ?? ''} alt="" class={`w-28 h-28 rounded-lg object-cover border border-gray-200 mb-2 ${emp.photo ? '' : 'hidden'}`} />
              <input type="hidden" name="photo" id="photoInput" value={emp.photo ?? ''} />
              <input type="file" id="photoFile" accept="image/png,image/jpeg,image/webp" class="block w-full text-sm file:mr-4 file:py-1.5 file:px-3 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" />
              <div class="flex items-center gap-3 mt-2">
                <button type="button" id="photoClear" class={`text-xs text-red-600 hover:underline ${emp.photo ? '' : 'hidden'}`}>Quitar foto</button>
                <button type="button" id="enrollFaceBtn" class={`text-xs font-medium text-blue-600 hover:underline ${emp.photo ? '' : 'hidden'}`}>Enrolar rostro desde la foto</button>
              </div>
              <p id="enrollStatus" class="hidden mt-2 text-xs"></p>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Cédula escaneada</label>
              <img id="scannedIdPreview" src={emp.scannedId ?? ''} alt="" class={`w-full max-w-xs rounded-lg object-cover border border-gray-200 mb-2 ${emp.scannedId ? '' : 'hidden'}`} />
              <input type="hidden" name="scannedId" id="scannedIdInput" value={emp.scannedId ?? ''} />
              <input type="file" id="scannedIdFile" accept="image/png,image/jpeg,image/webp" class="block w-full text-sm file:mr-4 file:py-1.5 file:px-3 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" />
              <button type="button" id="scannedIdClear" class={`mt-2 text-xs text-red-600 hover:underline ${emp.scannedId ? '' : 'hidden'}`}>Quitar imagen</button>
            </div>
          </div>
          <p id="imageError" class="hidden mt-3 text-xs text-red-600"></p>
        </div>
      </div>

      <!-- TAB: Datos Laborales -->
      <div id="tab-laboral" style="display:none">
        <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
          <h3 class="font-semibold text-gray-800 mb-4">Puesto y Departamento</h3>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Código de empleado *</label>
              <input type="text" name="code" class="input" required value={emp.code} />
            </div>

            {isPublica ? (
              <!-- Empresa pública: selector de posición con badge de estado -->
              <PositionSelect
                options={positionSelectOptions}
                selectedId={emp.positionId}
                allowEmpty
                label="Posición"
              />
              <!-- Cargo + departamento se derivan de la posición -->
              <input type="hidden" name="jobTitleId" id="hiddenCargoId" value={emp.jobTitleId ?? ''} />
              <input type="hidden" name="departmentId" id="hiddenDepartamentoId" value={emp.departmentId ?? ''} />
              <!-- La función es atributo del empleado, editable también con posición -->
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Función</label>
                <select name="jobFunctionId" class="input">
                  <option value="">— Sin función —</option>
                  {funcionOptions.map((f) => (
                    <option value={f.id} selected={emp!.jobFunctionId === f.id}>
                      {f.name} ({f.code})
                    </option>
                  ))}
                </select>
              </div>
            ) : (
              <!-- Empresa privada: selección directa -->
              <>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Departamento *</label>
                  <select name="departmentId" class="input" required>
                    <option value="">— Sin departamento —</option>
                    {deptOptions.map((d) => (
                      <option value={d.id} selected={emp!.departmentId === d.id}>
                        {d.name} ({d.code})
                      </option>
                    ))}
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Cargo</label>
                  <select name="jobTitleId" class="input">
                    <option value="">— Sin cargo —</option>
                    {cargoOptions.map((c) => (
                      <option value={c.id} selected={emp!.jobTitleId === c.id}>
                        {c.name} ({c.code})
                      </option>
                    ))}
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Función</label>
                  <select name="jobFunctionId" class="input">
                    <option value="">— Sin función —</option>
                    {funcionOptions.map((f) => (
                      <option value={f.id} selected={emp!.jobFunctionId === f.id}>
                        {f.name} ({f.code})
                      </option>
                    ))}
                  </select>
                </div>
              </>
            )}
          </div>
        </div>

        {isPublica && (
          <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4" id="positionInfoCard" style={currentPosition ? '' : 'display:none'}>
            <h3 class="font-semibold text-gray-800 mb-4">Información de la posición</h3>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
              <div>
                <div class="text-xs text-gray-500 mb-0.5">Cargo</div>
                <div class="text-gray-800" id="posInfoCargo">
                  {currentPosition?.jobTitleId ? (jobTitleNameById.get(currentPosition.jobTitleId) ?? '—') : '—'}
                </div>
              </div>
              <div>
                <div class="text-xs text-gray-500 mb-0.5">Salario de la posición</div>
                <div class="text-gray-800" id="posInfoSalary">{currentPosition ? `$${currentPosition.salary}` : '—'}</div>
              </div>
              <div>
                <div class="text-xs text-gray-500 mb-0.5">Sobresueldo</div>
                <div class="text-gray-800" id="posInfoOvertime">{currentPosition ? `$${currentPosition.overtimeAmount ?? '0'}` : '—'}</div>
              </div>
              <div>
                <div class="text-xs text-gray-500 mb-0.5">Gastos de representación</div>
                <div class="text-gray-800" id="posInfoRepresentation">{currentPosition ? `$${currentPosition.representationAmount ?? '0'}` : '—'}</div>
              </div>
            </div>
          </div>
        )}

        <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
          <h3 class="font-semibold text-gray-800 mb-4">Salario y Contrato</h3>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Fecha de ingreso *</label>
              <input type="date" name="hireDate" class="input" required value={emp.hireDate} />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Frecuencia de pago *</label>
              <select name="payFrequency" class="input" required>
                {(['biweekly', 'monthly', 'weekly'] as const).map((f) => (
                  <option value={f} selected={emp!.payFrequency === f}>{freqLabel[f]}</option>
                ))}
              </select>
            </div>
            <div class="col-span-2">
              <label class="block text-sm font-medium text-gray-700 mb-1">
                Salario base (USD) *
                {isPublica && (
                  <span class="ml-1 text-xs text-gray-400" id="salaryMaxHint">
                    {currentPosition ? `(máximo de la posición: $${currentPosition.salary})` : ''}
                  </span>
                )}
              </label>
              <input
                type="text"
                name="baseSalary"
                id="baseSalaryInput"
                class="input"
                required
                value={emp.baseSalary}
                data-position-max={currentPosition?.salary ?? ''}
              />
              {isPublica && (
                <p class="mt-1 text-xs text-gray-500">
                  Puede ajustar el salario hacia abajo; no puede superar el salario de la posición.
                </p>
              )}
            </div>
          </div>
        </div>

        <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
          <h3 class="font-semibold text-gray-800 mb-4">Datos gubernamentales y contratación</h3>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">N° Decreto</label>
              <input type="text" name="decreeNumber" class="input" value={emp.decreeNumber ?? ''} />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Fecha Decreto</label>
              <input type="date" name="decreeDate" class="input" value={emp.decreeDate ?? ''} />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">N° Resuelto</label>
              <input type="text" name="resolutionNumber" class="input" value={emp.resolutionNumber ?? ''} />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Fecha Resuelto</label>
              <input type="date" name="resolutionDate" class="input" value={emp.resolutionDate ?? ''} />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">N° Colaborador</label>
              <input type="text" name="collaboratorNumber" class="input" value={emp.collaboratorNumber ?? ''} />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Ref. usuario externo</label>
              <input type="text" name="externalUserRef" class="input" value={emp.externalUserRef ?? ''} />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Tipo de contrato *</label>
              <select name="contractType" class="input" required>
                <option value="">—</option>
                <option value="permanent" selected={emp.contractType === 'permanent'}>Permanente</option>
                <option value="transitory" selected={emp.contractType === 'transitory'}>Contrato transitorio</option>
                <option value="contingent" selected={emp.contractType === 'contingent'}>Contrato contingente</option>
                <option value="professional_services" selected={emp.contractType === 'professional_services'}>Servicios profesionales</option>
                <option value="deputy" selected={emp.contractType === 'deputy'}>Contrato diputado</option>
                <option value="interim" selected={emp.contractType === 'interim'}>Contrato interino</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Clave I/R</label>
              <input type="text" name="irKey" class="input" value={emp.irKey ?? ''} />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Horas base semanales</label>
              <input type="text" name="weeklyBaseHours" class="input" value={emp.weeklyBaseHours ?? ''} />
            </div>
            <div class="col-span-2 md:col-span-3">
              <label class="block text-sm font-medium text-gray-700 mb-1">Observaciones</label>
              <input type="text" name="observations" class="input" value={emp.observations ?? ''} />
            </div>
          </div>
        </div>

        {!emp.isActive && (
          <div class="bg-white rounded-xl border border-red-200 p-6 mb-4">
            <h3 class="font-semibold text-red-700 mb-4">Datos de baja</h3>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Decreto baja</label>
                <input type="text" name="terminationDecree" class="input" value={emp.terminationDecree ?? ''} />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Fecha decreto baja</label>
                <input type="date" name="terminationDecreeDate" class="input" value={emp.terminationDecreeDate ?? ''} />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Resuelto baja</label>
                <input type="text" name="terminationResolution" class="input" value={emp.terminationResolution ?? ''} />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Fecha resuelto baja</label>
                <input type="date" name="terminationResolutionDate" class="input" value={emp.terminationResolutionDate ?? ''} />
              </div>
              <div class="col-span-2 md:col-span-4">
                <label class="block text-sm font-medium text-gray-700 mb-1">Causal de baja</label>
                <input type="text" name="terminationReason" class="input" value={emp.terminationReason ?? ''} />
              </div>
            </div>
          </div>
        )}
      </div>

      <!-- TAB: Bancario -->
      <div id="tab-bancario" style="display:none">
        <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
          <h3 class="font-semibold text-gray-800 mb-1">Datos bancarios</h3>
          <p class="text-xs text-gray-500 mb-4">
            Configura cómo el empleado recibe su pago. El campo <strong>método</strong>
            determina si entra al lote ACH automático o si se le emite cheque manual
            desde el módulo de Tesorería.
          </p>

          <div>
            <label class="block text-sm text-gray-700 font-medium mb-1.5">Método de pago *</label>
            <div class="bank-radio-group">
              <label class="bank-radio-label">
                <input type="radio" name="paymentMethod" value="check" checked={(emp.paymentMethod ?? 'check') === 'check'} class="bank-radio-input" />
                <span class="bank-radio-card">Cheque</span>
              </label>
              <label class="bank-radio-label">
                <input type="radio" name="paymentMethod" value="ach" checked={emp.paymentMethod === 'ach'} class="bank-radio-input" />
                <span class="bank-radio-card">ACH</span>
              </label>
              <label class="bank-radio-label">
                <input type="radio" name="paymentMethod" value="cash" checked={emp.paymentMethod === 'cash'} class="bank-radio-input" />
                <span class="bank-radio-card">Efectivo</span>
              </label>
            </div>
          </div>

          <div id="bank-fields" class="grid grid-cols-2 gap-4 mt-4" style={emp.paymentMethod === 'cash' ? 'display:none' : ''}>
            <div>
              <label class="block text-sm text-gray-700 font-medium mb-1">Banco</label>
              <select name="bankId" class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm">
                <option value="">— Sin banco —</option>
                {banksCatalog.filter((b) => b.isActive === 1).map((b) => (
                  <option value={b.id} selected={emp.bankId === b.id}>{b.name}</option>
                ))}
              </select>
            </div>

            <div>
              <label class="block text-sm text-gray-700 font-medium mb-1">Tipo de cuenta</label>
              <select name="accountType" class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm">
                <option value="" selected={!emp.accountType}>— Sin cuenta —</option>
                <option value="savings" selected={emp.accountType === 'savings'}>Ahorros (SC)</option>
                <option value="checking" selected={emp.accountType === 'checking'}>Corriente (DC)</option>
              </select>
            </div>

            <div class="col-span-2">
              <label class="block text-sm text-gray-700 font-medium mb-1">Número de cuenta</label>
              <input type="text" name="accountNumber" value={emp.accountNumber ?? ''} maxlength="40" class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm font-mono" />
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4 mt-4">
            <div>
              <label class="block text-sm text-gray-700 font-medium mb-1">SIACAP %</label>
              <input type="text" name="siacapPct" value={emp.siacapPct ?? ''} maxlength="10" class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm" />
            </div>
          </div>
        </div>
      </div>

      <!-- TAB: Préstamos -->
      <div id="tab-prestamos" style="display:none">
        <div class="bg-white rounded-xl border border-gray-200 overflow-hidden mb-4">
          <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
            <h3 class="font-semibold text-gray-800">Préstamos</h3>
          </div>
          {loans.length === 0 ? (
            <div class="p-10 text-center text-gray-400 text-sm">
              Sin préstamos registrados.
            </div>
          ) : (
            <table class="w-full text-sm">
              <thead class="bg-gray-50 border-b border-gray-200">
                <tr>
                  <th class="text-left px-4 py-3 font-medium text-gray-600">Monto</th>
                  <th class="text-left px-4 py-3 font-medium text-gray-600">Saldo</th>
                  <th class="text-left px-4 py-3 font-medium text-gray-600">Cuota</th>
                  <th class="text-left px-4 py-3 font-medium text-gray-600">Inicio</th>
                  <th class="text-left px-4 py-3 font-medium text-gray-600">Fin</th>
                  <th class="text-left px-4 py-3 font-medium text-gray-600">Estado</th>
                  <th class="px-4 py-3"></th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                {loans.map((loan) => (
                  <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-4 py-3 text-gray-900">${loan.amount}</td>
                    <td class="px-4 py-3 text-gray-700">${loan.balance}</td>
                    <td class="px-4 py-3 text-gray-700">${loan.installment}</td>
                    <td class="px-4 py-3 text-gray-600">{loan.startDate}</td>
                    <td class="px-4 py-3 text-gray-600">{loan.endDate ?? '—'}</td>
                    <td class="px-4 py-3">
                      <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${loan.isActive ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500'}`}>
                        {loan.isActive ? 'Activo' : 'Cerrado'}
                      </span>
                    </td>
                    <td class="px-4 py-3">
                      <div class="flex items-center justify-end gap-1">
                        <a href={`/employees/${id}/loans/${loan.id}`} title="Editar" class="p-1.5 rounded-lg text-gray-400 hover:text-blue-600 hover:bg-blue-50 transition-colors">
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                          </svg>
                        </a>
                        {loan.isActive && (
                          <form method="POST" action={`/api/employees/${id}/loans/${loan.id}`}
                            data-confirm-submit="¿Cerrar este préstamo?" data-confirm-title="Cerrar préstamo" data-confirm-tone="danger" data-confirm-label="Cerrar"
                          >
                            <input type="hidden" name="_method" value="DELETE" />
                            <button type="submit" title="Cerrar préstamo" class="p-1.5 rounded-lg text-gray-400 hover:text-red-600 hover:bg-red-50 transition-colors">
                              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
                              </svg>
                            </button>
                          </form>
                        )}
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}
        </div>
      </div>

      <!-- TAB: Tipos de Planilla -->
      {payrollTypes.length > 0 && (
        <div id="tab-nomina" style="display:none">
          <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
            <h3 class="font-semibold text-gray-800 mb-1">Tipos de Planilla</h3>
            <p class="text-xs text-gray-500 mb-4">El empleado debe pertenecer a al menos un tipo de planilla.</p>
            <div class="grid grid-cols-2 gap-3">
              {payrollTypes.map((pt) => (
                <label class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:bg-gray-50 cursor-pointer">
                  <input
                    type="checkbox"
                    name="payrollTypeIds[]"
                    value={pt.id}
                    class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500"
                    checked={emp!.payrollTypeIds?.includes(pt.id) ?? false}
                  />
                  <span class="text-sm text-gray-700">{pt.name}</span>
                </label>
              ))}
            </div>
          </div>
        </div>
      )}

      <!-- TAB: Campos adicionales (custom_field_definitions) -->
      {customFieldDefs.length > 0 && (
        <div id="tab-adicionales" style="display:none">
          <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
            <h3 class="font-semibold text-gray-800 mb-1">Campos adicionales</h3>
            <p class="text-xs text-gray-500 mb-4">
              Definidos en <a href="/config/custom-fields" class="text-blue-600 hover:underline">Configuración → Campos
              adicionales</a>. Los valores numéricos se pueden referenciar en fórmulas con
              <code class="font-mono">CAMPOADICIONAL("código")</code>.
            </p>
            <CustomFieldInputs defs={customFieldDefs} values={cfValues} />
          </div>
        </div>
      )}

      <!-- TAB: Expedientes -->
      <div id="tab-expedientes" style="display:none">
        <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
          <div class="flex items-end justify-between mb-4">
            <div>
              <h3 class="font-semibold text-gray-800 mb-1">Expedientes del empleado</h3>
              <p class="text-xs text-gray-500">
                {efFiles.length} {efFiles.length === 1 ? 'registro' : 'registros'} — estudios, permisos, licencias, etc.
              </p>
            </div>
          </div>

          {efFiles.length === 0 ? (
            <p class="text-sm text-gray-400 py-8 text-center">
              Sin expedientes para este empleado todavía.{' '}
              <a href={`/employee-files?employeeId=${id}`} class="text-blue-600 hover:underline">Crear el primero</a>.
            </p>
          ) : (
            <div class="space-y-4">
              {efTypesWithFiles.map((g) => (
                <div>
                  <h4 class="text-xs font-semibold text-gray-700 uppercase tracking-wide mb-2">
                    {g.type.name}
                    <span class="ml-1.5 text-gray-400 normal-case font-normal">
                      · {g.rows.length} {g.rows.length === 1 ? 'expediente' : 'expedientes'}
                    </span>
                  </h4>
                  <div class="overflow-x-auto border border-gray-200 rounded-lg">
                    <table class="w-full text-sm">
                      <thead>
                        <tr class="border-b border-gray-200 bg-gray-50">
                          <th class="text-left px-3 py-2 text-xs font-medium text-gray-500 uppercase tracking-wide">Número</th>
                          <th class="text-left px-3 py-2 text-xs font-medium text-gray-500 uppercase tracking-wide">Fecha</th>
                          <th class="text-left px-3 py-2 text-xs font-medium text-gray-500 uppercase tracking-wide">Subtipo</th>
                          <th class="text-left px-3 py-2 text-xs font-medium text-gray-500 uppercase tracking-wide">Estado</th>
                          <th class="text-left px-3 py-2 text-xs font-medium text-gray-500 uppercase tracking-wide">Observaciones</th>
                          <th class="px-3 py-2"></th>
                        </tr>
                      </thead>
                      <tbody>
                        {g.rows.map((f) => {
                          const s = efSubtypeById.get(f.subtypeId)
                          const status = f.approvalStatus ?? 'approved'
                          const statusLabel = status === 'pending' ? 'Pendiente' : status === 'approved' ? 'Aprobado' : 'Rechazado'
                          const statusClass = status === 'pending'
                            ? 'bg-amber-100 text-amber-800'
                            : status === 'approved'
                              ? 'bg-green-100 text-green-700'
                              : 'bg-red-100 text-red-700'
                          return (
                            <tr class="border-b border-gray-100 last:border-0 hover:bg-gray-50 transition-colors">
                              <td class="px-3 py-2 font-mono text-xs text-gray-600 whitespace-nowrap">{f.documentNumber}</td>
                              <td class="px-3 py-2 text-xs text-gray-700 whitespace-nowrap">{fmtFileDate(f.documentDate)}</td>
                              <td class="px-3 py-2 text-xs text-gray-700">{s?.name ?? '—'}</td>
                              <td class="px-3 py-2 whitespace-nowrap">
                                <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-medium ${statusClass}`}>{statusLabel}</span>
                                {status === 'rejected' && f.rejectionReason && (
                                  <div class="text-[10px] text-gray-500 mt-0.5" title={f.rejectionReason}>
                                    {f.rejectionReason.length > 40 ? `${f.rejectionReason.slice(0, 40)}…` : f.rejectionReason}
                                  </div>
                                )}
                              </td>
                              <td class="px-3 py-2 text-xs text-gray-500 truncate max-w-xs" title={f.observations ?? ''}>
                                {f.observations ?? '—'}
                              </td>
                              <td class="px-3 py-2 text-right whitespace-nowrap">
                                <a href={`/employee-files/${f.id}`} class="text-xs text-gray-500 hover:text-gray-900">Ver</a>
                              </td>
                            </tr>
                          )
                        })}
                      </tbody>
                    </table>
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>
      </div>

      <!-- TAB: Saldos (vacaciones + compensatorios + incapacidades) -->
      <div id="tab-saldos" style="display:none">
        <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
          <div class="flex items-end justify-between mb-4">
            <div>
              <h3 class="font-semibold text-gray-800 mb-1">Saldo de vacaciones</h3>
              <p class="text-xs text-gray-500">
                30 días de cada tipo se acreditan al cumplir cada año desde la contratación.
                {vacBalance?.lastAccrualDate ? ` Último acreditado: ${vacBalance.lastAccrualDate}.` : ''}
              </p>
            </div>
          </div>

          {vacBalance ? (
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-2">
              <div class="vac-balance-card vac-balance-enjoy">
                <div class="vac-balance-header">Disfrute</div>
                <div class="flex items-baseline gap-2 mb-3">
                  <span class="vac-balance-number">{vacBalance.enjoy.available}</span>
                  <span class="vac-balance-total">/ {vacBalance.enjoy.earned} días disponibles</span>
                </div>
                <div class="vac-balance-detail">
                  <div>Acumulado: <strong>{vacBalance.enjoy.earned}</strong></div>
                  <div>Tomado: <strong>{vacBalance.enjoy.used}</strong></div>
                  <div>Reservado (pendientes): <strong>{vacBalance.enjoy.reserved}</strong></div>
                </div>
              </div>
              <div class="vac-balance-card vac-balance-paid">
                <div class="vac-balance-header vac-balance-header-paid">Pagado</div>
                <div class="flex items-baseline gap-2 mb-3">
                  <span class="vac-balance-number">{vacBalance.paid.available}</span>
                  <span class="vac-balance-total">/ {vacBalance.paid.earned} días disponibles</span>
                </div>
                <div class="vac-balance-detail">
                  <div>Acumulado: <strong>{vacBalance.paid.earned}</strong></div>
                  <div>Pagado: <strong>{vacBalance.paid.used}</strong></div>
                  <div>Reservado (pendientes): <strong>{vacBalance.paid.reserved}</strong></div>
                </div>
              </div>
            </div>
          ) : (
            <p class="text-sm text-gray-400 py-4">Saldo no disponible.</p>
          )}
        </div>

        <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
          <div class="flex items-end justify-between mb-3">
            <h3 class="font-semibold text-gray-800">Historial de solicitudes</h3>
            <span class="text-xs text-gray-500">{vacRequests.length} {vacRequests.length === 1 ? 'solicitud' : 'solicitudes'}</span>
          </div>
          {vacRequests.length === 0 ? (
            <p class="text-sm text-gray-400 py-6 text-center">Sin solicitudes registradas.</p>
          ) : (
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-gray-200 bg-gray-50">
                    <th class="text-left px-3 py-2 text-xs font-medium text-gray-500 uppercase tracking-wide">Número</th>
                    <th class="text-left px-3 py-2 text-xs font-medium text-gray-500 uppercase tracking-wide">Tipo</th>
                    <th class="text-left px-3 py-2 text-xs font-medium text-gray-500 uppercase tracking-wide">Período</th>
                    <th class="text-left px-3 py-2 text-xs font-medium text-gray-500 uppercase tracking-wide">Disfrute</th>
                    <th class="text-left px-3 py-2 text-xs font-medium text-gray-500 uppercase tracking-wide">Pago</th>
                    <th class="text-left px-3 py-2 text-xs font-medium text-gray-500 uppercase tracking-wide">Estado</th>
                    <th class="px-3 py-2"></th>
                  </tr>
                </thead>
                <tbody>
                  {vacRequests.map((r) => {
                    const statusLabel =
                      r.status === 'pending' ? 'Pendiente' :
                      r.status === 'approved' ? 'Aprobada' :
                      r.status === 'rejected' ? 'Rechazada' :
                      r.status === 'processed' ? 'Procesada' :
                      'Cancelada'
                    const statusClass =
                      r.status === 'pending' ? 'bg-amber-100 text-amber-800' :
                      r.status === 'approved' || r.status === 'processed' ? 'bg-green-100 text-green-700' :
                      r.status === 'rejected' ? 'bg-red-100 text-red-700' :
                      'bg-gray-100 text-gray-600'
                    const typeLabel = r.requestType === 'enjoy' ? 'Disfrute' : r.requestType === 'pay' ? 'Pago' : 'Mixto'
                    return (
                      <tr class="border-b border-gray-100 last:border-0 hover:bg-gray-50">
                        <td class="px-3 py-2 font-mono text-xs text-gray-700">{r.requestNumber}</td>
                        <td class="px-3 py-2 text-xs text-gray-700">{typeLabel}</td>
                        <td class="px-3 py-2 text-xs text-gray-700 whitespace-nowrap">
                          {r.startDate && r.endDate ? `${r.startDate} → ${r.endDate}` : '—'}
                        </td>
                        <td class="px-3 py-2 text-xs text-gray-700">{r.enjoyDays || '—'}</td>
                        <td class="px-3 py-2 text-xs text-gray-700">{r.paidDays || '—'}</td>
                        <td class="px-3 py-2">
                          <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-medium ${statusClass}`}>{statusLabel}</span>
                          {r.status === 'rejected' && r.rejectionReason && (
                            <div class="text-[10px] text-gray-500 mt-0.5" title={r.rejectionReason}>{r.rejectionReason.slice(0, 40)}</div>
                          )}
                        </td>
                        <td class="px-3 py-2 text-right whitespace-nowrap">
                          {r.status === 'pending' && (
                            <button type="button" class="text-[11px] text-red-600 hover:underline" data-cancel-vac={r.id} data-num={r.requestNumber}>Cancelar</button>
                          )}
                          {r.payrollId && (
                            <a href={`/payroll/${r.payrollId}`} class="text-[11px] text-blue-600 hover:underline" title="Ver planilla generada">
                              Planilla →
                            </a>
                          )}
                        </td>
                      </tr>
                    )
                  })}
                </tbody>
              </table>
            </div>
          )}
        </div>

        <!-- Modal: solicitar vacaciones -->
        <div id="vac-modal" class="fixed inset-0 bg-black/40 z-50 hidden items-center justify-center p-4">
          <div class="bg-white rounded-xl shadow-xl w-full max-w-lg border border-gray-200">
            <div class="px-5 py-3 border-b border-gray-200 flex items-center justify-between">
              <h3 class="font-semibold text-gray-900">Solicitar vacaciones</h3>
              <button type="button" id="vac-modal-close" class="text-gray-400 hover:text-gray-700 text-xl leading-none">×</button>
            </div>
            <form id="vac-form" class="p-5 space-y-3">
              <input type="hidden" name="employeeId" value={id} />
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1.5">Tipo de solicitud *</label>
                <div class="flex gap-2">
                  <label class="flex items-center gap-1.5 text-sm border border-gray-300 rounded-md px-3 py-2 cursor-pointer hover:bg-gray-50 flex-1 justify-center has-[:checked]:bg-blue-50 has-[:checked]:border-blue-500">
                    <input type="radio" name="requestType" value="enjoy" required checked />
                    <span>Disfrute</span>
                  </label>
                  <label class="flex items-center gap-1.5 text-sm border border-gray-300 rounded-md px-3 py-2 cursor-pointer hover:bg-gray-50 flex-1 justify-center has-[:checked]:bg-blue-50 has-[:checked]:border-blue-500">
                    <input type="radio" name="requestType" value="pay" />
                    <span>Pago</span>
                  </label>
                  <label class="flex items-center gap-1.5 text-sm border border-gray-300 rounded-md px-3 py-2 cursor-pointer hover:bg-gray-50 flex-1 justify-center has-[:checked]:bg-blue-50 has-[:checked]:border-blue-500">
                    <input type="radio" name="requestType" value="mixed" />
                    <span>Mixto</span>
                  </label>
                </div>
              </div>
              <div class="grid grid-cols-2 gap-3">
                <div data-show-when="enjoy mixed">
                  <label class="block text-xs font-medium text-gray-600 mb-1.5">Fecha inicio</label>
                  <input type="date" name="startDate" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md" />
                </div>
                <div data-show-when="enjoy mixed">
                  <label class="block text-xs font-medium text-gray-600 mb-1.5">Fecha fin</label>
                  <input type="date" name="endDate" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md" />
                </div>
              </div>
              <div class="grid grid-cols-2 gap-3">
                <div data-show-when="enjoy mixed">
                  <label class="block text-xs font-medium text-gray-600 mb-1.5">
                    Días de disfrute
                    <span class="text-gray-400 ml-1">(máx. {vacBalance?.enjoy.available ?? 0})</span>
                  </label>
                  <input type="number" name="enjoyDays" min="0" max={vacBalance?.enjoy.available ?? 0} value="0" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md" />
                </div>
                <div data-show-when="pay mixed">
                  <label class="block text-xs font-medium text-gray-600 mb-1.5">
                    Días a pagar
                    <span class="text-gray-400 ml-1">(máx. {vacBalance?.paid.available ?? 0})</span>
                  </label>
                  <input type="number" name="paidDays" min="0" max={vacBalance?.paid.available ?? 0} value="0" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md" />
                </div>
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1.5">Motivo (opcional)</label>
                <textarea name="reason" rows="2" maxlength="1000" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md"></textarea>
              </div>
              <div id="vac-form-error" class="hidden text-xs text-red-700 bg-red-50 border border-red-200 rounded-md px-3 py-2"></div>
              <div class="flex justify-end gap-2 pt-2">
                <button type="button" id="vac-modal-cancel" class="px-3 py-2 text-sm text-gray-600 hover:text-gray-900">Cancelar</button>
                <button type="submit" class="px-4 py-2 bg-blue-600 text-white text-sm rounded-md hover:bg-blue-700 font-medium">Enviar solicitud</button>
              </div>
            </form>
          </div>
        </div>

        <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4 mt-4">
          <div class="flex items-end justify-between mb-4 flex-wrap gap-3">
            <div>
              <h3 class="font-semibold text-gray-800 mb-1">Saldos de tiempo</h3>
              <p class="text-xs text-gray-500">Tiempo compensatorio, incapacidad y familiar con discapacidad. Se reinician cada 1 de enero.</p>
            </div>
            <div class="flex items-center gap-2">
              <label class="text-xs text-gray-500">Año</label>
              <select id="ct-year" class="px-2 py-1.5 text-sm border border-gray-300 rounded-md"></select>
            </div>
          </div>
          <div id="comp-time-cards" class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
            <div class="text-center py-6 text-sm text-gray-400 col-span-3">Cargando...</div>
          </div>
          <div id="comp-time-movements">
            <h4 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Movimientos del año</h4>
            <div id="comp-time-mov-body" class="text-center py-4 text-sm text-gray-400">Cargando...</div>
          </div>
        </div>
      </div>

      <!-- TAB: Dependientes -->
      <div id="tab-dependientes" style="display:none">
        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <div class="flex items-end justify-between mb-4">
            <div>
              <h3 class="font-semibold text-gray-800 mb-1">Dependientes</h3>
              <p class="text-xs text-gray-500">Carga familiar del empleado.</p>
            </div>
            <button type="button" id="dep-add-btn" class="px-3 py-1.5 text-xs font-medium text-white rounded-md" style="background:var(--navy)">
              + Agregar
            </button>
          </div>

          <div id="dep-form" class="hidden mb-4 p-4 rounded-lg border border-gray-200 bg-gray-50">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-3">
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">Nombre *</label>
                <input type="text" id="dep-firstName" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md" />
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">Apellido *</label>
                <input type="text" id="dep-lastName" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md" />
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">Cédula</label>
                <input type="text" id="dep-idNumber" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md" />
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">Parentesco *</label>
                <select id="dep-relationship" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md">
                  <option value="spouse">Cónyuge</option>
                  <option value="child">Hijo(a)</option>
                  <option value="parent">Padre/Madre</option>
                  <option value="sibling">Hermano(a)</option>
                  <option value="other">Otro</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">Fecha nacimiento</label>
                <input type="date" id="dep-birthDate" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md" />
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">Sexo</label>
                <select id="dep-sex" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md">
                  <option value="">—</option>
                  <option value="M">Masculino</option>
                  <option value="F">Femenino</option>
                </select>
              </div>
              <div class="col-span-2 flex items-center gap-3 pt-4">
                <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                  <input type="checkbox" id="dep-hasDisability" class="rounded" />
                  Con discapacidad
                </label>
              </div>
            </div>
            <div id="dep-disability-row" class="hidden mb-3">
              <label class="block text-xs font-medium text-gray-600 mb-1">Descripción de discapacidad</label>
              <input type="text" id="dep-disabilityDesc" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md" />
            </div>
            <div class="flex justify-end gap-2">
              <button type="button" id="dep-cancel-btn" class="px-3 py-1.5 text-sm text-gray-600">Cancelar</button>
              <button type="button" id="dep-save-btn" class="px-4 py-1.5 text-sm text-white rounded-md font-medium" style="background:var(--ok)">Guardar</button>
            </div>
          </div>

          <div id="dep-list">
            <div class="py-8 text-center text-sm text-gray-400">Cargando...</div>
          </div>
        </div>
      </div>

      <!-- TAB: Portal de colaboradores -->
      <div id="tab-portal" style="display:none">
        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h3 class="font-semibold text-gray-800">Portal de colaboradores</h3>
              <p class="text-xs text-gray-500 mt-0.5">Gestión de acceso al portal de autoservicio.</p>
            </div>
            <span id="portal-status-badge" class="text-xs font-medium px-2.5 py-0.5 rounded bg-gray-100 text-gray-500">Cargando...</span>
          </div>

          <div id="portal-controls" class="space-y-1">
            <div class="flex items-center justify-between py-3 border-b border-gray-100">
              <div>
                <div class="text-sm font-medium text-gray-800">Acceso al portal</div>
                <div class="text-xs text-gray-500">El empleado podrá ingresar con su cédula y contraseña.</div>
              </div>
              <button type="button" class="toggle-btn" onclick="togglePortalCb('portal-enabled')">
                <span class="toggle-track toggle-off" id="portal-enabled-track"><span class="toggle-knob knob-off" id="portal-enabled-knob"></span></span>
              </button>
              <input type="checkbox" id="portal-enabled" class="hidden" />
            </div>

            <div class="flex items-center justify-between py-3 border-b border-gray-100">
              <div>
                <div class="text-sm font-medium text-gray-800">Aprobador de departamento</div>
                <div class="text-xs text-gray-500">Puede aprobar/rechazar solicitudes de su departamento.</div>
              </div>
              <button type="button" class="toggle-btn" onclick="togglePortalCb('portal-approver')">
                <span class="toggle-track toggle-off" id="portal-approver-track"><span class="toggle-knob knob-off" id="portal-approver-knob"></span></span>
              </button>
              <input type="checkbox" id="portal-approver" class="hidden" />
            </div>

            <div class="py-3 border-b border-gray-100">
              <div class="text-sm font-medium text-gray-800 mb-3">Módulos habilitados</div>
              <div class="grid grid-cols-2 gap-3">
                <label class="adv-check-item portal-mod-label">
                  <span class="adv-check-box">
                    <input type="checkbox" id="mod-requests" class="peer sr-only portal-mod" data-module="requests" />
                    <span class="adv-check-mark"><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="2.5 6 5 8.5 9.5 3.5"/></svg></span>
                  </span>
                  <span class="adv-check-label"><span class="text-sm">Solicitudes</span><br/><span class="text-xs" style="color:var(--mute)">Crear y ver expedientes</span></span>
                </label>
                <label class="adv-check-item portal-mod-label">
                  <span class="adv-check-box">
                    <input type="checkbox" id="mod-attendance" class="peer sr-only portal-mod" data-module="attendance" />
                    <span class="adv-check-mark"><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="2.5 6 5 8.5 9.5 3.5"/></svg></span>
                  </span>
                  <span class="adv-check-label"><span class="text-sm">Marcaciones</span><br/><span class="text-xs" style="color:var(--mute)">Ver registros de asistencia</span></span>
                </label>
                <label class="adv-check-item portal-mod-label">
                  <span class="adv-check-box">
                    <input type="checkbox" id="mod-vacations" class="peer sr-only portal-mod" data-module="vacations" />
                    <span class="adv-check-mark"><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="2.5 6 5 8.5 9.5 3.5"/></svg></span>
                  </span>
                  <span class="adv-check-label"><span class="text-sm">Vacaciones</span><br/><span class="text-xs" style="color:var(--mute)">Solicitar y ver saldo</span></span>
                </label>

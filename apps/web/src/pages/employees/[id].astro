<script type="application/json" id="cfDefs" set:html={JSON.stringify(customFieldDefs)}></script>

<script is:inline>
  ;(function () {
    const defsEl = document.getElementById('cfDefs')
    if (!defsEl) return
    let defs
    try {
      defs = JSON.parse(defsEl.textContent || '[]')
    } catch {
      return
    }
    if (!Array.isArray(defs) || defs.length === 0) return

    function readDeps(def) {
      const rules = def.validationRules && Array.isArray(def.validationRules.dependsOn)
        ? def.validationRules.dependsOn
        : []
      return rules.filter((r) => r && typeof r === 'object' && r.field && r.op && r.effect)
    }
    function isEmpty(v) {
      if (v == null) return true
      if (typeof v === 'string') return v.trim() === ''
      return false
    }
    function toNum(v) {
      if (v == null || v === '') return null
      const n = Number(v)
      return Number.isFinite(n) ? n : null
    }
    function evalRule(r, values) {
      const v = values[r.field]
      switch (r.op) {
        case 'eq': return String(v ?? '') === String(r.value ?? '')
        case 'ne': return String(v ?? '') !== String(r.value ?? '')
        case 'gt': { const a = toNum(v), b = toNum(r.value); return a != null && b != null && a > b }
        case 'lt': { const a = toNum(v), b = toNum(r.value); return a != null && b != null && a < b }
        case 'gte': { const a = toNum(v), b = toNum(r.value); return a != null && b != null && a >= b }
        case 'lte': { const a = toNum(v), b = toNum(r.value); return a != null && b != null && a <= b }
        case 'in': return Array.isArray(r.values) && r.values.some((x) => String(x) === String(v ?? ''))
        case 'empty': return isEmpty(v)
        case 'notEmpty': return !isEmpty(v)
        default: return false
      }
    }
    function readValues() {
      const out = {}
      for (const def of defs) {
        const el = document.querySelector('[name="cf_' + def.code + '"]')
        out[def.code] = el ? el.value : ''
      }
      return out
    }
    function applyState() {
      const values = readValues()
      for (const def of defs) {
        const rules = readDeps(def)
        const row = document.querySelector('[data-cf-row="' + def.code + '"]')
        const input = document.querySelector('[name="cf_' + def.code + '"]')
        if (!row || !input) continue
        const visRules = rules.filter((r) => r.effect === 'visible')
        const reqRules = rules.filter((r) => r.effect === 'required')
        const roRules = rules.filter((r) => r.effect === 'readonly')
        const visible = visRules.length === 0 ? true : visRules.every((r) => evalRule(r, values))
        const required = !!def.isRequired || (reqRules.length > 0 && reqRules.every((r) => evalRule(r, values)))
        const readonly = roRules.length > 0 && roRules.every((r) => evalRule(r, values))
        row.style.display = visible ? '' : 'none'
        if (required && visible) input.setAttribute('required', 'required')
        else input.removeAttribute('required')
        if (readonly) input.setAttribute('readonly', 'readonly')
        else input.removeAttribute('readonly')
        if (!visible) input.value = ''
        // Toggle the asterisk on the label so the user sees state changes.
        const lbl = row.querySelector('label')
        if (lbl) {
          const star = lbl.querySelector('.cf-required-star')
          if (required && !star) {
            const sp = document.createElement('span')
            sp.className = 'cf-required-star text-red-500 ml-0.5'
            sp.textContent = '*'
            lbl.appendChild(sp)
          } else if (!required && star) {
            star.remove()
          }
        }
      }
    }
    for (const def of defs) {
      const el = document.querySelector('[name="cf_' + def.code + '"]')
      if (el) el.addEventListener('input', applyState)
      if (el) el.addEventListener('change', applyState)
    }
    applyState()
  })()
</script>

<script is:inline>
  function switchTab(tab, btn) {
    document.querySelectorAll('[id^="tab-"]').forEach(el => el.style.display = 'none')
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'))
    document.getElementById('tab-' + tab).style.display = ''
    btn.classList.add('active')
  }

  // ─── Bancario: ocultar campos cuando es Efectivo ───────────────────────
  ;(function() {
    var bankFields = document.getElementById('bank-fields');
    var radios = document.querySelectorAll('input[name="paymentMethod"]');
    if (!bankFields || !radios.length) return;
    radios.forEach(function(r) {
      r.addEventListener('change', function() { bankFields.style.display = this.value === 'cash' ? 'none' : ''; });
    });
  })();

  // ─── Vacaciones: modal de solicitud + cancelación ──────────────────────
  ;(function () {
    const modal = document.getElementById('vac-modal')
    const openBtn = document.getElementById('vac-request-btn')
    const closeBtn = document.getElementById('vac-modal-close')
    const cancelBtn = document.getElementById('vac-modal-cancel')
    const form = document.getElementById('vac-form')
    const errBox = document.getElementById('vac-form-error')

    function openModal() {
      if (!modal) return
      modal.classList.remove('hidden')
      modal.classList.add('flex')
      errBox.classList.add('hidden')
      applyTypeVisibility()
    }
    function closeModal() {
      if (!modal) return
      modal.classList.add('hidden')
      modal.classList.remove('flex')
      form.reset()
    }
    function applyTypeVisibility() {
      const selectedType = form.querySelector('input[name="requestType"]:checked')?.value || 'enjoy'
      form.querySelectorAll('[data-show-when]').forEach((el) => {
        const allowed = (el.getAttribute('data-show-when') || '').split(' ')
        el.style.display = allowed.includes(selectedType) ? '' : 'none'
      })
    }

    openBtn?.addEventListener('click', openModal)
    closeBtn?.addEventListener('click', closeModal)
    cancelBtn?.addEventListener('click', closeModal)
    modal?.addEventListener('click', (e) => { if (e.target === modal) closeModal() })
    form?.querySelectorAll('input[name="requestType"]').forEach((r) => r.addEventListener('change', applyTypeVisibility))

    form?.addEventListener('submit', async (e) => {
      e.preventDefault()
      errBox.classList.add('hidden')
      const fd = new FormData(form)
      const payload = {
        employeeId: fd.get('employeeId'),
        requestType: fd.get('requestType'),
        startDate: fd.get('startDate') || null,
        endDate: fd.get('endDate') || null,
        enjoyDays: parseInt(fd.get('enjoyDays') || '0', 10),
        paidDays: parseInt(fd.get('paidDays') || '0', 10),
        reason: fd.get('reason') || null,
      }
      try {
        const res = await fetch('/api/vacations/action?op=create', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-SA-Modal': '1' },
          body: JSON.stringify(payload),
        })
        const json = await res.json().catch(() => ({}))
        if (!json.ok) {
          errBox.textContent = json.error || ('HTTP ' + res.status)
          errBox.classList.remove('hidden')
          return
        }
        const sa = window.saModal
        if (sa) {
          await sa.success({
            title: 'Solicitud enviada',
            message: `Solicitud ${json.data?.requestNumber || ''} creada. El saldo quedó reservado hasta la aprobación.`,
            redirect: window.location.pathname,
          })
        } else {
          window.location.reload()
        }
      } catch (err) {
        errBox.textContent = 'Error de red: ' + String(err)
        errBox.classList.remove('hidden')
      }
    })

    // Cancelar solicitud pendiente
    document.querySelectorAll('[data-cancel-vac]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = btn.getAttribute('data-cancel-vac')
        const num = btn.getAttribute('data-num')
        const sa = window.saModal
        if (!sa) return
        const ok = await sa.confirm({
          title: 'Cancelar solicitud',
          message: `Vas a cancelar la solicitud ${num}. Los días reservados se devolverán al saldo.`,
          confirmLabel: 'Cancelar solicitud',
          tone: 'danger',
        })
        if (!ok) return
        sa.loading({ title: 'Cancelando', message: 'Procesando…' })
        const res = await fetch('/api/vacations/action?op=cancel&id=' + id, {
          method: 'POST',
          headers: { 'X-SA-Modal': '1' },
        })
        const json = await res.json().catch(() => ({}))
        if (!json.ok) {
          await sa.error({ title: 'No se pudo cancelar', message: json.error })
        } else {
          await sa.success({ title: 'Solicitud cancelada', redirect: window.location.pathname })
        }
      })
    })
  })()

  // Auto-fill cargo/depto/salary from selected position (empresa pública).
  // Salary is editable but capped at the position salary; selecting a
  // position seeds it with the maximum and refreshes the info block.
  const posInput = document.getElementById('positionId')
  const salaryInput = document.getElementById('baseSalaryInput')
  if (posInput && salaryInput) {
    posInput.addEventListener('change', function () {
      const ds = posInput.dataset
      const max = ds.salary || ''
      const hCargo = document.getElementById('hiddenCargoId')
      const hDepto = document.getElementById('hiddenDepartamentoId')
      if (hCargo) hCargo.value = ds.cargo || ''
      if (hDepto) hDepto.value = ds.depto || ''
      salaryInput.value = max
      salaryInput.dataset.positionMax = max
      const hint = document.getElementById('salaryMaxHint')
      if (hint) hint.textContent = max ? '(máximo de la posición: $' + max + ')' : ''
      const card = document.getElementById('positionInfoCard')
      if (card) card.style.display = posInput.value ? '' : 'none'
      const set = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val }
      set('posInfoCargo', ds.cargoName || '—')
      set('posInfoSalary', max ? '$' + max : '—')
      set('posInfoOvertime', '$' + (ds.overtime || '0'))
      set('posInfoRepresentation', '$' + (ds.representation || '0'))
    })
  }


  // Foto / cédula: leer el archivo a base64, validar MIME + tamaño, y dejarlo
  // en el input hidden que viaja en el form. Vista previa inmediata.
  const MAX_IMG_BYTES = 500 * 1024
  const ALLOWED_IMG = ['image/png', 'image/jpeg', 'image/webp']
  const imgError = document.getElementById('imageError')
  const enrollBtn = document.getElementById('enrollFaceBtn')
  function wireImageField(fileId, inputId, previewId, clearId, extraBtn) {
    const fileEl = document.getElementById(fileId)
    const hidden = document.getElementById(inputId)
    const preview = document.getElementById(previewId)
    const clearBtn = document.getElementById(clearId)
    if (!fileEl || !hidden) return
    fileEl.addEventListener('change', function () {
      const file = this.files && this.files[0]
      if (!file) return
      if (imgError) imgError.classList.add('hidden')
      if (!ALLOWED_IMG.includes(file.type)) {
        if (imgError) { imgError.textContent = 'Tipo no permitido. Use PNG, JPEG o WEBP.'; imgError.classList.remove('hidden') }
        this.value = ''
        return
      }
      if (file.size > MAX_IMG_BYTES) {
        if (imgError) { imgError.textContent = 'La imagen excede 500 KB.'; imgError.classList.remove('hidden') }
        this.value = ''
        return
      }
      const reader = new FileReader()
      reader.onload = function () {
        hidden.value = reader.result
        if (preview) { preview.src = reader.result; preview.classList.remove('hidden') }
        if (clearBtn) clearBtn.classList.remove('hidden')
        if (extraBtn) extraBtn.classList.remove('hidden')
      }
      reader.readAsDataURL(file)
    })
    clearBtn?.addEventListener('click', function () {
      hidden.value = ''
      if (preview) { preview.src = ''; preview.classList.add('hidden') }
      if (fileEl) fileEl.value = ''
      clearBtn.classList.add('hidden')
      if (extraBtn) extraBtn.classList.add('hidden')
    })
  }
  wireImageField('photoFile', 'photoInput', 'photoPreview', 'photoClear', enrollBtn)
  wireImageField('scannedIdFile', 'scannedIdInput', 'scannedIdPreview', 'scannedIdClear')
</script>

<script is:inline define:vars={{ empId: emp?.id ?? '' }}>
  // Enrolamiento facial desde la foto del colaborador. Reusa face-api y los
  // mismos modelos que el kiosko (/face-models): detecta el rostro en la foto
  // (un <img>), calcula el descriptor 128-d en el navegador y lo envía al
  // proxy /api/facial/enrollments. No requiere IA en el servidor.
  ;(function () {
    const btn = document.getElementById('enrollFaceBtn')
    const status = document.getElementById('enrollStatus')
    const photoInput = document.getElementById('photoInput')
    if (!btn || !photoInput) return
    let faceapi = null

    function show(msg, tone) {
      if (!status) return
      status.textContent = msg
      status.className = 'mt-2 text-xs ' + (tone === 'err' ? 'text-red-600' : tone === 'ok' ? 'text-emerald-600' : 'text-gray-500')
      status.classList.remove('hidden')
    }

    async function loadModels() {
      if (faceapi) return faceapi
      show('Cargando modelos…')
      faceapi = await import('/face-models/face-api.esm.js')
      const MODELS = '/face-models'
      await faceapi.nets.tinyFaceDetector.loadFromUri(MODELS)
      await faceapi.nets.faceLandmark68Net.loadFromUri(MODELS)
      await faceapi.nets.faceRecognitionNet.loadFromUri(MODELS)
      return faceapi
    }

    function loadImage(dataUrl) {
      return new Promise((resolve, reject) => {
        const img = new Image()
        img.onload = () => resolve(img)
        img.onerror = reject
        img.src = dataUrl
      })
    }

    btn.addEventListener('click', async () => {
      const photo = photoInput.value
      if (!photo) { show('Primero cargue una foto.', 'err'); return }
      btn.disabled = true
      try {
        const fa = await loadModels()
        show('Analizando rostro…')
        const img = await loadImage(photo)
        const detection = await fa
          .detectSingleFace(img, new fa.TinyFaceDetectorOptions({ inputSize: 320 }))
          .withFaceLandmarks()
          .withFaceDescriptor()
        if (!detection) {
          show('No se detectó un rostro en la foto. Use una imagen frontal y nítida.', 'err')
          btn.disabled = false
          return
        }
        show('Guardando enrolamiento…')
        const res = await fetch('/api/facial/enrollments', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            employeeId: empId,
            embedding: Array.from(detection.descriptor),
            qualityScore: detection.detection.score,
            isPrimary: true,
            notes: 'Enrolado desde la foto del colaborador',
          }),
        })
        if (res.ok) {
          show('Rostro enrolado correctamente (calidad ' + (detection.detection.score * 100).toFixed(0) + '%).', 'ok')
        } else {
          const j = await res.json().catch(() => ({}))
          show('Error: ' + (j.error ?? 'no se pudo enrolar'), 'err')
        }
      } catch (err) {
        show('Error: ' + (err && err.message ? err.message : String(err)), 'err')
      } finally {
        btn.disabled = false
      }
    })
  })()
</script>

<script is:inline>
function togglePortalCb(id) {
  var cb = document.getElementById(id);
  if (!cb) return;
  cb.checked = !cb.checked;
  syncToggleUI(id, cb.checked);
}
function syncToggleUI(id, val) {
  var cb = document.getElementById(id);
  var track = document.getElementById(id + '-track');
  var knob = document.getElementById(id + '-knob');
  if (cb) cb.checked = val;
  if (track) {
    track.classList.remove('toggle-on', 'toggle-off');
    track.classList.add(val ? 'toggle-on' : 'toggle-off');
  }
  if (knob) {
    knob.classList.remove('knob-on', 'knob-off');
    knob.classList.add(val ? 'knob-on' : 'knob-off');
  }
}

;(function() {
  var empId = window.location.pathname.split('/employees/')[1]?.split('/')[0] || '';
  if (!empId) return;
  var badge = document.getElementById('portal-status-badge');
  var enabledCb = document.getElementById('portal-enabled');
  var approverCb = document.getElementById('portal-approver');
  var modChecks = document.querySelectorAll('.portal-mod');
  var saveBtn = document.getElementById('portal-save');
  var resetBtn = document.getElementById('portal-reset-pw');
  var pwHint = document.getElementById('portal-pw-hint');
  var sa = window.saModal;
  if (!badge || !enabledCb || !saveBtn) return;

  function loadPortalData() {
    fetch('/api/employees/' + empId + '/portal')
      .then(function(r) { return r.json(); })
      .then(function(res) {
        if (!res.success) { badge.textContent = 'Error'; return; }
        var d = res.data;
        var isOn = false;
        if (!d.hasCredentials) {
          badge.textContent = 'Sin acceso';
          badge.className = 'text-xs font-medium px-2.5 py-0.5 rounded bg-gray-100 text-gray-500';
        } else if (d.credentials.isLocked) {
          badge.textContent = 'Bloqueado';
          badge.className = 'text-xs font-medium px-2.5 py-0.5 rounded bg-red-100 text-red-700';
          isOn = d.credentials.isActive;
        } else if (!d.credentials.isActive) {
          badge.textContent = 'Desactivado';
          badge.className = 'text-xs font-medium px-2.5 py-0.5 rounded bg-amber-100 text-amber-700';
        } else {
          badge.textContent = 'Activo';
          badge.className = 'text-xs font-medium px-2.5 py-0.5 rounded bg-green-100 text-green-700';
          isOn = true;
        }
        syncToggleUI('portal-enabled', isOn);
        syncToggleUI('portal-approver', d.credentials?.isApprover || false);
        var mods = {};
        (d.modules || []).forEach(function(m) { mods[m.module] = m.isEnabled; });
        modChecks.forEach(function(cb) { cb.checked = mods[cb.dataset.module] !== false; });
        if (d.credentials?.lastLoginAt) {
          pwHint.textContent = 'Último acceso: ' + new Date(d.credentials.lastLoginAt).toLocaleDateString('es-PA');
        }
      })
      .catch(function() { badge.textContent = 'Error de conexión'; });
  }

  saveBtn.addEventListener('click', function() {
    saveBtn.disabled = true;
    saveBtn.textContent = 'Guardando...';
    var modules = [];
    modChecks.forEach(function(cb) { modules.push({ module: cb.dataset.module, isEnabled: cb.checked }); });
    fetch('/api/employees/' + empId + '/portal', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ portalEnabled: enabledCb.checked, isApprover: approverCb.checked, modules: modules })
    })
    .then(function(r) { return r.json(); })
    .then(function(res) {
      saveBtn.disabled = false;
      saveBtn.textContent = 'Guardar configuración del portal';
      if (res.success) {
        loadPortalData();
        if (sa) sa.success({ title: 'Guardado', message: 'Configuración del portal actualizada.' });
      } else {
        if (sa) sa.error({ title: 'Error', message: res.error || 'No se pudo guardar.' });
      }
    })
    .catch(function() {
      saveBtn.disabled = false;
      saveBtn.textContent = 'Guardar configuración del portal';
      if (sa) sa.error({ title: 'Error', message: 'Error de conexión.' });
    });
  });

  resetBtn.addEventListener('click', async function() {
    if (!sa) return;
    var ok = await sa.confirm({
      title: 'Resetear contraseña',
      message: 'La contraseña se reseteará a 172839. El empleado deberá cambiarla en su próximo acceso.',
      confirmLabel: 'Resetear',
      tone: 'warning',
    });
    if (!ok) return;
    sa.loading({ title: 'Reseteando', message: 'Procesando…' });
    fetch('/api/employees/' + empId + '/portal', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ resetPassword: true })
    })
    .then(function(r) { return r.json(); })
    .then(function(res) {
      if (res.success) sa.success({ title: 'Listo', message: 'Contraseña reseteada a 172839.' });
      else sa.error({ title: 'Error', message: res.error || 'No se pudo resetear.' });
    })
    .catch(function() { sa.error({ title: 'Error', message: 'Error de conexión.' }); });
  });

  loadPortalData();
})();
</script>

<script is:inline>
;(function() {
  var empId = window.location.pathname.split('/employees/')[1]?.split('/')[0] || '';
  if (!empId) return;
  var listEl = document.getElementById('dep-list');
  var formEl = document.getElementById('dep-form');
  var addBtn = document.getElementById('dep-add-btn');
  var cancelBtn = document.getElementById('dep-cancel-btn');
  var saveBtn = document.getElementById('dep-save-btn');
  var hasDis = document.getElementById('dep-hasDisability');
  var disRow = document.getElementById('dep-disability-row');
  if (!listEl || !formEl || !addBtn) return;

  var REL_LABELS = { spouse:'Cónyuge', child:'Hijo(a)', parent:'Padre/Madre', sibling:'Hermano(a)', other:'Otro' };
  var editingId = null;

  hasDis?.addEventListener('change', function() {
    disRow.style.display = hasDis.checked ? '' : 'none';
  });
  addBtn.addEventListener('click', function() { editingId = null; clearForm(); formEl.classList.remove('hidden'); });
  cancelBtn?.addEventListener('click', function() { formEl.classList.add('hidden'); });

  function clearForm() {
    ['dep-firstName','dep-lastName','dep-idNumber','dep-birthDate','dep-disabilityDesc'].forEach(function(id) {
      var el = document.getElementById(id); if (el) el.value = '';
    });
    document.getElementById('dep-relationship').value = 'spouse';
    document.getElementById('dep-sex').value = '';
    hasDis.checked = false; disRow.style.display = 'none';
  }

  function loadDeps() {
    fetch('/api/employees/' + empId + '/dependents')
      .then(function(r) { return r.json(); })
      .then(function(res) {
        var deps = (res.data || []).filter(function(d) { return d.isActive !== false; });
        if (deps.length === 0) { listEl.innerHTML = '<div class="py-8 text-center text-sm text-gray-400">Sin dependientes registrados.</div>'; return; }
        var html = '<table class="w-full text-sm"><thead><tr class="border-b border-gray-200 bg-gray-50">' +
          '<th class="text-left px-3 py-2 text-xs font-medium text-gray-500 uppercase">Nombre</th>' +
          '<th class="text-left px-3 py-2 text-xs font-medium text-gray-500 uppercase">Cédula</th>' +
          '<th class="text-left px-3 py-2 text-xs font-medium text-gray-500 uppercase">Parentesco</th>' +
          '<th class="text-left px-3 py-2 text-xs font-medium text-gray-500 uppercase">Discapacidad</th>' +
          '<th class="px-3 py-2"></th></tr></thead><tbody>';
        deps.forEach(function(d) {
          html += '<tr class="border-b border-gray-100">' +
            '<td class="px-3 py-2.5 font-medium text-gray-900">' + d.firstName + ' ' + d.lastName + '</td>' +
            '<td class="px-3 py-2.5 text-gray-600 font-mono text-xs">' + (d.idNumber || '—') + '</td>' +
            '<td class="px-3 py-2.5 text-gray-600 text-xs">' + (REL_LABELS[d.relationship] || d.relationship) + '</td>' +
            '<td class="px-3 py-2.5">' + (d.hasDisability ? '<span class="text-xs font-medium px-1.5 py-0.5 rounded bg-amber-50 text-amber-700">Sí</span>' : '<span class="text-xs text-gray-400">No</span>') + '</td>' +
            '<td class="px-3 py-2.5 text-right"><button class="text-xs text-red-500 hover:underline" onclick="window.__depDel(\'' + d.id + '\')">Eliminar</button></td></tr>';
        });
        html += '</tbody></table>';
        listEl.innerHTML = html;
      })
      .catch(function() { listEl.innerHTML = '<div class="py-8 text-center text-sm text-red-400">Error al cargar.</div>'; });
  }

  saveBtn?.addEventListener('click', function() {
    var fn = document.getElementById('dep-firstName').value.trim();
    var ln = document.getElementById('dep-lastName').value.trim();
    if (!fn || !ln) return;
    var body = {
      firstName: fn, lastName: ln,
      idNumber: document.getElementById('dep-idNumber').value.trim() || null,
      relationship: document.getElementById('dep-relationship').value,
      birthDate: document.getElementById('dep-birthDate').value || null,
      sex: document.getElementById('dep-sex').value || null,
      hasDisability: hasDis.checked,
      disabilityDescription: document.getElementById('dep-disabilityDesc').value.trim() || null,
    };
    if (editingId) body._id = editingId;
    saveBtn.disabled = true;
    fetch('/api/employees/' + empId + '/dependents', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
    })
    .then(function(r) { return r.json(); })
    .then(function(res) {
      saveBtn.disabled = false;
      if (res.success) { formEl.classList.add('hidden'); loadDeps(); }
    })
    .catch(function() { saveBtn.disabled = false; });
  });

  window.__depDel = async function(depId) {
    var ok = window.saModal
      ? await window.saModal.confirm({
          title: 'Eliminar dependiente',
          message: '¿Eliminar este dependiente?',
          tone: 'danger',
          confirmLabel: 'Eliminar',
        })
      : confirm('¿Eliminar este dependiente?');
    if (!ok) return;
    if (window.saModal) window.saModal.close();
    fetch('/api/employees/' + empId + '/dependents', {
      method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ dependentId: depId }),
    }).then(function() { loadDeps(); });
  };

  loadDeps();
})();
</script>

<script is:inline define:vars={{ empId: emp?.id ?? '' }}>
(function() {
  if (!empId) return;
  var cardsEl = document.getElementById('comp-time-cards');
  var movEl = document.getElementById('comp-time-mov-body');
  var yearSel = document.getElementById('ct-year');
  var TYPE_LABELS = { compensatory: 'Tiempo Compensatorio', disability: 'Incapacidad', family_disability: 'Familiar con Discapacidad' };
  var MOV_LABELS = { initialization: 'Inicialización', credit: 'Crédito', debit: 'Débito', adjustment: 'Ajuste' };
  function h(min) { return (Number(min) / 60).toFixed(1); }

  // Year selector: current year + 4 previous (historical archive).
  var nowYear = new Date().getFullYear();
  for (var y = nowYear; y >= nowYear - 4; y--) {
    var opt = document.createElement('option');
    opt.value = String(y);
    opt.textContent = String(y) + (y === nowYear ? ' (actual)' : '');
    yearSel.appendChild(opt);
  }

  function loadBalances(year) {
    cardsEl.innerHTML = '<div class="text-center py-6 text-sm text-gray-400 col-span-3">Cargando...</div>';
    fetch('/api/time-balance/proxy?path=' + encodeURIComponent('balances/' + empId + '?year=' + year))
      .then(function(r) { return r.json(); })
      .then(function(res) {
        var balances = (res && res.data) || [];
        if (balances.length === 0) {
          cardsEl.innerHTML = '<div class="text-center py-6 text-sm text-gray-400 col-span-3">Sin saldos de tiempo para ' + year + '.</div>';
          return;
        }
        var html = '';
        for (var i = 0; i < balances.length; i++) {
          var b = balances[i];
          var label = TYPE_LABELS[b.balanceType] || b.balanceType;
          var negative = Number(b.availableMinutes) < 0;
          html += '<div class="border border-gray-200 rounded-lg p-4">' +
            '<h4 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">' + label + '</h4>' +
            '<div class="text-2xl font-light mb-2 ' + (negative ? 'text-red-600' : 'text-gray-900') + '">' + h(b.availableMinutes) + ' <span class="text-sm text-gray-500">hrs disponibles</span></div>' +
            '<div class="flex gap-4 text-xs text-gray-500">' +
              '<span>Acreditadas: <b class="text-gray-700">' + h(b.creditedMinutes) + '</b></span>' +
              '<span>Debitadas: <b class="text-gray-700">' + h(b.debitedMinutes) + '</b></span>' +
            '</div></div>';
        }
        cardsEl.innerHTML = html;
      })
      .catch(function() {
        cardsEl.innerHTML = '<div class="text-center py-4 text-sm text-red-400 col-span-3">Error al cargar saldos.</div>';
      });
  }

  function loadMovements(year) {
    movEl.innerHTML = '<div class="text-center py-4 text-sm text-gray-400">Cargando...</div>';
    fetch('/api/time-balance/proxy?path=' + encodeURIComponent('movements/' + empId + '?year=' + year + '&limit=100'))
      .then(function(r) { return r.json(); })
      .then(function(res) {
        var movs = (res && res.data) || [];
        if (movs.length === 0) {
          movEl.innerHTML = '<div class="text-center py-4 text-sm text-gray-400">Sin movimientos en ' + year + '.</div>';
          return;
        }
        var html = '<table class="w-full text-sm"><thead><tr class="border-b border-gray-200 text-xs text-gray-500 uppercase tracking-wide">' +
          '<th class="text-left py-2 px-2">Fecha</th><th class="text-left py-2 px-2">Cuenta</th><th class="text-left py-2 px-2">Tipo</th><th class="text-right py-2 px-2">Horas</th><th class="text-left py-2 px-2">Descripción</th></tr></thead><tbody>';
        for (var j = 0; j < movs.length; j++) {
          var m = movs[j];
          var mins = Number(m.amountMinutes);
          var color = mins >= 0 ? 'text-green-600' : 'text-red-600';
          var typeLabel = TYPE_LABELS[m.balanceType] || m.balanceType;
          var movLabel = MOV_LABELS[m.movementType] || m.movementType;
          html += '<tr class="border-b border-gray-100">' +
            '<td class="py-2 px-2 text-gray-600">' + (m.effectiveDate ? String(m.effectiveDate).substring(0, 10) : '—') + '</td>' +
            '<td class="py-2 px-2 text-gray-500 text-xs">' + typeLabel + '</td>' +
            '<td class="py-2 px-2">' + movLabel + '</td>' +
            '<td class="py-2 px-2 text-right font-medium ' + color + '">' + (mins >= 0 ? '+' : '') + h(mins) + '</td>' +
            '<td class="py-2 px-2 text-gray-400 text-xs truncate max-w-[200px]">' + (m.description || '—') + '</td></tr>';
        }
        html += '</tbody></table>';
        movEl.innerHTML = html;
      })
      .catch(function() {
        movEl.innerHTML = '<div class="text-center py-4 text-sm text-red-400">Error al cargar movimientos.</div>';
      });
  }

  function load(year) { loadBalances(year); loadMovements(year); }
  yearSel.addEventListener('change', function() { load(yearSel.value); });
  load(String(nowYear));
})();
</script>

<script is:inline id="empForm-required-validation">
  ;(function () {
    var form = document.getElementById('empForm')
    if (!form) return
    var banner = document.getElementById('reqError')

    function tabInfo(el) {
      var panel = el && el.closest ? el.closest('[id^="tab-"]') : null
      if (!panel) return null
      var key = panel.id.replace('tab-', '')
      var btn = document.querySelector('[data-tab="' + key + '"]')
      return { key: key, label: btn ? btn.textContent.trim() : key }
    }

    function fieldLabel(el) {
      var wrap = el.closest('div')
      var lbl = wrap ? wrap.querySelector('label') : null
      return lbl ? lbl.textContent.replace('*', '').trim() : el.name
    }

    function collectMissing() {
      var missing = []
      var seenRadios = {}
      var required = form.querySelectorAll('[required]')
      for (var i = 0; i < required.length; i++) {
        var el = required[i]
        if (el.type === 'radio') {
          if (seenRadios[el.name]) continue
          seenRadios[el.name] = true
          var group = form.querySelectorAll('input[name="' + el.name + '"]')
          var any = false
          for (var j = 0; j < group.length; j++) if (group[j].checked) { any = true; break }
          if (!any) missing.push({ el: group[0], label: fieldLabel(el) })
          continue
        }
        if (!String(el.value || '').trim()) missing.push({ el: el, label: fieldLabel(el) })
      }
      var ptypes = form.querySelectorAll('input[name="payrollTypeIds[]"]')
      if (ptypes.length) {
        var anyChecked = false
        for (var k = 0; k < ptypes.length; k++) if (ptypes[k].checked) { anyChecked = true; break }
        if (!anyChecked) missing.push({ el: ptypes[0], label: 'Tipo de planilla' })
      }
      return missing
    }

    // Mensajes para los códigos de error que devuelve el proxy vía JSON.
    var SERVER_ERRORS = {
      code_taken: 'El código de empleado ya está en uso.',
      id_taken: 'La cédula ya está registrada.',
      salary_max: 'El salario base no puede superar el salario de la posición.',
      position_occupied: 'La posición seleccionada ya está ocupada por otro empleado.',
      no_payroll_type: 'El empleado debe pertenecer a al menos un tipo de planilla.',
      'missing-fields': 'Completa todos los campos requeridos.',
      'server-error': 'Error del servidor. Intenta de nuevo.',
    }

    function showError(html, toastMsg) {
      if (banner) {
        banner.innerHTML = html
        banner.classList.remove('hidden')
        banner.scrollIntoView({ behavior: 'smooth', block: 'center' })
      }
      if (window.toast) window.toast.error(toastMsg || (banner ? banner.textContent.trim() : html))
    }

    var submitting = false

    form.addEventListener('submit', function (e) {
      // Siempre interceptamos: validación cliente y, si pasa, envío por fetch
      // para que un rechazo del servidor no recargue ni borre el formulario.
      e.preventDefault()
      e.stopImmediatePropagation()
      if (submitting) return
      if (banner) banner.classList.add('hidden')

      var missing = collectMissing()

      var salaryError = null
      var salary = document.getElementById('baseSalaryInput')
      if (salary) {
        var max = parseFloat(salary.dataset.positionMax || '')
        var val = parseFloat(salary.value || '')
        if (!isNaN(max) && !isNaN(val) && val > max) {
          salaryError = 'El salario base no puede superar el salario de la posición ($' + max + ').'
        }
      }

      if (missing.length || salaryError) {
        var lines = []
        if (missing.length) {
          lines.push('<strong>Faltan campos obligatorios:</strong>')
          for (var i = 0; i < missing.length; i++) {
            var t = tabInfo(missing[i].el)
            lines.push('• ' + (t ? 'Pestaña «' + t.label + '» → ' : '') + missing[i].label)
          }
        }
        if (salaryError) lines.push((missing.length ? '<br>' : '') + salaryError)

        var summary = salaryError && !missing.length
          ? salaryError
          : missing.length === 1
            ? 'Falta el campo «' + missing[0].label + '».'
            : 'Faltan ' + missing.length + ' campos obligatorios.'
        showError(lines.join('<br>'), summary)

        var focusEl = missing.length ? missing[0].el : salary
        if (focusEl) {
          var ti = tabInfo(focusEl)
          if (ti) switchTab(ti.key, document.querySelector('[data-tab="' + ti.key + '"]'))
          try { focusEl.focus() } catch (_) {}
        }
        return
      }

      // Validación local OK → envío AJAX. El _method=PUT viaja en el FormData.
      submitting = true
      var submitBtn = form.querySelector('button[type="submit"]')
      if (submitBtn) submitBtn.disabled = true

      fetch(form.action, {
        method: 'POST',
        headers: { 'X-Form-Submit': '1' },
        body: new FormData(form),
      })
        .then(function (res) {
          return res.json().catch(function () { return {} }).then(function (data) {
            if (res.ok && data.ok) {
              window.location.href = data.redirect || (window.location.pathname + '?success=1')
              return
            }
            var code = data.error || 'server-error'
            var msg = SERVER_ERRORS[code] || 'Ocurrió un error inesperado.'
            showError(msg, msg)
            submitting = false
            if (submitBtn) submitBtn.disabled = false
          })
        })
        .catch(function () {
          showError(SERVER_ERRORS['server-error'], SERVER_ERRORS['server-error'])
          submitting = false
          if (submitBtn) submitBtn.disabled = false
        })
    })

    // Si el server retornó error/éxito (banners SSR visibles al cargar),
    // dispara también el toast para que sea visible tras scroll/recarga.
    if (window.toast) {
      var serverErr = document.getElementById('serverError')
      if (serverErr) {
        var et = serverErr.textContent && serverErr.textContent.trim()
        if (et) window.toast.error(et)
      }
      var serverOk = document.getElementById('serverSuccess')
      if (serverOk) {
        var ot = serverOk.textContent && serverOk.textContent.trim()
        if (ot) window.toast.success(ot)
      }
    }
  })()
</script>

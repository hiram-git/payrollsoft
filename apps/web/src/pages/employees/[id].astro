<script type="application/json" id="cfDefs" set:html={JSON.stringify(customFieldDefs)}></script>

<script is:inline>
  ;(function () {
    const defsEl = document.getElementById('cfDefs')
    if (!defsEl) return
    let defs
    try {
      defs = JSON.parse(defsEl.textContent || '[]')
    } catch {
      return
    }
    if (!Array.isArray(defs) || defs.length === 0) return

    function readDeps(def) {
      const rules = def.validationRules && Array.isArray(def.validationRules.dependsOn)
        ? def.validationRules.dependsOn
        : []
      return rules.filter((r) => r && typeof r === 'object' && r.field && r.op && r.effect)
    }
    function isEmpty(v) {
      if (v == null) return true
      if (typeof v === 'string') return v.trim() === ''
      return false
    }
    function toNum(v) {
      if (v == null || v === '') return null
      const n = Number(v)
      return Number.isFinite(n) ? n : null
    }
    function evalRule(r, values) {
      const v = values[r.field]
      switch (r.op) {
        case 'eq': return String(v ?? '') === String(r.value ?? '')
        case 'ne': return String(v ?? '') !== String(r.value ?? '')
        case 'gt': { const a = toNum(v), b = toNum(r.value); return a != null && b != null && a > b }
        case 'lt': { const a = toNum(v), b = toNum(r.value); return a != null && b != null && a < b }
        case 'gte': { const a = toNum(v), b = toNum(r.value); return a != null && b != null && a >= b }
        case 'lte': { const a = toNum(v), b = toNum(r.value); return a != null && b != null && a <= b }
        case 'in': return Array.isArray(r.values) && r.values.some((x) => String(x) === String(v ?? ''))
        case 'empty': return isEmpty(v)
        case 'notEmpty': return !isEmpty(v)
        default: return false
      }
    }
    function readValues() {
      const out = {}
      for (const def of defs) {
        const el = document.querySelector('[name="cf_' + def.code + '"]')
        out[def.code] = el ? el.value : ''
      }
      return out
    }
    function applyState() {
      const values = readValues()
      for (const def of defs) {
        const rules = readDeps(def)
        const row = document.querySelector('[data-cf-row="' + def.code + '"]')
        const input = document.querySelector('[name="cf_' + def.code + '"]')
        if (!row || !input) continue
        const visRules = rules.filter((r) => r.effect === 'visible')
        const reqRules = rules.filter((r) => r.effect === 'required')
        const roRules = rules.filter((r) => r.effect === 'readonly')
        const visible = visRules.length === 0 ? true : visRules.every((r) => evalRule(r, values))
        const required = !!def.isRequired || (reqRules.length > 0 && reqRules.every((r) => evalRule(r, values)))
        const readonly = roRules.length > 0 && roRules.every((r) => evalRule(r, values))
        row.style.display = visible ? '' : 'none'
        if (required && visible) input.setAttribute('required', 'required')
        else input.removeAttribute('required')
        if (readonly) input.setAttribute('readonly', 'readonly')
        else input.removeAttribute('readonly')
        if (!visible) input.value = ''
        // Toggle the asterisk on the label so the user sees state changes.
        const lbl = row.querySelector('label')
        if (lbl) {
          const star = lbl.querySelector('.cf-required-star')
          if (required && !star) {
            const sp = document.createElement('span')
            sp.className = 'cf-required-star text-red-500 ml-0.5'
            sp.textContent = '*'
            lbl.appendChild(sp)
          } else if (!required && star) {
            star.remove()
          }
        }
      }
    }
    for (const def of defs) {
      const el = document.querySelector('[name="cf_' + def.code + '"]')
      if (el) el.addEventListener('input', applyState)
      if (el) el.addEventListener('change', applyState)
    }
    applyState()
  })()
</script>

<script is:inline>
  function switchTab(tab, btn) {
    document.querySelectorAll('[id^="tab-"]').forEach(el => el.style.display = 'none')
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'))
    document.getElementById('tab-' + tab).style.display = ''
    btn.classList.add('active')
  }

  // Auto-fill cargo/depto/funcion/salary from selected position (empresa pública)
  const posSelect = document.getElementById('positionSelect')
  if (posSelect) {
    posSelect.addEventListener('change', function () {
      const opt = this.options[this.selectedIndex]
      document.getElementById('hiddenCargoId').value = opt.dataset.cargo || ''
      document.getElementById('hiddenDepartamentoId').value = opt.dataset.depto || ''
      document.getElementById('hiddenFuncionId').value = opt.dataset.funcion || ''
      document.getElementById('baseSalaryInput').value = opt.dataset.salary || ''
    })
  }
</script>

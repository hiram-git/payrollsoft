---
import AppLayout from '../../layouts/AppLayout.astro'
import { resolveTenantSlugFromCookie } from '../../lib/tenant-slug'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')
const tenantSlug = resolveTenantSlugFromCookie(authCookie)

type CatalogItem = { id: string; code: string; name: string; isActive: boolean }
type Departamento = CatalogItem & { parentId: string | null }
type Position = {
  id: string
  code: string
  name: string
  salary: string
  overtimeAmount: string | null
  representationAmount: string | null
  jobTitleId: string | null
  departmentId: string | null
  jobFunctionId: string | null
  isActive: boolean
}
type CompanyConfig = { tipoInstitucion?: string | null }
type PayrollType = { id: string; code: string; name: string; sortOrder: number }

let cargos: CatalogItem[] = []
let funciones: CatalogItem[] = []
let departamentos: Departamento[] = []
let positions: Position[] = []
let payrollTypes: PayrollType[] = []
let tipoInstitucion = 'privada'

try {
  const headers = { Cookie: `auth=${authCookie}`, 'X-Tenant': tenantSlug }
  const [cRes, fRes, dRes, compRes, cfgRes] = await Promise.all([
    fetch(`${API_URL}/job-titles`, { headers }),
    fetch(`${API_URL}/job-functions`, { headers }),
    fetch(`${API_URL}/departments`, { headers }),
    fetch(`${API_URL}/company`, { headers }),
    fetch(`${API_URL}/concepts/config`, { headers }),
  ])
  if (cRes.ok) cargos = ((await cRes.json()) as { data: CatalogItem[] }).data ?? []
  if (fRes.ok) funciones = ((await fRes.json()) as { data: CatalogItem[] }).data ?? []
  if (dRes.ok) departamentos = ((await dRes.json()) as { data: Departamento[] }).data ?? []
  if (compRes.ok) {
    const cfg = ((await compRes.json()) as { data: CompanyConfig }).data
    tipoInstitucion = cfg?.institutionType ?? 'privada'
  }
  if (cfgRes.ok) {
    const cfgData = (await cfgRes.json()) as { data?: { payrollTypes?: PayrollType[] } }
    payrollTypes = (cfgData.data?.payrollTypes ?? []).sort((a, b) => a.sortOrder - b.sortOrder)
  }
  if (tipoInstitucion === 'publica') {
    const pRes = await fetch(`${API_URL}/positions?isActive=true`, { headers })
    if (pRes.ok) positions = ((await pRes.json()) as { data: Position[] }).data ?? []
  }
} catch {
  /* ignore — dropdowns show empty on error */
}

const isPublica = tipoInstitucion === 'publica'
const activeCargos = cargos.filter((c) => c.isActive)
const activeFunciones = funciones.filter((f) => f.isActive)
const activeDepts = departamentos.filter((d) => d.isActive)

const error = Astro.url.searchParams.get('error') ?? ''
const errorMessages: Record<string, string> = {
  code_taken: 'El código de empleado ya está en uso.',
  id_taken: 'La cédula ya está registrada.',
  salary_max: 'El salario base no puede superar el salario de la posición.',
  'server-error': 'Error del servidor. Intenta de nuevo.',
  'missing-fields': 'Completa todos los campos requeridos.',
}
---

<AppLayout title="Nuevo Empleado">
  <div class="p-8">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Nuevo Empleado</h1>
      </div>
      <a href="/employees" class="text-sm text-gray-500 hover:text-gray-700 flex items-center gap-1">
        ← Volver
      </a>
    </div>

    {error && (
      <div class="mb-6 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
        {errorMessages[error] ?? 'Ocurrió un error inesperado.'}
      </div>
    )}

    <form method="POST" action="/api/employees" id="empForm">
      <!-- Tabs -->
      <div class="flex gap-0 border-b-2 border-gray-200 mb-6">
        <button type="button" class="tab-btn active" data-tab="personal" onclick="switchTab('personal', this)">
          Datos Personales
        </button>
        <button type="button" class="tab-btn" data-tab="laboral" onclick="switchTab('laboral', this)">
          Datos Laborales
        </button>
        {payrollTypes.length > 0 && (
          <button type="button" class="tab-btn" data-tab="nomina" onclick="switchTab('nomina', this)">
            Tipos de Planilla
          </button>
        )}
      </div>

      <!-- TAB: Datos Personales -->
      <div id="tab-personal">
        <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
          <h3 class="font-semibold text-gray-800 mb-4">Identificación</h3>
          <div class="grid grid-cols-2 gap-4">
            <div class="form-group col-span-2 grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Nombre *</label>
                <input type="text" name="firstName" class="input" required placeholder="Juan" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Apellido *</label>
                <input type="text" name="lastName" class="input" required placeholder="Pérez" />
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Cédula *</label>
              <input type="text" name="idNumber" class="input" required placeholder="8-123-456" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Seguro Social</label>
              <input type="text" name="socialSecurityNumber" class="input" placeholder="000-00-0000" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Correo electrónico</label>
              <input type="email" name="email" class="input" placeholder="juan@empresa.com" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Teléfono</label>
              <input type="text" name="phone" class="input" placeholder="6000-0000" />
            </div>
          </div>
        </div>

        <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
          <h3 class="font-semibold text-gray-800 mb-1">Condición y registro</h3>
          <p class="text-xs text-gray-500 mb-4">
            Marque las casillas que apliquen. La discapacidad propia habilita el saldo
            de incapacidad del colaborador.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            <label class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:bg-gray-50 cursor-pointer">
              <input type="checkbox" name="hasOwnDisability" class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
              <span class="text-sm text-gray-700">Tiene discapacidad propia</span>
            </label>
            <label class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:bg-gray-50 cursor-pointer">
              <input type="checkbox" name="requiresAttendanceMarking" class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" checked />
              <span class="text-sm text-gray-700">Marca reloj (registra asistencia)</span>
            </label>
            <label class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:bg-gray-50 cursor-pointer">
              <input type="checkbox" name="canRead" class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
              <span class="text-sm text-gray-700">Sabe leer</span>
            </label>
            <label class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:bg-gray-50 cursor-pointer">
              <input type="checkbox" name="canWrite" class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
              <span class="text-sm text-gray-700">Sabe escribir</span>
            </label>
          </div>
        </div>

        <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
          <h3 class="font-semibold text-gray-800 mb-1">Foto y cédula</h3>
          <p class="text-xs text-gray-500 mb-4">
            Imágenes en formato PNG, JPEG o WEBP, hasta 500 KB cada una.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Foto del colaborador</label>
              <img id="photoPreview" src="" alt="" class="w-28 h-28 rounded-lg object-cover border border-gray-200 mb-2 hidden" />
              <input type="hidden" name="photo" id="photoInput" />
              <input type="file" id="photoFile" accept="image/png,image/jpeg,image/webp" class="block text-sm text-gray-600" />
              <button type="button" id="photoClear" class="mt-2 text-xs text-red-600 hover:underline hidden">Quitar foto</button>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Cédula escaneada</label>
              <img id="scannedIdPreview" src="" alt="" class="w-full max-w-xs rounded-lg object-cover border border-gray-200 mb-2 hidden" />
              <input type="hidden" name="scannedId" id="scannedIdInput" />
              <input type="file" id="scannedIdFile" accept="image/png,image/jpeg,image/webp" class="block text-sm text-gray-600" />
              <button type="button" id="scannedIdClear" class="mt-2 text-xs text-red-600 hover:underline hidden">Quitar imagen</button>
            </div>
          </div>
          <p id="imageError" class="hidden mt-3 text-xs text-red-600"></p>
        </div>
      </div>

      <!-- TAB: Datos Laborales -->
      <div id="tab-laboral" style="display:none">
        <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
          <h3 class="font-semibold text-gray-800 mb-4">Puesto y Departamento</h3>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Código de empleado *</label>
              <input type="text" name="code" class="input" required placeholder="E001" />
            </div>

            {isPublica ? (
              <!-- Empresa pública: selector de posición -->
              <div class="col-span-1">
                <label class="block text-sm font-medium text-gray-700 mb-1">Posición *</label>
                <select name="positionId" id="positionSelect" class="input" required>
                  <option value="">— Seleccionar posición —</option>
                  {positions.map((p) => (
                    <option
                      value={p.id}
                      data-cargo={p.jobTitleId ?? ''}
                      data-cargo-name={p.jobTitleId ? (activeCargos.find((c) => c.id === p.jobTitleId)?.name ?? '') : ''}
                      data-depto={p.departmentId ?? ''}
                      data-salary={p.salary}
                      data-overtime={p.overtimeAmount ?? '0'}
                      data-representation={p.representationAmount ?? '0'}
                    >
                      {p.name} ({p.code}) — ${p.salary}
                    </option>
                  ))}
                </select>
              </div>
              <!-- Cargo + departamento se derivan de la posición -->
              <input type="hidden" name="jobTitleId" id="hiddenCargoId" />
              <input type="hidden" name="departmentId" id="hiddenDepartamentoId" />
              <!-- La función es atributo del empleado, editable también con posición -->
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Función</label>
                <select name="jobFunctionId" class="input">
                  <option value="">— Sin función —</option>
                  {activeFunciones.map((f) => (
                    <option value={f.id}>{f.name} ({f.code})</option>
                  ))}
                </select>
              </div>
            ) : (
              <!-- Empresa privada: selección directa -->
              <>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Departamento</label>
                  <select name="departmentId" class="input">
                    <option value="">— Sin departamento —</option>
                    {activeDepts.map((d) => (
                      <option value={d.id}>{d.name} ({d.code})</option>
                    ))}
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Cargo</label>
                  <select name="jobTitleId" class="input">
                    <option value="">— Sin cargo —</option>
                    {activeCargos.map((c) => (
                      <option value={c.id}>{c.name} ({c.code})</option>
                    ))}
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Función</label>
                  <select name="jobFunctionId" class="input">
                    <option value="">— Sin función —</option>
                    {activeFunciones.map((f) => (
                      <option value={f.id}>{f.name} ({f.code})</option>
                    ))}
                  </select>
                </div>
              </>
            )}
          </div>
        </div>

        {isPublica && (
          <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4" id="positionInfoCard" style="display:none">
            <h3 class="font-semibold text-gray-800 mb-4">Información de la posición</h3>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
              <div>
                <div class="text-xs text-gray-500 mb-0.5">Cargo</div>
                <div class="text-gray-800" id="posInfoCargo">—</div>
              </div>
              <div>
                <div class="text-xs text-gray-500 mb-0.5">Salario de la posición</div>
                <div class="text-gray-800" id="posInfoSalary">—</div>
              </div>
              <div>
                <div class="text-xs text-gray-500 mb-0.5">Sobresueldo</div>
                <div class="text-gray-800" id="posInfoOvertime">—</div>
              </div>
              <div>
                <div class="text-xs text-gray-500 mb-0.5">Gastos de representación</div>
                <div class="text-gray-800" id="posInfoRepresentation">—</div>
              </div>
            </div>
          </div>
        )}

        <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
          <h3 class="font-semibold text-gray-800 mb-4">Salario y Contrato</h3>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Fecha de ingreso *</label>
              <input type="date" name="hireDate" class="input" required />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Frecuencia de pago *</label>
              <select name="payFrequency" class="input" required>
                <option value="biweekly">Quincenal</option>
                <option value="monthly">Mensual</option>
                <option value="weekly">Semanal</option>
              </select>
            </div>
            <div class="col-span-2">
              <label class="block text-sm font-medium text-gray-700 mb-1">
                Salario base (USD) *
                {isPublica && <span class="ml-1 text-xs text-gray-400" id="salaryMaxHint"></span>}
              </label>
              <input
                type="text"
                name="baseSalary"
                id="baseSalaryInput"
                class="input"
                required
                placeholder="1200.00"
                data-position-max=""
              />
              {isPublica && (
                <p class="mt-1 text-xs text-gray-500">
                  Puede ajustar el salario hacia abajo; no puede superar el salario de la posición.
                </p>
              )}
            </div>
          </div>
        </div>
      </div>

      <!-- TAB: Tipos de Planilla -->
      {payrollTypes.length > 0 && (
        <div id="tab-nomina" style="display:none">
          <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
            <h3 class="font-semibold text-gray-800 mb-1">Tipos de Planilla</h3>
            <p class="text-xs text-gray-500 mb-4">Selecciona al menos un tipo de planilla al que pertenece este empleado.</p>
            <div class="grid grid-cols-2 gap-3">
              {payrollTypes.map((pt) => (
                <label class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:bg-gray-50 cursor-pointer">
                  <input
                    type="checkbox"
                    name="payrollTypeIds[]"
                    value={pt.id}
                    class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500"
                    checked={pt.code === 'REGULAR'}
                  />
                  <span class="text-sm text-gray-700">{pt.name}</span>
                </label>
              ))}
            </div>
          </div>
        </div>
      )}

      <!-- Actions -->
      <div class="flex justify-end gap-3 mt-2">
        <a href="/employees" class="px-4 py-2 text-sm text-gray-600 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
          Cancelar
        </a>
        <button type="submit" class="px-4 py-2 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors">
          Guardar Empleado
        </button>
      </div>
    </form>
  </div>
</AppLayout>

<style>
  .input {
    @apply w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent;
  }
  .tab-btn {
    padding: 10px 20px;
    border: none;
    background: none;
    cursor: pointer;
    font-size: 14px;
    color: #6b7280;
    border-bottom: 3px solid transparent;
    margin-bottom: -2px;
    font-weight: 500;
  }
  .tab-btn.active {
    color: #2563eb;
    border-bottom-color: #2563eb;
    font-weight: 600;
  }
</style>

<script is:inline>
  function switchTab(tab, btn) {
    document.querySelectorAll('[id^="tab-"]').forEach(el => el.style.display = 'none')
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'))
    document.getElementById('tab-' + tab).style.display = ''
    btn.classList.add('active')
  }

  // Auto-fill cargo/depto/salary from selected position (empresa pública).
  // Salary is editable but capped at the position salary; selecting a
  // position seeds it with the maximum and refreshes the info block.
  const posSelect = document.getElementById('positionSelect')
  const salaryInput = document.getElementById('baseSalaryInput')
  if (posSelect && salaryInput) {
    posSelect.addEventListener('change', function () {
      const opt = this.options[this.selectedIndex]
      const max = opt.dataset.salary || ''
      const hCargo = document.getElementById('hiddenCargoId')
      const hDepto = document.getElementById('hiddenDepartamentoId')
      if (hCargo) hCargo.value = opt.dataset.cargo || ''
      if (hDepto) hDepto.value = opt.dataset.depto || ''
      salaryInput.value = max
      salaryInput.dataset.positionMax = max
      const hint = document.getElementById('salaryMaxHint')
      if (hint) hint.textContent = max ? '(máximo de la posición: $' + max + ')' : ''
      const card = document.getElementById('positionInfoCard')
      if (card) card.style.display = opt.value ? '' : 'none'
      const set = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val }
      set('posInfoCargo', opt.dataset.cargoName || '—')
      set('posInfoSalary', max ? '$' + max : '—')
      set('posInfoOvertime', '$' + (opt.dataset.overtime || '0'))
      set('posInfoRepresentation', '$' + (opt.dataset.representation || '0'))
    })
  }

  // On submit: validate required fields in hidden tabs + salary ceiling
  document.getElementById('empForm').addEventListener('submit', function (e) {
    const salary = document.getElementById('baseSalaryInput')
    if (salary) {
      const max = parseFloat(salary.dataset.positionMax || '')
      const val = parseFloat(salary.value || '')
      if (!isNaN(max) && !isNaN(val) && val > max) {
        e.preventDefault()
        switchTab('laboral', document.querySelector('[data-tab="laboral"]'))
        salary.focus()
        alert('El salario base no puede superar el salario de la posición ($' + max + ').')
        return
      }
    }
    const required = this.querySelectorAll('[required]')
    let firstInvalid = null
    for (const el of required) {
      if (!el.value.trim()) {
        if (!firstInvalid) firstInvalid = el
      }
    }
    if (firstInvalid) {
      e.preventDefault()
      const tabDiv = firstInvalid.closest('[id^="tab-"]')
      if (tabDiv) {
        const tabName = tabDiv.id.replace('tab-', '')
        const btn = document.querySelector(`[data-tab="${tabName}"]`)
        switchTab(tabName, btn)
      }
      firstInvalid.focus()
      firstInvalid.reportValidity()
    }
  })

  // Foto / cédula: leer el archivo a base64, validar MIME + tamaño, y dejarlo
  // en el input hidden que viaja en el form. Vista previa inmediata.
  const MAX_IMG_BYTES = 500 * 1024
  const ALLOWED_IMG = ['image/png', 'image/jpeg', 'image/webp']
  const imgError = document.getElementById('imageError')
  function wireImageField(fileId, inputId, previewId, clearId) {
    const fileEl = document.getElementById(fileId)
    const hidden = document.getElementById(inputId)
    const preview = document.getElementById(previewId)
    const clearBtn = document.getElementById(clearId)
    if (!fileEl || !hidden) return
    fileEl.addEventListener('change', function () {
      const file = this.files && this.files[0]
      if (!file) return
      if (imgError) imgError.classList.add('hidden')
      if (!ALLOWED_IMG.includes(file.type)) {
        if (imgError) { imgError.textContent = 'Tipo no permitido. Use PNG, JPEG o WEBP.'; imgError.classList.remove('hidden') }
        this.value = ''
        return
      }
      if (file.size > MAX_IMG_BYTES) {
        if (imgError) { imgError.textContent = 'La imagen excede 500 KB.'; imgError.classList.remove('hidden') }
        this.value = ''
        return
      }
      const reader = new FileReader()
      reader.onload = function () {
        hidden.value = reader.result
        if (preview) { preview.src = reader.result; preview.classList.remove('hidden') }
        if (clearBtn) clearBtn.classList.remove('hidden')
      }
      reader.readAsDataURL(file)
    })
    clearBtn?.addEventListener('click', function () {
      hidden.value = ''
      if (preview) { preview.src = ''; preview.classList.add('hidden') }
      if (fileEl) fileEl.value = ''
      clearBtn.classList.add('hidden')
    })
  }
  wireImageField('photoFile', 'photoInput', 'photoPreview', 'photoClear')
  wireImageField('scannedIdFile', 'scannedIdInput', 'scannedIdPreview', 'scannedIdClear')
</script>

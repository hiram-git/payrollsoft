---
import AppLayout from '../../layouts/AppLayout.astro'
import PositionSelect from '../../components/PositionSelect.astro'
import CustomFieldInputs from '../../components/CustomFieldInputs.astro'
import { customFieldValueToString } from '../../lib/custom-fields'
import { resolveTenantSlugFromCookie } from '../../lib/tenant-slug'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')
const tenantSlug = resolveTenantSlugFromCookie(authCookie)

type CatalogItem = { id: string; code: string; name: string; isActive: boolean }
type Departamento = CatalogItem & { parentId: string | null }
type Position = {
  id: string
  code: string
  name: string
  salary: string
  overtimeAmount: string | null
  representationAmount: string | null
  jobTitleId: string | null
  departmentId: string | null
  jobFunctionId: string | null
  isActive: boolean
  status: 'en_uso' | 'vacante' | string
}
type CompanyConfig = { tipoInstitucion?: string | null }
type PayrollType = { id: string; code: string; name: string; sortOrder: number }

type CustomFieldDefinition = {
  code: string
  name: string
  description: string | null
  fieldType: 'text' | 'integer' | 'float' | 'date'
  isRequired: boolean
  isActive: boolean
  defaultValue: unknown
  sortOrder: number
}

let cargos: CatalogItem[] = []
let funciones: CatalogItem[] = []
let departamentos: Departamento[] = []
let positions: Position[] = []
let payrollTypes: PayrollType[] = []
let customFieldDefs: CustomFieldDefinition[] = []
let tipoInstitucion = 'privada'

try {
  const headers = { Cookie: `auth=${authCookie}`, 'X-Tenant': tenantSlug }
  const [cRes, fRes, dRes, compRes, cfgRes, cfRes] = await Promise.all([
    fetch(`${API_URL}/job-titles`, { headers }),
    fetch(`${API_URL}/job-functions`, { headers }),
    fetch(`${API_URL}/departments`, { headers }),
    fetch(`${API_URL}/company`, { headers }),
    fetch(`${API_URL}/concepts/config`, { headers }),
    fetch(`${API_URL}/custom-fields`, { headers }),
  ])
  if (cRes.ok) cargos = ((await cRes.json()) as { data: CatalogItem[] }).data ?? []
  if (fRes.ok) funciones = ((await fRes.json()) as { data: CatalogItem[] }).data ?? []
  if (dRes.ok) departamentos = ((await dRes.json()) as { data: Departamento[] }).data ?? []
  if (cfRes.ok) {
    const cfJson = (await cfRes.json()) as { data: CustomFieldDefinition[] }
    customFieldDefs = (cfJson.data ?? []).filter((d) => d.isActive)
  }
  if (compRes.ok) {
    const cfg = ((await compRes.json()) as { data: CompanyConfig }).data
    tipoInstitucion = cfg?.institutionType ?? 'privada'
  }
  if (cfgRes.ok) {
    const cfgData = (await cfgRes.json()) as { data?: { payrollTypes?: PayrollType[] } }
    payrollTypes = (cfgData.data?.payrollTypes ?? []).sort((a, b) => a.sortOrder - b.sortOrder)
  }
  if (tipoInstitucion === 'publica') {
    const pRes = await fetch(`${API_URL}/positions?isActive=true`, { headers })
    if (pRes.ok) positions = ((await pRes.json()) as { data: Position[] }).data ?? []
  }
} catch {
  /* ignore — dropdowns show empty on error */
}

// Correlativo del sistema para el código de empleado nuevo.
let nextCode = ''
try {
  const res = await fetch(`${API_URL}/employees/next-code`, {
    headers: { Cookie: `auth=${authCookie}`, 'X-Tenant': tenantSlug },
  })
  if (res.ok) {
    const j = (await res.json()) as { data?: { code?: string } }
    nextCode = j.data?.code ?? ''
  }
} catch {
  /* si falla, el campo queda editable */
}

const isPublica = tipoInstitucion === 'publica'
const activeCargos = cargos.filter((c) => c.isActive)
const activeFunciones = funciones.filter((f) => f.isActive)
const activeDepts = departamentos.filter((d) => d.isActive)

const positionSelectOptions = positions.map((p) => ({
  id: p.id,
  name: p.name,
  code: p.code,
  salary: p.salary,
  status: p.status,
  jobTitleId: p.jobTitleId,
  cargoName: p.jobTitleId ? (activeCargos.find((c) => c.id === p.jobTitleId)?.name ?? '') : '',
  departmentId: p.departmentId,
  overtimeAmount: p.overtimeAmount ?? '0',
  representationAmount: p.representationAmount ?? '0',
}))

// Al crear, los campos adicionales arrancan con su valor por defecto.
const cfValues: Record<string, string> = {}
for (const cf of customFieldDefs) {
  cfValues[cf.code] = customFieldValueToString(cf.defaultValue, cf.fieldType)
}

const error = Astro.url.searchParams.get('error') ?? ''
const errorMessages: Record<string, string> = {
  code_taken: 'El código de empleado ya está en uso.',
  id_taken: 'La cédula ya está registrada.',
  salary_max: 'El salario base no puede superar el salario de la posición.',
  position_occupied: 'La posición seleccionada ya está ocupada por otro empleado.',
  custom_field_required: 'Faltan campos adicionales obligatorios.',
  custom_field_forbidden: 'No tienes permiso para escribir uno de los campos adicionales.',
  'server-error': 'Error del servidor. Intenta de nuevo.',
  'missing-fields': 'Completa todos los campos requeridos.',
}
---

<AppLayout title="Nuevo Empleado">
  <div class="p-8">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Nuevo Empleado</h1>
      </div>
      <a href="/employees" class="text-sm text-gray-500 hover:text-gray-700 flex items-center gap-1">
        ← Volver
      </a>
    </div>

    {error && (
      <div id="serverError" class="mb-6 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
        {errorMessages[error] ?? 'Ocurrió un error inesperado.'}
      </div>
    )}

    <form method="POST" action="/api/employees" id="empForm" novalidate>
      <div id="reqError" class="hidden mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700"></div>
      <!-- Tabs -->
      <div class="flex gap-0 border-b-2 border-gray-200 mb-6">
        <button type="button" class="tab-btn active" data-tab="personal" onclick="switchTab('personal', this)">
          Datos Personales
        </button>
        <button type="button" class="tab-btn" data-tab="laboral" onclick="switchTab('laboral', this)">
          Datos Laborales
        </button>
        {payrollTypes.length > 0 && (
          <button type="button" class="tab-btn" data-tab="nomina" onclick="switchTab('nomina', this)">
            Tipos de Planilla
          </button>
        )}
        {customFieldDefs.length > 0 && (
          <button type="button" class="tab-btn" data-tab="adicionales" onclick="switchTab('adicionales', this)">
            Campos adicionales
          </button>
        )}
      </div>

      <!-- TAB: Datos Personales -->
      <div id="tab-personal">
        <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
          <h3 class="font-semibold text-gray-800 mb-4">Identificación</h3>
          <div class="grid grid-cols-2 gap-4">
            <div class="form-group col-span-2 grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Nombre *</label>
                <input type="text" name="firstName" class="input" required placeholder="Juan" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Apellido *</label>
                <input type="text" name="lastName" class="input" required placeholder="Pérez" />
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Cédula *</label>
              <input type="text" name="idNumber" class="input" required placeholder="8-123-456" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Seguro Social</label>
              <input type="text" name="socialSecurityNumber" class="input" placeholder="000-00-0000" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Sexo *</label>
              <select name="sex" class="input" required>
                <option value="">—</option>
                <option value="M">Masculino</option>
                <option value="F">Femenino</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Nacionalidad *</label>
              <select name="nationality" class="input" required>
                <option value="">—</option>
                <option value="panamanian">Panameño(a)</option>
                <option value="foreign">Extranjero(a)</option>
                <option value="naturalized">Nacionalizado(a)</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Correo electrónico</label>
              <input type="email" name="email" class="input" placeholder="juan@empresa.com" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Teléfono</label>
              <input type="text" name="phone" class="input" placeholder="6000-0000" />
            </div>
          </div>
        </div>

        <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
          <h3 class="font-semibold text-gray-800 mb-1">Condición y registro</h3>
          <p class="text-xs text-gray-500 mb-4">
            Marque las casillas que apliquen. La discapacidad propia habilita el saldo
            de incapacidad del colaborador.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            <label class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:bg-gray-50 cursor-pointer">
              <input type="checkbox" name="hasOwnDisability" class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
              <span class="text-sm text-gray-700">Tiene discapacidad propia</span>
            </label>
            <label class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:bg-gray-50 cursor-pointer">
              <input type="checkbox" name="requiresAttendanceMarking" class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" checked />
              <span class="text-sm text-gray-700">Marca reloj (registra asistencia)</span>
            </label>
            <label class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:bg-gray-50 cursor-pointer">
              <input type="checkbox" name="canRead" class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
              <span class="text-sm text-gray-700">Sabe leer</span>
            </label>
            <label class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:bg-gray-50 cursor-pointer">
              <input type="checkbox" name="canWrite" class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
              <span class="text-sm text-gray-700">Sabe escribir</span>
            </label>
          </div>
        </div>

        <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
          <h3 class="font-semibold text-gray-800 mb-1">Foto y cédula</h3>
          <p class="text-xs text-gray-500 mb-4">
            Imágenes en formato PNG, JPEG o WEBP, hasta 500 KB cada una.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Foto del colaborador</label>
              <img id="photoPreview" src="" alt="" class="w-28 h-28 rounded-lg object-cover border border-gray-200 mb-2 hidden" />
              <input type="hidden" name="photo" id="photoInput" />
              <input type="file" id="photoFile" accept="image/png,image/jpeg,image/webp" class="block w-full text-sm file:mr-4 file:py-1.5 file:px-3 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" />
              <button type="button" id="photoClear" class="mt-2 text-xs text-red-600 hover:underline hidden">Quitar foto</button>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Cédula escaneada</label>
              <img id="scannedIdPreview" src="" alt="" class="w-full max-w-xs rounded-lg object-cover border border-gray-200 mb-2 hidden" />
              <input type="hidden" name="scannedId" id="scannedIdInput" />
              <input type="file" id="scannedIdFile" accept="image/png,image/jpeg,image/webp" class="block w-full text-sm file:mr-4 file:py-1.5 file:px-3 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" />
              <button type="button" id="scannedIdClear" class="mt-2 text-xs text-red-600 hover:underline hidden">Quitar imagen</button>
            </div>
          </div>
          <p id="imageError" class="hidden mt-3 text-xs text-red-600"></p>
        </div>
      </div>

      <!-- TAB: Datos Laborales -->
      <div id="tab-laboral" style="display:none">
        <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
          <h3 class="font-semibold text-gray-800 mb-4">Puesto y Departamento</h3>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Código de empleado *</label>
              <input type="text" name="code" class="input" required placeholder="E001" value={nextCode} readonly={!!nextCode} />
              {nextCode && <p class="mt-1 text-xs text-gray-500">Asignado automáticamente por el sistema.</p>}
            </div>

            {isPublica ? (
              <!-- Empresa pública: selector de posición con badge de estado -->
              <PositionSelect options={positionSelectOptions} required label="Posición" />
              <!-- Cargo + departamento se derivan de la posición -->
              <input type="hidden" name="jobTitleId" id="hiddenCargoId" />
              <input type="hidden" name="departmentId" id="hiddenDepartamentoId" />
              <!-- La función es atributo del empleado, editable también con posición -->
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Función</label>
                <select name="jobFunctionId" class="input">
                  <option value="">— Sin función —</option>
                  {activeFunciones.map((f) => (
                    <option value={f.id}>{f.name} ({f.code})</option>
                  ))}
                </select>
              </div>
            ) : (
              <!-- Empresa privada: selección directa -->
              <>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Departamento</label>
                  <select name="departmentId" class="input">
                    <option value="">— Sin departamento —</option>
                    {activeDepts.map((d) => (
                      <option value={d.id}>{d.name} ({d.code})</option>
                    ))}
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Cargo</label>
                  <select name="jobTitleId" class="input">
                    <option value="">— Sin cargo —</option>
                    {activeCargos.map((c) => (
                      <option value={c.id}>{c.name} ({c.code})</option>
                    ))}
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Función</label>
                  <select name="jobFunctionId" class="input">
                    <option value="">— Sin función —</option>
                    {activeFunciones.map((f) => (
                      <option value={f.id}>{f.name} ({f.code})</option>
                    ))}
                  </select>
                </div>
              </>
            )}
          </div>
        </div>

        {isPublica && (
          <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4" id="positionInfoCard" style="display:none">
            <h3 class="font-semibold text-gray-800 mb-4">Información de la posición</h3>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
              <div>
                <div class="text-xs text-gray-500 mb-0.5">Cargo</div>
                <div class="text-gray-800" id="posInfoCargo">—</div>
              </div>
              <div>
                <div class="text-xs text-gray-500 mb-0.5">Salario de la posición</div>
                <div class="text-gray-800" id="posInfoSalary">—</div>
              </div>
              <div>
                <div class="text-xs text-gray-500 mb-0.5">Sobresueldo</div>
                <div class="text-gray-800" id="posInfoOvertime">—</div>
              </div>
              <div>
                <div class="text-xs text-gray-500 mb-0.5">Gastos de representación</div>
                <div class="text-gray-800" id="posInfoRepresentation">—</div>
              </div>
            </div>
          </div>
        )}

        <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
          <h3 class="font-semibold text-gray-800 mb-4">Salario y Contrato</h3>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Fecha de ingreso *</label>
              <input type="date" name="hireDate" class="input" required />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Frecuencia de pago *</label>
              <select name="payFrequency" class="input" required>
                <option value="biweekly">Quincenal</option>
                <option value="monthly">Mensual</option>
                <option value="weekly">Semanal</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Tipo de contrato *</label>
              <select name="contractType" id="contractTypeSelect" class="input" required>
                <option value="">—</option>
                <option value="permanent">Permanente</option>
                <option value="transitory">Contrato transitorio</option>
                <option value="contingent">Contrato contingente</option>
                <option value="professional_services">Servicios profesionales</option>
                <option value="deputy">Contrato diputado</option>
                <option value="interim">Contrato interino</option>
              </select>
            </div>
            <div id="contractEndWrap" style="display:none">
              <label class="block text-sm font-medium text-gray-700 mb-1">Fin de contrato *</label>
              <input type="date" name="contractEndDate" id="contractEndInput" class="input" />
              <p class="mt-1 text-xs text-gray-500">Fecha de término del contrato (para alertas de vencimiento).</p>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Método de pago *</label>
              <select name="paymentMethod" class="input" required>
                <option value="check">Cheque</option>
                <option value="ach">ACH</option>
                <option value="cash">Efectivo</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Estatus</label>
              <select class="input" disabled>
                <option>Activo</option>
              </select>
              <p class="mt-1 text-xs text-gray-500">Los empleados nuevos se crean activos.</p>
            </div>
            <div class="col-span-2">
              <label class="block text-sm font-medium text-gray-700 mb-1">
                Salario base (USD) *
                {isPublica && <span class="ml-1 text-xs text-gray-400" id="salaryMaxHint"></span>}
              </label>
              <input
                type="text"
                name="baseSalary"
                id="baseSalaryInput"
                class="input"
                required
                placeholder="1200.00"
                data-position-max=""
              />
              {isPublica && (
                <p class="mt-1 text-xs text-gray-500">
                  Puede ajustar el salario hacia abajo; no puede superar el salario de la posición.
                </p>
              )}
            </div>
          </div>
        </div>
      </div>

      <!-- TAB: Tipos de Planilla -->
      {payrollTypes.length > 0 && (
        <div id="tab-nomina" style="display:none">
          <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
            <h3 class="font-semibold text-gray-800 mb-1">Tipos de Planilla</h3>
            <p class="text-xs text-gray-500 mb-4">Selecciona al menos un tipo de planilla al que pertenece este empleado.</p>
            <div class="grid grid-cols-2 gap-3">
              {payrollTypes.map((pt) => (
                <label class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:bg-gray-50 cursor-pointer">
                  <input
                    type="checkbox"
                    name="payrollTypeIds[]"
                    value={pt.id}
                    class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500"
                    checked={pt.code === 'REGULAR'}
                  />
                  <span class="text-sm text-gray-700">{pt.name}</span>
                </label>
              ))}
            </div>
          </div>
        </div>
      )}

      <!-- TAB: Campos adicionales -->
      {customFieldDefs.length > 0 && (
        <div id="tab-adicionales" style="display:none">
          <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
            <h3 class="font-semibold text-gray-800 mb-1">Campos adicionales</h3>
            <p class="text-xs text-gray-500 mb-4">
              Definidos en <a href="/config/custom-fields" class="text-blue-600 hover:underline">Configuración → Campos
              adicionales</a>. Si tienen valor por defecto, se cargan automáticamente.
            </p>
            <CustomFieldInputs defs={customFieldDefs} values={cfValues} />
          </div>
        </div>
      )}

      <!-- Actions -->
      <div class="flex justify-end gap-3 mt-2">
        <a href="/employees" class="px-4 py-2 text-sm text-gray-600 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
          Cancelar
        </a>
        <button type="submit" class="px-4 py-2 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors">
          Guardar Empleado
        </button>
      </div>
    </form>
  </div>
</AppLayout>

<style>
  .input {
    @apply w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent;
  }
  .tab-btn {
    padding: 10px 20px;
    border: none;
    background: none;
    cursor: pointer;
    font-size: 14px;
    color: #6b7280;
    border-bottom: 3px solid transparent;
    margin-bottom: -2px;
    font-weight: 500;
  }
  .tab-btn.active {
    color: #2563eb;
    border-bottom-color: #2563eb;
    font-weight: 600;
  }
</style>

<script is:inline>
  // "Fin de contrato" solo aplica a contratos a término (cualquier tipo
  // excepto Permanente). Se muestra/oculta según el tipo seleccionado.
  ;(function () {
    const sel = document.getElementById('contractTypeSelect')
    const wrap = document.getElementById('contractEndWrap')
    const input = document.getElementById('contractEndInput')
    if (!sel || !wrap) return
    function sync() {
      const show = sel.value !== '' && sel.value !== 'permanent'
      wrap.style.display = show ? '' : 'none'
      if (input) {
        input.required = show
        if (!show) input.value = ''
      }
    }
    sel.addEventListener('change', sync)
    sync()
  })()

  function switchTab(tab, btn) {
    document.querySelectorAll('[id^="tab-"]').forEach(el => el.style.display = 'none')
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'))
    document.getElementById('tab-' + tab).style.display = ''
    btn.classList.add('active')
  }

  // Auto-fill cargo/depto/salary from selected position (empresa pública).
  // Salary is editable but capped at the position salary; selecting a
  // position seeds it with the maximum and refreshes the info block.
  const posInput = document.getElementById('positionId')
  const salaryInput = document.getElementById('baseSalaryInput')
  if (posInput && salaryInput) {
    posInput.addEventListener('change', function () {
      const ds = posInput.dataset
      const max = ds.salary || ''
      const hCargo = document.getElementById('hiddenCargoId')
      const hDepto = document.getElementById('hiddenDepartamentoId')
      if (hCargo) hCargo.value = ds.cargo || ''
      if (hDepto) hDepto.value = ds.depto || ''
      salaryInput.value = max
      salaryInput.dataset.positionMax = max
      const hint = document.getElementById('salaryMaxHint')
      if (hint) hint.textContent = max ? '(máximo de la posición: $' + max + ')' : ''
      const card = document.getElementById('positionInfoCard')
      if (card) card.style.display = posInput.value ? '' : 'none'
      const set = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val }
      set('posInfoCargo', ds.cargoName || '—')
      set('posInfoSalary', max ? '$' + max : '—')
      set('posInfoOvertime', '$' + (ds.overtime || '0'))
      set('posInfoRepresentation', '$' + (ds.representation || '0'))
    })
  }

  // Validación al enviar: lista todos los obligatorios faltantes con la ruta
  // «Pestaña → Campo» en un banner, y enfoca el primero. También aplica el
  // tope salarial cuando la posición lo define.
  ;(function () {
    const form = document.getElementById('empForm')
    if (!form) return
    const banner = document.getElementById('reqError')

    function tabInfo(el) {
      const panel = el && el.closest ? el.closest('[id^="tab-"]') : null
      if (!panel) return null
      const key = panel.id.replace('tab-', '')
      const btn = document.querySelector('[data-tab="' + key + '"]')
      return { key, label: btn ? btn.textContent.trim() : key }
    }

    function fieldLabel(el) {
      const wrap = el.closest('div')
      const lbl = wrap ? wrap.querySelector('label') : null
      return lbl ? lbl.textContent.replace('*', '').trim() : el.name
    }

    function collectMissing() {
      const missing = []
      const required = form.querySelectorAll('[required]')
      for (const el of required) {
        if (!String(el.value || '').trim()) missing.push({ el, label: fieldLabel(el) })
      }
      const ptypes = form.querySelectorAll('input[name="payrollTypeIds[]"]')
      if (ptypes.length && ![...ptypes].some((b) => b.checked)) {
        missing.push({ el: ptypes[0], label: 'Tipo de planilla' })
      }
      return missing
    }

    // Mensajes para los códigos de error que devuelve el proxy vía JSON.
    const SERVER_ERRORS = {
      code_taken: 'El código de empleado ya está en uso.',
      id_taken: 'La cédula ya está registrada.',
      salary_max: 'El salario base no puede superar el salario de la posición.',
      position_occupied: 'La posición seleccionada ya está ocupada por otro empleado.',
      no_payroll_type: 'El empleado debe pertenecer a al menos un tipo de planilla.',
      custom_field_required: 'Faltan campos adicionales obligatorios.',
      custom_field_forbidden: 'No tienes permiso para escribir uno de los campos adicionales.',
      'missing-fields': 'Completa todos los campos requeridos.',
      'server-error': 'Error del servidor. Intenta de nuevo.',
    }

    function showError(html, toastMsg) {
      if (banner) {
        banner.innerHTML = html
        banner.classList.remove('hidden')
        banner.scrollIntoView({ behavior: 'smooth', block: 'center' })
      }
      if (window.toast) window.toast.error(toastMsg || (banner ? banner.textContent.trim() : html))
    }

    let submitting = false

    form.addEventListener('submit', function (e) {
      // Siempre interceptamos: validamos en cliente y, si pasa, enviamos por
      // fetch para que un error del servidor no recargue ni borre el formulario.
      e.preventDefault()
      e.stopImmediatePropagation()
      if (submitting) return
      if (banner) banner.classList.add('hidden')

      const missing = collectMissing()

      let salaryError = null
      const salary = document.getElementById('baseSalaryInput')
      if (salary) {
        const max = parseFloat(salary.dataset.positionMax || '')
        const val = parseFloat(salary.value || '')
        if (!isNaN(max) && !isNaN(val) && val > max) {
          salaryError = 'El salario base no puede superar el salario de la posición ($' + max + ').'
        }
      }

      if (missing.length || salaryError) {
        const lines = []
        if (missing.length) {
          lines.push('<strong>Faltan campos obligatorios:</strong>')
          for (const m of missing) {
            const t = tabInfo(m.el)
            lines.push('• ' + (t ? 'Pestaña «' + t.label + '» → ' : '') + m.label)
          }
        }
        if (salaryError) lines.push((missing.length ? '<br>' : '') + salaryError)

        const summary = salaryError && !missing.length
          ? salaryError
          : missing.length === 1
            ? 'Falta el campo «' + missing[0].label + '».'
            : 'Faltan ' + missing.length + ' campos obligatorios.'
        showError(lines.join('<br>'), summary)

        const focusEl = missing.length ? missing[0].el : salary
        if (focusEl) {
          const t = tabInfo(focusEl)
          if (t) switchTab(t.key, document.querySelector('[data-tab="' + t.key + '"]'))
          try { focusEl.focus() } catch (_) {}
        }
        return
      }

      // Validación local OK → envío AJAX. El estado del form se conserva ante
      // cualquier rechazo del servidor (posición ocupada, cédula duplicada…).
      submitting = true
      const submitBtn = form.querySelector('button[type="submit"]')
      if (submitBtn) submitBtn.disabled = true

      fetch(form.action, {
        method: 'POST',
        headers: { 'X-Form-Submit': '1' },
        body: new FormData(form),
      })
        .then(function (res) {
          return res.json().catch(function () { return {} }).then(function (data) {
            if (res.ok && data.ok) {
              window.location.href = data.redirect || '/employees'
              return
            }
            const code = data.error || 'server-error'
            const msg = SERVER_ERRORS[code] || 'Ocurrió un error inesperado.'
            showError(msg, msg)
            submitting = false
            if (submitBtn) submitBtn.disabled = false
          })
        })
        .catch(function () {
          showError(SERVER_ERRORS['server-error'], SERVER_ERRORS['server-error'])
          submitting = false
          if (submitBtn) submitBtn.disabled = false
        })
    })

    // Si el server retornó un error (banner SSR visible al cargar), dispara
    // también el toast para que sea visible aunque el usuario haya hecho scroll.
    const serverErr = document.getElementById('serverError')
    if (serverErr && window.toast) {
      const txt = serverErr.textContent && serverErr.textContent.trim()
      if (txt) window.toast.error(txt)
    }
  })()

  // Foto / cédula: leer el archivo a base64, validar MIME + tamaño, y dejarlo
  // en el input hidden que viaja en el form. Vista previa inmediata.
  const MAX_IMG_BYTES = 500 * 1024
  const ALLOWED_IMG = ['image/png', 'image/jpeg', 'image/webp']
  const imgError = document.getElementById('imageError')
  function wireImageField(fileId, inputId, previewId, clearId) {
    const fileEl = document.getElementById(fileId)
    const hidden = document.getElementById(inputId)
    const preview = document.getElementById(previewId)
    const clearBtn = document.getElementById(clearId)
    if (!fileEl || !hidden) return
    fileEl.addEventListener('change', function () {
      const file = this.files && this.files[0]
      if (!file) return
      if (imgError) imgError.classList.add('hidden')
      if (!ALLOWED_IMG.includes(file.type)) {
        if (imgError) { imgError.textContent = 'Tipo no permitido. Use PNG, JPEG o WEBP.'; imgError.classList.remove('hidden') }
        this.value = ''
        return
      }
      if (file.size > MAX_IMG_BYTES) {
        if (imgError) { imgError.textContent = 'La imagen excede 500 KB.'; imgError.classList.remove('hidden') }
        this.value = ''
        return
      }
      const reader = new FileReader()
      reader.onload = function () {
        hidden.value = reader.result
        if (preview) { preview.src = reader.result; preview.classList.remove('hidden') }
        if (clearBtn) clearBtn.classList.remove('hidden')
      }
      reader.readAsDataURL(file)
    })
    clearBtn?.addEventListener('click', function () {
      hidden.value = ''
      if (preview) { preview.src = ''; preview.classList.add('hidden') }
      if (fileEl) fileEl.value = ''
      clearBtn.classList.add('hidden')
    })
  }
  wireImageField('photoFile', 'photoInput', 'photoPreview', 'photoClear')
  wireImageField('scannedIdFile', 'scannedIdInput', 'scannedIdPreview', 'scannedIdClear')
</script>

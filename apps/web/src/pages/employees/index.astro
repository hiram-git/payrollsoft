---
import AppLayout from '../../layouts/AppLayout.astro'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'

const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')

type Employee = {
  id: string
  code: string
  firstName: string
  lastName: string
  idNumber: string
  position: string | null
  department: string | null
  baseSalary: string
  isActive: boolean
}

let employees: Employee[] = []
let total = 0
let error = ''

try {
  const res = await fetch(`${API_URL}/employees`, {
    headers: {
      Cookie: `auth=${authCookie}`,
      'X-Tenant': 'demo',
    },
  })
  if (res.ok) {
    const json = (await res.json()) as { data: Employee[]; total: number }
    employees = json.data ?? []
    total = json.total ?? 0
  } else if (res.status === 401) {
    return Astro.redirect('/login')
  } else {
    error = 'Error al cargar empleados'
  }
} catch {
  error = 'No se pudo conectar con el servidor'
}
---

<AppLayout title="Empleados">
  <div class="p-8">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Empleados</h1>
        <p class="text-sm text-gray-500 mt-0.5">{total} registros</p>
      </div>
      <a href="/employees/new" class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
        + Nuevo empleado
      </a>
    </div>

    {error && (
      <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
        {error}
      </div>
    )}

    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
      {employees.length === 0 ? (
        <div class="p-12 text-center text-gray-400 text-sm">
          No hay empleados registrados.{' '}
          <a href="/employees/new" class="text-blue-600 hover:underline">Agregar el primero</a>.
        </div>
      ) : (
        <table class="w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Código</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Nombre</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Cédula</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Puesto</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Salario base</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Estado</th>
              <th class="px-4 py-3"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {employees.map((emp) => (
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-4 py-3 font-mono text-xs text-gray-500">{emp.code}</td>
                <td class="px-4 py-3 font-medium text-gray-900">
                  {emp.firstName} {emp.lastName}
                </td>
                <td class="px-4 py-3 text-gray-600">{emp.idNumber}</td>
                <td class="px-4 py-3 text-gray-600">{emp.position ?? '—'}</td>
                <td class="px-4 py-3 text-gray-900">
                  ${Number(emp.baseSalary).toLocaleString('es-PA', { minimumFractionDigits: 2 })}
                </td>
                <td class="px-4 py-3">
                  <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${emp.isActive ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500'}`}>
                    {emp.isActive ? 'Activo' : 'Inactivo'}
                  </span>
                </td>
                <td class="px-4 py-3 text-right">
                  <a href={`/employees/${emp.id}`} class="text-blue-600 hover:underline text-xs">
                    Ver
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
  </div>
</AppLayout>

---
import AppLayout from '../../layouts/AppLayout.astro'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'

const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')

// Reactively filter the listing by the navbar's active payroll type — the
// AppLayout topbar form persists its choice in this cookie. When it is
// empty (user cleared the selector to "Todos los tipos"), no filter is
// applied and the query returns every employee. The backend joins via
// employee_payroll_types so an employee only appears when they have a
// valid row linking them to the selected type.
const activeTypeId = Astro.cookies.get('payroll.activeTypeId')?.value ?? ''

const PAGE_SIZE = 50

const page = Math.max(1, Number(Astro.url.searchParams.get('page') ?? '1'))
const q = Astro.url.searchParams.get('q') ?? ''

type Employee = {
  id: string
  code: string
  firstName: string
  lastName: string
  idNumber: string
  position: string | null
  department: string | null
  baseSalary: string
  isActive: boolean
}

let employees: Employee[] = []
let total = 0
let totalPages = 1
let error = ''

try {
  const params = new URLSearchParams({
    page: String(page),
    limit: String(PAGE_SIZE),
  })
  if (q) params.set('search', q)
  if (activeTypeId) params.set('payrollTypeId', activeTypeId)

  const res = await fetch(`${API_URL}/employees?${params}`, {
    headers: { Cookie: `auth=${authCookie}`, 'X-Tenant': 'demo' },
  })
  if (res.ok) {
    const json = (await res.json()) as {
      data: Employee[]
      total: number
      totalPages: number
    }
    employees = json.data ?? []
    total = json.total ?? 0
    totalPages = json.totalPages ?? 1
  } else if (res.status === 401) {
    return Astro.redirect('/login')
  } else {
    error = 'Error al cargar empleados'
  }
} catch {
  error = 'No se pudo conectar con el servidor'
}

function pageUrl(p: number) {
  const u = new URL(Astro.url)
  u.searchParams.set('page', String(p))
  if (q) u.searchParams.set('q', q)
  else u.searchParams.delete('q')
  return u.pathname + u.search
}

const showingFrom = total === 0 ? 0 : (page - 1) * PAGE_SIZE + 1
const showingTo = Math.min(page * PAGE_SIZE, total)
---

<AppLayout title="Empleados">
  <div class="p-8">

    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <div>
        <div class="flex items-center gap-2">
          <h1 class="text-xl font-semibold text-gray-900 tracking-tight">Empleados</h1>
          {activeTypeId && (
            <span
              class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700"
              title="La lista se está filtrando por el tipo de planilla activo en el navbar"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
              Filtrado por tipo de planilla
            </span>
          )}
        </div>
        <p class="text-sm text-gray-500 mt-0.5">{total} {total === 1 ? 'empleado' : 'empleados'}</p>
      </div>
      <a
        href="/employees/new"
        class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Nuevo empleado
      </a>
    </div>

    <!-- Search -->
    <form method="GET" action="/employees" class="mb-5">
      <div class="relative max-w-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input
          type="search"
          name="q"
          value={q}
          placeholder="Buscar por nombre, código o cédula…"
          class="w-full pl-9 pr-4 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent"
        />
      </div>
    </form>

    {error && (
      <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
    )}

    <!-- Table -->
    <div class="border border-gray-200 rounded-lg overflow-hidden bg-white">
      {employees.length === 0 ? (
        <div class="py-16 text-center">
          {q ? (
            <p class="text-sm text-gray-400">Sin resultados para "<span class="font-medium">{q}</span>"</p>
          ) : (
            <p class="text-sm text-gray-400 mb-1">
              No se encontraron registros para el tipo de planilla seleccionado.
              <br />
              <a href="/employees/new" class="text-gray-900 underline underline-offset-2 hover:text-gray-600">Agregar empleado</a>
            </p>
          )}
        </div>
      ) : (
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200 bg-gray-50">
              <th class="text-left px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Código</th>
              <th class="text-left px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Nombre</th>
              <th class="text-left px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Cédula</th>
              <th class="text-left px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Puesto</th>
              <th class="text-right px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Salario base</th>
              <th class="text-left px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Estado</th>
              <th class="px-4 py-3"></th>
            </tr>
          </thead>
          <tbody>
            {employees.map((emp) => (
              <tr class="border-b border-gray-100 last:border-0 hover:bg-gray-50 transition-colors">
                <td class="px-4 py-3.5 font-mono text-xs text-gray-500">{emp.code}</td>
                <td class="px-4 py-3.5 font-medium text-gray-900">
                  <a href={`/employees/${emp.id}`} class="hover:text-gray-600">
                    {emp.firstName} {emp.lastName}
                  </a>
                </td>
                <td class="px-4 py-3.5 text-gray-600 font-mono text-xs">{emp.idNumber}</td>
                <td class="px-4 py-3.5 text-gray-600 text-xs">{emp.position ?? '—'}</td>
                <td class="px-4 py-3.5 text-right text-gray-900 tabular-nums">
                  ${Number(emp.baseSalary).toLocaleString('es-PA', { minimumFractionDigits: 2 })}
                </td>
                <td class="px-4 py-3.5">
                  <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${emp.isActive ? 'bg-emerald-50 text-emerald-700' : 'bg-gray-100 text-gray-500'}`}>
                    {emp.isActive ? 'Activo' : 'Inactivo'}
                  </span>
                </td>
                <td class="px-4 py-3.5">
                  <div class="flex items-center justify-end gap-1">
                    <a href={`/employees/${emp.id}`} class="p-1.5 rounded text-gray-400 hover:text-blue-600 hover:bg-blue-50 transition-colors" title="Editar">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    </a>
                    {emp.isActive && (
                      <form method="POST" action={`/api/employees/${emp.id}`} onsubmit="return confirm('¿Dar de baja a este empleado?')">
                        <input type="hidden" name="_method" value="DELETE" />
                        <button type="submit" class="p-1.5 rounded text-gray-400 hover:text-red-600 hover:bg-red-50 transition-colors" title="Dar de baja">
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="17" y1="8" x2="23" y2="14"/><line x1="23" y1="8" x2="17" y2="14"/></svg>
                        </button>
                      </form>
                    )}
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>

    <!-- Pagination -->
    {totalPages > 1 && (
      <div class="mt-4 flex items-center justify-between text-sm text-gray-500">
        <span>
          Mostrando {showingFrom}–{showingTo} de {total}
        </span>
        <div class="flex items-center gap-1">
          {page > 1 ? (
            <a href={pageUrl(page - 1)} class="px-3 py-1.5 rounded-md border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 transition-colors text-xs font-medium">
              ← Anterior
            </a>
          ) : (
            <span class="px-3 py-1.5 rounded-md border border-gray-200 bg-gray-50 text-gray-300 text-xs font-medium cursor-not-allowed">
              ← Anterior
            </span>
          )}

          <span class="px-3 py-1.5 text-xs text-gray-600">
            Pág. {page} / {totalPages}
          </span>

          {page < totalPages ? (
            <a href={pageUrl(page + 1)} class="px-3 py-1.5 rounded-md border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 transition-colors text-xs font-medium">
              Siguiente →
            </a>
          ) : (
            <span class="px-3 py-1.5 rounded-md border border-gray-200 bg-gray-50 text-gray-300 text-xs font-medium cursor-not-allowed">
              Siguiente →
            </span>
          )}
        </div>
      </div>
    )}
  </div>
</AppLayout>

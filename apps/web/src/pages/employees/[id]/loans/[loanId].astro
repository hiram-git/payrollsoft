---
import AppLayout from '../../../../layouts/AppLayout.astro'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')

const { id, loanId } = Astro.params

type Employee = { id: string; firstName: string; lastName: string }
type Loan = {
  id: string
  amount: string
  balance: string
  installment: string
  startDate: string
  endDate: string | null
  isActive: boolean
  loanType: string | null
  frequency: string | null
  creditor: string | null
  creditorId: string | null
  allowDecember: boolean
}
type Installment = {
  id: string
  installmentNumber: number
  amount: string
  status: string
  payrollId: string | null
  paidAt: string | null
}

let emp: Employee | null = null
let loan: Loan | null = null
let installments: Installment[] = []

try {
  const headers = { Cookie: `auth=${authCookie}`, 'X-Tenant': 'demo' }
  const [empRes, loanRes, instRes] = await Promise.all([
    fetch(`${API_URL}/employees/${id}`, { headers }),
    fetch(`${API_URL}/loans/${loanId}`, { headers }),
    fetch(`${API_URL}/loans/${loanId}/installments`, { headers }),
  ])
  if (empRes.status === 401) return Astro.redirect('/login')
  if (empRes.status === 404) return Astro.redirect('/employees')
  if (empRes.ok) emp = ((await empRes.json()) as { data: Employee }).data
  if (loanRes.ok) loan = ((await loanRes.json()) as { data: Loan }).data
  if (instRes.ok) installments = ((await instRes.json()) as { data: Installment[] }).data ?? []
} catch {
  return Astro.redirect('/employees')
}

if (!emp || !loan) return Astro.redirect(`/employees/${id}`)

const error = Astro.url.searchParams.get('error') ?? ''
const success = Astro.url.searchParams.get('success') === '1'
const errorMessages: Record<string, string> = {
  'missing-fields': 'Completa todos los campos requeridos.',
  'server-error': 'Error del servidor. Intenta de nuevo.',
}

function computeDueDate(
  startDate: string,
  frequency: string | null,
  installmentNumber: number
): string {
  const date = new Date(`${startDate}T00:00:00`)
  const n = installmentNumber - 1
  if (frequency === 'semanal') {
    date.setDate(date.getDate() + n * 7)
  } else if (frequency === 'quincenal') {
    date.setDate(date.getDate() + n * 15)
  } else {
    date.setMonth(date.getMonth() + n)
  }
  const d = String(date.getDate()).padStart(2, '0')
  const m = String(date.getMonth() + 1).padStart(2, '0')
  return `${d}/${m}/${date.getFullYear()}`
}

const paid = installments.filter((i) => i.status === 'paid').length
const pending = installments.filter((i) => i.status === 'pending').length
const totalAmount = installments.reduce((s, i) => s + Number(i.amount), 0)
const paidAmount = installments
  .filter((i) => i.status === 'paid')
  .reduce((s, i) => s + Number(i.amount), 0)

const frequencyLabels: Record<string, string> = {
  semanal: 'Semanal',
  quincenal: 'Quincenal',
  mensual: 'Mensual',
  monthly: 'Mensual',
  weekly: 'Semanal',
  biweekly: 'Quincenal',
}
---

<AppLayout title="Editar Préstamo">
  <div class="p-8 max-w-4xl">

    <!-- Header -->
    <div class="flex items-center gap-2 mb-6">
      <a
        href={`/employees/${id}?tab=prestamos`}
        class="text-sm text-gray-500 hover:text-gray-700 transition-colors"
      >
        ← {emp.firstName} {emp.lastName}
      </a>
      <span class="text-gray-300">/</span>
      <h1 class="text-2xl font-bold text-gray-900">Préstamo</h1>
      {!loan.isActive && (
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500">
          Cerrado
        </span>
      )}
    </div>

    {success && (
      <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">
        Préstamo actualizado correctamente.
      </div>
    )}
    {error && (
      <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
        {errorMessages[error] ?? 'Ocurrió un error inesperado.'}
      </div>
    )}

    <form method="POST" action={`/api/employees/${id}/loans/${loanId}`}>
      <input type="hidden" name="_method" value="PUT" />

      <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
        <h2 class="font-semibold text-gray-800 mb-4">Datos del Préstamo</h2>

        {(loan.creditor || loan.loanType || loan.frequency) && (
          <div class="flex flex-wrap gap-2 mb-4">
            {loan.creditor && (
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500">
                {loan.creditor}
              </span>
            )}
            {loan.loanType && (
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500">
                {loan.loanType}
              </span>
            )}
            {loan.frequency && (
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500">
                {frequencyLabels[loan.frequency] ?? loan.frequency}
              </span>
            )}
          </div>
        )}

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Monto total (USD) *</label>
            <input type="text" name="amount" class="input" required value={loan.amount} />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Saldo actual (USD) *</label>
            <input type="text" name="balance" class="input" required value={loan.balance} />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Cuota por período (USD) *</label>
            <input type="text" name="installment" class="input" required value={loan.installment} />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Fecha de inicio *</label>
            <input type="date" name="startDate" class="input" required value={loan.startDate} />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Fecha estimada de fin</label>
            <input type="date" name="endDate" class="input" value={loan.endDate ?? ''} />
          </div>
          <div class="flex items-center gap-2 pt-5">
            <input
              type="checkbox"
              name="allowDecember"
              id="allowDecember"
              class="w-4 h-4 accent-blue-600"
              checked={loan.allowDecember}
            />
            <label for="allowDecember" class="text-xs font-medium text-gray-600">
              Descontar en diciembre
            </label>
          </div>
        </div>
      </div>

      <div class="flex justify-between">
        {loan.isActive && (
          <form
            method="POST"
            action={`/api/employees/${id}/loans/${loanId}`}
            onsubmit="return confirm('¿Cerrar este préstamo? Ya no se descontará de la nómina.')"
          >
            <input type="hidden" name="_method" value="DELETE" />
            <button
              type="submit"
              class="px-4 py-2 text-sm font-medium rounded-lg border border-red-300 text-red-600 hover:bg-red-50 transition-colors"
            >
              Cerrar préstamo
            </button>
          </form>
        )}
        <div class="flex gap-3 ml-auto">
          <a
            href={`/employees/${id}?tab=prestamos`}
            class="inline-flex items-center px-4 py-2 text-sm font-medium rounded-lg border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 transition-colors"
          >
            Cancelar
          </a>
          <button
            type="submit"
            class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors"
          >
            Guardar cambios
          </button>
        </div>
      </div>
    </form>

    <!-- Installments table -->
    {installments.length > 0 && (
      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden mt-6">
        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
          <h2 class="font-semibold text-gray-800">Tabla de Cuotas</h2>
          <div class="flex items-center gap-1.5 text-xs text-gray-500">
            <span><strong class="text-gray-700">{paid}</strong> pagadas</span>
            <span class="text-gray-300">·</span>
            <span><strong class="text-gray-700">{pending}</strong> pendientes</span>
            <span class="text-gray-300">·</span>
            <span>Total <strong class="text-gray-700">${totalAmount.toLocaleString('es-PA', { minimumFractionDigits: 2 })}</strong></span>
          </div>
        </div>

        <table class="w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="text-center px-4 py-3 font-medium text-gray-600 w-12">#</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Fecha estimada</th>
              <th class="text-right px-4 py-3 font-medium text-gray-600">Cuota</th>
              <th class="text-center px-4 py-3 font-medium text-gray-600 w-28">Estado</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {installments.map((inst) => (
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-4 py-3 text-center font-mono text-xs text-gray-400">
                  {inst.installmentNumber}
                </td>
                <td class="px-4 py-3 text-gray-600">
                  {computeDueDate(loan!.startDate, loan!.frequency, inst.installmentNumber)}
                </td>
                <td class="px-4 py-3 text-right font-medium text-gray-700 tabular-nums">
                  ${Number(inst.amount).toLocaleString('es-PA', { minimumFractionDigits: 2 })}
                </td>
                <td class="px-4 py-3 text-center">
                  {inst.status === 'paid'
                    ? <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">Pagada</span>
                    : <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-50 text-amber-700">Pendiente</span>
                  }
                </td>
              </tr>
            ))}
          </tbody>
        </table>

        <!-- Summary -->
        <div class="grid grid-cols-3 divide-x divide-gray-100 border-t border-gray-100">
          <div class="px-6 py-4 text-center">
            <p class="text-xs text-gray-500 mb-1">Cuota fija</p>
            <p class="text-base font-bold text-gray-900 tabular-nums">
              ${Number(loan.installment).toLocaleString('es-PA', { minimumFractionDigits: 2 })}
            </p>
          </div>
          <div class="px-6 py-4 text-center">
            <p class="text-xs text-gray-500 mb-1">Total amortizado</p>
            <p class="text-base font-bold text-green-600 tabular-nums">
              ${paidAmount.toLocaleString('es-PA', { minimumFractionDigits: 2 })}
            </p>
          </div>
          <div class="px-6 py-4 text-center">
            <p class="text-xs text-gray-500 mb-1">Saldo pendiente</p>
            <p class="text-base font-bold text-gray-900 tabular-nums">
              ${Number(loan.balance).toLocaleString('es-PA', { minimumFractionDigits: 2 })}
            </p>
          </div>
        </div>
      </div>
    )}
  </div>
</AppLayout>

<style>
  .input {
    @apply w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent;
  }
</style>

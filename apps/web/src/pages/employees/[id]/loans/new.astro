---
import AppLayout from '../../../../layouts/AppLayout.astro'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')

const { id } = Astro.params

type Employee = { id: string; firstName: string; lastName: string }
let emp: Employee | null = null

try {
  const res = await fetch(`${API_URL}/employees/${id}`, {
    headers: { Cookie: `auth=${authCookie}`, 'X-Tenant': 'demo' },
  })
  if (res.status === 401) return Astro.redirect('/login')
  if (res.status === 404) return Astro.redirect('/employees')
  if (res.ok) emp = ((await res.json()) as { data: Employee }).data
} catch {
  return Astro.redirect('/employees')
}

if (!emp) return Astro.redirect('/employees')

const error = Astro.url.searchParams.get('error') ?? ''
const errorMessages: Record<string, string> = {
  'missing-fields': 'Completa todos los campos requeridos.',
  'server-error': 'Error del servidor. Intenta de nuevo.',
}
---

<AppLayout title="Nuevo Préstamo">
  <div class="p-8 max-w-2xl">
    <div class="flex items-center gap-3 mb-6">
      <a href={`/employees/${id}?tab=prestamos`} class="text-sm text-gray-500 hover:text-gray-700">
        ← {emp.firstName} {emp.lastName}
      </a>
      <span class="text-gray-300">/</span>
      <h1 class="text-2xl font-bold text-gray-900">Nuevo Préstamo</h1>
    </div>

    {error && (
      <div class="mb-6 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
        {errorMessages[error] ?? 'Ocurrió un error inesperado.'}
      </div>
    )}

    <form method="POST" action={`/api/employees/${id}/loans`}>
      <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Monto total (USD) *</label>
            <input type="text" name="amount" class="input" required placeholder="1000.00" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Cuota por período (USD) *</label>
            <input type="text" name="installment" class="input" required placeholder="100.00" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Fecha de inicio *</label>
            <input type="date" name="startDate" class="input" required />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Fecha estimada de fin</label>
            <input type="date" name="endDate" class="input" />
          </div>
        </div>
        <p class="text-xs text-gray-400">El saldo inicial se establecerá igual al monto total.</p>
      </div>

      <div class="flex justify-end gap-3 mt-6">
        <a href={`/employees/${id}`} class="px-4 py-2 text-sm text-gray-600 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
          Cancelar
        </a>
        <button type="submit" class="px-4 py-2 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors">
          Registrar préstamo
        </button>
      </div>
    </form>
  </div>
</AppLayout>

<style>
  .input {
    @apply w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent;
  }
</style>

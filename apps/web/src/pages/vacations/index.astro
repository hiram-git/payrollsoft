---
import AppLayout from '../../layouts/AppLayout.astro'
import { can, getIdentity } from '../../lib/auth'

/**
 * Esqueleto de la vista de Vacaciones — solo prototipo. Renderiza la
 * estructura visual (KPIs, tabla, panel de balance) con datos
 * placeholder para que el flujo se pueda navegar antes de cablear el
 * backend. Cuando el módulo se implemente, los bloques `data-stub`
 * son los que hay que reemplazar por queries reales.
 */
const identity = getIdentity(Astro.cookies)
if (!identity) return Astro.redirect('/login')
if (!can(identity, 'vacations:read')) return Astro.redirect('/dashboard')

const stubKpis = [
  { label: 'Empleados con saldo > 0', value: '—' },
  { label: 'Días tomados este año', value: '—' },
  { label: 'Solicitudes pendientes', value: '—' },
  { label: 'Días por vencer (90 d)', value: '—' },
]
---

<AppLayout title="Vacaciones">
  <div class="mx-auto w-full max-w-7xl p-8 lg:w-3/4">
    <div class="flex items-start justify-between gap-4 mb-6">
      <div>
        <div class="flex items-center gap-2">
          <h1 class="text-xl font-semibold text-gray-900 tracking-tight">Vacaciones</h1>
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-50 text-amber-700 border border-amber-200">
            Próximamente
          </span>
        </div>
        <p class="text-sm text-gray-500 mt-0.5">
          Saldos, solicitudes y aprobaciones de vacaciones por empleado.
          Esta vista es un prototipo — la lógica de cálculo y persistencia se conectará en una fase posterior.
        </p>
      </div>
      <button
        type="button"
        disabled
        class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md bg-blue-600 text-white text-sm font-medium opacity-50 cursor-not-allowed"
        title="Disponible al implementar el módulo"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Nueva solicitud
      </button>
    </div>

    <!-- KPIs -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 mb-6" data-stub="kpis">
      {stubKpis.map((k) => (
        <div class="bg-white border border-gray-200 rounded-lg p-4">
          <div class="text-xs text-gray-500 uppercase tracking-wide">{k.label}</div>
          <div class="mt-1 text-2xl font-semibold text-gray-900 tabular-nums">{k.value}</div>
        </div>
      ))}
    </div>

    <!-- Tabla principal -->
    <div class="bg-white border border-gray-200 rounded-lg overflow-hidden" data-stub="balances-table">
      <div class="px-4 py-3 border-b border-gray-200 flex items-center justify-between">
        <h2 class="text-sm font-medium text-gray-900">Saldos por empleado</h2>
        <div class="flex items-center gap-2 text-xs text-gray-500">
          <input
            type="search"
            placeholder="Buscar empleado…"
            disabled
            class="px-2.5 py-1.5 border border-gray-300 rounded-md text-xs disabled:bg-gray-50 disabled:cursor-not-allowed"
          />
          <select disabled class="px-2.5 py-1.5 border border-gray-300 rounded-md text-xs disabled:bg-gray-50 disabled:cursor-not-allowed">
            <option>Todas las áreas</option>
          </select>
        </div>
      </div>
      <div class="py-16 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto w-10 h-10 text-gray-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2"/>
          <path d="M16 2v4M8 2v4M3 10h18"/>
        </svg>
        <p class="mt-3 text-sm text-gray-500">Aquí se listarán los saldos de vacaciones por empleado.</p>
        <p class="text-xs text-gray-400 mt-1 font-mono">vacations:read · vista en desarrollo</p>
      </div>
    </div>

    <!-- Panel de detalle (placeholder a la derecha en versiones futuras) -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 mt-6">
      <div class="bg-white border border-gray-200 rounded-lg p-5 lg:col-span-2" data-stub="requests-list">
        <h2 class="text-sm font-medium text-gray-900 mb-2">Solicitudes recientes</h2>
        <p class="text-sm text-gray-500">No hay solicitudes para mostrar todavía.</p>
      </div>
      <div class="bg-white border border-gray-200 rounded-lg p-5" data-stub="policy-card">
        <h2 class="text-sm font-medium text-gray-900 mb-2">Política vigente</h2>
        <p class="text-sm text-gray-500">
          La política de vacaciones se configurará desde
          <code class="font-mono text-xs">/config/company</code> y aplicará por antigüedad y tipo de contrato.
        </p>
      </div>
    </div>
  </div>
</AppLayout>

---
import AuthLayout from '../../layouts/AuthLayout.astro'
import { getIdentity } from '../../lib/auth'

const identity = getIdentity(Astro.cookies)
if (identity?.type === 'super_admin') {
  return Astro.redirect('/superadmin')
}

const errorMessages: Record<string, string> = {
  'missing-fields': 'Ingresa tu correo y contraseña.',
  'invalid-credentials': 'Credenciales inválidas.',
  'server-error': 'Error de servidor. Intenta de nuevo.',
}
const errorKey = Astro.url.searchParams.get('error') ?? ''
const errorMessage = errorMessages[errorKey] ?? ''
---
<AuthLayout title="Acceso Superadmin">
  <form class="form-wrap" method="POST" action="/api/superadmin/login" novalidate>
    <div class="eyebrow">
      <span class="eyebrow-dot"></span>
      Plataforma · Superadmin
    </div>
    <h1 class="form-h1">Acceso global</h1>
    <p class="form-sub">
      Solo para administradores de la plataforma. Si gestionas una sola empresa, accede desde
      <a href="/login">el portal de empresa</a>.
    </p>

    {errorMessage && (
      <div class="err-banner">
        <svg width="11" height="11" viewBox="0 0 11 11" fill="none" stroke="currentColor" stroke-width="1.3">
          <circle cx="5.5" cy="5.5" r="4.5"/>
          <path d="M5.5 3v3M5.5 7.8v.2"/>
        </svg>
        {errorMessage}
      </div>
    )}

    <div class="field">
      <div class="label-row"><span class="field-label">Correo electrónico</span></div>
      <div class="input-wrap">
        <input id="email" name="email" type="email" required autocomplete="email" placeholder="superadmin@payroll.dev" class="field-input" />
      </div>
    </div>

    <div class="field" style="margin-bottom:28px">
      <div class="label-row"><span class="field-label">Contraseña</span></div>
      <div class="input-wrap">
        <input id="password" name="password" type="password" required autocomplete="current-password" minlength="8" placeholder="••••••••••••" class="field-input" />
      </div>
    </div>

    <button type="submit" class="btn-primary">Ingresar</button>
  </form>
</AuthLayout>

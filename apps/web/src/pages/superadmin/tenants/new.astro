---
import SuperAdminLayout from '../../../layouts/SuperAdminLayout.astro'
import { getIdentity } from '../../../lib/auth'

const identity = getIdentity(Astro.cookies)
if (!identity || identity.type !== 'super_admin') {
  return Astro.redirect('/superadmin/login')
}

const errorFlag = Astro.url.searchParams.get('error')
const errorMessages: Record<string, string> = {
  'invalid-slug':
    'El slug no es válido. Usa solo letras minúsculas, números, guiones y guion bajo (3 a 50 caracteres).',
  'slug-taken': 'Ese slug ya está en uso por otra empresa.',
  'admin-email-invalid': 'El correo del administrador es inválido.',
  'missing-fields': 'Completa todos los campos obligatorios.',
  'weak-password': 'La contraseña debe tener al menos 12 caracteres.',
  'server-error': 'No se pudo crear la empresa. Revisa el detalle en auditoría.',
}
const errorMessage = errorFlag ? errorMessages[errorFlag] : ''

const prefillSlug = Astro.url.searchParams.get('slug') ?? ''
const prefillName = Astro.url.searchParams.get('name') ?? ''
---
<SuperAdminLayout title="Nueva empresa">
  <div class="p-8 max-w-2xl">
    <div class="mb-6">
      <a href="/superadmin/tenants" class="text-xs text-gray-500 hover:text-gray-900">← Volver a empresas</a>
      <h1 class="mt-2 text-xl font-semibold text-gray-900 tracking-tight">Nueva empresa</h1>
      <p class="text-sm text-gray-500 mt-0.5">Provisiona un nuevo tenant: se creará el schema <span class="font-mono">tenant_&lt;slug&gt;</span>, se aplicarán las migraciones y se creará el administrador inicial.</p>
    </div>

    {errorMessage && (
      <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{errorMessage}</div>
    )}

    <form method="POST" action="/api/superadmin/tenants/create" class="space-y-5 bg-white border border-gray-200 rounded-lg p-6">
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1.5">Nombre comercial</label>
        <input type="text" name="name" required minlength="1" maxlength="255" value={prefillName}
          class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent"
          placeholder="Ej. Acme Panamá, S.A." />
      </div>

      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1.5">Slug</label>
        <input type="text" name="slug" required minlength="3" maxlength="50" value={prefillSlug}
          pattern="[a-z0-9][a-z0-9_-]{2,49}"
          class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md font-mono focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent"
          placeholder="acme" />
        <p class="mt-1.5 text-xs text-gray-500">Identificador único en URLs y headers. Solo letras minúsculas, números, guion y guion bajo. No se podrá cambiar después.</p>
      </div>

      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1.5">Correo de contacto <span class="text-gray-400 font-normal">(opcional)</span></label>
        <input type="email" name="contactEmail"
          class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent"
          placeholder="contacto@empresa.com" />
      </div>

      <div class="border-t border-gray-200 pt-5 space-y-5">
        <div>
          <h2 class="text-sm font-medium text-gray-700">Administrador inicial</h2>
          <p class="text-xs text-gray-500 mt-0.5">Este usuario recibe el rol <span class="font-mono">tenant_admin</span> y la marca <span class="font-mono">is_tenant_admin</span>.</p>
        </div>

        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1.5">Nombre completo</label>
          <input type="text" name="adminName" required minlength="1" maxlength="255"
            class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent" />
        </div>

        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1.5">Correo</label>
          <input type="email" name="adminEmail" required
            class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent" />
        </div>

        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1.5">Contraseña inicial</label>
          <input type="password" name="adminPassword" required minlength="12" maxlength="256"
            class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent"
            placeholder="Mínimo 12 caracteres" />
          <p class="mt-1.5 text-xs text-gray-500">Comparte esta contraseña con el administrador por un canal seguro.</p>
        </div>
      </div>

      <div class="flex items-center gap-2 pt-2">
        <button type="submit" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-md bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 transition-colors">Provisionar empresa</button>
        <a href="/superadmin/tenants" class="px-4 py-2 text-sm text-gray-600 hover:text-gray-900">Cancelar</a>
      </div>
    </form>
  </div>
</SuperAdminLayout>

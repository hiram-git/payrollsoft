---
import AuthLayout from '../layouts/AuthLayout.astro'

const errorMessages: Record<string, string> = {
  'missing-fields': 'Completa todos los campos.',
  'invalid-email': 'Ingresa un correo electrónico válido.',
  'server-error': 'Error de servidor. Intenta de nuevo en unos minutos.',
}

const errorKey = Astro.url.searchParams.get('error') ?? ''
const errorMessage = errorMessages[errorKey] ?? ''
const sent = Astro.url.searchParams.get('sent') === '1'
---
<AuthLayout title="Recuperar contraseña">
  <form class="form-wrap" method="POST" action="/api/auth/forgot-password" novalidate>
    <div class="eyebrow">
      <span class="eyebrow-dot"></span>
      Portal de empresa · Recuperar contraseña
    </div>
    <h1 class="form-h1">¿Olvidaste tu contraseña?</h1>
    <p class="form-sub">
      Ingresa tu correo electrónico y te enviaremos un enlace para restablecerla.
      El enlace expira en 30 minutos.
    </p>

    {sent && (
      <div class="ok-banner">
        <svg width="11" height="11" viewBox="0 0 11 11" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="2 5.8 4.5 8.2 9 3.4"/>
        </svg>
        Si el correo está registrado, te enviamos las instrucciones para restablecer tu contraseña.
      </div>
    )}
    {errorMessage && (
      <div class="err-banner">
        <svg width="11" height="11" viewBox="0 0 11 11" fill="none" stroke="currentColor" stroke-width="1.3">
          <circle cx="5.5" cy="5.5" r="4.5"/>
          <path d="M5.5 3v3M5.5 7.8v.2"/>
        </svg>
        {errorMessage}
      </div>
    )}

    <div class="field">
      <div class="label-row"><span class="field-label">Código de empresa</span></div>
      <div class="input-wrap">
        <input
          id="tenant"
          name="tenant"
          type="text"
          required
          autocomplete="organization"
          placeholder="demo"
          class="field-input"
        />
      </div>
    </div>

    <div class="field" style="margin-bottom:28px">
      <div class="label-row"><span class="field-label">Correo electrónico</span></div>
      <div class="input-wrap">
        <input
          id="email"
          name="email"
          type="email"
          required
          autocomplete="email"
          placeholder="usuario@empresa.com"
          class="field-input"
        />
      </div>
      <p class="field-help">Te enviaremos el enlace de recuperación a esta dirección.</p>
    </div>

    <button type="submit" class="submit-btn">
      Enviar enlace
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="square">
        <path d="M2 7h10M8.5 3.5L12 7l-3.5 3.5"/>
      </svg>
    </button>

    <p class="auth-aside">
      <a href="/login" class="auth-link">← Volver a iniciar sesión</a>
    </p>
  </form>
</AuthLayout>

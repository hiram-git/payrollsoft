---
import AppLayout from '../../layouts/AppLayout.astro'
import { can, getIdentity } from '../../lib/auth'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'

const identity = getIdentity(Astro.cookies)
if (!identity) return Astro.redirect('/login')
if (!can(identity, 'attendance:sync')) return Astro.redirect('/dashboard')

const tenantSlug = identity.tenantSlug ?? 'demo'
const headers = { Cookie: `auth=${identity.raw}`, 'X-Tenant': tenantSlug }

type Device = {
  id: string
  code: string
  name: string
  deviceType: string
  connectionMethod: string
  status: string
  location: string | null
}

type SyncState = {
  id: string
  deviceId: string
  status: string
  intervalMinutes: number
  highWaterMark: number
  lastRunAt: string | null
  lastSuccessAt: string | null
  lastError: string | null
  punchesSynced: number
  daysConsolidated: number
  autoStart: boolean
  workerInMemory?: boolean
}

type SyncLogEntry = {
  id: string
  deviceId: string
  startedAt: string
  finishedAt: string | null
  status: string
  punchesFound: number
  punchesConsolidated: number
  daysAffected: number
  highWaterBefore: number | null
  highWaterAfter: number | null
  errorMessage: string | null
}

let devices: Device[] = []
let syncStates: SyncState[] = []
let error = ''

try {
  const [devRes, syncRes] = await Promise.all([
    fetch(`${API_URL}/attendance/devices`, { headers }),
    fetch(`${API_URL}/attendance/sync/status`, { headers }),
  ])
  if (devRes.status === 401) return Astro.redirect('/login')
  if (devRes.ok) devices = ((await devRes.json()) as { data: Device[] }).data ?? []
  if (syncRes.ok) syncStates = ((await syncRes.json()) as { data: SyncState[] }).data ?? []
} catch {
  error = 'No se pudo conectar con el servidor.'
}

const stateByDevice = new Map(syncStates.map((s) => [s.deviceId, s]))

function fmtDate(s: string | null): string {
  if (!s) return '—'
  return new Date(s).toLocaleString('es-PA')
}
---
<AppLayout title="Sincronización de marcaciones">
  <div class="mx-auto w-full max-w-7xl p-8 lg:w-3/4">
    <div class="mb-6">
      <h1 class="text-xl font-semibold tracking-tight sync-title">Sincronización de marcaciones</h1>
      <p class="text-sm mt-0.5 sync-subtitle">
        Controla la consolidación automática de marcaciones por dispositivo.
      </p>
    </div>

    {error && (
      <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
    )}

    <div id="flash-msg" class="mb-4 rounded-md px-4 py-3 text-sm hidden"></div>

    {devices.length === 0 ? (
      <section class="sync-card border rounded-lg px-8 py-16 text-center">
        <p class="text-sm sync-subtitle">No hay dispositivos registrados.</p>
        <a href="/attendance/devices" class="text-sm text-blue-500 hover:underline mt-1 inline-block">
          Ir a Dispositivos
        </a>
      </section>
    ) : (
      <section class="space-y-4">
        {devices.map((d) => {
          const s = stateByDevice.get(d.id)
          const isRunning = s?.status === 'running'
          return (
            <div class="sync-card border rounded-lg overflow-hidden" data-device-id={d.id}>
              <div class="px-5 py-4 flex items-center justify-between gap-4 flex-wrap">
                <div class="flex items-center gap-3 min-w-0">
                  <span class={`sync-indicator ${isRunning ? 'sync-indicator-on' : 'sync-indicator-off'}`}></span>
                  <div class="min-w-0">
                    <div class="font-medium sync-title text-sm truncate">
                      {d.name}
                      <span class="ml-2 font-mono text-xs sync-mute">{d.code}</span>
                    </div>
                    <div class="text-xs sync-subtitle mt-0.5">
                      {d.location ?? d.connectionMethod}
                      {s && (
                        <span class="ml-2">
                          — cada {s.intervalMinutes} min
                          {s.autoStart && <span class="ml-1 sync-badge-auto">auto</span>}
                        </span>
                      )}
                    </div>
                  </div>
                </div>
                <div class="flex items-center gap-2 flex-shrink-0">
                  {isRunning ? (
                    <button
                      type="button"
                      class="sync-btn sync-btn-stop px-3 py-1.5 rounded-md text-xs font-medium"
                      data-action="stop"
                      data-device-id={d.id}
                    >
                      Detener
                    </button>
                  ) : (
                    <button
                      type="button"
                      class="sync-btn sync-btn-start px-3 py-1.5 rounded-md text-xs font-medium"
                      data-action="start"
                      data-device-id={d.id}
                    >
                      Iniciar
                    </button>
                  )}
                  <button
                    type="button"
                    class="sync-btn sync-btn-trigger px-3 py-1.5 rounded-md text-xs font-medium"
                    data-action="trigger"
                    data-device-id={d.id}
                  >
                    Sincronizar ahora
                  </button>
                  <button
                    type="button"
                    class="sync-btn-config px-2 py-1.5 rounded-md text-xs"
                    data-toggle-config={d.id}
                    title="Configuración"
                  >
                    &#9881;
                  </button>
                </div>
              </div>

              {/* Stats row */}
              {s && (
                <div class="px-5 pb-3 flex flex-wrap gap-x-6 gap-y-1 text-xs">
                  <div>
                    <span class="sync-label">Última sync:</span>
                    <span class="sync-mute ml-1">{fmtDate(s.lastRunAt)}</span>
                  </div>
                  <div>
                    <span class="sync-label">Último éxito:</span>
                    <span class="sync-mute ml-1">{fmtDate(s.lastSuccessAt)}</span>
                  </div>
                  <div>
                    <span class="sync-label">Punches sincronizados:</span>
                    <span class="sync-mute ml-1">{s.punchesSynced.toLocaleString()}</span>
                  </div>
                  <div>
                    <span class="sync-label">Días consolidados:</span>
                    <span class="sync-mute ml-1">{s.daysConsolidated.toLocaleString()}</span>
                  </div>
                  {s.lastError && (
                    <div class="basis-full">
                      <span class="sync-label text-red-400">Último error:</span>
                      <span class="text-red-400 ml-1">{s.lastError}</span>
                    </div>
                  )}
                </div>
              )}

              {/* Config panel (hidden by default) */}
              <div class="sync-config-panel hidden border-t px-5 py-4" id={`config-${d.id}`}>
                <div class="flex flex-wrap gap-4 items-end">
                  <div>
                    <label class="block text-xs font-medium sync-label mb-1">Intervalo (minutos)</label>
                    <input
                      type="number"
                      min="1"
                      max="1440"
                      value={s?.intervalMinutes ?? 15}
                      class="w-24 px-2 py-1.5 text-sm border rounded-md sync-input"
                      data-interval-input={d.id}
                    />
                  </div>
                  <div class="flex items-center gap-2">
                    <input
                      type="checkbox"
                      id={`auto-${d.id}`}
                      checked={s?.autoStart ?? false}
                      data-autostart-input={d.id}
                    />
                    <label for={`auto-${d.id}`} class="text-xs sync-label">Inicio automático con el servidor</label>
                  </div>
                  <button
                    type="button"
                    class="sync-btn sync-btn-start px-3 py-1.5 rounded-md text-xs font-medium"
                    data-action="restart"
                    data-device-id={d.id}
                  >
                    Aplicar y reiniciar
                  </button>
                </div>
              </div>

              {/* Log section */}
              <div class="border-t sync-rule">
                <button
                  type="button"
                  class="w-full px-5 py-2 text-xs sync-mute hover:underline text-left"
                  data-toggle-log={d.id}
                >
                  Ver historial de sincronizaciones &#9662;
                </button>
                <div class="hidden px-5 pb-4" id={`log-${d.id}`}>
                  <table class="sync-log-table w-full text-xs">
                    <thead>
                      <tr>
                        <th class="text-left py-1.5 px-2">Fecha</th>
                        <th class="text-left py-1.5 px-2">Estado</th>
                        <th class="text-right py-1.5 px-2">Punches</th>
                        <th class="text-right py-1.5 px-2">Días</th>
                        <th class="text-left py-1.5 px-2">Error</th>
                      </tr>
                    </thead>
                    <tbody id={`log-body-${d.id}`}>
                      <tr><td colspan="5" class="py-4 text-center sync-mute">Cargando...</td></tr>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          )
        })}
      </section>
    )}
  </div>

  <script is:inline>
    ;(function () {
      const flash = document.getElementById('flash-msg')

      function showFlash(msg, ok) {
        if (!flash) return
        flash.textContent = msg
        flash.className = 'mb-4 rounded-md px-4 py-3 text-sm ' +
          (ok ? 'bg-green-50 border border-green-200 text-green-700' : 'bg-red-50 border border-red-200 text-red-700')
      }

      async function syncAction(op, deviceId, body) {
        try {
          const res = await fetch('/api/attendance/sync?op=' + op + '&deviceId=' + deviceId, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body || {}),
          })
          const json = await res.json().catch(function () { return {} })
          if (json.ok) {
            const msgs = {
              start: 'Worker iniciado.',
              stop: 'Worker detenido.',
              restart: 'Worker reiniciado.',
              trigger: 'Sincronización ejecutada. Punches: ' + (json.data?.punchesFound ?? 0) + ', Días: ' + (json.data?.daysAffected ?? 0),
            }
            showFlash(msgs[op] || 'OK', true)
            setTimeout(function () { window.location.reload() }, 1200)
          } else {
            showFlash(json.error || 'Error HTTP ' + res.status, false)
          }
        } catch (err) {
          showFlash('Error de red: ' + err, false)
        }
      }

      document.querySelectorAll('[data-action]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var action = btn.getAttribute('data-action')
          var deviceId = btn.getAttribute('data-device-id')
          var body = {}
          if (action === 'start' || action === 'restart') {
            var intervalInput = document.querySelector('[data-interval-input="' + deviceId + '"]')
            var autoInput = document.querySelector('[data-autostart-input="' + deviceId + '"]')
            if (intervalInput) body.intervalMinutes = parseInt(intervalInput.value, 10) || 15
            if (autoInput) body.autoStart = autoInput.checked
          }
          syncAction(action, deviceId, body)
        })
      })

      document.querySelectorAll('[data-toggle-config]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var id = btn.getAttribute('data-toggle-config')
          var panel = document.getElementById('config-' + id)
          if (panel) panel.classList.toggle('hidden')
        })
      })

      document.querySelectorAll('[data-toggle-log]').forEach(function (btn) {
        btn.addEventListener('click', async function () {
          var deviceId = btn.getAttribute('data-toggle-log')
          var container = document.getElementById('log-' + deviceId)
          if (!container) return

          if (!container.classList.contains('hidden')) {
            container.classList.add('hidden')
            return
          }
          container.classList.remove('hidden')

          var tbody = document.getElementById('log-body-' + deviceId)
          if (!tbody) return

          try {
            var res = await fetch('/api/attendance/sync/' + deviceId + '?view=log&limit=20')
            var json = await res.json().catch(function () { return {} })
            var logs = (json.data || [])
            if (logs.length === 0) {
              tbody.innerHTML = '<tr><td colspan="5" class="py-4 text-center sync-mute">Sin registros.</td></tr>'
              return
            }
            tbody.innerHTML = logs.map(function (l) {
              var statusCls = l.status === 'success' ? 'sync-log-ok' :
                l.status === 'partial' ? 'sync-log-partial' : 'sync-log-err'
              var dt = l.startedAt ? new Date(l.startedAt).toLocaleString('es-PA') : '—'
              return '<tr class="border-t sync-rule">' +
                '<td class="py-1.5 px-2 sync-mute whitespace-nowrap">' + dt + '</td>' +
                '<td class="py-1.5 px-2"><span class="sync-log-badge ' + statusCls + '">' + l.status + '</span></td>' +
                '<td class="py-1.5 px-2 text-right">' + l.punchesFound + '</td>' +
                '<td class="py-1.5 px-2 text-right">' + l.daysAffected + '</td>' +
                '<td class="py-1.5 px-2 sync-mute truncate max-w-[200px]">' + (l.errorMessage || '—') + '</td>' +
                '</tr>'
            }).join('')
          } catch (err) {
            tbody.innerHTML = '<tr><td colspan="5" class="py-4 text-center text-red-400">Error al cargar.</td></tr>'
          }
        })
      })
    })()
  </script>

  <style>
    .sync-title    { color: var(--fore); }
    .sync-subtitle { color: var(--fore-dim); }
    .sync-label    { color: var(--fore-dim); font-weight: 500; }
    .sync-mute     { color: var(--mute); }
    .sync-card     { background: var(--ink-2); border-color: var(--rule); }
    .sync-rule     { border-color: var(--rule); }
    .sync-config-panel { background: var(--ink-3); border-color: var(--rule); }
    .sync-input {
      background: var(--ink-1); border-color: var(--rule); color: var(--fore);
    }
    .sync-indicator {
      width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0;
    }
    .sync-indicator-on  { background: #34d399; box-shadow: 0 0 6px rgba(52,211,153,0.5); }
    .sync-indicator-off { background: var(--mute); }
    .sync-btn {
      transition: background 0.15s;
    }
    .sync-btn-start {
      background: rgba(16,185,129,0.18); color: #34d399;
    }
    .sync-btn-start:hover { background: rgba(16,185,129,0.3); }
    .sync-btn-stop {
      background: rgba(239,68,68,0.18); color: #f87171;
    }
    .sync-btn-stop:hover { background: rgba(239,68,68,0.3); }
    .sync-btn-trigger {
      background: rgba(96,165,250,0.18); color: #60a5fa;
    }
    .sync-btn-trigger:hover { background: rgba(96,165,250,0.3); }
    .sync-btn-config {
      color: var(--mute); background: transparent;
    }
    .sync-btn-config:hover { color: var(--fore); background: var(--ink-3); }
    .sync-badge-auto {
      display: inline-block; padding: 0 0.375rem; border-radius: 9999px;
      font-size: 0.625rem; font-weight: 600; text-transform: uppercase;
      background: rgba(96,165,250,0.18); color: #60a5fa;
    }
    .sync-log-table thead tr { color: var(--mute-2); }
    .sync-log-badge {
      display: inline-block; padding: 0.0625rem 0.375rem; border-radius: 0.25rem;
      font-size: 0.625rem; font-weight: 600; text-transform: uppercase;
    }
    .sync-log-ok      { background: rgba(16,185,129,0.18); color: #34d399; }
    .sync-log-partial  { background: rgba(245,158,11,0.18); color: #fbbf24; }
    .sync-log-err      { background: rgba(239,68,68,0.18); color: #f87171; }
    [data-theme='light'] .sync-card { background: #ffffff; }
    [data-theme='light'] .sync-config-panel { background: #f9fafb; }
    [data-theme='light'] .sync-input { background: #ffffff; }
    [data-theme='light'] .sync-btn-start { background: #d1fae5; color: #065f46; }
    [data-theme='light'] .sync-btn-start:hover { background: #a7f3d0; }
    [data-theme='light'] .sync-btn-stop { background: #fee2e2; color: #991b1b; }
    [data-theme='light'] .sync-btn-stop:hover { background: #fecaca; }
    [data-theme='light'] .sync-btn-trigger { background: #dbeafe; color: #1d4ed8; }
    [data-theme='light'] .sync-btn-trigger:hover { background: #bfdbfe; }
    [data-theme='light'] .sync-badge-auto { background: #dbeafe; color: #1d4ed8; }
    [data-theme='light'] .sync-log-ok      { background: #d1fae5; color: #065f46; }
    [data-theme='light'] .sync-log-partial  { background: #fef3c7; color: #92400e; }
    [data-theme='light'] .sync-log-err      { background: #fee2e2; color: #991b1b; }
  </style>
</AppLayout>

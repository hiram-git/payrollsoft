---
import AppLayout from '../../../layouts/AppLayout.astro'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')

const { id } = Astro.params

type Shift = {
  id: string
  name: string
  entryTime: string
  lunchStartTime: string | null
  lunchEndTime: string | null
  exitTime: string
  entryToleranceBefore: number
  entryToleranceAfter: number
  lunchStartToleranceBefore: number
  lunchStartToleranceAfter: number
  lunchEndToleranceBefore: number
  lunchEndToleranceAfter: number
  exitToleranceBefore: number
  exitToleranceAfter: number
  isDefault: boolean
}

let shift: Shift | null = null

try {
  const res = await fetch(`${API_URL}/attendance/shifts/${id}`, {
    headers: { Cookie: `auth=${authCookie}`, 'X-Tenant': 'demo' },
  })
  if (res.status === 401) return Astro.redirect('/login')
  if (res.status === 404) return Astro.redirect('/attendance/shifts')
  if (res.ok) {
    const json = (await res.json()) as { success: boolean; data: Shift }
    shift = json.data
  }
} catch {
  return Astro.redirect('/attendance/shifts')
}

if (!shift) return Astro.redirect('/attendance/shifts')

const msgSuccess = Astro.url.searchParams.get('success') ?? ''
const msgError = Astro.url.searchParams.get('error') ?? ''
---

<AppLayout title={`Horario — ${shift.name}`}>
  <div class="px-6 py-8 max-w-3xl mx-auto">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-1.5 text-sm text-gray-500 mb-6">
      <a href="/attendance" class="hover:text-gray-700 transition-colors">Asistencia</a>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      <a href="/attendance/shifts" class="hover:text-gray-700 transition-colors">Horarios</a>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      <span class="text-gray-900 font-medium">{shift.name}</span>
    </nav>

    <h1 class="text-2xl font-bold text-gray-900 mb-6">Editar horario</h1>

    {msgSuccess === '1' && (
      <div class="mb-5 flex items-center gap-2 rounded-md bg-emerald-50 border border-emerald-200 px-4 py-3 text-sm text-emerald-800">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        Horario guardado correctamente.
      </div>
    )}
    {msgError && (
      <div class="mb-5 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
        {msgError === 'server-error' ? 'Error del servidor. Intente nuevamente.' : decodeURIComponent(msgError)}
      </div>
    )}

    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <form method="POST" action={`/api/attendance/shifts/${id}`}>
        <input type="hidden" name="_method" value="PUT" />

        <div class="space-y-6">

          <!-- Name -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="name">
              Nombre <span class="text-red-500">*</span>
            </label>
            <input
              id="name"
              type="text"
              name="name"
              required
              value={shift.name}
              class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
            />
          </div>

          <!-- Entrada -->
          <div class="border border-gray-100 rounded-lg p-4 bg-gray-50">
            <p class="text-xs font-semibold text-gray-600 uppercase tracking-wide mb-3">Entrada</p>
            <div class="grid grid-cols-3 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="entryTime">
                  Hora <span class="text-red-500">*</span>
                </label>
                <input
                  id="entryTime"
                  type="time"
                  name="entryTime"
                  required
                  value={shift.entryTime}
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="entryToleranceBefore">Anticipado (min)</label>
                <input
                  id="entryToleranceBefore"
                  type="number"
                  name="entryToleranceBefore"
                  min="0"
                  value={shift.entryToleranceBefore}
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="entryToleranceAfter">Tardanza (min)</label>
                <input
                  id="entryToleranceAfter"
                  type="number"
                  name="entryToleranceAfter"
                  min="0"
                  value={shift.entryToleranceAfter}
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
            </div>
          </div>

          <!-- Salida almuerzo -->
          <div class="border border-gray-100 rounded-lg p-4 bg-gray-50">
            <p class="text-xs font-semibold text-gray-600 uppercase tracking-wide mb-3">Salida almuerzo</p>
            <div class="grid grid-cols-3 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="lunchStartTime">Hora</label>
                <input
                  id="lunchStartTime"
                  type="time"
                  name="lunchStartTime"
                  value={shift.lunchStartTime ?? ''}
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="lunchStartToleranceBefore">Anticipado (min)</label>
                <input
                  id="lunchStartToleranceBefore"
                  type="number"
                  name="lunchStartToleranceBefore"
                  min="0"
                  value={shift.lunchStartToleranceBefore}
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="lunchStartToleranceAfter">Tardanza (min)</label>
                <input
                  id="lunchStartToleranceAfter"
                  type="number"
                  name="lunchStartToleranceAfter"
                  min="0"
                  value={shift.lunchStartToleranceAfter}
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
            </div>
          </div>

          <!-- Entrada almuerzo -->
          <div class="border border-gray-100 rounded-lg p-4 bg-gray-50">
            <p class="text-xs font-semibold text-gray-600 uppercase tracking-wide mb-3">Entrada almuerzo</p>
            <div class="grid grid-cols-3 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="lunchEndTime">Hora</label>
                <input
                  id="lunchEndTime"
                  type="time"
                  name="lunchEndTime"
                  value={shift.lunchEndTime ?? ''}
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="lunchEndToleranceBefore">Anticipado (min)</label>
                <input
                  id="lunchEndToleranceBefore"
                  type="number"
                  name="lunchEndToleranceBefore"
                  min="0"
                  value={shift.lunchEndToleranceBefore}
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="lunchEndToleranceAfter">Tardanza (min)</label>
                <input
                  id="lunchEndToleranceAfter"
                  type="number"
                  name="lunchEndToleranceAfter"
                  min="0"
                  value={shift.lunchEndToleranceAfter}
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
            </div>
          </div>

          <!-- Salida -->
          <div class="border border-gray-100 rounded-lg p-4 bg-gray-50">
            <p class="text-xs font-semibold text-gray-600 uppercase tracking-wide mb-3">Salida</p>
            <div class="grid grid-cols-3 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="exitTime">
                  Hora <span class="text-red-500">*</span>
                </label>
                <input
                  id="exitTime"
                  type="time"
                  name="exitTime"
                  required
                  value={shift.exitTime}
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="exitToleranceBefore">Anticipado (min)</label>
                <input
                  id="exitToleranceBefore"
                  type="number"
                  name="exitToleranceBefore"
                  min="0"
                  value={shift.exitToleranceBefore}
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="exitToleranceAfter">Tardanza (min)</label>
                <input
                  id="exitToleranceAfter"
                  type="number"
                  name="exitToleranceAfter"
                  min="0"
                  value={shift.exitToleranceAfter}
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
            </div>
          </div>

          <!-- Default -->
          <div class="flex items-center gap-2.5">
            <input
              id="isDefault"
              type="checkbox"
              name="isDefault"
              checked={shift.isDefault}
              class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500"
            />
            <label class="text-sm font-medium text-gray-700" for="isDefault">Predeterminado</label>
            <span class="text-xs text-gray-400">(se asigna automáticamente a nuevos empleados)</span>
          </div>

        </div>

        <!-- Actions -->
        <div class="mt-6 flex items-center justify-between">
          <form id={`del-${id}`} method="POST" action={`/api/attendance/shifts/${id}`}>
            <input type="hidden" name="_method" value="DELETE" />
            <button
              type="button"
              data-confirm
              data-form={`del-${id}`}
              data-title="Eliminar horario"
              data-body={`¿Eliminar el horario "${shift.name}"? Esta acción no se puede deshacer.`}
              data-confirm-label="Eliminar"
              data-confirm-style="danger"
              class="px-4 py-2 text-sm font-medium text-red-600 border border-red-200 rounded-lg hover:bg-red-50 transition-colors"
            >
              Eliminar
            </button>
          </form>

          <div class="flex items-center gap-3">
            <a
              href="/attendance/shifts"
              class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors"
            >
              Cancelar
            </a>
            <button
              type="submit"
              class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors"
            >
              Guardar cambios
            </button>
          </div>
        </div>
      </form>
    </div>
  </div>

  <!-- Confirmation modal -->
  <div id="confirm-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4" role="dialog" aria-modal="true">
    <div id="modal-backdrop" class="absolute inset-0 bg-black/40 backdrop-blur-sm"></div>
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-md p-6">
      <div id="modal-icon" class="w-10 h-10 rounded-full flex items-center justify-center mb-4"></div>
      <h3 id="modal-title" class="text-base font-semibold text-gray-900 mb-1.5"></h3>
      <p id="modal-body" class="text-sm text-gray-500 leading-relaxed mb-6"></p>
      <div class="flex justify-end gap-2.5">
        <button id="modal-cancel" type="button" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Cancelar</button>
        <button id="modal-confirm" type="button" class="px-4 py-2 text-sm font-medium rounded-lg transition-colors">Confirmar</button>
      </div>
    </div>
  </div>
</AppLayout>

<script>
  const modal = document.getElementById('confirm-modal') as HTMLElement
  const modalBackdrop = document.getElementById('modal-backdrop') as HTMLElement
  const modalIcon = document.getElementById('modal-icon') as HTMLElement
  const modalTitle = document.getElementById('modal-title') as HTMLElement
  const modalBody = document.getElementById('modal-body') as HTMLElement
  const modalConfirm = document.getElementById('modal-confirm') as HTMLButtonElement
  const modalCancel = document.getElementById('modal-cancel') as HTMLButtonElement
  const dangerStyle = { btn: 'bg-red-600 hover:bg-red-700 text-white', icon: 'bg-red-100', svg: '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-red-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>' }
  let pendingFormId: string | null = null
  function openModal(btn: HTMLElement) {
    pendingFormId = btn.getAttribute('data-form')
    modalTitle.textContent = btn.getAttribute('data-title') ?? ''
    modalBody.textContent = btn.getAttribute('data-body') ?? ''
    modalConfirm.textContent = btn.getAttribute('data-confirm-label') ?? 'Confirmar'
    modalConfirm.className = `px-4 py-2 text-sm font-medium rounded-lg transition-colors ${dangerStyle.btn}`
    modalIcon.className = `w-10 h-10 rounded-full flex items-center justify-center mb-4 ${dangerStyle.icon}`
    modalIcon.innerHTML = dangerStyle.svg
    modal.classList.remove('hidden')
    modalConfirm.focus()
  }
  function closeModal() { modal.classList.add('hidden'); pendingFormId = null }
  document.querySelectorAll<HTMLElement>('[data-confirm]').forEach(btn => btn.addEventListener('click', () => openModal(btn)))
  modalCancel.addEventListener('click', closeModal)
  modalBackdrop.addEventListener('click', closeModal)
  modalConfirm.addEventListener('click', () => { if (pendingFormId) (document.getElementById(pendingFormId) as HTMLFormElement | null)?.submit(); closeModal() })
  document.addEventListener('keydown', e => { if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal() })
</script>

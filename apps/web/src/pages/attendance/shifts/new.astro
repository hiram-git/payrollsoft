---
import AppLayout from '../../../layouts/AppLayout.astro'

const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')

const msgError = Astro.url.searchParams.get('error') ?? ''
---

<AppLayout title="Nuevo horario">
  <div class="mx-auto w-full max-w-7xl p-8 lg:w-3/4">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-1.5 text-sm text-gray-500 mb-6">
      <a href="/attendance" class="hover:text-gray-700 transition-colors">Asistencia</a>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      <a href="/attendance/shifts" class="hover:text-gray-700 transition-colors">Horarios</a>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      <span class="text-gray-900 font-medium">Nuevo</span>
    </nav>

    <h1 class="text-2xl font-bold text-gray-900 mb-6">Nuevo horario</h1>

    {msgError && (
      <div class="mb-5 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
        {msgError === 'server-error' ? 'Error del servidor. Intente nuevamente.' : decodeURIComponent(msgError)}
      </div>
    )}

    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <form method="POST" action="/api/attendance/shifts">
        <div class="space-y-6">

          <!-- Name -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="name">
              Nombre <span class="text-red-500">*</span>
            </label>
            <input
              id="name"
              type="text"
              name="name"
              required
              placeholder="Ej. Turno regular"
              class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
            />
          </div>

          <!-- Entrada -->
          <div class="border border-gray-100 rounded-lg p-4 bg-gray-50">
            <p class="text-xs font-semibold text-gray-600 uppercase tracking-wide mb-3">Entrada</p>
            <div class="grid grid-cols-3 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="entryTime">
                  Hora <span class="text-red-500">*</span>
                </label>
                <input
                  id="entryTime"
                  type="time"
                  name="entryTime"
                  required
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="entryToleranceBefore">Anticipado (min)</label>
                <input
                  id="entryToleranceBefore"
                  type="number"
                  name="entryToleranceBefore"
                  min="0"
                  value="0"
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="entryToleranceAfter">Tardanza (min)</label>
                <input
                  id="entryToleranceAfter"
                  type="number"
                  name="entryToleranceAfter"
                  min="0"
                  value="0"
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
            </div>
          </div>

          <!-- Salida almuerzo -->
          <div class="border border-gray-100 rounded-lg p-4 bg-gray-50">
            <p class="text-xs font-semibold text-gray-600 uppercase tracking-wide mb-3">Salida almuerzo</p>
            <div class="grid grid-cols-3 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="lunchStartTime">Hora</label>
                <input
                  id="lunchStartTime"
                  type="time"
                  name="lunchStartTime"
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="lunchStartToleranceBefore">Anticipado (min)</label>
                <input
                  id="lunchStartToleranceBefore"
                  type="number"
                  name="lunchStartToleranceBefore"
                  min="0"
                  value="0"
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="lunchStartToleranceAfter">Tardanza (min)</label>
                <input
                  id="lunchStartToleranceAfter"
                  type="number"
                  name="lunchStartToleranceAfter"
                  min="0"
                  value="0"
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
            </div>
          </div>

          <!-- Entrada almuerzo -->
          <div class="border border-gray-100 rounded-lg p-4 bg-gray-50">
            <p class="text-xs font-semibold text-gray-600 uppercase tracking-wide mb-3">Entrada almuerzo</p>
            <div class="grid grid-cols-3 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="lunchEndTime">Hora</label>
                <input
                  id="lunchEndTime"
                  type="time"
                  name="lunchEndTime"
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="lunchEndToleranceBefore">Anticipado (min)</label>
                <input
                  id="lunchEndToleranceBefore"
                  type="number"
                  name="lunchEndToleranceBefore"
                  min="0"
                  value="0"
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="lunchEndToleranceAfter">Tardanza (min)</label>
                <input
                  id="lunchEndToleranceAfter"
                  type="number"
                  name="lunchEndToleranceAfter"
                  min="0"
                  value="0"
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
            </div>
          </div>

          <!-- Salida -->
          <div class="border border-gray-100 rounded-lg p-4 bg-gray-50">
            <p class="text-xs font-semibold text-gray-600 uppercase tracking-wide mb-3">Salida</p>
            <div class="grid grid-cols-3 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="exitTime">
                  Hora <span class="text-red-500">*</span>
                </label>
                <input
                  id="exitTime"
                  type="time"
                  name="exitTime"
                  required
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="exitToleranceBefore">Anticipado (min)</label>
                <input
                  id="exitToleranceBefore"
                  type="number"
                  name="exitToleranceBefore"
                  min="0"
                  value="0"
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="exitToleranceAfter">Tardanza (min)</label>
                <input
                  id="exitToleranceAfter"
                  type="number"
                  name="exitToleranceAfter"
                  min="0"
                  value="0"
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
            </div>
          </div>

          <!-- Días de la semana -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">
              Días de la semana <span class="text-red-500">*</span>
            </label>
            <p class="text-xs text-gray-500 mb-3">Seleccioná al menos un día. El calendario empresarial usa este valor para asignar este turno automáticamente.</p>
            <div class="flex flex-wrap gap-2">
              {[
                { v: 1, label: 'Lun' },
                { v: 2, label: 'Mar' },
                { v: 3, label: 'Mié' },
                { v: 4, label: 'Jue' },
                { v: 5, label: 'Vie' },
                { v: 6, label: 'Sáb' },
                { v: 7, label: 'Dom' },
              ].map((d) => (
                <label class="weekday-chip">
                  <input
                    type="checkbox"
                    name="weekdays"
                    value={d.v}
                    checked={d.v <= 5}
                    class="weekday-chip-input"
                  />
                  <span class="weekday-chip-label">{d.label}</span>
                </label>
              ))}
            </div>
          </div>

          <!-- Default -->
          <div class="flex items-center gap-2.5">
            <input
              id="isDefault"
              type="checkbox"
              name="isDefault"
              class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500"
            />
            <label class="text-sm font-medium text-gray-700" for="isDefault">Predeterminado</label>
            <span class="text-xs text-gray-400">(se asigna automáticamente a nuevos empleados)</span>
          </div>

        </div>

        <!-- Actions -->
        <div class="mt-6 flex items-center justify-end gap-3">
          <a
            href="/attendance/shifts"
            class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors"
          >
            Cancelar
          </a>
          <button
            type="submit"
            class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors"
          >
            Guardar horario
          </button>
        </div>
      </form>
    </div>
  </div>

  <style>
    .weekday-chip {
      display: inline-flex;
      align-items: center;
      cursor: pointer;
      user-select: none;
    }
    .weekday-chip-input {
      position: absolute;
      width: 1px;
      height: 1px;
      opacity: 0;
      pointer-events: none;
    }
    .weekday-chip-label {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 56px;
      padding: 6px 12px;
      border: 1px solid var(--rule, #d1d5db);
      border-radius: 999px;
      background: var(--ink-3, #fff);
      color: var(--mute-2, #6b7280);
      font-size: 13px;
      font-weight: 500;
      transition: background 140ms ease, color 140ms ease, border-color 140ms ease;
    }
    .weekday-chip:hover .weekday-chip-label {
      border-color: var(--rule-hi, #9ca3af);
      color: var(--fore-dim, #374151);
    }
    .weekday-chip-input:checked + .weekday-chip-label {
      background: var(--navy, #2563eb);
      border-color: var(--navy, #2563eb);
      color: #fff;
    }
    .weekday-chip-input:focus-visible + .weekday-chip-label {
      outline: none;
      box-shadow: 0 0 0 2px var(--navy-soft, rgba(37, 99, 235, 0.25));
    }
  </style>
</AppLayout>

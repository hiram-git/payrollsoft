---
/**
 * Registro unificado de dispositivos de marcación.
 *
 * Lista todos los dispositivos (relojes biométricos, tablets faciales,
 * lectores NFC, etc.) con su tipo, método de conexión, ubicación,
 * IP y estado. Permite crear nuevos dispositivos y editar los
 * existentes inline.
 */
import AppLayout from '../../layouts/AppLayout.astro'
import { can, getIdentity } from '../../lib/auth'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'

const identity = getIdentity(Astro.cookies)
if (!identity) return Astro.redirect('/login')
if (!can(identity, 'terminals:read')) return Astro.redirect('/dashboard')

const tenantSlug = identity.tenantSlug ?? 'demo'
const headers = { Cookie: `auth=${identity.raw}`, 'X-Tenant': tenantSlug }
const canWrite = can(identity, 'terminals:write')

type Device = {
  id: string
  code: string
  name: string
  deviceType: string
  connectionMethod: string
  location: string | null
  ipAddress: string | null
  latitude: string | null
  longitude: string | null
  serialNumber: string | null
  manufacturer: string | null
  model: string | null
  status: 'active' | 'inactive' | 'maintenance'
  lastSeenAt: string | null
  isActive: number
}

let devices: Device[] = []
let error = ''
const newDeviceToken: string | null = null

try {
  const res = await fetch(`${API_URL}/attendance/devices`, { headers })
  if (res.status === 401) return Astro.redirect('/login')
  if (res.ok) devices = ((await res.json()) as { data: Device[] }).data ?? []
  else error = `No se pudo cargar los dispositivos (HTTP ${res.status}).`
} catch {
  error = 'No se pudo conectar con el servidor.'
}

const flash = Astro.url.searchParams.get('flash') ?? ''
const flashMsg = Astro.url.searchParams.get('msg') ?? ''
const tokenFromUrl = Astro.url.searchParams.get('token') ?? null

const TYPE_LABELS: Record<string, string> = {
  biometric_clock: 'Reloj biométrico',
  facial_kiosk: 'Kiosk facial',
  tablet: 'Tablet',
  nfc_reader: 'Lector NFC',
  turnstile: 'Torniquete',
  other: 'Otro',
}
const CONN_LABELS: Record<string, string> = {
  txt_import: 'Importar TXT',
  api: 'API',
  webhook: 'Webhook',
  manual: 'Manual',
}
const STATUS_LABELS: Record<string, string> = {
  active: 'Activo',
  inactive: 'Inactivo',
  maintenance: 'En mantenimiento',
}

function fmtDate(s: string | null): string {
  if (!s) return 'Nunca'
  return new Date(s).toLocaleString('es-PA')
}
---
<AppLayout title="Dispositivos de marcación">
  <div class="mx-auto w-full max-w-7xl p-8 lg:w-3/4">
    <div class="mb-6 flex items-end justify-between gap-2">
      <div>
        <h1 class="text-xl font-semibold tracking-tight dev-title">Dispositivos de marcación</h1>
        <p class="text-sm mt-0.5 dev-subtitle">
          {devices.length} {devices.length === 1 ? 'dispositivo' : 'dispositivos'} — relojes biométricos, tablets, kiosks faciales, lectores NFC.
        </p>
      </div>
      {canWrite && (
        <button type="button" id="btn-new-device" class="dev-btn-primary px-3.5 py-2 rounded-md text-sm font-medium">
          + Nuevo dispositivo
        </button>
      )}
    </div>

    {flash === 'created' && (
      <div class="mb-4 rounded-md bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">
        Dispositivo creado.
        {tokenFromUrl && (
          <div class="mt-2 p-2 bg-green-100 border border-green-300 rounded font-mono text-xs break-all">
            <strong>Token API (una sola vez):</strong> {tokenFromUrl}
          </div>
        )}
      </div>
    )}
    {flash === 'updated' && (
      <div class="mb-4 rounded-md bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">Cambios guardados.</div>
    )}
    {flash === 'error' && (
      <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{flashMsg || 'Error.'}</div>
    )}
    {error && (
      <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
    )}

    {/* Modal de nuevo dispositivo */}
    {canWrite && (
      <div id="new-device-modal" class="fixed inset-0 bg-black/40 z-50 hidden items-center justify-center p-4">
        <div class="bg-white rounded-xl shadow-xl w-full max-w-2xl border border-gray-200 max-h-[90vh] overflow-y-auto">
          <div class="px-5 py-3 border-b border-gray-200 flex items-center justify-between sticky top-0 bg-white z-10">
            <h3 class="font-semibold text-gray-900">Nuevo dispositivo</h3>
            <button type="button" id="modal-close" class="text-gray-400 hover:text-gray-700 text-xl leading-none">×</button>
          </div>
          <form id="new-device-form" class="p-5 space-y-3">
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1.5">Código *</label>
                <input type="text" name="code" required maxlength="60" placeholder="ej. REL-01" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md font-mono" />
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1.5">Nombre *</label>
                <input type="text" name="name" required maxlength="160" placeholder="ej. Reloj Estacionamiento" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md" />
              </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1.5">Tipo *</label>
                <select name="deviceType" required class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md">
                  {Object.entries(TYPE_LABELS).map(([v, l]) => <option value={v}>{l}</option>)}
                </select>
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1.5">Conexión *</label>
                <select name="connectionMethod" required class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md">
                  {Object.entries(CONN_LABELS).map(([v, l]) => <option value={v}>{l}</option>)}
                </select>
              </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1.5">Ubicación</label>
                <input type="text" name="location" maxlength="200" placeholder="ej. Lobby planta baja" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md" />
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1.5">Dirección IP</label>
                <input type="text" name="ipAddress" maxlength="45" placeholder="ej. 192.168.1.100" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md font-mono" />
              </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1.5">Latitud</label>
                <input type="text" name="latitude" maxlength="20" placeholder="ej. 8.9936" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md font-mono" />
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1.5">Longitud</label>
                <input type="text" name="longitude" maxlength="20" placeholder="ej. -79.5197" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md font-mono" />
              </div>
            </div>
            <div class="grid grid-cols-3 gap-3">
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1.5">Fabricante</label>
                <input type="text" name="manufacturer" maxlength="100" placeholder="ej. ZKTeco" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md" />
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1.5">Modelo</label>
                <input type="text" name="model" maxlength="100" placeholder="ej. iClock 560" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md" />
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1.5">N° de serie</label>
                <input type="text" name="serialNumber" maxlength="100" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md font-mono" />
              </div>
            </div>
            <div id="form-error" class="hidden text-xs text-red-700 bg-red-50 border border-red-200 rounded-md px-3 py-2"></div>
            <div class="flex justify-end gap-2 pt-2">
              <button type="button" id="modal-cancel" class="px-3 py-2 text-sm text-gray-600">Cancelar</button>
              <button type="submit" class="px-4 py-2 bg-blue-600 text-white text-sm rounded-md hover:bg-blue-700 font-medium">Crear dispositivo</button>
            </div>
          </form>
        </div>
      </div>
    )}

    <section class="dev-card border rounded-lg overflow-hidden">
      {devices.length === 0 ? (
        <div class="py-16 text-center">
          <p class="text-sm dev-subtitle">Sin dispositivos registrados. Agrega el primero arriba.</p>
        </div>
      ) : (
        <table class="dev-table w-full text-sm">
          <thead>
            <tr>
              <th class="text-left px-5 py-3 text-xs font-medium uppercase tracking-wide">Código</th>
              <th class="text-left px-5 py-3 text-xs font-medium uppercase tracking-wide">Nombre</th>
              <th class="text-left px-5 py-3 text-xs font-medium uppercase tracking-wide">Tipo</th>
              <th class="text-left px-5 py-3 text-xs font-medium uppercase tracking-wide">Conexión</th>
              <th class="text-left px-5 py-3 text-xs font-medium uppercase tracking-wide">Ubicación / IP</th>
              <th class="text-left px-5 py-3 text-xs font-medium uppercase tracking-wide">Estado</th>
              <th class="text-left px-5 py-3 text-xs font-medium uppercase tracking-wide">Último contacto</th>
            </tr>
          </thead>
          <tbody>
            {devices.map((d) => {
              const statusCls = d.status === 'active' ? 'dev-status-active' :
                d.status === 'maintenance' ? 'dev-status-maint' : 'dev-status-inactive'
              return (
                <tr class="border-b last:border-0 dev-rule">
                  <td class="px-5 py-3 font-mono text-xs dev-cell">{d.code}</td>
                  <td class="px-5 py-3 dev-cell">
                    {d.name}
                    {d.manufacturer && <span class="ml-1.5 text-[10px] dev-mute">{d.manufacturer}{d.model ? ` ${d.model}` : ''}</span>}
                  </td>
                  <td class="px-5 py-3 text-xs">
                    <span class="dev-type-badge">{TYPE_LABELS[d.deviceType] ?? d.deviceType}</span>
                  </td>
                  <td class="px-5 py-3 text-xs dev-cell">{CONN_LABELS[d.connectionMethod] ?? d.connectionMethod}</td>
                  <td class="px-5 py-3 text-xs">
                    {d.location && <div class="dev-cell">{d.location}</div>}
                    {d.ipAddress && <div class="font-mono dev-mute">{d.ipAddress}</div>}
                    {d.latitude && d.longitude && (
                      <div class="font-mono dev-mute text-[10px]">{d.latitude}, {d.longitude}</div>
                    )}
                    {!d.location && !d.ipAddress && <span class="dev-mute">—</span>}
                  </td>
                  <td class="px-5 py-3">
                    <span class={`dev-status-badge ${statusCls}`}>{STATUS_LABELS[d.status] ?? d.status}</span>
                  </td>
                  <td class="px-5 py-3 text-xs dev-mute whitespace-nowrap">{fmtDate(d.lastSeenAt)}</td>
                </tr>
              )
            })}
          </tbody>
        </table>
      )}
    </section>
  </div>

  <script is:inline>
    ;(function () {
      const modal = document.getElementById('new-device-modal')
      if (!modal) return
      const open = document.getElementById('btn-new-device')
      const close = document.getElementById('modal-close')
      const cancel = document.getElementById('modal-cancel')
      const form = document.getElementById('new-device-form')
      const errBox = document.getElementById('form-error')

      const show = () => { modal.classList.remove('hidden'); modal.classList.add('flex') }
      const hide = () => { modal.classList.add('hidden'); modal.classList.remove('flex') }
      open?.addEventListener('click', show)
      close?.addEventListener('click', hide)
      cancel?.addEventListener('click', hide)
      modal.addEventListener('click', (e) => { if (e.target === modal) hide() })

      form?.addEventListener('submit', async (e) => {
        e.preventDefault()
        errBox.classList.add('hidden')
        const fd = new FormData(form)
        const payload = {}
        for (const [k, v] of fd.entries()) {
          if (typeof v === 'string' && v.trim() !== '') payload[k] = v.trim()
        }
        try {
          const res = await fetch('/api/attendance/devices?op=create', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-SA-Modal': '1' },
            body: JSON.stringify(payload),
          })
          const json = await res.json().catch(() => ({}))
          if (!json.ok) {
            errBox.textContent = json.error || 'HTTP ' + res.status
            errBox.classList.remove('hidden')
            return
          }
          // Si hay token API, lo mostramos en la URL de redirect
          const tokenParam = json.data?.apiToken ? '&token=' + encodeURIComponent(json.data.apiToken) : ''
          window.location.href = '/attendance/devices?flash=created' + tokenParam
        } catch (err) {
          errBox.textContent = 'Error de red: ' + String(err)
          errBox.classList.remove('hidden')
        }
      })
    })()
  </script>

  <style>
    .dev-title    { color: var(--fore); }
    .dev-subtitle { color: var(--fore-dim); }
    .dev-cell     { color: var(--fore-dim); }
    .dev-mute     { color: var(--mute); }
    .dev-card { background: var(--ink-2); border-color: var(--rule); }
    .dev-rule { border-color: var(--rule); }
    .dev-btn-primary { background: #2563eb; color: white; }
    .dev-btn-primary:hover { background: #1d4ed8; }
    .dev-table thead tr { background: var(--ink-3); border-color: var(--rule); color: var(--mute-2); }
    .dev-table tbody tr { background: var(--ink-2); border-color: var(--rule); }
    .dev-table tbody tr:hover { background: var(--ink-4); }
    .dev-type-badge {
      display: inline-block; padding: 0.125rem 0.5rem; border-radius: 0.25rem;
      font-size: 0.6875rem; font-weight: 500;
      background: rgba(96,165,250,0.18); color: #60a5fa;
    }
    .dev-status-badge {
      display: inline-block; padding: 0.125rem 0.5rem; border-radius: 9999px;
      font-size: 0.6875rem; font-weight: 500;
      text-transform: uppercase; letter-spacing: 0.04em;
    }
    .dev-status-active   { background: rgba(16,185,129,0.18); color: #34d399; }
    .dev-status-inactive { background: rgba(156,163,175,0.18); color: var(--mute); }
    .dev-status-maint    { background: rgba(245,158,11,0.18); color: #fbbf24; }
    [data-theme='light'] .dev-card { background: #ffffff; }
    [data-theme='light'] .dev-table thead tr { background: #f9fafb; }
    [data-theme='light'] .dev-table tbody tr { background: #ffffff; }
    [data-theme='light'] .dev-table tbody tr:hover { background: #f9fafb; }
    [data-theme='light'] .dev-type-badge { background: #dbeafe; color: #1d4ed8; }
    [data-theme='light'] .dev-status-active   { background: #d1fae5; color: #065f46; }
    [data-theme='light'] .dev-status-inactive { background: #f3f4f6; color: #6b7280; }
    [data-theme='light'] .dev-status-maint    { background: #fef3c7; color: #92400e; }
  </style>
</AppLayout>

---
import AppLayout from '../../layouts/AppLayout.astro'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')

type Creditor = {
  id: string
  code: string
  name: string
  description: string | null
  conceptCode: string | null
  isActive: boolean
  createdAt: string
}

let creditors: Creditor[] = []
let error = ''

try {
  const res = await fetch(`${API_URL}/creditors?all=true`, {
    headers: { Cookie: `auth=${authCookie}`, 'X-Tenant': 'demo' },
  })
  if (res.status === 401) return Astro.redirect('/login')
  if (res.ok) creditors = ((await res.json()) as { data: Creditor[] }).data ?? []
  else error = 'Error al cargar los acreedores'
} catch {
  error = 'No se pudo conectar con el servidor'
}

const success = Astro.url.searchParams.get('success') === '1'
---

<AppLayout title="Acreedores">
  <div class="px-6 py-8 max-w-5xl mx-auto">

    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-xl font-semibold text-gray-900 tracking-tight">Acreedores</h1>
        <p class="text-sm text-gray-500 mt-0.5">{creditors.length} {creditors.length === 1 ? 'acreedor' : 'acreedores'}</p>
      </div>
      <a
        href="/creditors/new"
        class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md bg-gray-900 text-white text-sm font-medium hover:bg-gray-700 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Nuevo acreedor
      </a>
    </div>

    {success && (
      <div class="mb-5 flex items-center gap-2 rounded-md bg-emerald-50 border border-emerald-200 px-4 py-3 text-sm text-emerald-800">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        Acreedor guardado correctamente.
      </div>
    )}
    {error && (
      <div class="mb-5 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
    )}

    <!-- Info box -->
    <div class="mb-6 rounded-lg bg-blue-50 border border-blue-100 px-4 py-3 text-sm text-blue-800">
      Al crear un acreedor se genera automáticamente un concepto de deducción con la fórmula
      <code class="font-mono font-semibold">CUOTA_ACREEDOR("CÓDIGO")</code>.
      Asigna ese concepto en los tipos de planilla correspondientes desde
      <a href="/config/conceptos" class="underline underline-offset-2">Configuración → Conceptos</a>.
    </div>

    <div class="border border-gray-200 rounded-lg overflow-hidden bg-white">
      {creditors.length === 0 ? (
        <div class="py-16 text-center">
          <p class="text-sm text-gray-400 mb-1">No hay acreedores registrados</p>
          <a href="/creditors/new" class="text-sm text-gray-900 underline underline-offset-2 hover:text-gray-600">
            Agregar el primero
          </a>
        </div>
      ) : (
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200 bg-gray-50">
              <th class="text-left px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Código</th>
              <th class="text-left px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Nombre</th>
              <th class="text-left px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Concepto asociado</th>
              <th class="text-left px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Estado</th>
              <th class="px-4 py-3"></th>
            </tr>
          </thead>
          <tbody>
            {creditors.map((c) => (
              <tr class="border-b border-gray-100 last:border-0 hover:bg-gray-50 transition-colors">
                <td class="px-4 py-3.5 font-mono text-xs text-gray-600 font-semibold">{c.code}</td>
                <td class="px-4 py-3.5 font-medium text-gray-900">{c.name}</td>
                <td class="px-4 py-3.5">
                  {c.conceptCode
                    ? <code class="text-xs font-mono bg-gray-100 px-1.5 py-0.5 rounded text-gray-700">{c.conceptCode}</code>
                    : <span class="text-xs text-gray-400 italic">Sin concepto</span>
                  }
                </td>
                <td class="px-4 py-3.5">
                  <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${
                    c.isActive ? 'bg-emerald-50 text-emerald-700' : 'bg-zinc-100 text-zinc-500'
                  }`}>
                    {c.isActive ? 'Activo' : 'Inactivo'}
                  </span>
                </td>
                <td class="px-4 py-3.5 text-right">
                  <a
                    href={`/creditors/${c.id}`}
                    class="p-1.5 inline-flex rounded text-gray-400 hover:text-gray-700 hover:bg-gray-100 transition-colors"
                    title="Editar"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
  </div>
</AppLayout>

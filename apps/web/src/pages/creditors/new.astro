---
import AppLayout from '../../layouts/AppLayout.astro'

const error = Astro.url.searchParams.get('error') ?? ''
---

<AppLayout title="Nuevo acreedor">
  <div class="px-6 py-8 max-w-2xl mx-auto">

    <div class="mb-6">
      <a href="/creditors" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 mb-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        Acreedores
      </a>
      <h1 class="text-xl font-semibold text-gray-900 tracking-tight">Nuevo acreedor</h1>
      <p class="text-sm text-gray-500 mt-0.5">Se creará automáticamente un concepto de deducción asociado.</p>
    </div>

    {error && (
      <div class="mb-5 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
        {error === 'duplicate-code' ? 'El código ya está en uso. Elige uno diferente.' : 'Ocurrió un error. Intenta nuevamente.'}
      </div>
    )}

    <form method="POST" action="/api/creditors" class="bg-white border border-gray-200 rounded-lg p-6 space-y-5">

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="code" class="block text-sm font-medium text-gray-700 mb-1">Código <span class="text-red-500">*</span></label>
          <input
            id="code" name="code" type="text" required maxlength="20"
            placeholder="BPNSA"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm font-mono uppercase focus:outline-none focus:ring-2 focus:ring-gray-400"
            oninput="this.value = this.value.toUpperCase()"
          />
          <p class="text-xs text-gray-400 mt-1">Hasta 20 caracteres. Será el nombre de la fórmula.</p>
        </div>
        <div>
          <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Nombre <span class="text-red-500">*</span></label>
          <input
            id="name" name="name" type="text" required maxlength="255"
            placeholder="Banco Panamá S.A."
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-400"
          />
        </div>
      </div>

      <div>
        <label for="description" class="block text-sm font-medium text-gray-700 mb-1">Descripción</label>
        <textarea
          id="description" name="description" rows="2"
          placeholder="Descripción opcional del acreedor..."
          class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-400 resize-none"
        ></textarea>
      </div>

      <!-- Preview -->
      <div class="rounded-md bg-gray-50 border border-gray-200 px-4 py-3 text-sm text-gray-600">
        Se creará el concepto <code id="previewCode" class="font-mono font-semibold text-gray-900">ACR_CÓDIGO</code>
        con fórmula <code id="previewFormula" class="font-mono font-semibold text-gray-900">CUOTA_ACREEDOR("CÓDIGO")</code>
      </div>

      <div class="flex gap-3 pt-1">
        <button
          type="submit"
          class="inline-flex items-center gap-1.5 px-4 py-2 rounded-md bg-gray-900 text-white text-sm font-medium hover:bg-gray-700 transition-colors"
        >
          Crear acreedor
        </button>
        <a
          href="/creditors"
          class="inline-flex items-center px-4 py-2 rounded-md border border-gray-300 text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors"
        >
          Cancelar
        </a>
      </div>
    </form>
  </div>
</AppLayout>

<script is:inline>
  const codeInput = document.getElementById('code')
  const previewCode = document.getElementById('previewCode')
  const previewFormula = document.getElementById('previewFormula')

  function updatePreview() {
    const code = codeInput.value.toUpperCase() || 'CÓDIGO'
    previewCode.textContent = `ACR_${code}`
    previewFormula.textContent = `CUOTA_ACREEDOR("${code}")`
  }

  codeInput.addEventListener('input', updatePreview)
</script>

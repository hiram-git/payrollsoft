---
/**
 * Detalle de una corrida de pago — punto central donde el contador
 * emite cheques, genera el ACH TXT, y descarga los archivos para
 * imprimir/enviar al banco.
 *
 * Si la corrida está asociada a una planilla, muestra preview de
 * pagables (employees con su payment_method) — el contador puede
 * generar el ACH con un click y emitir cheques uno por uno.
 */
import AppLayout from '../../layouts/AppLayout.astro'
import { can, getIdentity } from '../../lib/auth'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'

const identity = getIdentity(Astro.cookies)
if (!identity) return Astro.redirect('/login')
if (!can(identity, 'treasury:read')) return Astro.redirect('/dashboard')

const tenantSlug = identity.tenantSlug ?? 'demo'
const headers = { Cookie: `auth=${identity.raw}`, 'X-Tenant': tenantSlug }
const canWrite = can(identity, 'treasury:write')
const canVoid = can(identity, 'treasury:void')

const runId = Astro.params.id ?? ''

type Run = {
  id: string
  payrollId: string | null
  name: string
  status: 'draft' | 'open' | 'closed' | 'cancelled'
  totalAmount: string
  achTotal: string
  checkTotal: string
  cashTotal: string
  notes: string | null
  createdAt: string
}
type Check = {
  id: string
  checkNumber: number
  beneficiaryName: string
  beneficiaryType: string
  amount: string
  amountInWords: string
  concept: string | null
  status: 'issued' | 'printed' | 'cleared' | 'voided'
  issueDate: string
  voidReason: string | null
  checkbookId: string
}
type Payable = {
  beneficiaryType: string
  beneficiaryId: string
  beneficiaryName: string
  identification: string | null
  amount: number
  paymentMethod: 'ach' | 'check' | 'cash'
  bankRouting: string | null
  accountNumber: string | null
  accountType: string | null
}
type Checkbook = {
  id: string
  code: string
  name: string
  nextNumber: number
  endNumber: number
  isActive: number
  purpose: string
}
type Bank = {
  id: string
  code: string
  name: string
  achFormat: string | null
  achEntityCode: string | null
  isActive: number
}
type AchBatch = {
  id: string
  format: string
  fileName: string
  totalAmount: string
  recordCount: number
  generatedAt: string
}

// Buscar la corrida en el listado (no hay GET /:id todavía — ahorra round-trip)
let run: Run | null = null
let checks: Check[] = []
let payables: Payable[] = []
let creditorPayables: Payable[] = []
let checkbooks: Checkbook[] = []
let banks: Bank[] = []
let runBatches: AchBatch[] = []
let error = ''
const now = new Date()
let creditorMonth = now.getMonth() + 1
let creditorYear = now.getFullYear()

try {
  const runsRes = await fetch(`${API_URL}/treasury/runs`, { headers })
  if (runsRes.status === 401) return Astro.redirect('/login')
  if (runsRes.ok) {
    const runs = ((await runsRes.json()) as { data: Run[] }).data ?? []
    run = runs.find((r) => r.id === runId) ?? null
  }
  if (!run) return Astro.redirect('/treasury')

  const [cRes, cbRes, pRes, bRes, plRes] = await Promise.all([
    fetch(`${API_URL}/treasury/runs/${runId}/checks`, { headers }),
    fetch(`${API_URL}/treasury/checkbooks`, { headers }),
    run.payrollId
      ? fetch(`${API_URL}/treasury/payables?payrollId=${run.payrollId}`, { headers })
      : Promise.resolve(null),
    fetch(`${API_URL}/banks`, { headers }),
    run.payrollId
      ? fetch(`${API_URL}/payroll/${run.payrollId}?linesPage=1&linesLimit=1`, { headers })
      : Promise.resolve(null),
  ])
  if (cRes.ok) checks = ((await cRes.json()) as { data: Check[] }).data ?? []
  if (cbRes.ok) checkbooks = ((await cbRes.json()) as { data: Checkbook[] }).data ?? []
  if (pRes?.ok) payables = ((await pRes.json()) as { data: Payable[] }).data ?? []
  if (bRes.ok) banks = ((await bRes.json()) as { data: Bank[] }).data ?? []

  // Mes/año de la planilla → base para acreedores (pago por mes).
  if (plRes?.ok) {
    const pj = (await plRes.json()) as { data?: { payroll?: { paymentDate?: string | null; periodEnd?: string } } }
    const d = pj.data?.payroll?.paymentDate ?? pj.data?.payroll?.periodEnd ?? ''
    if (/^\d{4}-\d{2}-\d{2}/.test(d)) {
      creditorYear = Number(d.slice(0, 4))
      creditorMonth = Number(d.slice(5, 7))
    }
  }

  const [cpRes, abRes] = await Promise.all([
    run.payrollId
      ? fetch(`${API_URL}/treasury/creditor-payables?month=${creditorMonth}&year=${creditorYear}`, { headers })
      : Promise.resolve(null),
    fetch(`${API_URL}/treasury/ach?paymentRunId=${runId}`, { headers }),
  ])
  if (cpRes?.ok) creditorPayables = ((await cpRes.json()) as { data: Payable[] }).data ?? []
  if (abRes.ok) runBatches = ((await abRes.json()) as { data: AchBatch[] }).data ?? []
} catch {
  error = 'No se pudo conectar.'
}

if (!run) return Astro.redirect('/treasury')

const flash = Astro.url.searchParams.get('flash') ?? ''
const flashMsg = Astro.url.searchParams.get('msg') ?? ''

const activeCheckbooks = checkbooks.filter((c) => c.isActive === 1 && c.nextNumber <= c.endNumber)

// Beneficiarios sugeridos para emisión manual: empleados de la planilla +
// acreedores (con su monto retenido). Al elegir uno se autocompletan los campos.
const beneficiaryOptions = [
  ...payables.map((p) => ({
    type: 'employee' as const,
    ref: p.beneficiaryId,
    name: p.beneficiaryName,
    amount: p.amount,
  })),
  ...creditorPayables.map((p) => ({
    type: 'creditor' as const,
    ref: p.beneficiaryId,
    name: p.beneficiaryName,
    amount: p.amount,
  })),
]

// ─── Resumen y vista de acreedores ──────────────────────────────────────────
const MESES_ES = [
  'Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio',
  'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre',
]
const mesLabel = MESES_ES[creditorMonth - 1] ?? ''
const checksLive = checks.filter((c) => c.status !== 'voided')
const checksTotal = checksLive.reduce((a, c) => a + (Number(c.amount) || 0), 0)
const batchesTotal = runBatches.reduce((a, b) => a + (Number(b.totalAmount) || 0), 0)
const creditorTotal = creditorPayables.reduce((a, p) => a + p.amount, 0)
const creditorChecks = checksLive.filter((c) => c.beneficiaryType === 'creditor')
const creditorCheckPayables = creditorPayables.filter((p) => p.paymentMethod === 'check')
function creditorStatus(p: Payable): { label: string; cls: string } {
  if (p.paymentMethod === 'ach') {
    return p.accountNumber && p.bankRouting
      ? { label: 'ACH listo', cls: 'tr-status-closed' }
      : { label: 'ACH sin cuenta', cls: 'tr-status-cancelled' }
  }
  if (p.paymentMethod === 'check') return { label: 'Cheque', cls: 'tr-status-open' }
  return { label: 'Efectivo', cls: 'tr-status-draft' }
}
const FORMAT_LABELS: Record<string, string> = {
  banco_nacional: 'Banco Nacional (L)',
  banco_general: 'Banco General (C/D/T)',
  bloqueo_quincenal: 'Bloqueo quincenal',
  bloqueo_mensual: 'Bloqueo mensual',
  mupa_v1: 'ACH legacy',
}

const achEligible = payables.filter(
  (p) => p.paymentMethod === 'ach' && p.accountNumber && p.bankRouting && p.accountType
)
const checkEligible = payables.filter(
  (p) =>
    p.paymentMethod === 'check' &&
    !checks.some((c) => c.beneficiaryName === p.beneficiaryName && c.status !== 'voided')
)
const achTotal = achEligible.reduce((a, p) => a + p.amount, 0)
const checkTotal = checkEligible.reduce((a, p) => a + p.amount, 0)

function fmtMoney(n: number | string): string {
  const v = typeof n === 'string' ? Number.parseFloat(n) : n
  if (!Number.isFinite(v)) return '—'
  return `B/. ${v.toFixed(2)}`
}
function checkStatusBadge(s: string): { label: string; cls: string } {
  switch (s) {
    case 'issued':
      return { label: 'Emitido', cls: 'tr-chk-issued' }
    case 'printed':
      return { label: 'Impreso', cls: 'tr-chk-printed' }
    case 'cleared':
      return { label: 'Cobrado', cls: 'tr-chk-cleared' }
    case 'voided':
      return { label: 'Anulado', cls: 'tr-chk-voided' }
    default:
      return { label: s, cls: 'tr-chk-issued' }
  }
}

const today = new Date().toISOString().slice(0, 10)
---
<AppLayout title={`Tesorería · ${run.name}`}>
  <div class="mx-auto w-full max-w-7xl p-8 lg:w-3/4">
    <div class="mb-6">
      <a href="/treasury" class="text-xs tr-mute hover:underline">← Tesorería</a>
      <div class="mt-2 flex items-end justify-between gap-3 flex-wrap">
        <div>
          <h1 class="text-xl font-semibold tracking-tight tr-title">{run.name}</h1>
          <p class="text-sm mt-0.5 tr-subtitle">
            Total <strong>{fmtMoney(run.totalAmount)}</strong>
            {' · '} ACH <strong>{fmtMoney(run.achTotal)}</strong>
            {' · '} Cheques <strong>{fmtMoney(run.checkTotal)}</strong>
          </p>
        </div>
        <div class="flex items-center gap-2">
          {run.status === 'open' && canWrite && (
            <form method="POST" action={`/api/treasury/action?op=run-close&id=${runId}`}
              data-saconfirm
              data-sa-title="Cerrar generación de pagos"
              data-sa-message="Una generación cerrada ya no acepta nuevos cheques o ACH. ¿Continuar?"
              data-sa-confirm-label="Cerrar generación"
              data-sa-tone="primary"
              style="display:inline">
              <input type="hidden" name="_redirect" value={`/treasury/${runId}`} />
              <button type="submit" class="tr-btn-secondary px-3 py-1.5 text-xs rounded-md">Cerrar generación</button>
            </form>
          )}
        </div>
      </div>
    </div>

    {flash === 'created' && (
      <div class="mb-4 rounded-md bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">{flashMsg || 'Operación completada.'}</div>
    )}
    {flash === 'updated' && (
      <div class="mb-4 rounded-md bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">Cambios guardados.</div>
    )}
    {flash === 'error' && (
      <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{flashMsg || 'Error.'}</div>
    )}
    {error && (
      <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
    )}

    {/* ─── Resumen de generación ───────────────────────────── */}
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-5">
      <div class="tr-card border rounded-lg p-4">
        <p class="text-xs tr-mute">Cheques emitidos</p>
        <p class="text-lg font-semibold tr-title">{checksLive.length}</p>
        <p class="text-xs tr-cell">{fmtMoney(checksTotal)}</p>
      </div>
      <div class="tr-card border rounded-lg p-4">
        <p class="text-xs tr-mute">Archivos ACH generados</p>
        <p class="text-lg font-semibold tr-title">{runBatches.length}</p>
        <p class="text-xs tr-cell">{fmtMoney(batchesTotal)}</p>
      </div>
      <div class="tr-card border rounded-lg p-4">
        <p class="text-xs tr-mute">Acreedores por pagar{mesLabel ? ` · ${mesLabel} ${creditorYear}` : ''}</p>
        <p class="text-lg font-semibold tr-title">{creditorPayables.length}</p>
        <p class="text-xs tr-cell">{fmtMoney(creditorTotal)}</p>
      </div>
    </div>

    <div class="flex gap-1 mb-4 border-b tr-rule">
      <button type="button" class="tr-tab tr-tab-active" data-target="tab-checks">
        Cheques ({checks.length})
      </button>
      <button type="button" class="tr-tab" data-target="tab-ach">ACH</button>
      {run.payrollId && (
        <button type="button" class="tr-tab" data-target="tab-payables">Pagables ({payables.length})</button>
      )}
      {run.payrollId && (
        <button type="button" class="tr-tab" data-target="tab-creditors">Acreedores ({creditorPayables.length})</button>
      )}
    </div>

    {/* ─── Tab Cheques ────────────────────────────────────── */}
    <section id="tab-checks">
      <div class="tr-card border rounded-lg overflow-hidden">
        <header class="px-5 py-3 border-b tr-rule flex items-center justify-between">
          <h2 class="text-sm font-semibold tr-title">Cheques emitidos</h2>
          {run.status === 'open' && canWrite && activeCheckbooks.length > 0 && (
            <div class="flex items-center gap-2">
              {checks.filter((c) => c.status !== 'voided').length > 0 && (
                <>
                  <button type="button" class="tr-btn-xs" onclick={`window.location.href='/api/treasury/runs/${runId}/checks-pdf'`}>PDF (todos)</button>
                  <button type="button" class="tr-btn-xs" onclick={`window.location.href='/api/treasury/runs/${runId}/checks-xlsx'`}>Excel (todos)</button>
                </>
              )}
              <button type="button" id="btn-issue-bulk" class="text-xs tr-link">+ Generar en lote</button>
              <span class="tr-mute text-xs">·</span>
              <button type="button" id="btn-issue-check" class="text-xs tr-link">+ Emitir cheque</button>
            </div>
          )}
        </header>

        {run.status === 'open' && canWrite && (
          <form id="form-issue-check" method="POST" action={`/api/treasury/action?op=check-issue&runId=${runId}`} class="hidden px-5 py-4 border-b tr-rule">
            <input type="hidden" name="_redirect" value={`/treasury/${runId}`} />
            <input type="hidden" name="beneficiaryRefId" id="benef-ref" value="" />
            <div class="grid grid-cols-1 md:grid-cols-12 gap-3">
              {beneficiaryOptions.length > 0 && (
                <div class="md:col-span-12">
                  <label class="block text-xs font-medium tr-subtitle mb-1.5">Seleccionar beneficiario (autocompleta nombre y monto)</label>
                  <select id="benef-select" class="tr-input w-full px-3 py-2 text-sm rounded-md">
                    <option value="">— Entrada manual —</option>
                    <optgroup label="Empleados">
                      {beneficiaryOptions.filter((o) => o.type === 'employee').map((o, i) => (
                        <option value={`employee:${i}`} data-name={o.name} data-amount={o.amount} data-type="employee" data-ref={o.ref}>
                          {o.name} · B/. {o.amount.toFixed(2)}
                        </option>
                      ))}
                    </optgroup>
                    <optgroup label="Acreedores">
                      {beneficiaryOptions.filter((o) => o.type === 'creditor').map((o, i) => (
                        <option value={`creditor:${i}`} data-name={o.name} data-amount={o.amount} data-type="creditor" data-ref={o.ref}>
                          {o.name} · B/. {o.amount.toFixed(2)}
                        </option>
                      ))}
                    </optgroup>
                  </select>
                </div>
              )}
              <div class="md:col-span-4">
                <label class="block text-xs font-medium tr-subtitle mb-1.5">Chequera *</label>
                <select name="checkbookId" required class="tr-input w-full px-3 py-2 text-sm rounded-md">
                  {activeCheckbooks.length === 0 ? (
                    <option value="">— No hay chequeras activas —</option>
                  ) : (
                    activeCheckbooks.map((c) => (
                      <option value={c.id}>
                        {c.name} · próx. {String(c.nextNumber).padStart(7, '0')}
                      </option>
                    ))
                  )}
                </select>
              </div>
              <div class="md:col-span-5">
                <label class="block text-xs font-medium tr-subtitle mb-1.5">Beneficiario *</label>
                <input type="text" id="benef-name" name="beneficiaryName" required maxlength="255" class="tr-input w-full px-3 py-2 text-sm rounded-md" />
              </div>
              <div class="md:col-span-3">
                <label class="block text-xs font-medium tr-subtitle mb-1.5">Monto *</label>
                <input type="number" step="0.01" id="benef-amount" name="amount" required min="0.01" class="tr-input w-full px-3 py-2 text-sm rounded-md font-mono" />
              </div>
              <div class="md:col-span-3">
                <label class="block text-xs font-medium tr-subtitle mb-1.5">Fecha *</label>
                <input type="date" name="issueDate" required value={today} class="tr-input w-full px-3 py-2 text-sm rounded-md" />
              </div>
              <div class="md:col-span-3">
                <label class="block text-xs font-medium tr-subtitle mb-1.5">Tipo de beneficiario</label>
                <select id="benef-type" name="beneficiaryType" class="tr-input w-full px-3 py-2 text-sm rounded-md">
                  <option value="employee">Empleado</option>
                  <option value="creditor">Acreedor</option>
                  <option value="other">Otro</option>
                </select>
              </div>
              <div class="md:col-span-6">
                <label class="block text-xs font-medium tr-subtitle mb-1.5">Concepto</label>
                <input type="text" name="concept" maxlength="500" placeholder="ej. Quincena 1 enero 2026" class="tr-input w-full px-3 py-2 text-sm rounded-md" />
              </div>
            </div>
            <div class="flex justify-end gap-2 mt-3">
              <button type="button" id="btn-issue-cancel" class="tr-mute px-3 py-2 text-sm">Cancelar</button>
              <button type="submit" class="px-4 py-2 rounded-md bg-blue-600 text-white text-sm font-medium hover:bg-blue-700">Emitir cheque</button>
            </div>
          </form>
        )}

        {run.status === 'open' && canWrite && (
          <form id="form-issue-bulk" method="POST" action={`/api/treasury/action?op=checks-bulk&runId=${runId}`} class="hidden px-5 py-4 border-b tr-rule">
            <input type="hidden" name="_redirect" value={`/treasury/${runId}`} />
            <input type="hidden" name="payrollId" value={run.payrollId} />
            <p class="text-xs tr-mute mb-3">
              Emite un cheque por cada beneficiario con método <strong>cheque</strong>. Omite los que
              ya tienen cheque vigente en esta generación.
            </p>
            <div class="grid grid-cols-1 md:grid-cols-12 gap-3">
              <div class="md:col-span-4">
                <label class="block text-xs font-medium tr-subtitle mb-1.5">Chequera *</label>
                <select name="checkbookId" required class="tr-input w-full px-3 py-2 text-sm rounded-md">
                  {activeCheckbooks.map((c) => (
                    <option value={c.id}>{c.name} · próx. {String(c.nextNumber).padStart(7, '0')}</option>
                  ))}
                </select>
              </div>
              <div class="md:col-span-4">
                <label class="block text-xs font-medium tr-subtitle mb-1.5">Beneficiarios</label>
                <select id="bulk-benef" name="beneficiary" class="tr-input w-full px-3 py-2 text-sm rounded-md">
                  <option value="employees">Empleados (esta planilla)</option>
                  <option value="creditors">Acreedores (del mes)</option>
                </select>
              </div>
              <div class="md:col-span-4">
                <label class="block text-xs font-medium tr-subtitle mb-1.5">Fecha *</label>
                <input type="date" name="issueDate" required value={today} class="tr-input w-full px-3 py-2 text-sm rounded-md" />
              </div>
              <div class="md:col-span-3 bulk-period hidden">
                <label class="block text-xs font-medium tr-subtitle mb-1.5">Mes</label>
                <input type="number" name="month" min="1" max="12" value={creditorMonth} class="tr-input w-full px-3 py-2 text-sm rounded-md" />
              </div>
              <div class="md:col-span-3 bulk-period hidden">
                <label class="block text-xs font-medium tr-subtitle mb-1.5">Año</label>
                <input type="number" name="year" min="2000" max="2100" value={creditorYear} class="tr-input w-full px-3 py-2 text-sm rounded-md" />
              </div>
              <div class="md:col-span-6">
                <label class="block text-xs font-medium tr-subtitle mb-1.5">Concepto</label>
                <input type="text" name="concept" maxlength="500" placeholder="ej. Pago acreedores junio 2026" class="tr-input w-full px-3 py-2 text-sm rounded-md" />
              </div>
            </div>
            <div class="flex justify-end gap-2 mt-3">
              <button type="button" id="btn-bulk-cancel" class="tr-mute px-3 py-2 text-sm">Cancelar</button>
              <button type="submit" class="px-4 py-2 rounded-md bg-blue-600 text-white text-sm font-medium hover:bg-blue-700">Generar cheques</button>
            </div>
          </form>
        )}

        {checks.length === 0 ? (
          <div class="py-10 text-center">
            <p class="text-sm tr-mute">Sin cheques emitidos en esta generación de pagos.</p>
          </div>
        ) : (
          <div data-tr-list data-tr-page-size="10">
          <div class="px-5 py-2.5 border-b tr-rule">
            <input type="search" data-tr-search placeholder="Buscar número, beneficiario, concepto…" class="tr-input w-full max-w-xs px-3 py-1.5 text-sm rounded-md" />
          </div>
          <table class="tr-table w-full text-sm">
            <thead>
              <tr>
                <th class="text-left px-5 py-2 text-xs font-medium uppercase tracking-wide">N°</th>
                <th class="text-left px-5 py-2 text-xs font-medium uppercase tracking-wide">Fecha</th>
                <th class="text-left px-5 py-2 text-xs font-medium uppercase tracking-wide">Beneficiario</th>
                <th class="text-right px-5 py-2 text-xs font-medium uppercase tracking-wide">Monto</th>
                <th class="text-left px-5 py-2 text-xs font-medium uppercase tracking-wide">Estado</th>
                <th class="px-5 py-2"></th>
              </tr>
            </thead>
            <tbody data-tr-rows>
              {checks.map((c) => {
                const sb = checkStatusBadge(c.status)
                return (
                  <tr class="border-b last:border-0 tr-rule">
                    <td class="px-5 py-3 font-mono text-xs tr-cell">{String(c.checkNumber).padStart(7, '0')}</td>
                    <td class="px-5 py-3 text-xs tr-cell whitespace-nowrap">{c.issueDate}</td>
                    <td class="px-5 py-3 tr-cell">{c.beneficiaryName}{c.concept && <div class="text-[10px] tr-mute mt-0.5">{c.concept}</div>}</td>
                    <td class="px-5 py-3 text-right font-mono text-xs tr-cell">{fmtMoney(c.amount)}</td>
                    <td class="px-5 py-3">
                      <span class={`tr-chk-badge ${sb.cls}`}>{sb.label}</span>
                      {c.status === 'voided' && c.voidReason && (
                        <div class="text-[10px] tr-mute mt-0.5">{c.voidReason}</div>
                      )}
                    </td>
                    <td class="px-5 py-3 text-right whitespace-nowrap">
                      {c.status !== 'voided' && (
                        <>
                          <button type="button" class="tr-btn-xs mr-2" onclick={`window.location.href='/api/treasury/checks/${c.id}/pdf'`}>PDF</button>
                          <button type="button" class="tr-btn-xs mr-2" onclick={`window.location.href='/api/treasury/checks/${c.id}/xlsx'`}>Excel</button>
                          {canVoid && c.status !== 'cleared' && (
                            <button type="button" class="tr-btn-xs tr-btn-xs-danger" data-void-id={c.id} data-num={c.checkNumber}>
                              Anular
                            </button>
                          )}
                        </>
                      )}
                    </td>
                  </tr>
                )
              })}
            </tbody>
          </table>
          <div data-tr-pager class="flex items-center justify-between gap-3 px-5 py-2.5 border-t tr-rule text-xs tr-mute"></div>
          </div>
        )}
      </div>
    </section>

    {/* ─── Tab ACH ────────────────────────────────────────── */}
    <section id="tab-ach" class="hidden">
      <div class="tr-card border rounded-lg overflow-hidden">
        <header class="px-5 py-3 border-b tr-rule">
          <h2 class="text-sm font-semibold tr-title">Lotes ACH generados</h2>
          <p class="text-xs tr-mute mt-0.5">
            Genera el archivo TXT con todos los empleados elegibles (con cuenta y ruta configuradas).
            El archivo se persiste y queda descargable después.
          </p>
        </header>

        {runBatches.length > 0 && (
          <div data-tr-list data-tr-page-size="10">
          <div class="px-5 py-2.5 border-b tr-rule">
            <input type="search" data-tr-search placeholder="Buscar archivo o formato…" class="tr-input w-full max-w-xs px-3 py-1.5 text-sm rounded-md" />
          </div>
          <table class="tr-table w-full text-sm border-b tr-rule">
            <thead>
              <tr>
                <th class="text-left px-5 py-2 text-xs font-medium uppercase tracking-wide">Archivo</th>
                <th class="text-left px-5 py-2 text-xs font-medium uppercase tracking-wide">Formato</th>
                <th class="text-right px-5 py-2 text-xs font-medium uppercase tracking-wide">Registros</th>
                <th class="text-right px-5 py-2 text-xs font-medium uppercase tracking-wide">Total</th>
                <th class="px-5 py-2"></th>
              </tr>
            </thead>
            <tbody data-tr-rows>
              {runBatches.map((b) => (
                <tr class="border-b last:border-0 tr-rule">
                  <td class="px-5 py-2.5 font-mono text-xs tr-cell">{b.fileName}</td>
                  <td class="px-5 py-2.5 text-xs tr-cell">{FORMAT_LABELS[b.format] ?? b.format}</td>
                  <td class="px-5 py-2.5 text-right font-mono text-xs tr-cell">{b.recordCount}</td>
                  <td class="px-5 py-2.5 text-right font-mono text-xs tr-cell">{fmtMoney(b.totalAmount)}</td>
                  <td class="px-5 py-2.5 text-right">
                    <a href={`/api/treasury/ach/${b.id}/download`} class="text-xs tr-link">Descargar</a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
          <div data-tr-pager class="flex items-center justify-between gap-3 px-5 py-2.5 border-b tr-rule text-xs tr-mute"></div>
          </div>
        )}

        {run.payrollId && run.status === 'open' && canWrite && (
          <form method="POST" action={`/api/treasury/action?op=ach-generate&runId=${runId}`} class="px-5 py-4 border-b tr-rule">
            <input type="hidden" name="_redirect" value={`/treasury/${runId}`} />
            <input type="hidden" name="payrollId" value={run.payrollId} />
            <div class="mb-3">
              <p class="text-sm tr-cell">
                <strong>{achEligible.length}</strong> empleados elegibles para ACH ·
                Total: <strong>{fmtMoney(achTotal)}</strong>
              </p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-4 gap-3 items-end">
              <div>
                <label class="block text-xs font-medium tr-subtitle mb-1.5">Frecuencia</label>
                <select name="frequency" class="tr-input w-full px-3 py-2 text-sm rounded-md">
                  <option value="first">Primera quincena</option>
                  <option value="second">Segunda quincena</option>
                  <option value="monthly">Mensual</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-medium tr-subtitle mb-1.5">Mes</label>
                <input type="number" name="month" min="1" max="12" value={creditorMonth} class="tr-input w-full px-3 py-2 text-sm rounded-md" />
              </div>
              <div>
                <label class="block text-xs font-medium tr-subtitle mb-1.5">Año</label>
                <input type="number" name="year" min="2000" max="2100" value={creditorYear} class="tr-input w-full px-3 py-2 text-sm rounded-md" />
              </div>
              <div>
                <label class="block text-xs font-medium tr-subtitle mb-1.5">Fecha de pago *</label>
                <input type="date" name="paymentDate" required value={today} class="tr-input w-full px-3 py-2 text-sm rounded-md" />
              </div>
            </div>
            <div class="flex justify-end mt-3">
              <button type="submit" disabled={achEligible.length === 0} class="px-4 py-2 rounded-md bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 disabled:opacity-40 disabled:cursor-not-allowed">
                Generar TXT ACH
              </button>
            </div>
          </form>
        )}

        {!run.payrollId && (
          <div class="px-5 py-10 text-center">
            <p class="text-sm tr-mute">
              Esta generación de pagos no está enlazada a una planilla. El ACH se genera desde una generación con planilla asociada.
            </p>
          </div>
        )}

        {run.payrollId && achEligible.length === 0 && (
          <div class="px-5 py-6">
            <p class="text-xs tr-mute">
              No hay empleados con datos bancarios completos para ACH. Revisa el tab "Bancario" de cada empleado.
            </p>
          </div>
        )}
      </div>

      {run.payrollId && canWrite && (
        <div class="tr-card border rounded-lg overflow-hidden mt-4">
          <header class="px-5 py-3 border-b tr-rule">
            <h2 class="text-sm font-semibold tr-title">Archivos de banco y contraloría</h2>
            <p class="text-xs tr-mute mt-0.5">
              Genera y descarga el archivo en el formato del banco originador, o los bloqueos
              presupuestarios. La planilla debe estar cerrada.
            </p>
          </header>

          {/* ACH por banco — el formato lo determina el banco seleccionado */}
          <form method="POST" action="/api/treasury/files/generate" class="px-5 py-4 border-b tr-rule" id="bank-file-form">
            <input type="hidden" name="_redirect" value={`/treasury/${runId}`} />
            <input type="hidden" name="runId" value={runId} />
            <input type="hidden" name="payrollId" value={run.payrollId} />
            <input type="hidden" name="format" id="bank-file-format" value="" />
            <div class="grid grid-cols-1 md:grid-cols-4 gap-3 items-end">
              <div>
                <label class="block text-xs font-medium tr-subtitle mb-1.5">Beneficiarios</label>
                <select id="bank-file-benef" name="beneficiary" class="tr-input w-full px-3 py-2 text-sm rounded-md">
                  <option value="employees">Empleados (esta planilla)</option>
                  <option value="creditors">Acreedores (del mes)</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-medium tr-subtitle mb-1.5">Banco originador (formato ACH)</label>
                <select id="bank-file-select" name="sourceBankId" class="tr-input w-full px-3 py-2 text-sm rounded-md">
                  {banks
                    .filter((b) => b.isActive === 1 && b.achFormat)
                    .map((b) => (
                      <option value={b.id} data-format={b.achFormat}>{b.name} · {b.achFormat}</option>
                    ))}
                </select>
              </div>
              <div>
                <label class="block text-xs font-medium tr-subtitle mb-1.5">Descripción (opcional)</label>
                <input type="text" name="description" maxlength="200" placeholder="Auto" class="tr-input w-full px-3 py-2 text-sm rounded-md" />
              </div>
              <div class="flex justify-end">
                <button type="submit" disabled={banks.filter((b) => b.isActive === 1 && b.achFormat).length === 0} class="px-4 py-2 rounded-md bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 disabled:opacity-40 disabled:cursor-not-allowed">
                  Generar y descargar
                </button>
              </div>
            </div>
            <div id="bank-file-period" class="grid grid-cols-2 md:grid-cols-4 gap-3 mt-3 hidden">
              <div>
                <label class="block text-xs font-medium tr-subtitle mb-1.5">Mes (acreedores)</label>
                <input type="number" name="month" min="1" max="12" value={creditorMonth} class="tr-input w-full px-3 py-2 text-sm rounded-md" />
              </div>
              <div>
                <label class="block text-xs font-medium tr-subtitle mb-1.5">Año</label>
                <input type="number" name="year" min="2000" max="2100" value={creditorYear} class="tr-input w-full px-3 py-2 text-sm rounded-md" />
              </div>
            </div>
            {banks.filter((b) => b.isActive === 1 && b.achFormat).length === 0 && (
              <p class="text-xs tr-mute mt-2">
                Ningún banco tiene formato ACH configurado. Asígnalo en el catálogo de bancos.
              </p>
            )}
          </form>

          {/* Bloqueo presupuestario quincenal */}
          <form method="POST" action="/api/treasury/files/generate" class="px-5 py-4 border-b tr-rule">
            <input type="hidden" name="_redirect" value={`/treasury/${runId}`} />
            <input type="hidden" name="runId" value={runId} />
            <input type="hidden" name="payrollId" value={run.payrollId} />
            <input type="hidden" name="format" value="bloqueo_quincenal" />
            <div class="flex items-center justify-between gap-4">
              <p class="text-sm tr-cell">
                Bloqueo presupuestario <strong>quincenal</strong> — totales por partida de lo pagado.
              </p>
              <button type="submit" class="px-4 py-2 rounded-md bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 whitespace-nowrap">
                Generar y descargar
              </button>
            </div>
          </form>

          {/* Bloqueo presupuestario mensual (desde el presupuesto de posiciones) */}
          <form method="POST" action="/api/treasury/files/generate" class="px-5 py-4">
            <input type="hidden" name="_redirect" value={`/treasury/${runId}`} />
            <input type="hidden" name="format" value="bloqueo_mensual" />
            <div class="grid grid-cols-1 md:grid-cols-3 gap-3 items-end">
              <div>
                <label class="block text-xs font-medium tr-subtitle mb-1.5">Mes</label>
                <input type="number" name="month" min="1" max="12" value={creditorMonth} class="tr-input w-full px-3 py-2 text-sm rounded-md" />
              </div>
              <div>
                <label class="block text-xs font-medium tr-subtitle mb-1.5">Año</label>
                <input type="number" name="year" min="2000" max="2100" value={creditorYear} class="tr-input w-full px-3 py-2 text-sm rounded-md" />
              </div>
              <div class="flex justify-end">
                <button type="submit" class="px-4 py-2 rounded-md bg-blue-600 text-white text-sm font-medium hover:bg-blue-700">
                  Generar y descargar
                </button>
              </div>
            </div>
            <p class="text-xs tr-mute mt-2">
              El bloqueo mensual se calcula desde el presupuesto de las posiciones (no de esta planilla).
            </p>
          </form>
        </div>
      )}
    </section>

    {/* ─── Tab Pagables (preview de empleados) ─────────────── */}
    {run.payrollId && (
      <section id="tab-payables" class="hidden">
        <div class="tr-card border rounded-lg overflow-hidden">
          <header class="px-5 py-3 border-b tr-rule">
            <h2 class="text-sm font-semibold tr-title">Pagables de la planilla</h2>
            <p class="text-xs tr-mute mt-0.5">
              Empleados de la planilla con su método de pago configurado. Los que están en
              <strong> ACH</strong> entran al batch automático; los de <strong>cheque</strong>
              hay que emitirles cheque uno por uno.
            </p>
          </header>
          {payables.length === 0 ? (
            <div class="py-10 text-center">
              <p class="text-sm tr-mute">No hay líneas pagables para esta planilla.</p>
            </div>
          ) : (
            <div data-tr-list data-tr-page-size="10">
            <div class="px-5 py-2.5 border-b tr-rule">
              <input type="search" data-tr-search placeholder="Buscar beneficiario o cuenta…" class="tr-input w-full max-w-xs px-3 py-1.5 text-sm rounded-md" />
            </div>
            <table class="tr-table w-full text-sm">
              <thead>
                <tr>
                  <th class="text-left px-5 py-2 text-xs font-medium uppercase tracking-wide">Beneficiario</th>
                  <th class="text-left px-5 py-2 text-xs font-medium uppercase tracking-wide">Método</th>
                  <th class="text-left px-5 py-2 text-xs font-medium uppercase tracking-wide">Cuenta</th>
                  <th class="text-right px-5 py-2 text-xs font-medium uppercase tracking-wide">Monto</th>
                </tr>
              </thead>
              <tbody data-tr-rows>
                {payables.map((p) => (
                  <tr class="border-b last:border-0 tr-rule">
                    <td class="px-5 py-3 tr-cell">
                      {p.beneficiaryName}
                      {p.identification && <span class="ml-2 text-xs tr-mute font-mono">{p.identification}</span>}
                    </td>
                    <td class="px-5 py-3">
                      <span class={`tr-method-${p.paymentMethod}`}>{p.paymentMethod.toUpperCase()}</span>
                    </td>
                    <td class="px-5 py-3 text-xs tr-mute font-mono">
                      {p.accountNumber ? `${p.accountNumber} · ${p.accountType ?? '?'}` : '—'}
                    </td>
                    <td class="px-5 py-3 text-right font-mono text-xs tr-cell">{fmtMoney(p.amount)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
            <div data-tr-pager class="flex items-center justify-between gap-3 px-5 py-2.5 border-t tr-rule text-xs tr-mute"></div>
            </div>
          )}
        </div>
      </section>
    )}

    {/* ─── Tab Acreedores ─────────────────────────────────── */}
    {run.payrollId && (
      <section id="tab-creditors" class="hidden">
        {/* Cheques de acreedores — mismo flujo que empleados: generar en lote
            y descargar el formato (PDF / Excel), pero acotado a acreedores. */}
        {run.status === 'open' && canWrite && (
          <div class="tr-card border rounded-lg overflow-hidden mb-4">
            <header class="px-5 py-3 border-b tr-rule flex items-center justify-between gap-3 flex-wrap">
              <div>
                <h2 class="text-sm font-semibold tr-title">Cheques a acreedores</h2>
                <p class="text-xs tr-mute mt-0.5">
                  {creditorCheckPayables.length} acreedor(es) con método <strong>cheque</strong> ·
                  {creditorChecks.length} cheque(s) ya emitido(s).
                </p>
              </div>
              <div class="flex items-center gap-2">
                {creditorChecks.length > 0 && (
                  <>
                    <button type="button" class="tr-btn-xs" onclick={`window.location.href='/api/treasury/runs/${runId}/checks-pdf?beneficiary=creditor'`}>PDF (acreedores)</button>
                    <button type="button" class="tr-btn-xs" onclick={`window.location.href='/api/treasury/runs/${runId}/checks-xlsx?beneficiary=creditor'`}>Excel (acreedores)</button>
                    <span class="tr-mute text-xs">·</span>
                  </>
                )}
                {activeCheckbooks.length > 0 && (
                  <button type="button" id="btn-cred-checks" class="text-xs tr-link">+ Generar cheques</button>
                )}
              </div>
            </header>

            {activeCheckbooks.length > 0 && (
              <form id="form-cred-checks" method="POST" action={`/api/treasury/action?op=checks-bulk&runId=${runId}`} class="hidden px-5 py-4 border-b tr-rule">
                <input type="hidden" name="_redirect" value={`/treasury/${runId}`} />
                <input type="hidden" name="beneficiary" value="creditors" />
                <input type="hidden" name="month" value={creditorMonth} />
                <input type="hidden" name="year" value={creditorYear} />
                <p class="text-xs tr-mute mb-3">
                  Emite un cheque por cada acreedor con método <strong>cheque</strong> del mes
                  {mesLabel ? ` (${mesLabel} ${creditorYear})` : ''}. Omite los que ya tienen cheque vigente.
                </p>
                <div class="grid grid-cols-1 md:grid-cols-12 gap-3 items-end">
                  <div class="md:col-span-5">
                    <label class="block text-xs font-medium tr-subtitle mb-1.5">Chequera *</label>
                    <select name="checkbookId" required class="tr-input w-full px-3 py-2 text-sm rounded-md">
                      {activeCheckbooks.map((c) => (
                        <option value={c.id}>{c.name} · próx. {String(c.nextNumber).padStart(7, '0')}</option>
                      ))}
                    </select>
                  </div>
                  <div class="md:col-span-4">
                    <label class="block text-xs font-medium tr-subtitle mb-1.5">Fecha *</label>
                    <input type="date" name="issueDate" required value={today} class="tr-input w-full px-3 py-2 text-sm rounded-md" />
                  </div>
                  <div class="md:col-span-3 flex justify-end gap-2">
                    <button type="button" id="btn-cred-checks-cancel" class="tr-mute px-3 py-2 text-sm">Cancelar</button>
                    <button type="submit" disabled={creditorCheckPayables.length === 0} class="px-4 py-2 rounded-md bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 disabled:opacity-40 disabled:cursor-not-allowed">Generar cheques</button>
                  </div>
                </div>
              </form>
            )}
          </div>
        )}

        <div class="tr-card border rounded-lg overflow-hidden">
          <header class="px-5 py-3 border-b tr-rule">
            <h2 class="text-sm font-semibold tr-title">
              Acreedores por pagar{mesLabel ? ` · ${mesLabel} ${creditorYear}` : ''}
            </h2>
            <p class="text-xs tr-mute mt-0.5">
              Suma de las deducciones <strong>ACR_*</strong> retenidas en las planillas cerradas del
              mes, agrupada por proveedor (se paga por mes — ambas quincenas).
            </p>
          </header>
          {creditorPayables.length === 0 ? (
            <div class="py-10 text-center">
              <p class="text-sm tr-mute">No hay montos retenidos a acreedores en el mes.</p>
            </div>
          ) : (
            <div data-tr-list data-tr-page-size="10">
            <div class="px-5 py-2.5 border-b tr-rule">
              <input type="search" data-tr-search placeholder="Buscar proveedor o cuenta…" class="tr-input w-full max-w-xs px-3 py-1.5 text-sm rounded-md" />
            </div>
            <table class="tr-table w-full text-sm">
              <thead>
                <tr>
                  <th class="text-left px-5 py-2 text-xs font-medium uppercase tracking-wide">Proveedor</th>
                  <th class="text-left px-5 py-2 text-xs font-medium uppercase tracking-wide">Método</th>
                  <th class="text-left px-5 py-2 text-xs font-medium uppercase tracking-wide">Banco / Cuenta</th>
                  <th class="text-left px-5 py-2 text-xs font-medium uppercase tracking-wide">Estado</th>
                  <th class="text-right px-5 py-2 text-xs font-medium uppercase tracking-wide">Monto</th>
                </tr>
              </thead>
              <tbody data-tr-rows>
                {creditorPayables.map((p) => {
                  const st = creditorStatus(p)
                  return (
                    <tr class="border-b last:border-0 tr-rule">
                      <td class="px-5 py-3 tr-cell">
                        {p.beneficiaryName}
                        {p.identification && <span class="ml-2 text-xs tr-mute font-mono">{p.identification}</span>}
                      </td>
                      <td class="px-5 py-3">
                        <span class={`tr-method-${p.paymentMethod}`}>{p.paymentMethod.toUpperCase()}</span>
                      </td>
                      <td class="px-5 py-3 text-xs tr-mute font-mono">
                        {p.accountNumber ? `${p.accountNumber} · ${p.accountType ?? '?'}` : '—'}
                      </td>
                      <td class="px-5 py-3">
                        <span class={`tr-status-badge ${st.cls}`}>{st.label}</span>
                      </td>
                      <td class="px-5 py-3 text-right font-mono text-xs tr-cell">{fmtMoney(p.amount)}</td>
                    </tr>
                  )
                })}
                <tr class="tr-rule" data-tr-keep>
                  <td class="px-5 py-3 text-right text-xs font-semibold tr-subtitle" colspan="4">Total</td>
                  <td class="px-5 py-3 text-right font-mono text-sm font-semibold tr-title">{fmtMoney(creditorTotal)}</td>
                </tr>
              </tbody>
            </table>
            <div data-tr-pager class="flex items-center justify-between gap-3 px-5 py-2.5 border-t tr-rule text-xs tr-mute"></div>
            </div>
          )}
        </div>
      </section>
    )}
  </div>

  <dialog id="void-modal" class="void-modal">
    <div class="void-modal-card">
      <div class="void-modal-icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      </div>
      <h3 class="void-modal-title">Anular cheque</h3>
      <p class="void-modal-sub">
        Cheque N.º <strong data-void-num></strong>. Esta acción no se puede deshacer.
      </p>
      <label class="void-modal-label" for="void-reason">Razón de la anulación</label>
      <textarea
        id="void-reason"
        class="void-modal-textarea"
        rows="3"
        placeholder="Describe el motivo (mínimo 3 caracteres)…"
      ></textarea>
      <p class="void-modal-error" data-void-error hidden></p>
      <div class="void-modal-actions">
        <button type="button" class="void-modal-btn void-modal-btn-ghost" data-void-cancel>Cancelar</button>
        <button type="button" class="void-modal-btn void-modal-btn-danger" data-void-confirm>Anular cheque</button>
      </div>
    </div>
  </dialog>

  <script is:inline>
    ;(function () {
      // Tabs
      document.querySelectorAll('.tr-tab').forEach((btn) => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.tr-tab').forEach((b) => b.classList.remove('tr-tab-active'))
          btn.classList.add('tr-tab-active')
          const target = btn.getAttribute('data-target')
          for (const id of ['tab-checks', 'tab-ach', 'tab-payables', 'tab-creditors']) {
            const el = document.getElementById(id)
            if (el) el.classList.toggle('hidden', id !== target)
          }
        })
      })

      // Archivo ACH por banco: el formato lo dicta el banco seleccionado
      const bankForm = document.getElementById('bank-file-form')
      const bankSel = document.getElementById('bank-file-select')
      const bankFmt = document.getElementById('bank-file-format')
      if (bankForm && bankSel && bankFmt) {
        const syncFmt = () => {
          const opt = bankSel.options[bankSel.selectedIndex]
          bankFmt.value = opt ? opt.getAttribute('data-format') || '' : ''
        }
        bankSel.addEventListener('change', syncFmt)
        bankForm.addEventListener('submit', syncFmt)
        syncFmt()
      }

      // Mostrar mes/año cuando el beneficiario son acreedores (pago por mes)
      const benefSel = document.getElementById('bank-file-benef')
      const periodBox = document.getElementById('bank-file-period')
      if (benefSel && periodBox) {
        const syncBenef = () => periodBox.classList.toggle('hidden', benefSel.value !== 'creditors')
        benefSel.addEventListener('change', syncBenef)
        syncBenef()
      }

      // Toggle form emitir cheque
      const issueBtn = document.getElementById('btn-issue-check')
      const issueForm = document.getElementById('form-issue-check')
      const issueCancel = document.getElementById('btn-issue-cancel')
      issueBtn?.addEventListener('click', () => issueForm?.classList.toggle('hidden'))
      issueCancel?.addEventListener('click', () => issueForm?.classList.add('hidden'))

      // Cheques a acreedores (tab Acreedores)
      const credChecksBtn = document.getElementById('btn-cred-checks')
      const credChecksForm = document.getElementById('form-cred-checks')
      const credChecksCancel = document.getElementById('btn-cred-checks-cancel')
      credChecksBtn?.addEventListener('click', () => credChecksForm?.classList.toggle('hidden'))
      credChecksCancel?.addEventListener('click', () => credChecksForm?.classList.add('hidden'))

      // Cheques en lote
      const bulkBtn = document.getElementById('btn-issue-bulk')
      const bulkForm = document.getElementById('form-issue-bulk')
      const bulkCancel = document.getElementById('btn-bulk-cancel')
      bulkBtn?.addEventListener('click', () => bulkForm?.classList.toggle('hidden'))
      bulkCancel?.addEventListener('click', () => bulkForm?.classList.add('hidden'))
      const bulkBenef = document.getElementById('bulk-benef')
      if (bulkBenef) {
        const syncBulk = () => {
          document.querySelectorAll('.bulk-period').forEach((el) => {
            el.classList.toggle('hidden', bulkBenef.value !== 'creditors')
          })
        }
        bulkBenef.addEventListener('change', syncBulk)
        syncBulk()
      }

      // Autocompletar el cheque al elegir un beneficiario de la planilla
      const benefSelect = document.getElementById('benef-select')
      if (benefSelect) {
        benefSelect.addEventListener('change', () => {
          const opt = benefSelect.options[benefSelect.selectedIndex]
          if (!opt || !opt.value) return
          const name = document.getElementById('benef-name')
          const amount = document.getElementById('benef-amount')
          const type = document.getElementById('benef-type')
          const ref = document.getElementById('benef-ref')
          if (name) name.value = opt.getAttribute('data-name') || ''
          if (amount) amount.value = opt.getAttribute('data-amount') || ''
          if (type) type.value = opt.getAttribute('data-type') || 'employee'
          if (ref) ref.value = opt.getAttribute('data-ref') || ''
        })
      }

      // Anular cheque — modal con campo para la razón
      const voidModal = document.getElementById('void-modal')
      const voidReason = document.getElementById('void-reason')
      const voidError = voidModal && voidModal.querySelector('[data-void-error]')
      const voidNumEl = voidModal && voidModal.querySelector('[data-void-num]')
      let voidCheckId = null

      function showVoidError(msg) {
        if (!voidError) return
        voidError.textContent = msg
        voidError.hidden = false
      }
      function closeVoidModal() {
        if (voidModal && typeof voidModal.close === 'function') voidModal.close()
      }
      function openVoidModal(id, num) {
        voidCheckId = id
        if (voidNumEl) voidNumEl.textContent = num || ''
        if (voidReason) voidReason.value = ''
        if (voidError) voidError.hidden = true
        if (voidModal && typeof voidModal.showModal === 'function') {
          voidModal.showModal()
          if (voidReason) voidReason.focus()
        }
      }

      document.querySelectorAll('[data-void-id]').forEach((btn) => {
        btn.addEventListener('click', () => {
          openVoidModal(btn.getAttribute('data-void-id'), btn.getAttribute('data-num'))
        })
      })

      if (voidModal) {
        const cancelBtn = voidModal.querySelector('[data-void-cancel]')
        const confirmBtn = voidModal.querySelector('[data-void-confirm]')
        if (cancelBtn) cancelBtn.addEventListener('click', closeVoidModal)
        // Cerrar al hacer clic fuera de la tarjeta (sobre el backdrop)
        voidModal.addEventListener('click', (e) => {
          if (e.target === voidModal) closeVoidModal()
        })
        if (voidReason) voidReason.addEventListener('input', () => { if (voidError) voidError.hidden = true })
        if (confirmBtn)
          confirmBtn.addEventListener('click', async () => {
            const sa = window.saModal
            const reason = ((voidReason && voidReason.value) || '').trim()
            if (reason.length < 3) {
              showVoidError('Escribe al menos 3 caracteres.')
              if (voidReason) voidReason.focus()
              return
            }
            closeVoidModal()
            if (sa) sa.loading({ title: 'Anulando', message: 'Procesando…' })
            const res = await fetch(`/api/treasury/action?op=check-void&id=${voidCheckId}`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'X-SA-Modal': '1' },
              body: JSON.stringify({ reason }),
            })
            const json = await res.json().catch(() => ({}))
            if (!json.ok) {
              if (sa) await sa.error({ title: 'No se pudo anular', message: json.error })
            } else if (sa) {
              await sa.success({ title: 'Cheque anulado', redirect: window.location.pathname })
            } else {
              window.location.reload()
            }
          })
      }

      // ── Buscador + paginador para las tablas de cada tab ──────
      function setupTrList(root) {
        const tbody = root.querySelector('[data-tr-rows]')
        if (!tbody) return
        const search = root.querySelector('[data-tr-search]')
        const pager = root.querySelector('[data-tr-pager]')
        const pageSize = Number(root.getAttribute('data-tr-page-size')) || 10
        const rows = Array.prototype.slice
          .call(tbody.children)
          .filter((r) => r.tagName === 'TR' && !r.hasAttribute('data-tr-keep'))
        let page = 1
        function apply() {
          const q = ((search && search.value) || '').trim().toLowerCase()
          const filtered = q
            ? rows.filter((r) => r.textContent.toLowerCase().indexOf(q) !== -1)
            : rows
          const total = filtered.length
          const pages = Math.max(1, Math.ceil(total / pageSize))
          if (page > pages) page = pages
          if (page < 1) page = 1
          rows.forEach((r) => { r.style.display = 'none' })
          const start = (page - 1) * pageSize
          filtered.slice(start, start + pageSize).forEach((r) => { r.style.display = '' })
          if (!pager) return
          if (total <= pageSize && !q) { pager.innerHTML = ''; pager.style.display = 'none'; return }
          pager.style.display = ''
          const from = total === 0 ? 0 : start + 1
          const to = Math.min(start + pageSize, total)
          pager.innerHTML =
            '<span>' + from + '–' + to + ' de ' + total + '</span>' +
            '<span class="flex items-center gap-2">' +
            '<button type="button" data-tr-prev class="tr-btn-xs"' + (page <= 1 ? ' disabled' : '') + '>‹ Anterior</button>' +
            '<button type="button" data-tr-next class="tr-btn-xs"' + (page >= pages ? ' disabled' : '') + '>Siguiente ›</button>' +
            '</span>'
          const prev = pager.querySelector('[data-tr-prev]')
          const next = pager.querySelector('[data-tr-next]')
          if (prev) prev.addEventListener('click', () => { if (page > 1) { page--; apply() } })
          if (next) next.addEventListener('click', () => { if (page < pages) { page++; apply() } })
        }
        if (search) search.addEventListener('input', () => { page = 1; apply() })
        apply()
      }
      document.querySelectorAll('[data-tr-list]').forEach(setupTrList)
    })()
  </script>

  <style>
    .tr-title    { color: var(--fore); }
    .tr-subtitle { color: var(--fore-dim); }
    .tr-cell     { color: var(--fore-dim); }
    .tr-mute     { color: var(--mute); }
    .tr-card { background: var(--ink-2); border-color: var(--rule); }
    .tr-rule { border-color: var(--rule); }
    .tr-link { color: #60a5fa; }
    .tr-link:hover { text-decoration: underline; }
    .tr-btn-xs { display: inline-block; padding: 0.2rem 0.6rem; border-radius: 0.375rem; font-size: 0.6875rem; font-weight: 500; border: 1px solid rgba(148,163,184,0.35); color: #60a5fa; background: transparent; cursor: pointer; }
    .tr-btn-xs:hover { background: rgba(148,163,184,0.12); }
    .tr-btn-xs-danger { color: #f87171; border-color: rgba(248,113,113,0.4); }
    .tr-btn-xs-danger:hover { background: rgba(248,113,113,0.12); }
    .tr-btn-xs:disabled { opacity: 0.4; cursor: not-allowed; }
    .tr-input {
      background: var(--ink-2); border: 1px solid var(--rule); color: var(--fore);
    }
    .tr-input:focus { border-color: var(--rule-hi); outline: none; }
    .tr-btn-secondary {
      background: var(--ink-2); border: 1px solid var(--rule); color: var(--fore-dim);
    }
    .tr-btn-secondary:hover { background: var(--ink-4); color: var(--fore); }
    .tr-table thead tr { background: var(--ink-3); border-color: var(--rule); color: var(--mute-2); }
    .tr-table tbody tr { background: var(--ink-2); border-color: var(--rule); }
    .tr-table tbody tr:hover { background: var(--ink-4); }

    .tr-tab {
      padding: 0.5rem 1rem; font-size: 0.875rem; color: var(--mute-2);
      border-bottom: 2px solid transparent; margin-bottom: -1px; background: transparent;
    }
    .tr-tab:hover { color: var(--fore); }
    .tr-tab-active { color: #60a5fa; border-bottom-color: #60a5fa; font-weight: 500; }

    .tr-chk-badge {
      display: inline-block; padding: 0.125rem 0.5rem; border-radius: 9999px;
      font-size: 0.6875rem; font-weight: 500;
      text-transform: uppercase; letter-spacing: 0.04em;
    }
    .tr-chk-issued  { background: rgba(96,165,250,0.18); color: #60a5fa; }
    .tr-chk-printed { background: rgba(245,158,11,0.18); color: #fbbf24; }
    .tr-chk-cleared { background: rgba(16,185,129,0.18); color: #34d399; }
    .tr-chk-voided  { background: rgba(248,113,113,0.18); color: #f87171; }

    .tr-method-ach   { display: inline-block; padding: 0.125rem 0.5rem; border-radius: 0.25rem; font-size: 0.6875rem; font-weight: 500; background: rgba(16,185,129,0.18); color: #34d399; }
    .tr-method-check { display: inline-block; padding: 0.125rem 0.5rem; border-radius: 0.25rem; font-size: 0.6875rem; font-weight: 500; background: rgba(96,165,250,0.18); color: #60a5fa; }
    .tr-method-cash  { display: inline-block; padding: 0.125rem 0.5rem; border-radius: 0.25rem; font-size: 0.6875rem; font-weight: 500; background: rgba(156,163,175,0.18); color: var(--mute); }
    .tr-status-badge { display: inline-block; padding: 0.125rem 0.5rem; border-radius: 9999px; font-size: 0.6875rem; font-weight: 500; }
    .tr-status-draft     { background: rgba(156,163,175,0.18); color: var(--mute); }
    .tr-status-open      { background: rgba(96,165,250,0.18); color: #60a5fa; }
    .tr-status-closed    { background: rgba(16,185,129,0.18); color: #34d399; }
    .tr-status-cancelled { background: rgba(248,113,113,0.18); color: #f87171; }

    [data-theme='light'] .tr-card { background: #ffffff; }
    [data-theme='light'] .tr-table thead tr { background: #f9fafb; }
    [data-theme='light'] .tr-table tbody tr { background: #ffffff; }
    [data-theme='light'] .tr-table tbody tr:hover { background: #f9fafb; }
    [data-theme='light'] .tr-input { background: #ffffff; }
    [data-theme='light'] .tr-link { color: #2563eb; }
    [data-theme='light'] .tr-tab-active { color: #2563eb; border-bottom-color: #2563eb; }
    [data-theme='light'] .tr-chk-issued  { background: #dbeafe; color: #1d4ed8; }
    [data-theme='light'] .tr-chk-printed { background: #fef3c7; color: #92400e; }
    [data-theme='light'] .tr-chk-cleared { background: #d1fae5; color: #065f46; }
    [data-theme='light'] .tr-chk-voided  { background: #fee2e2; color: #991b1b; }
    [data-theme='light'] .tr-method-ach   { background: #d1fae5; color: #065f46; }
    [data-theme='light'] .tr-method-check { background: #dbeafe; color: #1d4ed8; }
    [data-theme='light'] .tr-method-cash  { background: #f3f4f6; color: #6b7280; }

    /* ── Modal: anular cheque (razón) ───────────────────────── */
    .void-modal { border: none; background: transparent; padding: 0; max-width: 440px; width: calc(100% - 32px); color: var(--fore); }
    .void-modal::backdrop { background: rgba(7,16,31,0.62); backdrop-filter: blur(2px); }
    [data-theme='light'] .void-modal::backdrop { background: rgba(12,20,36,0.45); }
    .void-modal-card { background: var(--ink-2); border: 1px solid var(--rule); border-radius: 12px; padding: 22px; box-shadow: 0 24px 60px rgba(0,0,0,0.45); font-family: var(--f-sans); }
    .void-modal-icon { width: 38px; height: 38px; display: grid; place-items: center; border-radius: 999px; background: rgba(224,107,92,0.18); color: var(--err); margin-bottom: 12px; }
    .void-modal-title { margin: 0 0 6px; font-family: var(--f-display); font-size: 18px; font-weight: 400; letter-spacing: -0.01em; color: var(--fore); }
    .void-modal-sub { margin: 0 0 16px; font-size: 13px; line-height: 1.5; color: var(--fore-dim); }
    .void-modal-sub strong { color: var(--fore); font-weight: 600; }
    .void-modal-label { display: block; font-family: var(--f-mono); font-size: 11px; letter-spacing: .1em; text-transform: uppercase; color: var(--mute-2); margin-bottom: 6px; }
    .void-modal-textarea { width: 100%; box-sizing: border-box; background: var(--ink-3); border: 1px solid var(--rule); border-radius: 8px; color: var(--fore); font-family: var(--f-sans); font-size: 14px; line-height: 1.5; padding: 10px 12px; resize: vertical; min-height: 76px; }
    .void-modal-textarea::placeholder { color: var(--mute); }
    .void-modal-textarea:focus { outline: none; border-color: var(--navy-hi); box-shadow: 0 0 0 2px var(--navy-soft); }
    .void-modal-error { margin: 8px 0 0; font-size: 12px; color: var(--err); }
    .void-modal-actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 18px; }
    .void-modal-btn { padding: 8px 16px; border-radius: 8px; font-size: 13px; font-weight: 500; cursor: pointer; font-family: var(--f-sans); transition: background 140ms ease, color 140ms ease; }
    .void-modal-btn-ghost { background: transparent; border: 1px solid var(--rule); color: var(--fore-dim); }
    .void-modal-btn-ghost:hover { background: var(--ink-4); color: var(--fore); }
    .void-modal-btn-danger { background: var(--btn-danger-bg); border: 1px solid var(--btn-edge); color: #fff; }
    .void-modal-btn-danger:hover { background: var(--btn-danger-bg-hover); }
  </style>
</AppLayout>

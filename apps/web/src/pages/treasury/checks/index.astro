---
/**
 * Vista consolidada de cheques — todos los cheques emitidos en todas las
 * corridas de pago, con su chequera, banco y corrida de origen.
 */
import AppLayout from '../../../layouts/AppLayout.astro'
import { can, getIdentity } from '../../../lib/auth'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'

const identity = getIdentity(Astro.cookies)
if (!identity) return Astro.redirect('/login')
if (!can(identity, 'treasury:read')) return Astro.redirect('/dashboard')

const tenantSlug = identity.tenantSlug ?? 'demo'
const headers = { Cookie: `auth=${identity.raw}`, 'X-Tenant': tenantSlug }

type Check = {
  id: string
  checkNumber: number
  beneficiaryName: string
  amount: string
  status: 'issued' | 'printed' | 'cleared' | 'voided'
  issueDate: string
  concept: string | null
  paymentRunId: string | null
  checkbookName: string | null
  bankName: string | null
  runName: string | null
}

let checks: Check[] = []
let error = ''
try {
  const res = await fetch(`${API_URL}/treasury/checks`, { headers })
  if (res.status === 401) return Astro.redirect('/login')
  if (res.ok) checks = ((await res.json()) as { data: Check[] }).data ?? []
  else error = `No se pudo cargar el listado (HTTP ${res.status}).`
} catch {
  error = 'No se pudo conectar.'
}

const total = checks
  .filter((c) => c.status !== 'voided')
  .reduce((a, c) => a + (Number(c.amount) || 0), 0)

function statusLabel(s: string): string {
  return s === 'issued'
    ? 'Emitido'
    : s === 'printed'
      ? 'Impreso'
      : s === 'cleared'
        ? 'Cobrado'
        : 'Anulado'
}
function statusClass(s: string): string {
  if (s === 'issued') return 'tr-status-open'
  if (s === 'printed') return 'tr-status-draft'
  if (s === 'cleared') return 'tr-status-closed'
  return 'tr-status-cancelled'
}
function fmtDate(s: string): string {
  if (!s) return '—'
  return new Date(s).toLocaleDateString('es-PA')
}
function fmtMoney(s: string | number): string {
  const n = Number(s)
  if (!Number.isFinite(n)) return '—'
  return `B/. ${n.toFixed(2)}`
}
---
<AppLayout title="Tesorería · Cheques">
  <div class="mx-auto w-full max-w-7xl p-8 lg:w-3/4">
    <div class="mb-6 flex items-end justify-between gap-2">
      <div>
        <h1 class="text-xl font-semibold tracking-tight tr-title">Cheques</h1>
        <p class="text-sm mt-0.5 tr-subtitle">
          {checks.length} {checks.length === 1 ? 'cheque' : 'cheques'} en total · Vigentes:
          <strong>{fmtMoney(total)}</strong>
        </p>
      </div>
      <a href="/treasury" class="tr-btn-ghost">← Corridas de pago</a>
    </div>

    {error && (
      <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
    )}

    <section class="tr-card border rounded-lg overflow-hidden">
      {checks.length === 0 ? (
        <div class="py-16 text-center">
          <p class="text-sm tr-subtitle">No hay cheques emitidos.</p>
        </div>
      ) : (
        <table class="tr-table w-full text-sm">
          <thead>
            <tr>
              <th class="text-left px-5 py-3 text-xs font-medium uppercase tracking-wide">N°</th>
              <th class="text-left px-5 py-3 text-xs font-medium uppercase tracking-wide">Beneficiario</th>
              <th class="text-right px-5 py-3 text-xs font-medium uppercase tracking-wide">Monto</th>
              <th class="text-left px-5 py-3 text-xs font-medium uppercase tracking-wide">Estado</th>
              <th class="text-left px-5 py-3 text-xs font-medium uppercase tracking-wide">Chequera</th>
              <th class="text-left px-5 py-3 text-xs font-medium uppercase tracking-wide">Corrida</th>
              <th class="text-left px-5 py-3 text-xs font-medium uppercase tracking-wide">Fecha</th>
              <th class="px-5 py-3"></th>
            </tr>
          </thead>
          <tbody>
            {checks.map((c) => (
              <tr class="border-b last:border-0 tr-rule">
                <td class="px-5 py-3 align-top font-mono text-xs tr-cell">{c.checkNumber}</td>
                <td class="px-5 py-3 align-top tr-cell">{c.beneficiaryName}</td>
                <td class="px-5 py-3 align-top text-right font-mono text-xs tr-cell">{fmtMoney(c.amount)}</td>
                <td class="px-5 py-3 align-top">
                  <span class={`tr-status-badge ${statusClass(c.status)}`}>{statusLabel(c.status)}</span>
                </td>
                <td class="px-5 py-3 align-top text-xs tr-mute">
                  {c.checkbookName ?? '—'}
                  {c.bankName && <span class="block tr-mute">{c.bankName}</span>}
                </td>
                <td class="px-5 py-3 align-top text-xs tr-mute">{c.runName ?? '—'}</td>
                <td class="px-5 py-3 align-top text-xs tr-mute whitespace-nowrap">{fmtDate(c.issueDate)}</td>
                <td class="px-5 py-3 align-top text-right">
                  {c.paymentRunId && <a href={`/treasury/${c.paymentRunId}`} class="tr-btn-ghost">Ver corrida</a>}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </section>
  </div>

  <style>
    .tr-title    { color: var(--fore); }
    .tr-subtitle { color: var(--fore-dim); }
    .tr-cell     { color: var(--fore-dim); }
    .tr-mute     { color: var(--mute); }
    .tr-card { background: var(--ink-2); border-color: var(--rule); }
    .tr-rule { border-color: var(--rule); }
    .tr-btn-ghost {
      display:inline-flex; align-items:center; gap:4px;
      padding:5px 12px; border-radius:6px; font-size:12px; font-weight:500;
      border:1px solid var(--rule); color:var(--fore-dim); text-decoration:none;
      transition:border-color 140ms, background 140ms, color 140ms;
    }
    .tr-btn-ghost:hover { border-color:var(--rule-hi); background:var(--ink-4); color:var(--fore); }
    .tr-table thead tr { background: var(--ink-3); border-color: var(--rule); color: var(--mute-2); }
    .tr-table tbody tr { background: var(--ink-2); border-color: var(--rule); }
    .tr-table tbody tr:hover { background: var(--ink-4); }
    .tr-status-badge {
      display: inline-block; padding: 0.125rem 0.5rem; border-radius: 9999px;
      font-size: 0.6875rem; font-weight: 500;
      text-transform: uppercase; letter-spacing: 0.04em;
    }
    .tr-status-draft     { background: rgba(156,163,175,0.18); color: var(--mute); }
    .tr-status-open      { background: rgba(245,158,11,0.18); color: #fbbf24; }
    .tr-status-closed    { background: rgba(16,185,129,0.18); color: #34d399; }
    .tr-status-cancelled { background: rgba(248,113,113,0.18); color: #f87171; }
    [data-theme='light'] .tr-card { background: #ffffff; }
    [data-theme='light'] .tr-table thead tr { background: #f9fafb; }
    [data-theme='light'] .tr-table tbody tr { background: #ffffff; }
    [data-theme='light'] .tr-table tbody tr:hover { background: #f9fafb; }
    [data-theme='light'] .tr-status-draft     { background: #f3f4f6; color: #6b7280; }
    [data-theme='light'] .tr-status-open      { background: #fef3c7; color: #92400e; }
    [data-theme='light'] .tr-status-closed    { background: #d1fae5; color: #065f46; }
    [data-theme='light'] .tr-status-cancelled { background: #fee2e2; color: #991b1b; }
  </style>
</AppLayout>

---
/**
 * Vista consolidada de cheques — todos los cheques emitidos en todas las
 * corridas de pago, con su chequera, banco y corrida de origen.
 */
import AppLayout from '../../../layouts/AppLayout.astro'
import { can, getIdentity } from '../../../lib/auth'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'

const identity = getIdentity(Astro.cookies)
if (!identity) return Astro.redirect('/login')
if (!can(identity, 'treasury:read')) return Astro.redirect('/dashboard')

const tenantSlug = identity.tenantSlug ?? 'demo'
const headers = { Cookie: `auth=${identity.raw}`, 'X-Tenant': tenantSlug }

type Check = {
  id: string
  checkNumber: number
  beneficiaryName: string
  amount: string
  status: 'issued' | 'printed' | 'cleared' | 'voided'
  issueDate: string
  concept: string | null
  paymentRunId: string | null
  checkbookName: string | null
  bankName: string | null
  runName: string | null
}

let checks: Check[] = []
let error = ''
try {
  const res = await fetch(`${API_URL}/treasury/checks`, { headers })
  if (res.status === 401) return Astro.redirect('/login')
  if (res.ok) checks = ((await res.json()) as { data: Check[] }).data ?? []
  else error = `No se pudo cargar el listado (HTTP ${res.status}).`
} catch {
  error = 'No se pudo conectar.'
}

const total = checks
  .filter((c) => c.status !== 'voided')
  .reduce((a, c) => a + (Number(c.amount) || 0), 0)

function statusLabel(s: string): string {
  return s === 'issued'
    ? 'Emitido'
    : s === 'printed'
      ? 'Impreso'
      : s === 'cleared'
        ? 'Cobrado'
        : 'Anulado'
}
function statusClass(s: string): string {
  if (s === 'issued') return 'tr-status-open'
  if (s === 'printed') return 'tr-status-draft'
  if (s === 'cleared') return 'tr-status-closed'
  return 'tr-status-cancelled'
}
function fmtDate(s: string): string {
  if (!s) return '—'
  return new Date(s).toLocaleDateString('es-PA')
}
function fmtMoney(s: string | number): string {
  const n = Number(s)
  if (!Number.isFinite(n)) return '—'
  return `B/. ${n.toFixed(2)}`
}
---
<AppLayout title="Tesorería · Cheques">
  <div class="mx-auto w-full max-w-7xl p-8 lg:w-3/4">
    <div class="mb-6 flex items-end justify-between gap-2">
      <div>
        <h1 class="text-xl font-semibold tracking-tight tr-title">Cheques</h1>
        <p class="text-sm mt-0.5 tr-subtitle">
          {checks.length} {checks.length === 1 ? 'cheque' : 'cheques'} en total · Vigentes:
          <strong>{fmtMoney(total)}</strong>
        </p>
      </div>
      <a href="/treasury" class="tr-btn-ghost">← Generación de pagos</a>
    </div>

    {error && (
      <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
    )}

    <section class="tr-card border rounded-lg overflow-hidden">
      {checks.length === 0 ? (
        <div class="py-16 text-center">
          <p class="text-sm tr-subtitle">No hay cheques emitidos.</p>
        </div>
      ) : (
        <div data-tr-list data-tr-page-size="12">
        <div class="px-5 py-2.5 border-b tr-rule">
          <input type="search" data-tr-search placeholder="Buscar número, beneficiario, chequera, generación…" class="tr-input w-full max-w-sm px-3 py-1.5 text-sm rounded-md" />
        </div>
        <table class="tr-table w-full text-sm">
          <thead>
            <tr>
              <th class="text-left px-5 py-3 text-xs font-medium uppercase tracking-wide">N°</th>
              <th class="text-left px-5 py-3 text-xs font-medium uppercase tracking-wide">Beneficiario</th>
              <th class="text-right px-5 py-3 text-xs font-medium uppercase tracking-wide">Monto</th>
              <th class="text-left px-5 py-3 text-xs font-medium uppercase tracking-wide">Estado</th>
              <th class="text-left px-5 py-3 text-xs font-medium uppercase tracking-wide">Chequera</th>
              <th class="text-left px-5 py-3 text-xs font-medium uppercase tracking-wide">Generación</th>
              <th class="text-left px-5 py-3 text-xs font-medium uppercase tracking-wide">Fecha</th>
              <th class="px-5 py-3"></th>
            </tr>
          </thead>
          <tbody data-tr-rows>
            {checks.map((c) => (
              <tr class="border-b last:border-0 tr-rule">
                <td class="px-5 py-3 align-top font-mono text-xs tr-cell">{c.checkNumber}</td>
                <td class="px-5 py-3 align-top tr-cell">{c.beneficiaryName}</td>
                <td class="px-5 py-3 align-top text-right font-mono text-xs tr-cell">{fmtMoney(c.amount)}</td>
                <td class="px-5 py-3 align-top">
                  <span class={`tr-status-badge ${statusClass(c.status)}`}>{statusLabel(c.status)}</span>
                </td>
                <td class="px-5 py-3 align-top text-xs tr-mute">
                  {c.checkbookName ?? '—'}
                  {c.bankName && <span class="block tr-mute">{c.bankName}</span>}
                </td>
                <td class="px-5 py-3 align-top text-xs tr-mute">{c.runName ?? '—'}</td>
                <td class="px-5 py-3 align-top text-xs tr-mute whitespace-nowrap">{fmtDate(c.issueDate)}</td>
                <td class="px-5 py-3 align-top text-right">
                  <div class="inline-flex items-center gap-1.5">
                    {c.status !== 'voided' && (
                      <>
                        <button type="button" class="tr-icon-btn tr-icon-pdf" title="Imprimir cheque (PDF)" aria-label="Imprimir cheque en PDF" onclick={`window.location.href='/api/treasury/checks/${c.id}/pdf'`}>
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
                        </button>
                        <button type="button" class="tr-icon-btn tr-icon-xls" title="Imprimir cheque (Excel)" aria-label="Imprimir cheque en Excel" onclick={`window.location.href='/api/treasury/checks/${c.id}/xlsx'`}>
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="3" x2="9" y2="21"/></svg>
                        </button>
                      </>
                    )}
                    {c.paymentRunId && (
                      <a href={`/treasury/${c.paymentRunId}`} class="tr-icon-btn tr-icon-view" title="Ver generación" aria-label="Ver generación de origen">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>
                      </a>
                    )}
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
        <div data-tr-pager class="flex items-center justify-between gap-3 px-5 py-2.5 border-t tr-rule text-xs tr-mute"></div>
        </div>
      )}
    </section>
  </div>

  <style>
    .tr-title    { color: var(--fore); }
    .tr-subtitle { color: var(--fore-dim); }
    .tr-cell     { color: var(--fore-dim); }
    .tr-mute     { color: var(--mute); }
    .tr-card { background: var(--ink-2); border-color: var(--rule); }
    .tr-rule { border-color: var(--rule); }
    .tr-btn-ghost {
      display:inline-flex; align-items:center; gap:4px;
      padding:5px 12px; border-radius:6px; font-size:12px; font-weight:500;
      border:1px solid var(--rule); color:var(--fore-dim); text-decoration:none;
      transition:border-color 140ms, background 140ms, color 140ms;
    }
    .tr-btn-ghost:hover { border-color:var(--rule-hi); background:var(--ink-4); color:var(--fore); }
    .tr-input { background: var(--ink-3); border: 1px solid var(--rule); color: var(--fore); outline: none; }
    .tr-input:focus { border-color: var(--navy-hi); box-shadow: 0 0 0 2px var(--navy-soft); }
    .tr-input::placeholder { color: var(--mute); }
    .tr-icon-btn { display: inline-grid; place-items: center; width: 28px; height: 28px; border-radius: 6px; border: 1px solid var(--rule); background: transparent; cursor: pointer; text-decoration: none; transition: background .15s, color .15s, border-color .15s; }
    .tr-icon-btn svg { width: 15px; height: 15px; }
    .tr-icon-pdf  { color: #dc2626; background: color-mix(in srgb, #dc2626 10%, transparent); border-color: color-mix(in srgb, #dc2626 28%, transparent); }
    .tr-icon-pdf:hover  { background: color-mix(in srgb, #dc2626 20%, transparent); }
    .tr-icon-xls  { color: #059669; background: color-mix(in srgb, #059669 12%, transparent); border-color: color-mix(in srgb, #059669 28%, transparent); }
    .tr-icon-xls:hover  { background: color-mix(in srgb, #059669 22%, transparent); }
    .tr-icon-view { color: #2563eb; background: color-mix(in srgb, #2563eb 10%, transparent); border-color: color-mix(in srgb, #2563eb 28%, transparent); }
    .tr-icon-view:hover { background: color-mix(in srgb, #2563eb 22%, transparent); color: #1d4ed8; }
    .tr-pager-btn { display: inline-block; padding: 0.2rem 0.6rem; border-radius: 0.375rem; font-size: 0.6875rem; font-weight: 500; border: 1px solid var(--rule); color: var(--fore-dim); background: transparent; cursor: pointer; }
    .tr-pager-btn:hover { background: var(--ink-4); }
    .tr-pager-btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .tr-table thead tr { background: var(--ink-3); border-color: var(--rule); color: var(--mute-2); }
    .tr-table tbody tr { background: var(--ink-2); border-color: var(--rule); }
    .tr-table tbody tr:hover { background: var(--ink-4); }
    .tr-status-badge {
      display: inline-block; padding: 0.125rem 0.5rem; border-radius: 9999px;
      font-size: 0.6875rem; font-weight: 500;
      text-transform: uppercase; letter-spacing: 0.04em;
    }
    .tr-status-draft     { background: rgba(156,163,175,0.18); color: var(--mute); }
    .tr-status-open      { background: rgba(245,158,11,0.18); color: #fbbf24; }
    .tr-status-closed    { background: rgba(16,185,129,0.18); color: #34d399; }
    .tr-status-cancelled { background: rgba(248,113,113,0.18); color: #f87171; }
    [data-theme='light'] .tr-card { background: #ffffff; }
    [data-theme='light'] .tr-table thead tr { background: #f9fafb; }
    [data-theme='light'] .tr-table tbody tr { background: #ffffff; }
    [data-theme='light'] .tr-table tbody tr:hover { background: #f9fafb; }
    [data-theme='light'] .tr-status-draft     { background: #f3f4f6; color: #6b7280; }
    [data-theme='light'] .tr-status-open      { background: #fef3c7; color: #92400e; }
    [data-theme='light'] .tr-status-closed    { background: #d1fae5; color: #065f46; }
    [data-theme='light'] .tr-status-cancelled { background: #fee2e2; color: #991b1b; }
  </style>

  <script is:inline>
    ;(function () {
      function setupTrList(root) {
        const tbody = root.querySelector('[data-tr-rows]')
        if (!tbody) return
        const search = root.querySelector('[data-tr-search]')
        const pager = root.querySelector('[data-tr-pager]')
        const pageSize = Number(root.getAttribute('data-tr-page-size')) || 10
        const rows = Array.prototype.slice
          .call(tbody.children)
          .filter((r) => r.tagName === 'TR' && !r.hasAttribute('data-tr-keep'))
        let page = 1
        function apply() {
          const q = ((search && search.value) || '').trim().toLowerCase()
          const filtered = q
            ? rows.filter((r) => r.textContent.toLowerCase().indexOf(q) !== -1)
            : rows
          const total = filtered.length
          const pages = Math.max(1, Math.ceil(total / pageSize))
          if (page > pages) page = pages
          if (page < 1) page = 1
          rows.forEach((r) => { r.style.display = 'none' })
          const start = (page - 1) * pageSize
          filtered.slice(start, start + pageSize).forEach((r) => { r.style.display = '' })
          if (!pager) return
          if (total <= pageSize && !q) { pager.innerHTML = ''; pager.style.display = 'none'; return }
          pager.style.display = ''
          const from = total === 0 ? 0 : start + 1
          const to = Math.min(start + pageSize, total)
          pager.innerHTML =
            '<span>' + from + '–' + to + ' de ' + total + '</span>' +
            '<span class="flex items-center gap-2">' +
            '<button type="button" data-tr-first class="tr-pager-btn"' + (page <= 1 ? ' disabled' : '') + '>« Inicio</button>' +
            '<button type="button" data-tr-prev class="tr-pager-btn"' + (page <= 1 ? ' disabled' : '') + '>‹ Anterior</button>' +
            '<button type="button" data-tr-next class="tr-pager-btn"' + (page >= pages ? ' disabled' : '') + '>Siguiente ›</button>' +
            '<button type="button" data-tr-last class="tr-pager-btn"' + (page >= pages ? ' disabled' : '') + '>Fin »</button>' +
            '</span>'
          const first = pager.querySelector('[data-tr-first]')
          const prev = pager.querySelector('[data-tr-prev]')
          const next = pager.querySelector('[data-tr-next]')
          const last = pager.querySelector('[data-tr-last]')
          if (first) first.addEventListener('click', () => { if (page > 1) { page = 1; apply() } })
          if (prev) prev.addEventListener('click', () => { if (page > 1) { page--; apply() } })
          if (next) next.addEventListener('click', () => { if (page < pages) { page++; apply() } })
          if (last) last.addEventListener('click', () => { if (page < pages) { page = pages; apply() } })
        }
        if (search) search.addEventListener('input', () => { page = 1; apply() })
        apply()
      }
      document.querySelectorAll('[data-tr-list]').forEach(setupTrList)
    })()
  </script>
</AppLayout>

---
/**
 * Hub del módulo de tesorería — listado de corridas de pago.
 *
 * Cada corrida agrupa todo lo que se pagó (ACH + cheques + efectivo)
 * para una planilla específica o un evento manual. Desde aquí el
 * contador entra al detalle para emitir cheques o generar el ACH TXT.
 */
import AppLayout from '../../layouts/AppLayout.astro'
import { can, getIdentity } from '../../lib/auth'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'

const identity = getIdentity(Astro.cookies)
if (!identity) return Astro.redirect('/login')
if (!can(identity, 'treasury:read')) return Astro.redirect('/dashboard')

const tenantSlug = identity.tenantSlug ?? 'demo'
const headers = { Cookie: `auth=${identity.raw}`, 'X-Tenant': tenantSlug }
const canWrite = can(identity, 'treasury:write')

type PaymentRun = {
  id: string
  payrollId: string | null
  name: string
  status: 'draft' | 'open' | 'closed' | 'cancelled'
  totalAmount: string
  achTotal: string
  checkTotal: string
  cashTotal: string
  createdAt: string
  closedAt: string | null
}
type PayrollOpt = { id: string; name: string; status: string }

let runs: PaymentRun[] = []
let payrolls: PayrollOpt[] = []
let error = ''
try {
  const [rRes, pRes] = await Promise.all([
    fetch(`${API_URL}/treasury/runs`, { headers }),
    fetch(`${API_URL}/payroll?status=closed`, { headers }).catch(() => null),
  ])
  if (rRes.status === 401) return Astro.redirect('/login')
  if (rRes.ok) runs = ((await rRes.json()) as { data: PaymentRun[] }).data ?? []
  if (pRes?.ok) {
    const j = (await pRes.json()) as { data?: PayrollOpt[]; payrolls?: PayrollOpt[] }
    payrolls = j.data ?? j.payrolls ?? []
  }
} catch {
  error = 'No se pudo conectar.'
}

const flash = Astro.url.searchParams.get('flash') ?? ''
const flashMsg = Astro.url.searchParams.get('msg') ?? ''

function statusLabel(s: string): string {
  return s === 'draft'
    ? 'Borrador'
    : s === 'open'
      ? 'Abierta'
      : s === 'closed'
        ? 'Cerrada'
        : 'Cancelada'
}
function statusClass(s: string): string {
  if (s === 'open') return 'tr-status-open'
  if (s === 'closed') return 'tr-status-closed'
  if (s === 'draft') return 'tr-status-draft'
  return 'tr-status-cancelled'
}
function fmtDate(s: string): string {
  if (!s) return '—'
  return new Date(s).toLocaleDateString('es-PA')
}
function fmtMoney(s: string): string {
  const n = Number(s)
  if (!Number.isFinite(n)) return '—'
  return `B/. ${n.toFixed(2)}`
}
---
<AppLayout title="Tesorería">
  <div class="mx-auto w-full max-w-7xl p-8 lg:w-3/4">
    <div class="mb-6 flex items-end justify-between gap-2">
      <div>
        <h1 class="text-xl font-semibold tracking-tight tr-title">Tesorería</h1>
        <p class="text-sm mt-0.5 tr-subtitle">Generación de Cheques y ACH por planilla cerrada</p>
      </div>
      {canWrite && (
        <button type="button" id="btn-new-run" class="tr-btn-primary px-3.5 py-2 rounded-md text-sm font-medium">
          + Generar Cheques
        </button>
      )}
    </div>

    {flash === 'created' && (
      <div class="mb-4 rounded-md bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">Generación de pagos creada.</div>
    )}
    {flash === 'error' && (
      <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{flashMsg || 'Error.'}</div>
    )}
    {error && (
      <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
    )}

    {/* Modal de nueva corrida */}
    {canWrite && (
      <div id="new-run-modal" class="fixed inset-0 bg-black/40 z-50 hidden items-center justify-center p-4">
        <div class="bg-white rounded-xl shadow-xl w-full max-w-lg border border-gray-200">
          <div class="px-5 py-3 border-b border-gray-200 flex items-center justify-between">
            <h3 class="font-semibold text-gray-900">Generar Cheques</h3>
            <button type="button" id="new-run-close" class="text-gray-400 hover:text-gray-700 text-xl leading-none">×</button>
          </div>
          <form method="POST" action="/api/treasury/action?op=run-create" class="p-5 space-y-3">
            <input type="hidden" name="_redirect" value="/treasury" />
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1.5">Nombre *</label>
              <input type="text" name="name" required maxlength="255" placeholder="ej. Quincena Enero 2026" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md" />
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1.5">Planilla asociada (opcional)</label>
              <select name="payrollId" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md">
                <option value="">— Sin planilla (pago manual) —</option>
                {payrolls.map((p) => <option value={p.id}>{p.name}</option>)}
              </select>
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1.5">Notas (opcional)</label>
              <textarea name="notes" rows="2" maxlength="1000" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md"></textarea>
            </div>
            <div class="flex justify-end gap-2 pt-2">
              <button type="button" id="new-run-cancel" class="px-3 py-2 text-sm text-gray-600">Cancelar</button>
              <button type="submit" class="px-4 py-2 text-white text-sm rounded-md font-medium tr-btn-primary">Generar</button>
            </div>
          </form>
        </div>
      </div>
    )}

    <section class="tr-card border rounded-lg overflow-hidden">
      {runs.length === 0 ? (
        <div class="py-16 text-center">
          <p class="text-sm tr-subtitle">No hay generaciones de pagos registradas.</p>
        </div>
      ) : (
        <table class="tr-table w-full text-sm">
          <thead>
            <tr>
              <th class="text-left px-5 py-3 text-xs font-medium uppercase tracking-wide">Nombre</th>
              <th class="text-left px-5 py-3 text-xs font-medium uppercase tracking-wide">Estado</th>
              <th class="text-right px-5 py-3 text-xs font-medium uppercase tracking-wide">Total</th>
              <th class="text-right px-5 py-3 text-xs font-medium uppercase tracking-wide">ACH</th>
              <th class="text-right px-5 py-3 text-xs font-medium uppercase tracking-wide">Cheques</th>
              <th class="text-left px-5 py-3 text-xs font-medium uppercase tracking-wide">Creada</th>
              <th class="px-5 py-3"></th>
            </tr>
          </thead>
          <tbody>
            {runs.map((r) => (
              <tr class="border-b last:border-0 tr-rule">
                <td class="px-5 py-3 align-top tr-cell">{r.name}</td>
                <td class="px-5 py-3 align-top">
                  <span class={`tr-status-badge ${statusClass(r.status)}`}>{statusLabel(r.status)}</span>
                </td>
                <td class="px-5 py-3 align-top text-right font-mono text-xs tr-cell">{fmtMoney(r.totalAmount)}</td>
                <td class="px-5 py-3 align-top text-right font-mono text-xs tr-cell">{fmtMoney(r.achTotal)}</td>
                <td class="px-5 py-3 align-top text-right font-mono text-xs tr-cell">{fmtMoney(r.checkTotal)}</td>
                <td class="px-5 py-3 align-top text-xs tr-mute whitespace-nowrap">{fmtDate(r.createdAt)}</td>
                <td class="px-5 py-3 align-top text-right">
                  <a href={`/treasury/${r.id}`} class="tr-icon-btn tr-icon-view" title="Ver detalle" aria-label="Ver detalle de la generación">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </section>
  </div>

  <script is:inline>
    ;(function () {
      const modal = document.getElementById('new-run-modal')
      if (!modal) return
      const open = document.getElementById('btn-new-run')
      const close = document.getElementById('new-run-close')
      const cancel = document.getElementById('new-run-cancel')
      const show = () => { modal.classList.remove('hidden'); modal.classList.add('flex') }
      const hide = () => { modal.classList.add('hidden'); modal.classList.remove('flex') }
      open?.addEventListener('click', show)
      close?.addEventListener('click', hide)
      cancel?.addEventListener('click', hide)
      modal.addEventListener('click', (e) => { if (e.target === modal) hide() })
    })()
  </script>

  <style>
    .tr-title    { color: var(--fore); }
    .tr-subtitle { color: var(--fore-dim); }
    .tr-cell     { color: var(--fore-dim); }
    .tr-mute     { color: var(--mute); }
    .tr-card { background: var(--ink-2); border-color: var(--rule); }
    .tr-rule { border-color: var(--rule); }
    .tr-btn-primary { background: var(--navy); color: white; }
    .tr-btn-primary:hover { background: var(--navy-hi); }
    .tr-btn-ghost {
      display:inline-flex; align-items:center; gap:4px;
      padding:5px 12px; border-radius:6px; font-size:12px; font-weight:500;
      border:1px solid var(--rule); color:var(--fore-dim); text-decoration:none;
      transition:border-color 140ms, background 140ms, color 140ms;
    }
    .tr-btn-ghost:hover { border-color:var(--rule-hi); background:var(--ink-4); color:var(--fore); }
    .tr-table thead tr { background: var(--ink-3); border-color: var(--rule); color: var(--mute-2); }
    .tr-table tbody tr { background: var(--ink-2); border-color: var(--rule); }
    .tr-table tbody tr:hover { background: var(--ink-4); }
    .tr-status-badge {
      display: inline-block; padding: 0.125rem 0.5rem; border-radius: 9999px;
      font-size: 0.6875rem; font-weight: 500;
      text-transform: uppercase; letter-spacing: 0.04em;
    }
    .tr-status-draft     { background: rgba(156,163,175,0.18); color: var(--mute); }
    .tr-status-open      { background: var(--navy); color: #fff; }
    .tr-status-closed    { background: #dc2626; color: #fff; }
    .tr-status-cancelled { background: rgba(248,113,113,0.18); color: #f87171; }

    /* Icon action button (Ver detalle) */
    .tr-icon-btn { display: inline-grid; place-items: center; width: 30px; height: 30px; border-radius: 6px; border: 1px solid var(--rule); background: transparent; cursor: pointer; text-decoration: none; transition: background .15s, color .15s, border-color .15s; }
    .tr-icon-btn svg { width: 16px; height: 16px; }
    .tr-icon-view { color: #2563eb; background: color-mix(in srgb, #2563eb 10%, transparent); border-color: color-mix(in srgb, #2563eb 28%, transparent); }
    .tr-icon-view:hover { background: color-mix(in srgb, #2563eb 22%, transparent); color: #1d4ed8; }

    [data-theme='light'] .tr-card { background: #ffffff; }
    [data-theme='light'] .tr-table thead tr { background: #f9fafb; }
    [data-theme='light'] .tr-table tbody tr { background: #ffffff; }
    [data-theme='light'] .tr-table tbody tr:hover { background: #f9fafb; }
    [data-theme='light'] .tr-link { color: #2563eb; }
    [data-theme='light'] .tr-status-draft     { background: #f3f4f6; color: #6b7280; }
    [data-theme='light'] .tr-status-open      { background: var(--navy); color: #fff; }
    [data-theme='light'] .tr-status-closed    { background: #dc2626; color: #fff; }
    [data-theme='light'] .tr-status-cancelled { background: #fee2e2; color: #991b1b; }
  </style>
</AppLayout>

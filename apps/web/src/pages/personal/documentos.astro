---
import AppLayout from '../../layouts/AppLayout.astro'
import { can, getIdentity } from '../../lib/auth'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'

const identity = getIdentity(Astro.cookies)
if (!identity) return Astro.redirect('/login')
if (!can(identity, 'employees:read')) return Astro.redirect('/dashboard')

const tenantSlug = identity.tenantSlug ?? 'demo'
const headers = { Cookie: `auth=${identity.raw}`, 'X-Tenant': tenantSlug }

type Employee = {
  id: string
  code: string
  firstName: string
  lastName: string
  idNumber: string
  position: string | null
  department: string | null
  baseSalary: string
  hireDate?: string
  isActive: boolean
}

const q = (Astro.url.searchParams.get('q') ?? '').trim()

let employees: Employee[] = []
let total = 0
let error = ''

try {
  // Pull a generous batch of active employees for the picker. The list
  // is filtered client-side by name/code/idNumber so we don't need
  // pagination for the prototype — the page is admin-only and 1k
  // empleados activos is well within in-memory render budget.
  const params = new URLSearchParams({ limit: '1000' })
  if (q) params.set('search', q)
  const res = await fetch(`${API_URL}/employees?${params}`, { headers })
  if (res.status === 401) return Astro.redirect('/login')
  if (res.ok) {
    const json = (await res.json()) as { data: Employee[]; total?: number }
    employees = (json.data ?? []).filter((e) => e.isActive)
    total = json.total ?? employees.length
  } else {
    error = `No se pudo cargar empleados (HTTP ${res.status}).`
  }
} catch (err) {
  error = err instanceof Error ? err.message : 'No se pudo conectar con el servidor.'
}

function fmtSalary(v: string | number) {
  const n = Number(v)
  if (!Number.isFinite(n)) return String(v)
  return n.toLocaleString('es-PA', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
}
---

<AppLayout title="Documentos del personal">
  <div class="mx-auto w-full max-w-7xl p-8 lg:w-3/4">
    <div class="flex items-start justify-between gap-4 mb-6">
      <div>
        <h1 class="text-xl font-semibold text-gray-900 tracking-tight">Documentos del personal</h1>
        <p class="text-sm text-gray-500 mt-0.5">
          Genera contratos, certificaciones y cartas de trabajo en formato Word a partir de los datos
          activos del empleado y la configuración de la empresa.
        </p>
      </div>
    </div>

    {error && (
      <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
    )}

    <!-- Buscador -->
    <form method="GET" action="/personal/documentos" class="mb-5">
      <div class="grid grid-cols-1 sm:grid-cols-[1fr_auto_auto] gap-2">
        <input
          type="search"
          name="q"
          value={q}
          placeholder="Buscar por nombre, código o cédula…"
          class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent"
        />
        <button
          type="submit"
          class="inline-flex items-center justify-center gap-1.5 px-3.5 py-2 rounded-md bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 transition-colors"
        >
          Buscar
        </button>
        {q && (
          <a
            href="/personal/documentos"
            class="inline-flex items-center justify-center px-3.5 py-2 rounded-md border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors"
          >
            Limpiar
          </a>
        )}
      </div>
    </form>

    <!-- Tabla -->
    <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
      <div class="px-4 py-3 border-b border-gray-200 flex items-center justify-between">
        <h2 class="text-sm font-medium text-gray-900">Personal activo</h2>
        <span class="text-xs text-gray-500 font-mono">{employees.length} {employees.length === 1 ? 'empleado' : 'empleados'}</span>
      </div>

      {employees.length === 0 ? (
        <div class="py-16 text-center">
          <p class="text-sm text-gray-500">{q ? 'Ningún empleado coincide con la búsqueda.' : 'No hay personal activo todavía.'}</p>
        </div>
      ) : (
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-200 bg-gray-50">
                <th class="text-left px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide w-24">Código</th>
                <th class="text-left px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Empleado</th>
                <th class="text-left px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Posición</th>
                <th class="text-right px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Salario</th>
                <th class="text-right px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide w-[28rem]">Generar documento</th>
              </tr>
            </thead>
            <tbody>
              {employees.map((emp) => (
                <tr class="border-b border-gray-100 last:border-0 hover:bg-gray-50 transition-colors">
                  <td class="px-4 py-3 font-mono text-xs text-gray-500">{emp.code}</td>
                  <td class="px-4 py-3">
                    <div class="font-medium text-gray-900">{emp.lastName}, {emp.firstName}</div>
                    <div class="text-xs text-gray-400 font-mono">{emp.idNumber}</div>
                  </td>
                  <td class="px-4 py-3 text-gray-700">
                    <div>{emp.position ?? '—'}</div>
                    {emp.department && (
                      <div class="text-xs text-gray-400">{emp.department}</div>
                    )}
                  </td>
                  <td class="px-4 py-3 text-right tabular-nums text-gray-900">B/. {fmtSalary(emp.baseSalary)}</td>
                  <td class="px-4 py-3">
                    <div class="flex items-center justify-end gap-2 flex-wrap">
                      <a
                        href={`/api/personal/documentos/contrato/${emp.id}`}
                        class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md border border-gray-300 bg-white text-gray-700 text-xs font-medium hover:bg-gray-50 transition-colors"
                        title="Contrato de trabajo"
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                          <polyline points="14 2 14 8 20 8"/>
                        </svg>
                        Contrato
                      </a>
                      <a
                        href={`/api/personal/documentos/certificacion/${emp.id}`}
                        class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md border border-gray-300 bg-white text-gray-700 text-xs font-medium hover:bg-gray-50 transition-colors"
                        title="Certificación de trabajo"
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                          <polyline points="22 4 12 14.01 9 11.01"/>
                        </svg>
                        Certificación
                      </a>
                      <a
                        href={`/api/personal/documentos/carta/${emp.id}`}
                        class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md border border-gray-300 bg-white text-gray-700 text-xs font-medium hover:bg-gray-50 transition-colors"
                        title="Carta de trabajo"
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                          <polyline points="22 6 12 13 2 6"/>
                        </svg>
                        Carta
                      </a>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>

    <p class="mt-4 text-xs text-gray-400">
      Los textos legales son una base estándar — ajústalos según tu reglamento interno desde
      <code class="font-mono">apps/web/src/lib/docs/employee-docs.ts</code> o (a futuro)
      cargando una plantilla `.docx` editable por la empresa.
    </p>
  </div>
</AppLayout>

---
import ServerToastBridge from '../../../components/ServerToastBridge.astro'
import AppLayout from '../../../layouts/AppLayout.astro'
import { resolveTenantSlugFromCookie } from '../../../lib/tenant-slug'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')
const tenantSlug = resolveTenantSlugFromCookie(authCookie)

const { id } = Astro.params

type Partida = { id: string; code: string; name: string; isActive: boolean }

let partida: Partida | null = null

try {
  const res = await fetch(`${API_URL}/budget-items/${id}`, {
    headers: { Cookie: `auth=${authCookie}`, 'X-Tenant': tenantSlug },
  })
  if (res.status === 401) return Astro.redirect('/login')
  if (res.status === 404) return Astro.redirect('/config/budget-items')
  if (res.ok) partida = ((await res.json()) as { data: Partida }).data
} catch {
  return Astro.redirect('/config/budget-items')
}

if (!partida) return Astro.redirect('/config/budget-items')

const error = Astro.url.searchParams.get('error') ?? ''
const success = Astro.url.searchParams.get('success') === '1'
const errorMessages: Record<string, string> = {
  code_taken: 'El código ya está en uso.',
  'server-error': 'Error del servidor. Intenta de nuevo.',
  'missing-fields': 'Completa todos los campos requeridos.',
}
---

<AppLayout title={partida.name}>
  <div class="p-8 max-w-lg">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">{partida.name}</h1>
        <p class="text-sm text-gray-500 mt-0.5">Código: {partida.code}</p>
      </div>
      <div class="flex items-center gap-3">
        {!partida.isActive && (
          <span class="px-3 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-500">Inactivo</span>
        )}
        <a href="/config/budget-items" class="text-sm text-gray-500 hover:text-gray-700">← Volver</a>
      </div>
    </div>

    {success && (
      <div data-server-toast="success" class="mb-6 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">
        Partida actualizada correctamente.
      </div>
    )}
    {error && (
      <div data-server-toast="error" class="mb-6 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
        {errorMessages[error] ?? 'Ocurrió un error inesperado.'}
      </div>
    )}

    <form id="budgetEditForm" method="POST" action={`/api/config/budget-items/${id}`}>
      <input type="hidden" name="_method" value="PUT" />

      <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Código *</label>
          <input
            type="text"
            name="code"
            class="input"
            required
            value={partida.code}
            maxlength="20"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Nombre *</label>
          <input
            type="text"
            name="name"
            class="input"
            required
            value={partida.name}
          />
        </div>
      </div>
    </form>

    {partida.isActive && (
      <form
        id="budgetDeleteForm"
        method="POST"
        action={`/api/config/budget-items/${id}`}
        data-confirm-submit="¿Dar de baja esta partida?" data-confirm-title="Dar de baja partida" data-confirm-tone="danger" data-confirm-label="Dar de baja"
      >
        <input type="hidden" name="_method" value="DELETE" />
      </form>
    )}

    <div class="flex justify-between mt-4">
      {partida.isActive && (
        <button
          type="submit"
          form="budgetDeleteForm"
          class="px-4 py-2 text-sm text-red-600 bg-white border border-red-300 rounded-lg hover:bg-red-50 transition-colors"
        >
          Dar de baja
        </button>
      )}
      <div class="flex gap-3 ml-auto">
        <a
          href="/config/budget-items"
          class="px-4 py-2 text-sm text-gray-600 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors"
        >
          Cancelar
        </a>
        <button
          type="submit"
          form="budgetEditForm"
          class="px-4 py-2 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors"
        >
          Guardar cambios
        </button>
      </div>
    </div>
  </div>
  <ServerToastBridge />
</AppLayout>

<style>
  .input {
    @apply w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent;
  }
</style>

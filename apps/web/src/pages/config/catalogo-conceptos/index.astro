---
import AppLayout from '../../../layouts/AppLayout.astro'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')

type CatalogItem = { id: string; code: string; name: string; sortOrder: number }
type Catalogs = {
  payrollTypes: CatalogItem[]
  frequencies: CatalogItem[]
  situations: CatalogItem[]
  accumulators: CatalogItem[]
}
type CuentaContable = { id: string; code: string; name: string; isActive: boolean }

let catalogs: Catalogs = { payrollTypes: [], frequencies: [], situations: [], accumulators: [] }
let cuentasContables: CuentaContable[] = []
let loadError = ''

try {
  const headers = { Cookie: `auth=${authCookie}`, 'X-Tenant': 'demo' }
  const [configRes, cuentasRes] = await Promise.all([
    fetch(`${API_URL}/concepts/config`, { headers }),
    fetch(`${API_URL}/cuentas-contables`, { headers }),
  ])
  if (configRes.status === 401) return Astro.redirect('/login')
  if (configRes.ok) catalogs = ((await configRes.json()) as { data: Catalogs }).data
  if (cuentasRes.ok)
    cuentasContables = ((await cuentasRes.json()) as { data: CuentaContable[] }).data ?? []
} catch {
  loadError = 'No se pudo conectar con el servidor'
}

const activeTab = Astro.url.searchParams.get('tab') ?? 'payrollTypes'
const success = Astro.url.searchParams.get('success') === '1'
const error = Astro.url.searchParams.get('error') ?? ''

const errorMessages: Record<string, string> = {
  code_taken: 'El código ya está en uso.',
  has_links: 'No se puede eliminar: está siendo usado por conceptos.',
  'server-error': 'Error del servidor.',
  'missing-fields': 'Completa todos los campos.',
}

const tabs = [
  {
    key: 'payrollTypes',
    label: 'Tipos de Planilla',
    kind: 'payroll-types',
    items: catalogs.payrollTypes,
  },
  { key: 'frequencies', label: 'Frecuencias', kind: 'frequencies', items: catalogs.frequencies },
  { key: 'situations', label: 'Situaciones', kind: 'situations', items: catalogs.situations },
  { key: 'accumulators', label: 'Acumulados', kind: 'accumulators', items: catalogs.accumulators },
]
const currentTab = tabs.find((t) => t.key === activeTab) ?? tabs[0]
const isCuentasTab = activeTab === 'cuentas'
---

<AppLayout title="Catálogos de Conceptos">
  <div class="page">
    <div class="page-header">
      <div>
        <h1 class="page-title">Catálogos de Conceptos</h1>
        <p class="page-sub">Gestión de tipos, frecuencias, situaciones y acumulados vinculables a conceptos</p>
      </div>
    </div>

    {loadError && <div class="alert alert-err">{loadError}</div>}
    {success && <div class="alert alert-ok">Guardado correctamente.</div>}
    {error && <div class="alert alert-err">{errorMessages[error] ?? 'Ocurrió un error inesperado.'}</div>}

    <!-- Tab Navigation -->
    <div class="tabs-bar">
      {tabs.map((tab) => (
        <a
          href={`/config/catalogo-conceptos?tab=${tab.key}`}
          class={`tab-link${tab.key === activeTab ? ' tab-active' : ''}`}
        >
          {tab.label}
          <span class="tab-count">{tab.items.length}</span>
        </a>
      ))}
      <a
        href="/config/catalogo-conceptos?tab=cuentas"
        class={`tab-link${isCuentasTab ? ' tab-active' : ''}`}
      >
        Cuentas Contables
        <span class="tab-count">{cuentasContables.length}</span>
      </a>
    </div>

    <!-- Card -->
    <div class="card">
      <div class="card-header">
        <span class="card-title">{isCuentasTab ? 'Cuentas Contables' : currentTab.label}</span>
        <button type="button" id="btnNew" class="btn-primary">+ Nuevo</button>
      </div>

      {isCuentasTab ? (
        <>
          <!-- New cuenta contable form -->
          <div id="newItemForm" class="new-form hidden">
            <form method="POST" action="/api/config/cuentas-contables" class="new-form-row">
              <div class="field">
                <label class="label">Código *</label>
                <input type="text" name="code" class="inp" required maxlength="20" placeholder="ej: 1001" />
              </div>
              <div class="field flex-1">
                <label class="label">Nombre *</label>
                <input type="text" name="name" class="inp" required maxlength="255" placeholder="ej: Caja General" />
              </div>
              <div class="form-actions">
                <button type="submit" class="btn-ok">Guardar</button>
                <button type="button" id="btnCancelNew" class="btn-ghost">Cancelar</button>
              </div>
            </form>
          </div>

          {cuentasContables.length === 0 ? (
            <div class="empty-state">No hay cuentas contables registradas.</div>
          ) : (
            <table class="tbl">
              <thead>
                <tr>
                  <th class="th">Código</th>
                  <th class="th">Nombre</th>
                  <th class="th w-28"></th>
                </tr>
              </thead>
              <tbody>
                {cuentasContables.map((item) => (
                  <tr
                    class="tr"
                    id={`row-${item.id}`}
                    data-edit-target={item.id}
                    data-name={item.name}
                  >
                    <td class="td td-code">{item.code}</td>
                    <td class="td view-name">{item.name}</td>

                    <td class="td hidden edit-cell" colspan="2">
                      <form
                        method="POST"
                        action={`/api/config/cuentas-contables/${item.id}`}
                        class="edit-row"
                      >
                        <input type="hidden" name="_method" value="PUT" />
                        <input type="text" name="name" value={item.name} data-edit-input="name" class="inp flex-1" required maxlength="255" />
                        <button type="submit" class="btn-ok-sm">Guardar</button>
                        <button type="button" data-cancel-edit={item.id} class="btn-ghost-sm">Cancelar</button>
                      </form>
                    </td>

                    <td class="td view-actions">
                      <div class="row-actions">
                        <button
                          type="button"
                          data-start-edit-cuenta={item.id}
                          title="Editar"
                          class="action-btn"
                        >
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                          </svg>
                        </button>
                        <form
                          method="POST"
                          action={`/api/config/cuentas-contables/${item.id}`}
                          onsubmit="return confirm('¿Dar de baja esta cuenta contable?')"
                        >
                          <input type="hidden" name="_method" value="DELETE" />
                          <button type="submit" title="Dar de baja" class="action-btn action-del">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                              <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                            </svg>
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}
        </>
      ) : (
        <>
          <!-- New item form (hidden by default) -->
          <div id="newItemForm" class="new-form hidden">
            <form method="POST" action={`/api/config/catalogo-conceptos/${currentTab.kind}`} class="new-form-row">
              <input type="hidden" name="_tab" value={activeTab} />
              <div class="field">
                <label class="label">Código *</label>
                <input type="text" name="code" class="inp" required maxlength="50" placeholder="ej: quincenal" />
              </div>
              <div class="field flex-1">
                <label class="label">Nombre *</label>
                <input type="text" name="name" class="inp" required maxlength="100" placeholder="ej: Quincenal" />
              </div>
              <div class="field w-24">
                <label class="label">Orden</label>
                <input type="number" name="sortOrder" class="inp" value="0" min="0" />
              </div>
              <div class="form-actions">
                <button type="submit" class="btn-ok">Guardar</button>
                <button type="button" id="btnCancelNew" class="btn-ghost">Cancelar</button>
              </div>
            </form>
          </div>

          <!-- Items table -->
          {currentTab.items.length === 0 ? (
            <div class="empty-state">No hay registros en este catálogo.</div>
          ) : (
            <table class="tbl">
              <thead>
                <tr>
                  <th class="th">Código</th>
                  <th class="th">Nombre</th>
                  <th class="th w-20 text-center">Orden</th>
                  <th class="th w-28"></th>
                </tr>
              </thead>
              <tbody>
                {currentTab.items.map((item) => (
                  <tr
                    class="tr"
                    id={`row-${item.id}`}
                    data-edit-target={item.id}
                    data-name={item.name}
                    data-sort-order={item.sortOrder}
                  >
                    <td class="td td-code">{item.code}</td>
                    <td class="td view-name">{item.name}</td>
                    <td class="td text-center view-order">{item.sortOrder}</td>

                    <!-- Edit inline form (hidden, spans name+order+actions cols via JS) -->
                    <td class="td hidden edit-cell" colspan="3">
                      <form
                        method="POST"
                        action={`/api/config/catalogo-conceptos/${currentTab.kind}/${item.id}`}
                        class="edit-row"
                      >
                        <input type="hidden" name="_method" value="PUT" />
                        <input type="hidden" name="_tab" value={activeTab} />
                        <input type="text" name="name" value={item.name} data-edit-input="name" class="inp flex-1" required maxlength="100" />
                        <input type="number" name="sortOrder" value={item.sortOrder} data-edit-input="sortOrder" class="inp w-20" min="0" />
                        <button type="submit" class="btn-ok-sm">Guardar</button>
                        <button type="button" data-cancel-edit={item.id} class="btn-ghost-sm">Cancelar</button>
                      </form>
                    </td>

                    <td class="td view-actions">
                      <div class="row-actions">
                        <button
                          type="button"
                          data-start-edit={item.id}
                          title="Editar"
                          class="action-btn"
                        >
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                          </svg>
                        </button>
                        <form
                          method="POST"
                          action={`/api/config/catalogo-conceptos/${currentTab.kind}/${item.id}`}
                          onsubmit="return confirm('¿Eliminar este registro?')"
                        >
                          <input type="hidden" name="_method" value="DELETE" />
                          <input type="hidden" name="_tab" value={activeTab} />
                          <button type="submit" title="Eliminar" class="action-btn action-del">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                              <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                            </svg>
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}
        </>
      )}
    </div>
  </div>
</AppLayout>

<style>
  .page        { padding: 2rem; max-width: 860px; }
  .page-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 1.5rem; }
  .page-title  { font-size: 1.25rem; font-weight: 600; color: var(--fore); margin: 0 0 .25rem; font-family: var(--f-display); }
  .page-sub    { font-size: .8125rem; color: var(--mute); margin: 0; }

  .alert        { padding: .75rem 1rem; border-radius: 6px; font-size: .8125rem; margin-bottom: 1rem; border: 1px solid; }
  .alert-ok     { background: color-mix(in srgb, var(--ok) 10%, var(--ink-2)); border-color: var(--ok); color: var(--ok); }
  .alert-err    { background: color-mix(in srgb, var(--err) 10%, var(--ink-2)); border-color: var(--err); color: var(--err); }

  /* Tabs */
  .tabs-bar   { display: flex; gap: 0; border-bottom: 1px solid var(--rule); margin-bottom: 1.25rem; }
  .tab-link   { display: flex; align-items: center; gap: .5rem; padding: .625rem 1.25rem; font-size: .8125rem; font-weight: 500; color: var(--mute); text-decoration: none; border-bottom: 2px solid transparent; margin-bottom: -1px; transition: color .15s, border-color .15s; }
  .tab-link:hover  { color: var(--fore); }
  .tab-active { color: var(--navy-hi); border-bottom-color: var(--navy-hi); }
  .tab-count  { background: var(--ink-4); color: var(--mute-2); font-size: .7rem; font-weight: 600; padding: .1rem .4rem; border-radius: 20px; min-width: 1.4rem; text-align: center; }
  .tab-active .tab-count { background: var(--navy-soft); color: var(--navy-hi); }

  /* Card */
  .card        { background: var(--ink-2); border: 1px solid var(--rule); border-radius: 8px; overflow: hidden; }
  .card-header { display: flex; align-items: center; justify-content: space-between; padding: .875rem 1.25rem; border-bottom: 1px solid var(--rule); }
  .card-title  { font-size: .875rem; font-weight: 600; color: var(--fore); }

  /* New form */
  .new-form     { padding: 1rem 1.25rem; border-bottom: 1px solid var(--rule); background: var(--ink-3); }
  .new-form-row { display: flex; gap: .75rem; align-items: flex-end; flex-wrap: wrap; }
  .field        { display: flex; flex-direction: column; gap: .25rem; }
  .flex-1       { flex: 1; }
  .w-24         { width: 6rem; }
  .label        { font-size: .75rem; font-weight: 500; color: var(--mute-2); }
  .form-actions { display: flex; gap: .5rem; align-items: flex-end; }

  /* Table */
  .tbl { width: 100%; border-collapse: collapse; font-size: .8125rem; }
  .th  { padding: .625rem 1rem; text-align: left; font-size: .75rem; font-weight: 600; color: var(--mute); text-transform: uppercase; letter-spacing: .04em; background: var(--ink-3); border-bottom: 1px solid var(--rule); }
  .td  { padding: .75rem 1rem; color: var(--fore); border-bottom: 1px solid var(--rule); vertical-align: middle; }
  .tr:last-child .td { border-bottom: none; }
  .tr:hover .td { background: var(--ink-3); }
  .td-code { font-family: var(--f-mono); font-size: .75rem; color: var(--mute-2); }
  .w-20 { width: 5rem; }
  .w-28 { width: 7rem; }
  .text-center { text-align: center; }

  /* Edit inline */
  .edit-cell { padding: .5rem 1rem; }
  .edit-row  { display: flex; gap: .625rem; align-items: center; }

  /* Row actions */
  .row-actions { display: flex; align-items: center; justify-content: flex-end; gap: .25rem; }
  .action-btn  { display: flex; align-items: center; justify-content: center; width: 28px; height: 28px; border-radius: 6px; border: none; background: transparent; color: var(--mute); cursor: pointer; transition: background .15s, color .15s; }
  .action-btn:hover { background: var(--navy-soft); color: var(--navy-hi); }
  .action-del:hover { background: color-mix(in srgb, var(--err) 12%, transparent); color: var(--err); }

  /* Buttons */
  .btn-primary { background: var(--navy); color: #fff; border: none; padding: .5rem 1rem; border-radius: 6px; font-size: .8125rem; font-weight: 600; cursor: pointer; transition: background .15s; }
  .btn-primary:hover { background: var(--navy-hi); }
  .btn-ok      { background: var(--ok); color: #fff; border: none; padding: .5rem .875rem; border-radius: 6px; font-size: .8125rem; font-weight: 600; cursor: pointer; transition: opacity .15s; white-space: nowrap; }
  .btn-ok:hover { opacity: .88; }
  .btn-ok-sm   { background: var(--navy); color: #fff; border: none; padding: .375rem .75rem; border-radius: 5px; font-size: .75rem; font-weight: 600; cursor: pointer; white-space: nowrap; }
  .btn-ok-sm:hover { background: var(--navy-hi); }
  .btn-ghost   { background: transparent; color: var(--mute-2); border: 1px solid var(--rule); padding: .5rem .875rem; border-radius: 6px; font-size: .8125rem; cursor: pointer; transition: background .15s; white-space: nowrap; }
  .btn-ghost:hover { background: var(--ink-4); }
  .btn-ghost-sm { background: transparent; color: var(--mute-2); border: 1px solid var(--rule); padding: .375rem .625rem; border-radius: 5px; font-size: .75rem; cursor: pointer; white-space: nowrap; }
  .btn-ghost-sm:hover { background: var(--ink-4); }

  /* Input */
  .inp { background: var(--ink); color: var(--fore); border: 1px solid var(--rule); border-radius: 5px; padding: .4375rem .625rem; font-size: .8125rem; outline: none; font-family: inherit; width: 100%; }
  .inp:focus { border-color: var(--navy-hi); box-shadow: 0 0 0 2px var(--navy-soft); }

  /* Empty */
  .empty-state { padding: 3rem; text-align: center; color: var(--mute); font-size: .875rem; }

  .hidden { display: none !important; }
</style>

<script is:inline>
  // Toggle new item form
  document.getElementById('btnNew')?.addEventListener('click', () => {
    document.getElementById('newItemForm')?.classList.toggle('hidden')
  })
  document.getElementById('btnCancelNew')?.addEventListener('click', () => {
    document.getElementById('newItemForm')?.classList.add('hidden')
  })

  // Sync the inline-edit inputs with the canonical values carried on the row
  // via `data-*` attributes. Rewriting the .value on every open guarantees
  // the field reflects the latest DB value that was server-rendered — any
  // stale text left over from a previous aborted edit is wiped. Without
  // this, the browser would keep whatever the user last typed into the
  // input node, making the field appear "not pre-loaded".
  function resetEditInputs(row) {
    var inputs = row.querySelectorAll('[data-edit-input]')
    for (var i = 0; i < inputs.length; i++) {
      var input = inputs[i]
      var key = input.getAttribute('data-edit-input')
      if (key === 'name') input.value = row.dataset.name || ''
      else if (key === 'sortOrder') input.value = row.dataset.sortOrder || '0'
    }
  }

  function openEdit(row, hideSelectors) {
    resetEditInputs(row)
    row.querySelectorAll(hideSelectors).forEach(function (el) { el.classList.add('hidden') })
    row.querySelectorAll('.edit-cell').forEach(function (el) { el.classList.remove('hidden') })
    var firstInput = row.querySelector('[data-edit-input="name"]')
    if (firstInput) {
      firstInput.focus()
      firstInput.select()
    }
  }

  function closeEdit(row, showSelectors) {
    row.querySelectorAll(showSelectors).forEach(function (el) { el.classList.remove('hidden') })
    row.querySelectorAll('.edit-cell').forEach(function (el) { el.classList.add('hidden') })
  }

  // Delegated listeners — robust against Astro's script scoping and easier
  // to reason about than a string of onclick="fn(id)" attributes.
  document.addEventListener('click', function (e) {
    var target = e.target instanceof Element ? e.target : null
    if (!target) return
    var startBtn = target.closest('[data-start-edit]')
    if (startBtn) {
      var id = startBtn.getAttribute('data-start-edit')
      var row = document.getElementById('row-' + id)
      if (row) openEdit(row, '.view-name, .view-order, .view-actions')
      return
    }
    var startCuentaBtn = target.closest('[data-start-edit-cuenta]')
    if (startCuentaBtn) {
      var idC = startCuentaBtn.getAttribute('data-start-edit-cuenta')
      var rowC = document.getElementById('row-' + idC)
      if (rowC) openEdit(rowC, '.view-name, .view-actions')
      return
    }
    var cancelBtn = target.closest('[data-cancel-edit]')
    if (cancelBtn) {
      var idX = cancelBtn.getAttribute('data-cancel-edit')
      var rowX = document.getElementById('row-' + idX)
      if (rowX) {
        var showSel = rowX.dataset.sortOrder !== undefined
          ? '.view-name, .view-order, .view-actions'
          : '.view-name, .view-actions'
        closeEdit(rowX, showSel)
      }
    }
  })
</script>

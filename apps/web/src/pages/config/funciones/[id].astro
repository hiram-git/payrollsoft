---
import AppLayout from '../../../layouts/AppLayout.astro'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')

const { id } = Astro.params

type Funcion = {
  id: string
  code: string
  name: string
  description: string | null
  isActive: boolean
}

let funcion: Funcion | null = null

try {
  const res = await fetch(`${API_URL}/funciones/${id}`, {
    headers: { Cookie: `auth=${authCookie}`, 'X-Tenant': 'demo' },
  })
  if (res.status === 401) return Astro.redirect('/login')
  if (res.status === 404) return Astro.redirect('/config/funciones')
  if (res.ok) {
    const json = (await res.json()) as { data: Funcion }
    funcion = json.data
  }
} catch {
  return Astro.redirect('/config/funciones')
}

if (!funcion) return Astro.redirect('/config/funciones')

const error = Astro.url.searchParams.get('error') ?? ''
const success = Astro.url.searchParams.get('success') === '1'
const errorMessages: Record<string, string> = {
  code_taken: 'El código ya está en uso.',
  'server-error': 'Error del servidor. Intenta de nuevo.',
  'missing-fields': 'Completa todos los campos requeridos.',
}
---

<AppLayout title={funcion.name}>
  <div class="p-8 max-w-2xl">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">{funcion.name}</h1>
        <p class="text-sm text-gray-500 mt-0.5">Código: {funcion.code}</p>
      </div>
      <div class="flex items-center gap-3">
        {!funcion.isActive && (
          <span class="px-3 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-500">Inactivo</span>
        )}
        <a href="/config/funciones" class="text-sm text-gray-500 hover:text-gray-700">← Volver</a>
      </div>
    </div>

    {success && (
      <div class="mb-6 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">
        Función actualizada correctamente.
      </div>
    )}
    {error && (
      <div class="mb-6 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
        {errorMessages[error] ?? 'Ocurrió un error inesperado.'}
      </div>
    )}

    <form method="POST" action={`/api/config/funciones/${id}`}>
      <input type="hidden" name="_method" value="PUT" />

      <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Código *</label>
            <input type="text" name="code" class="input" required value={funcion.code} maxlength="20" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Nombre *</label>
            <input type="text" name="name" class="input" required value={funcion.name} />
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Descripción</label>
          <textarea name="description" class="input resize-none" rows="3" maxlength="500">{funcion.description ?? ''}</textarea>
        </div>
      </div>

      <div class="flex justify-between mt-4">
        {funcion.isActive && (
          <form method="POST" action={`/api/config/funciones/${id}`}
            onsubmit="return confirm('¿Dar de baja esta función?')"
          >
            <input type="hidden" name="_method" value="DELETE" />
            <button type="submit" class="px-4 py-2 text-sm text-red-600 bg-white border border-red-300 rounded-lg hover:bg-red-50 transition-colors">
              Dar de baja
            </button>
          </form>
        )}
        <div class="flex gap-3 ml-auto">
          <a href="/config/funciones" class="px-4 py-2 text-sm text-gray-600 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
            Cancelar
          </a>
          <button type="submit" class="px-4 py-2 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors">
            Guardar cambios
          </button>
        </div>
      </div>
    </form>
  </div>
</AppLayout>

<style>
  .input {
    @apply w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent;
  }
</style>

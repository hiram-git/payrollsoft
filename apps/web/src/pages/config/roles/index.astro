---
import PermissionGate from '../../../components/PermissionGate.astro'
import AppLayout from '../../../layouts/AppLayout.astro'
import { can, getIdentity } from '../../../lib/auth'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'

const identity = getIdentity(Astro.cookies)
if (!identity) return Astro.redirect('/login')
if (!can(identity, 'roles:read')) return Astro.redirect('/dashboard')

const tenantSlug = identity.tenantSlug ?? 'demo'

type Role = {
  id: string
  code: string
  name: string
  description: string | null
  isSystem: boolean
  createdAt: string
  updatedAt: string
}

let roles: Role[] = []
let error = ''

try {
  const res = await fetch(`${API_URL}/roles`, {
    headers: { Cookie: `auth=${identity.raw}`, 'X-Tenant': tenantSlug },
  })
  if (res.ok) {
    const json = (await res.json()) as { data: Role[] }
    roles = json.data ?? []
  } else if (res.status === 401) {
    return Astro.redirect('/login')
  } else {
    error = 'No se pudo cargar la lista de roles.'
  }
} catch {
  error = 'No se pudo conectar con el servidor.'
}

const flash = Astro.url.searchParams.get('flash')
---

<AppLayout title="Roles y permisos">
  <div class="p-8">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-xl font-semibold text-gray-900 tracking-tight">Roles y permisos</h1>
        <p class="text-sm text-gray-500 mt-0.5">{roles.length} {roles.length === 1 ? 'rol' : 'roles'} disponibles. Los roles del sistema no pueden eliminarse.</p>
      </div>
      <PermissionGate require="roles:create">
        <a
          href="/config/roles/new"
          class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Nuevo rol
        </a>
      </PermissionGate>
    </div>

    {flash === 'created' && (
      <div class="mb-4 rounded-md bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">Rol creado correctamente.</div>
    )}
    {flash === 'updated' && (
      <div class="mb-4 rounded-md bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">Permisos actualizados.</div>
    )}
    {error && (
      <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
    )}

    <div class="border border-gray-200 rounded-lg overflow-hidden bg-white">
      {roles.length === 0 ? (
        <div class="py-16 text-center text-sm text-gray-400">No hay roles para mostrar.</div>
      ) : (
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200 bg-gray-50">
              <th class="text-left px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Código</th>
              <th class="text-left px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Nombre</th>
              <th class="text-left px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Descripción</th>
              <th class="text-left px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Tipo</th>
              <th class="px-4 py-3"></th>
            </tr>
          </thead>
          <tbody>
            {roles.map((r) => (
              <tr class="border-b border-gray-100 last:border-0 hover:bg-gray-50 transition-colors">
                <td class="px-4 py-3.5 font-mono text-xs text-gray-500">{r.code}</td>
                <td class="px-4 py-3.5 font-medium text-gray-900">
                  <a href={`/config/roles/${r.id}`} class="hover:text-gray-600">{r.name}</a>
                </td>
                <td class="px-4 py-3.5 text-gray-600">{r.description ?? '—'}</td>
                <td class="px-4 py-3.5">
                  {r.isSystem ? (
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700">Sistema</span>
                  ) : (
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">Personalizado</span>
                  )}
                </td>
                <td class="px-4 py-3.5 text-right">
                  <a href={`/config/roles/${r.id}`} title="Permisos" aria-label="Permisos" class="inline-flex items-center justify-center text-blue-600 hover:text-blue-800">
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
  </div>
</AppLayout>

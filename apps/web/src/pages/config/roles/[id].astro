---
import AppLayout from '../../../layouts/AppLayout.astro'
import { can, getIdentity } from '../../../lib/auth'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'

const identity = getIdentity(Astro.cookies)
if (!identity) return Astro.redirect('/login')
if (!can(identity, 'roles:read')) return Astro.redirect('/dashboard')

const tenantSlug = identity.tenantSlug ?? 'demo'
const roleId = Astro.params.id ?? ''

type RoleDetail = {
  id: string
  code: string
  name: string
  description: string | null
  isSystem: boolean
  permissions: string[]
  parentRoleIds: string[]
  childRoleIds: string[]
  userCount: number
  createdAt: string
  updatedAt: string
}

type CatalogEntry = {
  code: string
  module: string
  action: string
  scope: 'tenant' | 'global'
  description: string
  isDangerous: boolean
}

let role: RoleDetail | null = null
let catalog: CatalogEntry[] = []
let error = ''

try {
  const [roleRes, catRes] = await Promise.all([
    fetch(`${API_URL}/roles/${roleId}`, {
      headers: { Cookie: `auth=${identity.raw}`, 'X-Tenant': tenantSlug },
    }),
    fetch(`${API_URL}/roles/permissions/catalog`, {
      headers: { Cookie: `auth=${identity.raw}`, 'X-Tenant': tenantSlug },
    }),
  ])
  if (roleRes.ok) {
    const json = (await roleRes.json()) as { data: RoleDetail }
    role = json.data
  } else if (roleRes.status === 404) {
    return Astro.redirect('/config/roles')
  }
  if (catRes.ok) {
    const json = (await catRes.json()) as { data: CatalogEntry[] }
    catalog = json.data ?? []
  }
} catch {
  error = 'No se pudo cargar el rol.'
}

const editable = role && !role.isSystem && can(identity, 'roles:update')
const granted = new Set(role?.permissions ?? [])

// Group catalog by module for the tree view, ignoring global permissions
// since this page is tenant-scoped.
const grouped = new Map<string, CatalogEntry[]>()
for (const entry of catalog) {
  if (entry.scope !== 'tenant') continue
  if (!grouped.has(entry.module)) grouped.set(entry.module, [])
  grouped.get(entry.module)?.push(entry)
}
const moduleLabels: Record<string, string> = {
  employees: 'Empleados',
  positions: 'Posiciones',
  shifts: 'Turnos',
  attendance: 'Asistencia',
  vacations: 'Vacaciones',
  loans: 'Préstamos',
  advances: 'Anticipos',
  creditors: 'Acreedores',
  payroll: 'Planilla',
  concepts: 'Conceptos',
  catalogs: 'Catálogos',
  payslip: 'Comprobantes',
  reports: 'Reportes',
  users: 'Usuarios',
  roles: 'Roles',
  settings: 'Ajustes',
  audit: 'Auditoría',
}
const moduleEntries = Array.from(grouped.entries()).sort((a, b) =>
  (moduleLabels[a[0]] ?? a[0]).localeCompare(moduleLabels[b[0]] ?? b[0], 'es')
)

const flash = Astro.url.searchParams.get('flash')
---

<AppLayout title={role?.name ?? 'Rol'}>
  <div class="p-8 max-w-5xl">
    <div class="mb-6">
      <a href="/config/roles" class="text-xs text-gray-500 hover:text-gray-900">← Volver a roles</a>
      <div class="mt-2 flex items-center justify-between">
        <div>
          <h1 class="text-xl font-semibold text-gray-900 tracking-tight">{role?.name ?? 'Rol'}</h1>
          <p class="text-sm text-gray-500 mt-0.5">
            Código: <span class="font-mono">{role?.code}</span>
            {role?.isSystem && (
              <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700">Rol del sistema</span>
            )}
            <span class="ml-2 text-gray-400">· {role?.userCount ?? 0} {role?.userCount === 1 ? 'usuario' : 'usuarios'}</span>
          </p>
          {role?.description && <p class="text-sm text-gray-600 mt-2">{role.description}</p>}
        </div>
      </div>
    </div>

    {flash === 'updated' && (
      <div class="mb-4 rounded-md bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">Permisos actualizados.</div>
    )}
    {error && (
      <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
    )}

    {role && (
      <form method="POST" action={`/api/roles/${role.id}/permissions`} class="space-y-4">
        {role.isSystem && (
          <div class="rounded-md bg-amber-50 border border-amber-200 px-4 py-3 text-sm text-amber-800">
            Este es un rol del sistema. Sus permisos están definidos por la plantilla y no pueden editarse.
          </div>
        )}

        {moduleEntries.length === 0 ? (
          <div class="border border-gray-200 rounded-lg bg-white p-6 text-sm text-gray-500">
            No se pudo cargar el catálogo de permisos. Recarga la página o contacta a soporte.
          </div>
        ) : (
          <div class="space-y-3">
            {moduleEntries.map(([module, entries]) => (
              <details class="border border-gray-200 rounded-lg bg-white" open={entries.some((e) => granted.has(e.code))}>
                <summary class="cursor-pointer px-4 py-3 flex items-center justify-between hover:bg-gray-50 transition-colors">
                  <div>
                    <span class="text-sm font-medium text-gray-900">{moduleLabels[module] ?? module}</span>
                    <span class="ml-2 text-xs text-gray-400">{entries.filter((e) => granted.has(e.code)).length} / {entries.length}</span>
                  </div>
                  <span class="text-xs text-gray-400 font-mono">{module}</span>
                </summary>
                <div class="border-t border-gray-100 px-4 py-3 space-y-2">
                  {entries.map((p) => (
                    <label class="flex items-start gap-3 py-1 cursor-pointer">
                      <input
                        type="checkbox"
                        name="permissions"
                        value={p.code}
                        checked={granted.has(p.code)}
                        disabled={!editable}
                        class="mt-0.5 h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500"
                      />
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2">
                          <code class="text-xs font-mono text-gray-700">{p.code}</code>
                          {p.isDangerous && (
                            <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-red-50 text-red-700">Sensible</span>
                          )}
                        </div>
                        <div class="text-xs text-gray-500 mt-0.5">{p.description}</div>
                      </div>
                    </label>
                  ))}
                </div>
              </details>
            ))}
          </div>
        )}

        {editable && (
          <div class="flex items-center gap-2 pt-2">
            <button type="submit" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-md bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 transition-colors">Guardar permisos</button>
            <a href="/config/roles" class="px-4 py-2 text-sm text-gray-600 hover:text-gray-900">Cancelar</a>
          </div>
        )}
      </form>
    )}
  </div>
</AppLayout>

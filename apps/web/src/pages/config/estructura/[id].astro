---
import ServerToastBridge from '../../../components/ServerToastBridge.astro'
import AppLayout from '../../../layouts/AppLayout.astro'
import { resolveTenantSlugFromCookie } from '../../../lib/tenant-slug'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')
const tenantSlug = resolveTenantSlugFromCookie(authCookie)

const { id } = Astro.params

type Position = {
  id: string
  code: string
  name: string
  salary: string
  overtimeAmount: string | null
  representationAmount: string | null
  jobTitleId: string | null
  departmentId: string | null
  budgetItemId: string | null
  overtimeBudgetItemId: string | null
  representationBudgetItemId: string | null
  thirteenthMonthBudgetItemId: string | null
  isActive: boolean
  status: 'en_uso' | 'vacante' | string
}
type CatalogItem = { id: string; code: string; name: string; isActive: boolean }

let pos: Position | null = null
let cargos: CatalogItem[] = []
let departamentos: CatalogItem[] = []
let partidas: CatalogItem[] = []

try {
  const headers = { Cookie: `auth=${authCookie}`, 'X-Tenant': tenantSlug }
  const [pRes, cRes, dRes, ptRes] = await Promise.all([
    fetch(`${API_URL}/positions/${id}`, { headers }),
    fetch(`${API_URL}/job-titles`, { headers }),
    fetch(`${API_URL}/departments`, { headers }),
    fetch(`${API_URL}/budget-items`, { headers }),
  ])
  if (pRes.status === 401) return Astro.redirect('/login')
  if (pRes.status === 404) return Astro.redirect('/config/estructura')
  if (pRes.ok) pos = ((await pRes.json()) as { data: Position }).data
  if (cRes.ok) cargos = ((await cRes.json()) as { data: CatalogItem[] }).data ?? []
  if (dRes.ok) departamentos = ((await dRes.json()) as { data: CatalogItem[] }).data ?? []
  if (ptRes.ok) partidas = ((await ptRes.json()) as { data: CatalogItem[] }).data ?? []
} catch {
  return Astro.redirect('/config/estructura')
}

if (!pos) return Astro.redirect('/config/estructura')

function buildOptions(items: CatalogItem[], currentId: string | null) {
  const active = items.filter((i) => i.isActive)
  if (currentId && !active.find((i) => i.id === currentId)) {
    const current = items.find((i) => i.id === currentId)
    if (current) active.unshift(current)
  }
  return active
}

const cargoOptions = buildOptions(cargos, pos.jobTitleId)
const deptOptions = buildOptions(departamentos, pos.departmentId)
// Each concept's partida selector keeps its currently-assigned (even if
// inactive) item visible so editing doesn't silently drop it.
const basePartidaOptions = buildOptions(partidas, pos.budgetItemId)
const overtimePartidaOptions = buildOptions(partidas, pos.overtimeBudgetItemId)
const representationPartidaOptions = buildOptions(partidas, pos.representationBudgetItemId)
const thirteenthPartidaOptions = buildOptions(partidas, pos.thirteenthMonthBudgetItemId)

const error = Astro.url.searchParams.get('error') ?? ''
const success = Astro.url.searchParams.get('success') === '1'
const errorMessages: Record<string, string> = {
  code_taken: 'El código ya está en uso.',
  invalid_budget_item: 'Una de las partidas seleccionadas no existe o está inactiva.',
  'server-error': 'Error del servidor. Intenta de nuevo.',
  'missing-fields': 'Completa todos los campos requeridos.',
}
---

<AppLayout title={pos.name}>
  <div class="p-8 max-w-2xl">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">{pos.name}</h1>
        <p class="text-sm text-gray-500 mt-0.5">Código: {pos.code}</p>
      </div>
      <div class="flex items-center gap-3">
        {!pos.isActive && (
          <span class="px-3 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-500">Inactivo</span>
        )}
        <a href="/config/estructura" class="text-sm text-gray-500 hover:text-gray-700">← Volver</a>
      </div>
    </div>

    {success && (
      <div data-server-toast="success" class="mb-6 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">
        Posición actualizada correctamente.
      </div>
    )}
    {error && (
      <div data-server-toast="error" class="mb-6 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
        {errorMessages[error] ?? 'Ocurrió un error inesperado.'}
      </div>
    )}

    <form method="POST" action={`/api/config/estructura/${id}`}>
      <input type="hidden" name="_method" value="PUT" />

      <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Código *</label>
            <input
              type="text"
              name="code"
              id="position-code"
              class="input"
              required
              value={pos.code}
              maxlength="20"
              data-original={pos.code}
              data-exclude-id={pos.id}
              autocomplete="off"
            />
            <p id="position-code-feedback" class="hidden mt-1 text-xs"></p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Nombre *</label>
            <input type="text" name="name" class="input" required value={pos.name} />
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Salario base (USD) *</label>
            <input type="text" name="salary" class="input" required value={pos.salary} />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Estatus *</label>
            <select name="status" class="input" required>
              <option value="vacante" selected={pos.status === 'vacante'}>Vacante</option>
              <option value="en_uso" selected={pos.status === 'en_uso'}>En uso</option>
            </select>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Sobresueldo (USD)</label>
            <input type="text" name="overtimeAmount" class="input" value={pos.overtimeAmount ?? '0'} />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Gastos de representación (USD)</label>
            <input type="text" name="representationAmount" class="input" value={pos.representationAmount ?? '0'} />
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Cargo</label>
            <select name="jobTitleId" class="input">
              <option value="">— Sin cargo —</option>
              {cargoOptions.map((c) => (
                <option value={c.id} selected={pos!.jobTitleId === c.id}>{c.name} ({c.code})</option>
              ))}
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Departamento</label>
            <select name="departmentId" class="input">
              <option value="">— Sin departamento —</option>
              {deptOptions.map((d) => (
                <option value={d.id} selected={pos!.departmentId === d.id}>{d.name} ({d.code})</option>
              ))}
            </select>
          </div>
        </div>
        <div class="border-t border-gray-100 pt-4">
          <h4 class="text-sm font-semibold text-gray-700 mb-3">Partidas presupuestarias por concepto</h4>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Partida — salario base</label>
              <select name="budgetItemId" class="input">
                <option value="">— Sin partida —</option>
                {basePartidaOptions.map((p) => (
                  <option value={p.id} selected={pos!.budgetItemId === p.id}>{p.code} — {p.name}</option>
                ))}
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Partida — sobresueldo</label>
              <select name="overtimeBudgetItemId" class="input">
                <option value="">— Sin partida —</option>
                {overtimePartidaOptions.map((p) => (
                  <option value={p.id} selected={pos!.overtimeBudgetItemId === p.id}>{p.code} — {p.name}</option>
                ))}
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Partida — gastos de representación</label>
              <select name="representationBudgetItemId" class="input">
                <option value="">— Sin partida —</option>
                {representationPartidaOptions.map((p) => (
                  <option value={p.id} selected={pos!.representationBudgetItemId === p.id}>{p.code} — {p.name}</option>
                ))}
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Partida — décimo tercer mes</label>
              <select name="thirteenthMonthBudgetItemId" class="input">
                <option value="">— Sin partida —</option>
                {thirteenthPartidaOptions.map((p) => (
                  <option value={p.id} selected={pos!.thirteenthMonthBudgetItemId === p.id}>{p.code} — {p.name}</option>
                ))}
              </select>
            </div>
          </div>
        </div>
      </div>

      <div class="flex justify-between mt-4">
        {pos.isActive && (
          <form method="POST" action={`/api/config/estructura/${id}`}
            onsubmit="return confirm('¿Dar de baja esta posición?')"
          >
            <input type="hidden" name="_method" value="DELETE" />
            <button type="submit" class="px-4 py-2 text-sm text-red-600 bg-white border border-red-300 rounded-lg hover:bg-red-50 transition-colors">
              Dar de baja
            </button>
          </form>
        )}
        <div class="flex gap-3 ml-auto">
          <a href="/config/estructura" class="px-4 py-2 text-sm text-gray-600 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
            Cancelar
          </a>
          <button type="submit" class="px-4 py-2 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors">
            Guardar cambios
          </button>
        </div>
      </div>
    </form>
  </div>
  <ServerToastBridge />
</AppLayout>

<style>
  .input {
    @apply w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent;
  }
</style>

<script>
  // Realtime code-availability check on blur. The edit form passes
  // excludeId so the position's *own* code doesn't trip a phantom
  // collision. If the user blurs the field with the original value the
  // network call is skipped — nothing changed, nothing to validate.
  const codeInput = document.getElementById('position-code') as HTMLInputElement | null
  const feedback = document.getElementById('position-code-feedback') as HTMLElement | null
  const submitBtn = document.querySelector<HTMLButtonElement>('button[type="submit"]')
  if (codeInput && feedback) {
    const original = codeInput.dataset.original ?? ''
    const excludeId = codeInput.dataset.excludeId ?? ''
    let abort: AbortController | null = null
    codeInput.addEventListener('blur', async () => {
      const code = codeInput.value.trim()
      feedback.classList.add('hidden')
      feedback.className = 'hidden mt-1 text-xs'
      if (submitBtn) submitBtn.disabled = false
      if (!code || code === original) return
      abort?.abort()
      abort = new AbortController()
      try {
        const params = new URLSearchParams({ code })
        if (excludeId) params.set('excludeId', excludeId)
        const res = await fetch(`/api/config/estructura/check-code?${params}`, {
          signal: abort.signal,
        })
        if (!res.ok) return
        const data = (await res.json()) as { available: boolean }
        feedback.classList.remove('hidden')
        if (data.available) {
          feedback.textContent = '✓ Código disponible'
          feedback.className = 'mt-1 text-xs text-emerald-600'
        } else {
          feedback.textContent = '✕ El código ya está en uso'
          feedback.className = 'mt-1 text-xs text-red-600'
          if (submitBtn) submitBtn.disabled = true
        }
      } catch {
        /* network errors → silent */
      }
    })
    codeInput.addEventListener('input', () => {
      feedback.classList.add('hidden')
      if (submitBtn) submitBtn.disabled = false
    })
  }
</script>

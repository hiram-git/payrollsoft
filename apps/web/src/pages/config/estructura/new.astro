---
import AppLayout from '../../../layouts/AppLayout.astro'
import { resolveTenantSlugFromCookie } from '../../../lib/tenant-slug'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')
const tenantSlug = resolveTenantSlugFromCookie(authCookie)

type CatalogItem = { id: string; code: string; name: string; isActive: boolean }

let cargos: CatalogItem[] = []
let departamentos: CatalogItem[] = []
let partidas: CatalogItem[] = []

try {
  const headers = { Cookie: `auth=${authCookie}`, 'X-Tenant': tenantSlug }
  const [cRes, dRes, pRes] = await Promise.all([
    fetch(`${API_URL}/job-titles`, { headers }),
    fetch(`${API_URL}/departments`, { headers }),
    fetch(`${API_URL}/budget-items`, { headers }),
  ])
  if (cRes.ok) cargos = ((await cRes.json()) as { data: CatalogItem[] }).data ?? []
  if (dRes.ok) departamentos = ((await dRes.json()) as { data: CatalogItem[] }).data ?? []
  if (pRes.ok) partidas = ((await pRes.json()) as { data: CatalogItem[] }).data ?? []
} catch {
  /* dropdowns show empty on error */
}

const activeCargos = cargos.filter((c) => c.isActive)
const activeDepts = departamentos.filter((d) => d.isActive)
const activePartidas = partidas.filter((p) => p.isActive)

const error = Astro.url.searchParams.get('error') ?? ''
const errorMessages: Record<string, string> = {
  code_taken: 'El código ya está en uso.',
  invalid_budget_item: 'Una de las partidas seleccionadas no existe o está inactiva.',
  'server-error': 'Error del servidor. Intenta de nuevo.',
  'missing-fields': 'Completa todos los campos requeridos.',
}
---

<AppLayout title="Nueva Posición">
  <div class="mx-auto w-full max-w-7xl p-8 lg:w-3/4">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-2xl font-bold text-gray-900">Nueva Posición</h1>
      <a href="/config/estructura" class="text-sm text-gray-500 hover:text-gray-700">← Volver</a>
    </div>

    {error && (
      <div class="mb-6 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
        {errorMessages[error] ?? 'Ocurrió un error inesperado.'}
      </div>
    )}

    <form method="POST" action="/api/config/estructura">
      <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Código *</label>
            <input
              type="text"
              name="code"
              id="position-code"
              class="input"
              required
              placeholder="GEN-001"
              maxlength="20"
              autocomplete="off"
            />
            <p id="position-code-feedback" class="hidden mt-1 text-xs"></p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Nombre *</label>
            <input type="text" name="name" class="input" required placeholder="Analista de RRHH" />
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Salario base (USD) *</label>
            <input type="text" name="salary" class="input" required placeholder="1200.00" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Estatus *</label>
            <select name="status" class="input" required>
              <option value="vacante">Vacante</option>
              <option value="en_uso">En uso</option>
            </select>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Sobresueldo (USD)</label>
            <input type="text" name="overtimeAmount" class="input" placeholder="0.00" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Gastos de representación (USD)</label>
            <input type="text" name="representationAmount" class="input" placeholder="0.00" />
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Cargo</label>
            <select name="jobTitleId" class="input">
              <option value="">— Sin cargo —</option>
              {activeCargos.map((c) => (
                <option value={c.id}>{c.name} ({c.code})</option>
              ))}
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Departamento</label>
            <select name="departmentId" class="input">
              <option value="">— Sin departamento —</option>
              {activeDepts.map((d) => (
                <option value={d.id}>{d.name} ({d.code})</option>
              ))}
            </select>
          </div>
        </div>
        <div class="border-t border-gray-100 pt-4">
          <h4 class="text-sm font-semibold text-gray-700 mb-3">Partidas presupuestarias por concepto</h4>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Partida — salario base</label>
              <select name="budgetItemId" class="input">
                <option value="">— Sin partida —</option>
                {activePartidas.map((p) => (
                  <option value={p.id}>{p.code} — {p.name}</option>
                ))}
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Partida — sobresueldo</label>
              <select name="overtimeBudgetItemId" class="input">
                <option value="">— Sin partida —</option>
                {activePartidas.map((p) => (
                  <option value={p.id}>{p.code} — {p.name}</option>
                ))}
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Partida — gastos de representación</label>
              <select name="representationBudgetItemId" class="input">
                <option value="">— Sin partida —</option>
                {activePartidas.map((p) => (
                  <option value={p.id}>{p.code} — {p.name}</option>
                ))}
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Partida — décimo tercer mes</label>
              <select name="thirteenthMonthBudgetItemId" class="input">
                <option value="">— Sin partida —</option>
                {activePartidas.map((p) => (
                  <option value={p.id}>{p.code} — {p.name}</option>
                ))}
              </select>
            </div>
          </div>
        </div>
      </div>

      <div class="flex justify-end gap-3 mt-4">
        <a href="/config/estructura" class="px-4 py-2 text-sm text-gray-600 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
          Cancelar
        </a>
        <button type="submit" class="px-4 py-2 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors">
          Guardar posición
        </button>
      </div>
    </form>
  </div>
</AppLayout>

<style>
  .input {
    @apply w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent;
  }
</style>

<script>
  // Realtime code-availability check on blur. Hits the same endpoint
  // the API uses and surfaces an inline message + disables Save when
  // the code is taken — the operator gets feedback without waiting
  // for the form submit to round-trip.
  const codeInput = document.getElementById('position-code') as HTMLInputElement | null
  const feedback = document.getElementById('position-code-feedback') as HTMLElement | null
  const submitBtn = document.querySelector<HTMLButtonElement>('button[type="submit"]')
  if (codeInput && feedback) {
    let abort: AbortController | null = null
    codeInput.addEventListener('blur', async () => {
      const code = codeInput.value.trim()
      feedback.classList.add('hidden')
      feedback.className = 'hidden mt-1 text-xs'
      if (submitBtn) submitBtn.disabled = false
      if (!code) return
      abort?.abort()
      abort = new AbortController()
      try {
        const res = await fetch(
          `/api/config/estructura/check-code?code=${encodeURIComponent(code)}`,
          { signal: abort.signal }
        )
        if (!res.ok) return
        const data = (await res.json()) as { available: boolean }
        feedback.classList.remove('hidden')
        if (data.available) {
          feedback.textContent = '✓ Código disponible'
          feedback.className = 'mt-1 text-xs text-emerald-600'
        } else {
          feedback.textContent = '✕ El código ya está en uso'
          feedback.className = 'mt-1 text-xs text-red-600'
          if (submitBtn) submitBtn.disabled = true
        }
      } catch {
        /* network errors → silent; the server will catch a duplicate on submit */
      }
    })
    // Re-enable submit + hide feedback as soon as the user starts typing again.
    codeInput.addEventListener('input', () => {
      feedback.classList.add('hidden')
      if (submitBtn) submitBtn.disabled = false
    })
  }
</script>

---
import AppLayout from '../../../layouts/AppLayout.astro'
import { can, getIdentity } from '../../../lib/auth'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'

const identity = getIdentity(Astro.cookies)
if (!identity) return Astro.redirect('/login')
if (!can(identity, 'banks:read')) return Astro.redirect('/dashboard')

const tenantSlug = identity.tenantSlug ?? 'demo'
const headers = { Cookie: `auth=${identity.raw}`, 'X-Tenant': tenantSlug }
const canWrite = can(identity, 'banks:write')

type Bank = {
  id: string
  code: string
  name: string
  routing: string | null
  swift: string | null
  achFormat: string | null
  achEntityCode: string | null
  country: string
  isActive: number
  sortOrder: number
}

const ACH_FORMATS = [
  { value: '', label: '— Ninguno —' },
  { value: 'banco_nacional', label: 'Banco Nacional (líneas L)' },
  { value: 'banco_general', label: 'Banco General (C/D/T)' },
  { value: 'mupa_v1', label: 'MUPA v1 (legado)' },
]
function achFormatLabel(v: string | null): string {
  return ACH_FORMATS.find((f) => f.value === (v ?? ''))?.label ?? (v ?? '—')
}

let banks: Bank[] = []
let loadError = ''
try {
  const res = await fetch(`${API_URL}/banks`, { headers })
  if (res.status === 401) return Astro.redirect('/login')
  if (res.ok) banks = ((await res.json()) as { data: Bank[] }).data ?? []
  else loadError = `No se pudo cargar el catálogo (HTTP ${res.status}).`
} catch {
  loadError = 'No se pudo conectar con el servidor.'
}

const success =
  Astro.url.searchParams.get('flash') === 'created' ||
  Astro.url.searchParams.get('flash') === 'updated'
const error =
  Astro.url.searchParams.get('flash') === 'error'
    ? Astro.url.searchParams.get('msg') || 'Error.'
    : ''
---
<AppLayout title="Configuración · Bancos">
  <div class="page">
    <div class="page-header">
      <div>
        <h1 class="page-title">Catálogo de Bancos</h1>
        <p class="page-sub">{banks.length} bancos · El número de ruta es obligatorio para pagos ACH</p>
      </div>
    </div>

    {loadError && <div class="alert alert-err">{loadError}</div>}
    {success && <div class="alert alert-ok">Guardado correctamente.</div>}
    {error && <div class="alert alert-err">{error}</div>}

    <div class="card">
      <div class="card-header">
        <span class="card-title">Bancos</span>
        {canWrite && <button type="button" id="btnNew" class="btn-primary">+ Nuevo</button>}
      </div>

      {canWrite && (
        <div id="newItemForm" class="new-form hidden">
          <form method="POST" action="/api/treasury/action?op=bank-create" class="new-form-row">
            <input type="hidden" name="_redirect" value="/config/banks" />
            <div class="field">
              <label class="label">Código *</label>
              <input type="text" name="code" class="inp" required maxlength="20" />
            </div>
            <div class="field flex-1">
              <label class="label">Nombre *</label>
              <input type="text" name="name" class="inp" required maxlength="120" />
            </div>
            <div class="field">
              <label class="label">Ruta</label>
              <input type="text" name="routing" class="inp w-ruta" maxlength="15" placeholder="0006" />
            </div>
            <div class="field">
              <label class="label">SWIFT</label>
              <input type="text" name="swift" class="inp w-ruta" maxlength="15" />
            </div>
            <div class="field">
              <label class="label">Formato ACH</label>
              <select name="achFormat" class="inp w-32">
                {ACH_FORMATS.map((f) => <option value={f.value}>{f.label}</option>)}
              </select>
            </div>
            <div class="field">
              <label class="label">Cód. entidad</label>
              <input type="text" name="achEntityCode" class="inp w-ruta" maxlength="9" placeholder="000000071" />
            </div>
            <div class="form-actions">
              <button type="submit" class="btn-ok">Guardar</button>
              <button type="button" id="btnCancelNew" class="btn-ghost">Cancelar</button>
            </div>
          </form>
        </div>
      )}

      {banks.length === 0 ? (
        <div class="empty-state">No hay bancos registrados.</div>
      ) : (
        <table class="tbl">
          <thead>
            <tr>
              <th class="th w-24">Código</th>
              <th class="th">Nombre</th>
              <th class="th w-24">Ruta</th>
              <th class="th w-24">SWIFT</th>
              <th class="th w-32">Formato ACH</th>
              <th class="th w-20 text-center">Estado</th>
              {canWrite && <th class="th w-24"></th>}
            </tr>
          </thead>
          <tbody>
            {banks.map((b) => (
              <tr class="tr" id={`row-${b.id}`} data-edit-target={b.id} data-name={b.name} data-routing={b.routing ?? ''} data-swift={b.swift ?? ''} data-achformat={b.achFormat ?? ''} data-achentitycode={b.achEntityCode ?? ''}>
                <td class="td td-code w-24">{b.code}</td>
                <td class="td">
                  <span class="view-mode">{b.name}</span>
                  {canWrite && (
                    <form id={`edit-form-${b.id}`} method="POST" action={`/api/treasury/action?op=bank-update&id=${b.id}`} class="edit-mode hidden">
                      <input type="hidden" name="_redirect" value="/config/banks" />
                      <input type="text" name="name" value={b.name} data-edit-input="name" class="inp" required maxlength="120" />
                    </form>
                  )}
                </td>
                <td class="td w-24">
                  <span class="view-mode td-code">{b.routing ?? '—'}</span>
                  {canWrite && <input type="text" form={`edit-form-${b.id}`} name="routing" value={b.routing ?? ''} data-edit-input="routing" class="inp edit-mode hidden" maxlength="15" />}
                </td>
                <td class="td w-24">
                  <span class="view-mode td-code">{b.swift ?? '—'}</span>
                  {canWrite && <input type="text" form={`edit-form-${b.id}`} name="swift" value={b.swift ?? ''} data-edit-input="swift" class="inp edit-mode hidden" maxlength="15" />}
                </td>
                <td class="td w-32">
                  <span class="view-mode">
                    {achFormatLabel(b.achFormat)}
                    {b.achEntityCode && <span class="td-code"> · {b.achEntityCode}</span>}
                  </span>
                  {canWrite && (
                    <select form={`edit-form-${b.id}`} name="achFormat" data-edit-input="achformat" class="inp edit-mode hidden">
                      {ACH_FORMATS.map((f) => <option value={f.value} selected={(b.achFormat ?? '') === f.value}>{f.label}</option>)}
                    </select>
                  )}
                  {canWrite && <input type="text" form={`edit-form-${b.id}`} name="achEntityCode" value={b.achEntityCode ?? ''} data-edit-input="achentitycode" class="inp edit-mode hidden" maxlength="9" placeholder="Cód. entidad" />}
                </td>
                <td class="td w-20 text-center">
                  <span class={`status-badge ${b.isActive === 1 ? 'status-ok' : 'status-off'}`}>
                    {b.isActive === 1 ? 'activo' : 'inactivo'}
                  </span>
                </td>
                {canWrite && (
                  <td class="td w-24">
                    <div class="row-actions view-mode">
                      <span class="tooltip-wrap">
                        <button type="button" data-start-edit={b.id} aria-label="Editar" class="action-btn">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                        </button>
                        <span class="tooltip" role="tooltip">Editar</span>
                      </span>
                    </div>
                    <div class="row-actions edit-actions edit-mode hidden">
                      <span class="tooltip-wrap">
                        <button type="submit" form={`edit-form-${b.id}`} aria-label="Guardar" class="action-btn action-ok">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        </button>
                        <span class="tooltip" role="tooltip">Guardar</span>
                      </span>
                      <span class="tooltip-wrap">
                        <button type="button" data-cancel-edit={b.id} aria-label="Cancelar" class="action-btn action-cancel">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                        </button>
                        <span class="tooltip" role="tooltip">Cancelar</span>
                      </span>
                    </div>
                  </td>
                )}
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
  </div>

  <style>
    .page        { padding: 2rem; }
    .page-header { display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:1.5rem; }
    .page-title  { font-size:1.25rem; font-weight:600; color:var(--fore); margin:0 0 .25rem; font-family:var(--f-display); }
    .page-sub    { font-size:.8125rem; color:var(--mute); margin:0; }
    .alert       { padding:.75rem 1rem; border-radius:6px; font-size:.8125rem; margin-bottom:1rem; border:1px solid; }
    .alert-ok    { background:color-mix(in srgb, var(--ok) 10%, var(--ink-2)); border-color:var(--ok); color:var(--ok); }
    .alert-err   { background:color-mix(in srgb, var(--err) 10%, var(--ink-2)); border-color:var(--err); color:var(--err); }
    .card        { background:var(--ink-2); border:1px solid var(--rule); border-radius:8px; overflow:hidden; }
    .card-header { display:flex; align-items:center; justify-content:space-between; padding:.875rem 1.25rem; border-bottom:1px solid var(--rule); }
    .card-title  { font-size:.875rem; font-weight:600; color:var(--fore); }
    .new-form     { padding:1rem 1.25rem; border-bottom:1px solid var(--rule); background:var(--ink-3); }
    .new-form-row { display:flex; gap:.75rem; align-items:flex-end; flex-wrap:wrap; }
    .field       { display:flex; flex-direction:column; gap:.25rem; }
    .flex-1      { flex:1; }
    .w-ruta      { width:7rem; }
    .label       { font-size:.75rem; font-weight:500; color:var(--mute-2); }
    .form-actions { display:flex; gap:.5rem; align-items:flex-end; }
    .tbl { width:100%; border-collapse:collapse; font-size:.8125rem; table-layout:fixed; }
    .th  { padding:.625rem 1rem; text-align:left; font-size:.75rem; font-weight:600; color:var(--mute); text-transform:uppercase; letter-spacing:.04em; background:var(--ink-3); border-bottom:1px solid var(--rule); }
    .td  { padding:.75rem 1rem; color:var(--fore); border-bottom:1px solid var(--rule); vertical-align:middle; }
    .tr:last-child .td { border-bottom:none; }
    .tr:hover .td { background:var(--ink-3); }
    .td-code { font-family:var(--f-mono); font-size:.75rem; color:var(--mute-2); }
    .w-20 { width:5rem; } .w-24 { width:6rem; } .w-28 { width:7rem; } .w-32 { width:8rem; }
    .text-center { text-align:center; }
    .status-badge { display:inline-block; padding:.125rem .5rem; border-radius:9999px; font-size:.6875rem; font-weight:500; text-transform:uppercase; letter-spacing:.04em; }
    .status-ok  { background:color-mix(in srgb, var(--ok) 14%, transparent); color:var(--ok); }
    .status-off { background:var(--ink-4); color:var(--mute); }
    .row-actions { display:flex; align-items:center; justify-content:flex-end; gap:.25rem; }
    .action-btn  { display:flex; align-items:center; justify-content:center; width:28px; height:28px; border-radius:6px; border:none; background:transparent; color:var(--mute); cursor:pointer; transition:background .15s, color .15s; }
    .action-btn:hover { background:var(--navy-soft); color:var(--navy-hi); }
    .action-ok:hover     { background:color-mix(in srgb, var(--ok) 14%, transparent); color:var(--ok); }
    .action-cancel:hover { background:var(--ink-4); color:var(--fore-dim); }
    .tooltip-wrap { position:relative; display:inline-flex; }
    .tooltip { position:absolute; bottom:calc(100% + 6px); left:50%; transform:translateX(-50%); background:var(--ink-2); color:var(--fore-dim); border:1px solid var(--rule-hi); padding:3px 8px; border-radius:4px; font-size:11px; font-weight:500; white-space:nowrap; opacity:0; pointer-events:none; transition:opacity .12s; z-index:20; box-shadow:0 2px 6px rgba(0,0,0,.18); }
    .tooltip-wrap:hover > .tooltip { opacity:1; }
    .btn-primary { background:var(--navy); color:#fff; border:none; padding:.5rem 1rem; border-radius:6px; font-size:.8125rem; font-weight:600; cursor:pointer; transition:background .15s; }
    .btn-primary:hover { background:var(--navy-hi); }
    .btn-ok      { background:var(--ok); color:#fff; border:none; padding:.5rem .875rem; border-radius:6px; font-size:.8125rem; font-weight:600; cursor:pointer; white-space:nowrap; }
    .btn-ok:hover { opacity:.88; }
    .btn-ghost   { background:transparent; color:var(--mute-2); border:1px solid var(--rule); padding:.5rem .875rem; border-radius:6px; font-size:.8125rem; cursor:pointer; white-space:nowrap; }
    .btn-ghost:hover { background:var(--ink-4); }
    .inp { background:var(--ink); color:var(--fore); border:1px solid var(--rule); border-radius:5px; padding:.4375rem .625rem; font-size:.8125rem; outline:none; font-family:inherit; width:100%; }
    .inp:focus { border-color:var(--navy-hi); box-shadow:0 0 0 2px var(--navy-soft); }
    .empty-state { padding:3rem; text-align:center; color:var(--mute); font-size:.875rem; }
    .hidden { display:none !important; }
  </style>

  <script is:inline>
    document.getElementById('btnNew')?.addEventListener('click', function() {
      document.getElementById('newItemForm')?.classList.toggle('hidden')
    })
    document.getElementById('btnCancelNew')?.addEventListener('click', function() {
      document.getElementById('newItemForm')?.classList.add('hidden')
    })

    function resetEditInputs(row) {
      var inputs = row.querySelectorAll('[data-edit-input]')
      for (var i = 0; i < inputs.length; i++) {
        var input = inputs[i]
        var key = input.getAttribute('data-edit-input')
        if (row.dataset[key] !== undefined) input.value = row.dataset[key]
      }
    }

    document.querySelectorAll('[data-start-edit]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var id = this.getAttribute('data-start-edit')
        var row = document.getElementById('row-' + id)
        if (!row) return
        resetEditInputs(row)
        row.querySelectorAll('.view-mode').forEach(function(el) { el.classList.add('hidden') })
        row.querySelectorAll('.edit-mode').forEach(function(el) { el.classList.remove('hidden') })
        var first = row.querySelector('.edit-mode input[type="text"]')
        if (first) { first.focus(); first.select() }
      })
    })

    document.querySelectorAll('[data-cancel-edit]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var id = this.getAttribute('data-cancel-edit')
        var row = document.getElementById('row-' + id)
        if (!row) return
        row.querySelectorAll('.view-mode').forEach(function(el) { el.classList.remove('hidden') })
        row.querySelectorAll('.edit-mode').forEach(function(el) { el.classList.add('hidden') })
      })
    })
  </script>
</AppLayout>

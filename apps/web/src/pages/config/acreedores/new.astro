---
import ServerToastBridge from '../../../components/ServerToastBridge.astro'
import AppLayout from '../../../layouts/AppLayout.astro'
import { resolveTenantSlugFromCookie } from '../../../lib/tenant-slug'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')
const tenantSlug = resolveTenantSlugFromCookie(authCookie)

type Bank = { id: string; name: string; isActive: number }
let banks: Bank[] = []
try {
  const res = await fetch(`${API_URL}/banks`, {
    headers: { Cookie: `auth=${authCookie}`, 'X-Tenant': tenantSlug },
  })
  if (res.ok) banks = ((await res.json()) as { data: Bank[] }).data ?? []
} catch {
  /* sin bancos */
}
const activeBanks = banks.filter((b) => b.isActive === 1)

const errorParam = Astro.url.searchParams.get('error')
const errorMessages: Record<string, string> = {
  'missing-fields': 'Código y nombre son obligatorios.',
  code_taken: 'Ese código ya está en uso por otro acreedor.',
  concept_code_taken: 'Ya existe un concepto con ese código.',
  'server-error': 'Error al conectar con el servidor.',
}
const errorMsg = errorParam ? (errorMessages[errorParam] ?? 'Error desconocido.') : null
---

<AppLayout title="Nuevo Acreedor">
  <div class="mx-auto w-full max-w-7xl p-8 lg:w-3/4">
    <div class="mb-6">
      <nav class="text-sm text-gray-400 mb-1">
        <a href="/config/acreedores" class="hover:text-gray-600">Acreedores</a>
        <span class="mx-1.5">›</span>
        <span class="text-gray-600">Nuevo</span>
      </nav>
      <h1 class="text-2xl font-bold text-gray-900">Nuevo Acreedor</h1>
      <p class="text-sm text-gray-500 mt-0.5">Se creará automáticamente un concepto de deducción asociado.</p>
    </div>

    {errorMsg && (
      <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700" data-server-toast="error">
        {errorMsg}
      </div>
    )}

    <form method="POST" action="/api/config/acreedores" class="bg-white rounded-xl border border-gray-200 p-6 space-y-5">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5" for="code">
          Código <span class="text-red-500">*</span>
        </label>
        <input
          id="code"
          name="code"
          type="text"
          required
          maxlength="20"
          placeholder="Ej: BANCO_NAC"
          class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm font-mono uppercase focus:outline-none focus:ring-2 focus:ring-blue-500"
        />
        <p class="mt-1 text-xs text-gray-400">Se usará también como código del concepto de deducción.</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5" for="name">
          Nombre <span class="text-red-500">*</span>
        </label>
        <input
          id="name"
          name="name"
          type="text"
          required
          maxlength="255"
          placeholder="Ej: Banco Nacional de Panamá"
          class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
        />
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5" for="paymentMethod">Forma de pago</label>
        <select
          id="paymentMethod"
          name="paymentMethod"
          class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
        >
          <option value="check">Cheque</option>
          <option value="ach">ACH (transferencia)</option>
          <option value="cash">Efectivo</option>
        </select>
      </div>

      <div id="ach-fields" class="space-y-5 rounded-lg border border-gray-200 bg-gray-50 p-4 hidden">
        <p class="text-xs font-medium text-gray-500">Datos para transferencia ACH</p>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5" for="bankId">Banco</label>
          <select
            id="bankId"
            name="bankId"
            class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-blue-500"
          >
            <option value="">— Selecciona un banco —</option>
            {activeBanks.map((b) => <option value={b.id}>{b.name}</option>)}
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5" for="accountNumber">N° de cuenta</label>
          <input
            id="accountNumber"
            name="accountNumber"
            type="text"
            maxlength="40"
            class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5" for="accountType">Tipo de cuenta</label>
          <select
            id="accountType"
            name="accountType"
            class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-blue-500"
          >
            <option value="checking">Corriente</option>
            <option value="savings">Ahorro</option>
          </select>
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5" for="beneficiaryName">
          Nombre del beneficiario <span class="text-gray-400">(opcional)</span>
        </label>
        <input
          id="beneficiaryName"
          name="beneficiaryName"
          type="text"
          maxlength="255"
          placeholder="Si difiere del nombre del acreedor"
          class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
        />
      </div>

      <div class="flex gap-3 pt-2">
        <button
          type="submit"
          class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-5 py-2 rounded-lg transition-colors"
        >
          Guardar
        </button>
        <a
          href="/config/acreedores"
          class="text-sm text-gray-500 hover:text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-100 transition-colors"
        >
          Cancelar
        </a>
      </div>
    </form>
  </div>
  <ServerToastBridge />
</AppLayout>

<script>
  // Auto-uppercase code input
  const codeInput = document.getElementById('code') as HTMLInputElement | null
  codeInput?.addEventListener('input', () => {
    const pos = codeInput.selectionStart
    codeInput.value = codeInput.value.toUpperCase()
    codeInput.setSelectionRange(pos, pos)
  })

  // Mostrar/ocultar los campos ACH según la forma de pago
  const pm = document.getElementById('paymentMethod') as HTMLSelectElement | null
  const achFields = document.getElementById('ach-fields')
  const syncAch = () => achFields?.classList.toggle('hidden', pm?.value !== 'ach')
  pm?.addEventListener('change', syncAch)
  syncAch()
</script>

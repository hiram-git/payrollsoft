---
import ServerToastBridge from '../../../components/ServerToastBridge.astro'
import AppLayout from '../../../layouts/AppLayout.astro'
import { resolveTenantSlugFromCookie } from '../../../lib/tenant-slug'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')
const tenantSlug = resolveTenantSlugFromCookie(authCookie)

let nextCode = ''
try {
  const res = await fetch(`${API_URL}/job-functions/next-code`, {
    headers: { Cookie: `auth=${authCookie}`, 'X-Tenant': tenantSlug },
  })
  if (res.ok) nextCode = ((await res.json()) as { data?: { code?: string } }).data?.code ?? ''
} catch {
  /* si falla, el campo queda editable */
}

const error = Astro.url.searchParams.get('error') ?? ''
const errorMessages: Record<string, string> = {
  code_taken: 'El código ya está en uso.',
  'server-error': 'Error del servidor. Intenta de nuevo.',
  'missing-fields': 'Completa todos los campos requeridos.',
}
---

<AppLayout title="Nueva Función">
  <div class="mx-auto w-full max-w-7xl p-8 lg:w-3/4">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-2xl font-bold text-gray-900">Nueva Función</h1>
      <a href="/config/job-functions" class="text-sm text-gray-500 hover:text-gray-700">← Volver</a>
    </div>

    {error && (
      <div data-server-toast="error" class="mb-6 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
        {errorMessages[error] ?? 'Ocurrió un error inesperado.'}
      </div>
    )}

    <form method="POST" action="/api/config/job-functions">
      <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Código *</label>
            <input type="text" name="code" class="input" required placeholder="FUN0001" maxlength="20" value={nextCode} readonly={!!nextCode} />
            {nextCode && <p class="mt-1 text-xs text-gray-500">Asignado automáticamente.</p>}
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Nombre *</label>
            <input type="text" name="name" class="input" required placeholder="Administración" />
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Descripción</label>
          <textarea name="description" class="input resize-none" rows="3" placeholder="Descripción opcional de la función..." maxlength="500"></textarea>
        </div>
      </div>

      <div class="flex justify-end gap-3 mt-4">
        <a href="/config/job-functions" class="px-4 py-2 text-sm text-gray-600 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
          Cancelar
        </a>
        <button type="submit" class="px-4 py-2 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors">
          Guardar función
        </button>
      </div>
    </form>
  </div>
  <ServerToastBridge />
</AppLayout>

<style>
  .input {
    @apply w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent;
  }
</style>

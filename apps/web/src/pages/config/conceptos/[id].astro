---
import FormulaEditor from '../../../components/FormulaEditor.astro'
import AppLayout from '../../../layouts/AppLayout.astro'

const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')

const { id } = Astro.params
const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const headers = { Cookie: `auth=${authCookie}`, 'X-Tenant': 'demo' }

type CatalogItem = { id: string; code: string; name: string; sortOrder: number }
type ConceptConfig = {
  payrollTypes: CatalogItem[]
  frequencies: CatalogItem[]
  situations: CatalogItem[]
  accumulators: CatalogItem[]
}
type ConceptLinks = {
  payrollTypeIds: string[]
  frequencyIds: string[]
  situationIds: string[]
  accumulatorIds: string[]
}
type Concept = {
  id: string
  code: string
  name: string
  type: string
  formula: string | null
  isActive: boolean
  unit: string
  printDetails: boolean
  prorates: boolean
  allowModify: boolean
  isReferenceValue: boolean
  useAmountCalc: boolean
  allowZero: boolean
  cuentaContableId: string | null
  links: ConceptLinks
}
type CuentaContable = { id: string; code: string; name: string }

// Fetch concept and config in parallel
let concept: Concept | null = null
let config: ConceptConfig = { payrollTypes: [], frequencies: [], situations: [], accumulators: [] }
let cuentasContables: CuentaContable[] = []

const [conceptRes, configRes, cuentasRes] = await Promise.allSettled([
  fetch(`${API_URL}/concepts/${id}`, { headers }),
  fetch(`${API_URL}/concepts/config`, { headers }),
  fetch(`${API_URL}/cuentas-contables`, { headers }),
])

if (conceptRes.status === 'fulfilled') {
  const res = conceptRes.value
  if (res.status === 401) return Astro.redirect('/login')
  if (res.status === 404) return Astro.redirect('/config/conceptos')
  if (res.ok) concept = ((await res.json()) as { data: Concept }).data
}
if (!concept) return Astro.redirect('/config/conceptos')

if (cuentasRes.status === 'fulfilled' && cuentasRes.value.ok) {
  cuentasContables = ((await cuentasRes.value.json()) as { data: CuentaContable[] }).data ?? []
}

if (configRes.status === 'fulfilled') {
  const res = configRes.value
  if (res.status === 401) return Astro.redirect('/login')
  if (res.ok) config = ((await res.json()) as { data: ConceptConfig }).data
}

const links: ConceptLinks = concept.links ?? {
  payrollTypeIds: [],
  frequencyIds: [],
  situationIds: [],
  accumulatorIds: [],
}

const error = Astro.url.searchParams.get('error') ?? ''
const success = Astro.url.searchParams.get('success') === '1'
const errorMessages: Record<string, string> = {
  code_taken: 'El código ya está en uso.',
  invalid_type: 'El tipo debe ser Asignación, Deducción o Patronal.',
  'server-error': 'Error del servidor. Intenta de nuevo.',
  'missing-fields': 'Completa todos los campos requeridos.',
}
---

<AppLayout title={concept.name}>
  <div class="px-6 py-8 max-w-4xl mx-auto">

    <!-- Breadcrumb + status badge -->
    <div class="flex items-center gap-2 text-sm text-gray-500 mb-6">
      <a href="/config/conceptos" class="hover:text-gray-700 transition-colors">← Conceptos</a>
      <span class="text-gray-300">/</span>
      <span class="text-gray-900 font-medium">{concept.name}</span>
      {!concept.isActive && (
        <span class="ml-1 px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500">Inactivo</span>
      )}
    </div>

    {success && (
      <div class="mb-6 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">
        Concepto actualizado correctamente.
      </div>
    )}
    {error && (
      <div class="mb-6 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
        {errorMessages[error] ?? 'Ocurrió un error inesperado.'}
      </div>
    )}

    <form method="POST" action={`/api/config/conceptos/${id}`}>
      <input type="hidden" name="_method" value="PUT" />

      <!-- ── 1. Información Básica ──────────────────────────────────────────── -->
      <section class="section-card mb-4">
        <h2 class="section-title">
          <span class="section-icon bg-blue-50 text-blue-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          </span>
          Información Básica
        </h2>
        <div class="grid grid-cols-3 gap-4 p-5">
          <div>
            <label class="field-label">Código *</label>
            <input type="text" name="code" class="input uppercase" required maxlength="20" value={concept.code} />
            <p class="field-hint">Se guardará en mayúsculas</p>
          </div>
          <div class="col-span-2">
            <label class="field-label">Nombre / Descripción *</label>
            <input type="text" name="name" class="input" required maxlength="255" value={concept.name} />
          </div>
        </div>
      </section>

      <!-- ── 2. Naturaleza del Concepto ────────────────────────────────────── -->
      <section class="section-card mb-4">
        <h2 class="section-title">
          <span class="section-icon bg-emerald-50 text-emerald-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
          </span>
          Naturaleza del Concepto
        </h2>
        <div class="grid grid-cols-2 gap-6 p-5">
          <!-- Tipo -->
          <div>
            <p class="field-label mb-2">Tipo de Concepto *</p>
            <div class="flex flex-col gap-2">
              {[
                { value: 'income', label: 'Asignación', desc: 'Ingreso para el empleado', color: 'blue' },
                { value: 'deduction', label: 'Deducción', desc: 'Descuento al empleado', color: 'red' },
                { value: 'patronal', label: 'Patronal', desc: 'Cargo del empleador', color: 'amber' },
              ].map(({ value, label, desc, color }) => (
                <label class={`radio-card border-${color}-200 has-[:checked]:border-${color}-500 has-[:checked]:bg-${color}-50`}>
                  <input type="radio" name="type" value={value} class="sr-only" required checked={concept!.type === value} />
                  <span class={`radio-dot border-${color}-400`} />
                  <span>
                    <span class="radio-label">{label}</span>
                    <span class="radio-desc">{desc}</span>
                  </span>
                </label>
              ))}
            </div>
          </div>
          <!-- Unidad -->
          <div>
            <p class="field-label mb-2">Unidad de Medida</p>
            <div class="grid grid-cols-2 gap-2">
              {[
                { value: 'amount', label: 'Monto ($)', icon: '$' },
                { value: 'hours', label: 'Horas', icon: 'h' },
                { value: 'percentage', label: 'Porcentaje (%)', icon: '%' },
                { value: 'days', label: 'Días', icon: 'd' },
              ].map(({ value, label, icon }) => (
                <label class="unit-card has-[:checked]:border-indigo-500 has-[:checked]:bg-indigo-50 has-[:checked]:text-indigo-700">
                  <input type="radio" name="unit" value={value} class="sr-only" checked={concept!.unit === value || (!concept!.unit && value === 'amount')} />
                  <span class="text-xs font-bold">{icon}</span>
                  <span class="text-xs">{label}</span>
                </label>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- ── 3. Fórmula ────────────────────────────────────────────────────── -->
      <section class="section-card mb-4">
        <h2 class="section-title">
          <span class="section-icon bg-violet-50 text-violet-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="12" y2="14"/></svg>
          </span>
          Fórmula de Cálculo
        </h2>
        <div class="p-5">
          <FormulaEditor name="formula" value={concept.formula ?? ''} rows={4} />
        </div>
      </section>

      <!-- ── 4. Opciones de Comportamiento ─────────────────────────────────── -->
      <section class="section-card mb-4">
        <h2 class="section-title">
          <span class="section-icon bg-amber-50 text-amber-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93l-1.41 1.41M4.93 4.93l1.41 1.41M12 2v2M12 20v2M20 12h2M2 12h2M17.66 17.66l-1.41-1.41M6.34 6.34L4.93 4.93"/></svg>
          </span>
          Opciones de Comportamiento
        </h2>
        <div class="grid grid-cols-2 gap-x-8 gap-y-3 p-5">
          {[
            { name: 'printDetails', label: 'Imprimir detalles en el recibo', desc: 'Muestra este concepto en el comprobante de pago', checked: concept.printDetails },
            { name: 'prorates', label: 'Prorratear el concepto', desc: 'Divide el monto entre los días del período', checked: concept.prorates },
            { name: 'allowModify', label: 'Permitir modificar valor manualmente', desc: 'El usuario puede sobreescribir el valor calculado', checked: concept.allowModify },
            { name: 'isReferenceValue', label: 'Es valor de referencia', desc: 'Solo sirve como base de cálculo, no aparece en la planilla', checked: concept.isReferenceValue },
            { name: 'useAmountCalc', label: 'Usar cálculo de monto', desc: 'Aplica la lógica de cálculo por monto fijo', checked: concept.useAmountCalc },
            { name: 'allowZero', label: 'Permitir monto en cero', desc: 'Incluye el concepto aunque el resultado sea $0.00', checked: concept.allowZero },
          ].map(({ name, label, desc, checked }) => (
            <label class="flex items-start gap-3 cursor-pointer group">
              <div class="relative flex-shrink-0 mt-0.5">
                <input type="checkbox" name={name} value="1" class="peer sr-only" checked={checked} />
                <div class="w-4 h-4 rounded border-2 border-gray-300 bg-white peer-checked:bg-gray-900 peer-checked:border-gray-900 group-hover:border-gray-400 transition-colors" />
                <svg class="absolute inset-0 w-4 h-4 text-white opacity-0 peer-checked:opacity-100 pointer-events-none" viewBox="0 0 16 16" fill="none"><path d="M3 8l3.5 3.5L13 4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <span>
                <span class="text-sm font-medium text-gray-800 leading-none">{label}</span>
                <span class="block text-xs text-gray-400 mt-0.5">{desc}</span>
              </span>
            </label>
          ))}
        </div>
      </section>

      <!-- ── 5. Configuraciones Avanzadas ──────────────────────────────────── -->
      <section class="section-card mb-4">
        <h2 class="section-title">
          <span class="section-icon bg-gray-100 text-gray-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="20" y2="12"/><line x1="12" y1="18" x2="20" y2="18"/><circle cx="2" cy="6" r="2" fill="currentColor" stroke="none"/><circle cx="4" cy="12" r="2" fill="currentColor" stroke="none"/><circle cx="8" cy="18" r="2" fill="currentColor" stroke="none"/></svg>
          </span>
          Configuraciones Avanzadas
        </h2>
        <div class="p-5">
          <div class="grid grid-cols-4 gap-4">

            <!-- Tipos de planilla -->
            <div>
              <p class="adv-panel-label text-blue-700">Tipos de Planilla</p>
              <div class="adv-panel">
                {config.payrollTypes.map((item) => (
                  <label class="adv-check-item">
                    <input type="checkbox" name="payrollTypeIds[]" value={item.id} class="adv-checkbox" checked={links.payrollTypeIds.includes(item.id)} />
                    <span>{item.name}</span>
                  </label>
                ))}
                {config.payrollTypes.length === 0 && <p class="text-xs text-gray-400 py-1">Sin datos</p>}
              </div>
            </div>

            <!-- Frecuencias -->
            <div>
              <p class="adv-panel-label text-emerald-700">Frecuencias</p>
              <div class="adv-panel">
                {config.frequencies.map((item) => (
                  <label class="adv-check-item">
                    <input type="checkbox" name="frequencyIds[]" value={item.id} class="adv-checkbox" checked={links.frequencyIds.includes(item.id)} />
                    <span>{item.name}</span>
                  </label>
                ))}
                {config.frequencies.length === 0 && <p class="text-xs text-gray-400 py-1">Sin datos</p>}
              </div>
            </div>

            <!-- Situaciones -->
            <div>
              <p class="adv-panel-label text-amber-700">Situaciones del Empleado</p>
              <div class="adv-panel">
                {config.situations.map((item) => (
                  <label class="adv-check-item">
                    <input type="checkbox" name="situationIds[]" value={item.id} class="adv-checkbox" checked={links.situationIds.includes(item.id)} />
                    <span>{item.name}</span>
                  </label>
                ))}
                {config.situations.length === 0 && <p class="text-xs text-gray-400 py-1">Sin datos</p>}
              </div>
            </div>

            <!-- Acumulados -->
            <div>
              <p class="adv-panel-label text-violet-700">Acumulados</p>
              <div class="adv-panel" style="max-height: 220px">
                {config.accumulators.map((item) => (
                  <label class="adv-check-item">
                    <input type="checkbox" name="accumulatorIds[]" value={item.id} class="adv-checkbox" checked={links.accumulatorIds.includes(item.id)} />
                    <span>{item.name}</span>
                  </label>
                ))}
                {config.accumulators.length === 0 && <p class="text-xs text-gray-400 py-1">Sin datos</p>}
              </div>
            </div>

          </div>
          <p class="mt-3 text-xs text-gray-400">
            Los acumulados permiten que este concepto contribuya al cálculo de XIII mes, vacaciones, indemnizaciones y otros beneficios según la legislación panameña.
          </p>
        </div>
      </section>

      <!-- ── 6. Cuenta Contable ─────────────────────────────────────────────── -->
      <section class="section-card mb-6">
        <h2 class="section-title">
          <span class="section-icon bg-teal-50 text-teal-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          </span>
          Cuenta Contable
        </h2>
        <div class="p-5">
          <div class="max-w-xs">
            <label class="field-label">Cuenta contable asociada</label>
            <select name="cuentaContableId" class="input">
              <option value="">— Sin cuenta —</option>
              {cuentasContables.map((c) => (
                <option value={c.id} selected={concept!.cuentaContableId === c.id}>{c.code} — {c.name}</option>
              ))}
            </select>
          </div>
        </div>
      </section>

      <!-- Actions -->
      <div class="flex justify-end gap-3">
        <a href="/config/conceptos" class="btn-secondary">Cancelar</a>
        <button type="submit" class="btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
          Guardar cambios
        </button>
      </div>
    </form>

    <!-- Toggle activo/inactivo — FUERA del form principal (HTML no admite forms anidados) -->
    <form
      id="toggle-form"
      method="POST"
      action={`/api/config/conceptos/${id}`}
      class="toggle-form"
    >
      <input type="hidden" name="_method" value={concept.isActive ? 'DELETE' : 'ACTIVATE'} />
      <button
        type="submit"
        class="toggle-btn"
        onclick={concept.isActive ? "return confirm('¿Dar de baja este concepto?')" : undefined}
        title={concept.isActive ? 'Dar de baja este concepto' : 'Reactivar este concepto'}
      >
        <span class={`toggle-track ${concept.isActive ? 'toggle-on' : 'toggle-off'}`}>
          <span class={`toggle-knob ${concept.isActive ? 'knob-on' : 'knob-off'}`} />
        </span>
        <span class={`toggle-label ${concept.isActive ? 'label-on' : 'label-off'}`}>
          {concept.isActive ? 'Activo' : 'Inactivo'}
        </span>
      </button>
    </form>

  </div>
</AppLayout>

<style>
  .section-card  { background: var(--ink-2); border: 1px solid var(--rule); border-radius: .75rem; overflow: hidden; }
  .section-title { display: flex; align-items: center; gap: .625rem; padding: .875rem 1.25rem; border-bottom: 1px solid var(--rule); font-size: .875rem; font-weight: 600; color: var(--fore); background: var(--ink-3); }
  .section-icon  { padding: .375rem; border-radius: .375rem; flex-shrink: 0; }
  .field-label   { display: block; font-size: .875rem; font-weight: 500; color: var(--fore-dim); margin-bottom: .25rem; }
  .field-hint    { margin-top: .25rem; font-size: .75rem; color: var(--mute); }

  .input {
    width: 100%;
    background: var(--ink-3);
    color: var(--fore);
    border: 1px solid var(--rule);
    border-radius: .5rem;
    padding: .4375rem .75rem;
    font-size: .875rem;
    font-family: inherit;
    outline: none;
    transition: border-color .15s, box-shadow .15s;
  }
  .input:focus { border-color: var(--navy-hi); box-shadow: 0 0 0 2px var(--navy-soft); }

  .radio-card  { display: flex; align-items: center; gap: .75rem; padding: .75rem; border-radius: .5rem; border: 2px solid var(--rule); cursor: pointer; transition: border-color .15s, background .15s; }
  .radio-card:hover { border-color: var(--rule-hi); }
  .radio-dot   { width: 1rem; height: 1rem; border-radius: 50%; border: 2px solid; flex-shrink: 0; transition: background .15s; }
  input[type="radio"]:checked ~ .radio-dot { background: currentColor; }
  .radio-label { display: block; font-size: .875rem; font-weight: 500; color: var(--fore); }
  .radio-desc  { display: block; font-size: .75rem; color: var(--mute); }

  .unit-card { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: .25rem; padding: .75rem; border-radius: .5rem; border: 2px solid var(--rule); color: var(--mute-2); cursor: pointer; transition: border-color .15s, background .15s, color .15s; }
  .unit-card:hover { border-color: var(--rule-hi); color: var(--fore); }

  .adv-panel-label { font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; margin-bottom: .5rem; }
  .adv-panel {
    border: 1px solid var(--rule);
    border-radius: .5rem;
    padding: .75rem;
    background: var(--ink-3);
    overflow-y: auto;
    min-height: 120px;
    max-height: 160px;
  }
  .adv-check-item { display: flex; align-items: center; gap: .5rem; padding: .25rem 0; cursor: pointer; font-size: .8125rem; color: var(--fore-dim); }
  .adv-check-item:hover { color: var(--fore); }
  .adv-checkbox   { width: .875rem; height: .875rem; border-radius: 3px; accent-color: var(--navy-hi); cursor: pointer; }

  .btn-primary   { display: inline-flex; align-items: center; gap: .5rem; padding: .5rem 1rem; font-size: .875rem; font-weight: 600; color: #fff; background: var(--navy); border: none; border-radius: .5rem; cursor: pointer; transition: background .15s; }
  .btn-primary:hover { background: var(--navy-hi); }
  .btn-secondary { display: inline-flex; align-items: center; padding: .5rem 1rem; font-size: .875rem; color: var(--mute-2); background: transparent; border: 1px solid var(--rule); border-radius: .5rem; cursor: pointer; transition: background .15s, color .15s; text-decoration: none; }
  .btn-secondary:hover { background: var(--ink-4); color: var(--fore); }

  /* Status toggle */
  .toggle-form  { margin-top: 1.5rem; padding-top: 1.25rem; border-top: 1px solid var(--rule); }
  .toggle-btn   { display: flex; align-items: center; gap: .625rem; background: none; border: none; cursor: pointer; padding: 0; }
  .toggle-track { position: relative; display: inline-flex; width: 2.25rem; height: 1.25rem; border-radius: 9999px; flex-shrink: 0; transition: background .2s; }
  .toggle-on    { background: var(--ok); }
  .toggle-off   { background: var(--ink-4); border: 1px solid var(--rule); }
  .toggle-knob  { position: absolute; top: .125rem; width: 1rem; height: 1rem; border-radius: 50%; background: #fff; transition: transform .2s; }
  .knob-on      { transform: translateX(1.125rem); }
  .knob-off     { transform: translateX(.125rem); }
  .toggle-label { font-size: .875rem; font-weight: 500; }
  .label-on     { color: var(--ok); }
  .label-off    { color: var(--mute); }
</style>

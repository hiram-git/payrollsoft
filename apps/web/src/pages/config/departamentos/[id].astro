---
import AppLayout from '../../../layouts/AppLayout.astro'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')

const { id } = Astro.params

type Departamento = {
  id: string
  code: string
  name: string
  parentId: string | null
  isActive: boolean
}

let dept: Departamento | null = null
let allDepts: Departamento[] = []

try {
  const [deptRes, allRes] = await Promise.all([
    fetch(`${API_URL}/departamentos/${id}`, {
      headers: { Cookie: `auth=${authCookie}`, 'X-Tenant': 'demo' },
    }),
    fetch(`${API_URL}/departamentos`, {
      headers: { Cookie: `auth=${authCookie}`, 'X-Tenant': 'demo' },
    }),
  ])

  if (deptRes.status === 401) return Astro.redirect('/login')
  if (deptRes.status === 404) return Astro.redirect('/config/departamentos')
  if (deptRes.ok) {
    const json = (await deptRes.json()) as { data: Departamento }
    dept = json.data
  }

  if (allRes.ok) {
    const json = (await allRes.json()) as { data: Departamento[] }
    allDepts = json.data ?? []
  }
} catch {
  return Astro.redirect('/config/departamentos')
}

if (!dept) return Astro.redirect('/config/departamentos')

// Collect all descendant IDs (including self) to prevent cycles in dropdown
function getDescendants(flat: Departamento[], rootId: string): Set<string> {
  const ids = new Set<string>([rootId])
  let changed = true
  while (changed) {
    changed = false
    for (const d of flat) {
      if (d.parentId && ids.has(d.parentId) && !ids.has(d.id)) {
        ids.add(d.id)
        changed = true
      }
    }
  }
  return ids
}

const excluded = getDescendants(allDepts, dept.id)
const parentOptions = allDepts.filter((d) => d.isActive && !excluded.has(d.id))

const error = Astro.url.searchParams.get('error') ?? ''
const success = Astro.url.searchParams.get('success') === '1'
const errorMessages: Record<string, string> = {
  code_taken: 'El código ya está en uso.',
  has_children: 'No se puede dar de baja un departamento con sub-departamentos activos.',
  cycle: 'El departamento padre no puede ser un descendiente del departamento actual.',
  'server-error': 'Error del servidor. Intenta de nuevo.',
  'missing-fields': 'Completa todos los campos requeridos.',
}
---

<AppLayout title={dept.name}>
  <div class="p-8 max-w-2xl">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">{dept.name}</h1>
        <p class="text-sm text-gray-500 mt-0.5">Código: {dept.code}</p>
      </div>
      <div class="flex items-center gap-3">
        {!dept.isActive && (
          <span class="px-3 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-500">Inactivo</span>
        )}
        <a href="/config/departamentos" class="text-sm text-gray-500 hover:text-gray-700">← Volver</a>
      </div>
    </div>

    {success && (
      <div class="mb-6 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">
        Departamento actualizado correctamente.
      </div>
    )}
    {error && (
      <div class="mb-6 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
        {errorMessages[error] ?? 'Ocurrió un error inesperado.'}
      </div>
    )}

    <form method="POST" action={`/api/config/departamentos/${id}`}>
      <input type="hidden" name="_method" value="PUT" />

      <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Código *</label>
            <input type="text" name="code" class="input" required value={dept.code} maxlength="20" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Nombre *</label>
            <input type="text" name="name" class="input" required value={dept.name} />
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Departamento padre</label>
          <select name="parentId" class="input">
            <option value="">— Sin padre (departamento raíz) —</option>
            {parentOptions.map((d) => (
              <option value={d.id} selected={dept!.parentId === d.id}>{d.name} ({d.code})</option>
            ))}
          </select>
        </div>
      </div>

      <div class="flex justify-between mt-4">
        {dept.isActive && (
          <form method="POST" action={`/api/config/departamentos/${id}`}
            onsubmit="return confirm('¿Dar de baja este departamento?')"
          >
            <input type="hidden" name="_method" value="DELETE" />
            <button type="submit" class="px-4 py-2 text-sm text-red-600 bg-white border border-red-300 rounded-lg hover:bg-red-50 transition-colors">
              Dar de baja
            </button>
          </form>
        )}
        <div class="flex gap-3 ml-auto">
          <a href="/config/departamentos" class="px-4 py-2 text-sm text-gray-600 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
            Cancelar
          </a>
          <button type="submit" class="px-4 py-2 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors">
            Guardar cambios
          </button>
        </div>
      </div>
    </form>
  </div>
</AppLayout>

<style>
  .input {
    @apply w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent;
  }
</style>

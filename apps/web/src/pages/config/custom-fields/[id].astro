---
import ServerToastBridge from '../../../components/ServerToastBridge.astro'
import AppLayout from '../../../layouts/AppLayout.astro'
import { can, getIdentity } from '../../../lib/auth'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'

const identity = getIdentity(Astro.cookies)
if (!identity) return Astro.redirect('/login')
if (!can(identity, 'settings:company.read')) return Astro.redirect('/dashboard')

const tenantSlug = identity.tenantSlug ?? 'demo'
const headers = { Cookie: `auth=${identity.raw}`, 'X-Tenant': tenantSlug }
const id = Astro.params.id ?? ''

type DependencyRule = {
  field: string
  op: 'eq' | 'ne' | 'gt' | 'lt' | 'gte' | 'lte' | 'in' | 'empty' | 'notEmpty'
  value?: unknown
  values?: unknown[]
  effect: 'required' | 'visible' | 'readonly'
}
type ValidationRules = {
  dependsOn?: DependencyRule[]
  readPermission?: string | null
  writePermission?: string | null
  includeInCreditorsReport?: boolean
} & Record<string, unknown>
type CustomField = {
  id: string
  code: string
  name: string
  description: string | null
  fieldType: 'text' | 'integer' | 'float' | 'date'
  isRequired: boolean
  defaultValue: unknown
  sortOrder: number
  isActive: boolean
  validationRules?: ValidationRules | null
}

type UsageConcept = {
  id: string
  code: string
  name: string
  type: string
  formula: string
  isActive: boolean
}

let field: CustomField | null = null
let error = ''
let allFields: { code: string; name: string; fieldType: string }[] = []
let usage: UsageConcept[] = []

try {
  const [res, listRes, usageRes] = await Promise.all([
    fetch(`${API_URL}/custom-fields/${id}`, { headers }),
    fetch(`${API_URL}/custom-fields`, { headers }),
    fetch(`${API_URL}/custom-fields/${id}/usage`, { headers }),
  ])
  if (res.status === 404) return Astro.redirect('/config/custom-fields')
  if (res.ok) {
    field = ((await res.json()) as { data: CustomField }).data
  } else {
    error = `No se pudo cargar el campo (HTTP ${res.status}).`
  }
  if (listRes.ok) {
    const all = ((await listRes.json()) as { data: CustomField[] }).data ?? []
    allFields = all
      .filter((f) => f.code !== id && f.code !== field?.code)
      .map((f) => ({ code: f.code, name: f.name, fieldType: f.fieldType }))
  }
  if (usageRes.ok) {
    const j = (await usageRes.json()) as {
      data: { referencingConcepts: UsageConcept[] }
    }
    usage = j.data?.referencingConcepts ?? []
  }
} catch (err) {
  error = err instanceof Error ? err.message : 'No se pudo conectar.'
}

const dependencies = (field?.validationRules?.dependsOn ?? []) as DependencyRule[]
const readPermission = field?.validationRules?.readPermission ?? ''
const writePermission = field?.validationRules?.writePermission ?? ''
const includeInCreditorsReport = field?.validationRules?.includeInCreditorsReport === true

const editable = can(identity, 'settings:company.update')
const errorFlag = Astro.url.searchParams.get('error') ?? ''
const errorDetail = Astro.url.searchParams.get('detail') ?? ''
---

<AppLayout title={field?.name ?? 'Campo'}>
  <div class="mx-auto w-full max-w-7xl p-8 lg:w-3/4">
    <div class="mb-6">
      <a href="/config/custom-fields" class="text-xs text-gray-500 hover:text-gray-900">← Volver al catálogo</a>
      <h1 class="mt-2 text-xl font-semibold text-gray-900 tracking-tight">{field?.name ?? '—'}</h1>
      <p class="text-sm text-gray-500 mt-0.5">
        Código: <span class="font-mono">{field?.code}</span>
      </p>
    </div>

    {error && (
      <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700" data-server-toast="error">{error}</div>
    )}
    {errorFlag && (
      <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700" data-server-toast="error">
        No se pudo guardar el campo.
        {errorDetail && <pre class="mt-2 whitespace-pre-wrap break-words text-xs font-mono opacity-80">{errorDetail}</pre>}
      </div>
    )}

    {field && (
      <script type="application/json" id="depCatalog" set:html={JSON.stringify(allFields)}></script>
    )}
    {field && (
      <form method="POST" action={`/api/config/custom-fields/${field.id}`} class="space-y-5">
        <input type="hidden" name="_method" value="UPDATE" />
        <section class="bg-white border border-gray-200 rounded-lg p-6 space-y-4">
          <h2 class="text-sm font-medium text-gray-900">Identificación</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1.5">Nombre</label>
              <input
                type="text"
                name="name"
                required
                minlength="1"
                maxlength="255"
                value={field.name}
                disabled={!editable}
                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent disabled:bg-gray-50"
              />
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1.5">Código</label>
              <input
                type="text"
                value={field.code}
                disabled
                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md font-mono bg-gray-50 text-gray-500"
              />
              <p class="mt-1.5 text-xs text-gray-500">El código no se puede cambiar.</p>
            </div>
            <div class="md:col-span-2">
              <label class="block text-xs font-medium text-gray-600 mb-1.5">Descripción</label>
              <textarea
                name="description"
                maxlength="2000"
                rows="2"
                disabled={!editable}
                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent disabled:bg-gray-50"
              >{field.description ?? ''}</textarea>
            </div>
          </div>
        </section>

        <section class="bg-white border border-gray-200 rounded-lg p-6 space-y-4">
          <h2 class="text-sm font-medium text-gray-900">Tipo y validación</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1.5">Tipo de dato</label>
              <select
                name="fieldType"
                disabled={!editable}
                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent disabled:bg-gray-50"
              >
                <option value="text" selected={field.fieldType === 'text'}>Texto</option>
                <option value="integer" selected={field.fieldType === 'integer'}>Número entero</option>
                <option value="float" selected={field.fieldType === 'float'}>Número decimal</option>
                <option value="date" selected={field.fieldType === 'date'}>Fecha</option>
              </select>
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1.5">Orden</label>
              <input
                type="number"
                name="sortOrder"
                min="0"
                max="9999"
                value={field.sortOrder}
                disabled={!editable}
                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent disabled:bg-gray-50"
              />
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1.5">Valor por defecto</label>
              <input
                type="text"
                name="defaultValue"
                maxlength="255"
                value={field.defaultValue == null ? '' : String(field.defaultValue)}
                disabled={!editable}
                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent disabled:bg-gray-50"
              />
            </div>
          </div>
          <label class="flex items-center gap-2 text-sm text-gray-700">
            <input type="checkbox" name="isRequired" value="1" checked={field.isRequired} disabled={!editable} class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
            Obligatorio
          </label>
          <label class="flex items-center gap-2 text-sm text-gray-700">
            <input type="checkbox" name="isActive" value="1" checked={field.isActive} disabled={!editable} class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
            Activo
          </label>
        </section>

        <section class="bg-white border border-gray-200 rounded-lg p-6 space-y-4">
          <div>
            <h2 class="text-sm font-medium text-gray-900">Dependencias</h2>
            <p class="text-xs text-gray-500 mt-1">
              Las reglas hacen que este campo sea obligatorio, visible o de solo lectura
              dependiendo del valor de otro campo. Si añades varias reglas con el mismo efecto, todas
              deben cumplirse para que el efecto se active (AND).
            </p>
          </div>
          <input type="hidden" name="dependsOnJson" id="dependsOnJson" value={JSON.stringify(dependencies)} />
          <div id="depRows" class="space-y-2"></div>
          {editable && (
            <button type="button" id="depAdd" class="inline-flex items-center gap-1 px-3 py-1.5 text-xs rounded-md border border-gray-300 bg-white text-gray-700 hover:bg-gray-50">
              + Agregar regla
            </button>
          )}
          <p class="text-xs text-gray-400 pt-2 border-t border-gray-100">
            Ejemplo: <span class="font-mono">campo "hijos" obligatorio si "estado_civil" = "casado"</span>.
          </p>
        </section>

        <section class="bg-white border border-gray-200 rounded-lg p-6 space-y-3">
          <div class="flex items-center justify-between">
            <h2 class="text-sm font-medium text-gray-900">Uso en fórmulas</h2>
            <span class="text-xs text-gray-400">
              {usage.length} {usage.length === 1 ? 'concepto referencia' : 'conceptos referencian'} este campo
            </span>
          </div>
          <p class="text-xs text-gray-500">
            Búsqueda automática de <code class="font-mono">CAMPOADICIONAL("{field.code}")</code> en las
            fórmulas del catálogo de conceptos. Si desactivas este campo, las fórmulas seguirán
            evaluando como <code class="font-mono">0</code> para los empleados que no tengan valor.
          </p>
          {usage.length === 0 ? (
            <p class="text-xs text-gray-400 italic py-2">
              Ningún concepto utiliza este campo todavía. Puedes referenciarlo desde
              <a href="/config/concepts" class="text-blue-600 hover:underline ml-1">Configuración → Conceptos</a>.
            </p>
          ) : (
            <div class="overflow-x-auto -mx-2">
              <table class="w-full text-xs">
                <thead>
                  <tr class="border-b border-gray-200 bg-gray-50">
                    <th class="text-left px-3 py-2 font-medium text-gray-500 uppercase tracking-wide">Concepto</th>
                    <th class="text-left px-3 py-2 font-medium text-gray-500 uppercase tracking-wide">Tipo</th>
                    <th class="text-left px-3 py-2 font-medium text-gray-500 uppercase tracking-wide">Estado</th>
                    <th class="text-left px-3 py-2 font-medium text-gray-500 uppercase tracking-wide">Fórmula</th>
                  </tr>
                </thead>
                <tbody>
                  {usage.map((c) => (
                    <tr class="border-b border-gray-100 last:border-0">
                      <td class="px-3 py-2">
                        <div class="font-mono text-gray-700">{c.code}</div>
                        <div class="text-gray-500">{c.name}</div>
                      </td>
                      <td class="px-3 py-2 text-gray-600">{c.type}</td>
                      <td class="px-3 py-2">
                        {c.isActive ? (
                          <span class="inline-flex px-1.5 py-0.5 rounded bg-emerald-50 text-emerald-700">Activo</span>
                        ) : (
                          <span class="inline-flex px-1.5 py-0.5 rounded bg-gray-100 text-gray-500">Inactivo</span>
                        )}
                      </td>
                      <td class="px-3 py-2 font-mono text-[11px] text-gray-700 break-all">{c.formula}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </section>

        <section class="bg-white border border-gray-200 rounded-lg p-6 space-y-4">
          <h2 class="text-sm font-medium text-gray-900">Permisos por campo</h2>
          <p class="text-xs text-gray-500 -mt-2">
            Restringe quién puede leer o escribir el valor de este campo. Si dejas el permiso vacío,
            cualquier usuario autorizado para empleados podrá usarlo.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1.5">Permiso para leer</label>
              <input
                type="text"
                name="readPermission"
                maxlength="100"
                value={readPermission}
                disabled={!editable}
                placeholder="ej. employees:read"
                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md font-mono focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent disabled:bg-gray-50"
              />
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1.5">Permiso para escribir</label>
              <input
                type="text"
                name="writePermission"
                maxlength="100"
                value={writePermission}
                disabled={!editable}
                placeholder="ej. employees:update"
                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md font-mono focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent disabled:bg-gray-50"
              />
            </div>
          </div>
        </section>

        <section class="bg-white border border-gray-200 rounded-lg p-6 space-y-3">
          <h2 class="text-sm font-medium text-gray-900">Visibilidad en reportes</h2>
          <p class="text-xs text-gray-500 -mt-2">
            Marca aquí los reportes donde este campo debe aparecer como columna adicional al
            descargarlo o visualizarlo.
          </p>
          <label class="flex items-start gap-2 text-sm text-gray-700">
            <input
              type="checkbox"
              name="includeInCreditorsReport"
              value="1"
              checked={includeInCreditorsReport}
              disabled={!editable}
              class="mt-0.5 h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500"
            />
            <span>
              <span class="block font-medium">Incluir en el reporte de acreedores</span>
              <span class="block text-xs text-gray-500">
                Cuando esté activo, el valor del campo se agrega como columna en
                <a href="/reports/creditors" class="text-blue-600 hover:underline">/reports/creditors</a>
                (tabla web, XLSX y PDF mensual).
              </span>
            </span>
          </label>
        </section>

        {editable && (
          <div class="flex items-center justify-between pt-2 border-t border-gray-200">
            <form method="POST" action={`/api/config/custom-fields/${field.id}`} style="display:inline"
              data-saconfirm
              data-sa-title="Desactivar campo"
              data-sa-message={`Vas a desactivar el campo "${field.name}". No se eliminarán los valores ya guardados en empleados.`}
              data-sa-confirm-label="Desactivar"
              data-sa-tone="danger"
              data-sa-loading-title="Desactivando"
              data-sa-success-title="Campo desactivado"
              data-sa-error-title="No se pudo desactivar"
            >
              <input type="hidden" name="_method" value="DELETE" />
              <button type="submit" class="px-3 py-1.5 text-xs rounded-md border border-red-200 text-red-700 hover:bg-red-50">
                Desactivar campo
              </button>
            </form>
            <div class="flex items-center gap-2">
              <a href="/config/custom-fields" class="px-4 py-2 text-sm text-gray-600 hover:text-gray-900">Cancelar</a>
              <button
                type="submit"
                class="inline-flex items-center gap-1.5 px-4 py-2 rounded-md bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 transition-colors"
              >
                Guardar cambios
              </button>
            </div>
          </div>
        )}
      </form>
    )}
  </div>

  <script is:inline>
    ;(function () {
      const json = document.getElementById('dependsOnJson')
      const catalogEl = document.getElementById('depCatalog')
      const rowsEl = document.getElementById('depRows')
      const addBtn = document.getElementById('depAdd')
      if (!json || !rowsEl || !catalogEl) return
      const catalog = JSON.parse(catalogEl.textContent || '[]')
      let rules
      try {
        rules = JSON.parse(json.value || '[]')
      } catch {
        rules = []
      }

      const OPS = [
        ['eq', '='],
        ['ne', '≠'],
        ['gt', '>'],
        ['lt', '<'],
        ['gte', '≥'],
        ['lte', '≤'],
        ['in', 'en lista'],
        ['empty', 'vacío'],
        ['notEmpty', 'no vacío'],
      ]
      const EFFECTS = [
        ['required', 'Obligatorio'],
        ['visible', 'Visible'],
        ['readonly', 'Solo lectura'],
      ]

      function render() {
        rowsEl.innerHTML = ''
        rules.forEach((rule, idx) => {
          const row = document.createElement('div')
          row.className = 'flex items-center gap-2 flex-wrap'
          const fieldSel = document.createElement('select')
          fieldSel.className = 'px-2 py-1.5 text-xs border border-gray-300 rounded-md font-mono'
          fieldSel.innerHTML = '<option value="">Campo origen…</option>'
          for (const f of catalog) {
            const opt = document.createElement('option')
            opt.value = f.code
            opt.textContent = `${f.code} (${f.name})`
            if (rule.field === f.code) opt.selected = true
            fieldSel.appendChild(opt)
          }
          fieldSel.addEventListener('change', (e) => {
            rule.field = e.target.value
            sync()
          })

          const opSel = document.createElement('select')
          opSel.className = 'px-2 py-1.5 text-xs border border-gray-300 rounded-md'
          for (const [v, l] of OPS) {
            const opt = document.createElement('option')
            opt.value = v
            opt.textContent = l
            if (rule.op === v) opt.selected = true
            opSel.appendChild(opt)
          }
          opSel.addEventListener('change', (e) => {
            rule.op = e.target.value
            render()
          })

          const valInput = document.createElement('input')
          valInput.type = 'text'
          valInput.className = 'px-2 py-1.5 text-xs border border-gray-300 rounded-md flex-1 min-w-[120px]'
          valInput.placeholder = rule.op === 'in' ? 'a, b, c' : 'Valor'
          valInput.value =
            rule.op === 'in'
              ? Array.isArray(rule.values)
                ? rule.values.join(', ')
                : ''
              : rule.value == null
                ? ''
                : String(rule.value)
          if (rule.op === 'empty' || rule.op === 'notEmpty') {
            valInput.disabled = true
            valInput.placeholder = '—'
            valInput.value = ''
          }
          valInput.addEventListener('input', (e) => {
            const v = e.target.value
            if (rule.op === 'in') {
              rule.values = v
                .split(',')
                .map((s) => s.trim())
                .filter(Boolean)
              delete rule.value
            } else {
              rule.value = v
              delete rule.values
            }
            sync()
          })

          const effSel = document.createElement('select')
          effSel.className = 'px-2 py-1.5 text-xs border border-gray-300 rounded-md'
          for (const [v, l] of EFFECTS) {
            const opt = document.createElement('option')
            opt.value = v
            opt.textContent = '→ ' + l
            if (rule.effect === v) opt.selected = true
            effSel.appendChild(opt)
          }
          effSel.addEventListener('change', (e) => {
            rule.effect = e.target.value
            sync()
          })

          const rmBtn = document.createElement('button')
          rmBtn.type = 'button'
          rmBtn.className = 'px-2 py-1 text-xs text-red-600 hover:bg-red-50 rounded'
          rmBtn.textContent = '✕'
          rmBtn.title = 'Quitar regla'
          rmBtn.addEventListener('click', () => {
            rules.splice(idx, 1)
            sync()
            render()
          })

          row.append(fieldSel, opSel, valInput, effSel, rmBtn)
          rowsEl.appendChild(row)
        })
        if (rules.length === 0) {
          const empty = document.createElement('p')
          empty.className = 'text-xs text-gray-400 italic'
          empty.textContent = 'Sin reglas. Este campo siempre se comporta según los valores estáticos.'
          rowsEl.appendChild(empty)
        }
      }

      function sync() {
        json.value = JSON.stringify(rules)
      }

      if (addBtn) {
        addBtn.addEventListener('click', () => {
          rules.push({ field: '', op: 'eq', value: '', effect: 'required' })
          sync()
          render()
        })
      }
      render()
    })()
  </script>
  <ServerToastBridge />
</AppLayout>

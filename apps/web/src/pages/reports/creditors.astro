---
import AppLayout from '../../layouts/AppLayout.astro'
import { can, getIdentity } from '../../lib/auth'
import {
  type CreditorsCustomFieldDef,
  formatCustomFieldValue,
  loadCreditorsExtras,
} from '../../lib/reports/creditors-extra-columns'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'

const identity = getIdentity(Astro.cookies)
if (!identity) return Astro.redirect('/login')
if (!can(identity, 'reports:loans.view')) return Astro.redirect('/dashboard')

const tenantSlug = identity.tenantSlug ?? 'demo'
const headers = { Cookie: `auth=${identity.raw}`, 'X-Tenant': tenantSlug }

const today = new Date()
const currentYear = today.getFullYear()
const currentMonth = today.getMonth() + 1

const reqYear = Number.parseInt(Astro.url.searchParams.get('year') ?? '', 10)
const reqMonth = Number.parseInt(Astro.url.searchParams.get('month') ?? '', 10)
const year =
  Number.isInteger(reqYear) && reqYear >= currentYear - 10 && reqYear <= currentYear + 1
    ? reqYear
    : currentYear
const month =
  Number.isInteger(reqMonth) && reqMonth >= 1 && reqMonth <= 12 ? reqMonth : currentMonth

const yearOptions = Array.from({ length: 12 }, (_, i) => currentYear - 10 + i)
const monthLabels = [
  'Enero',
  'Febrero',
  'Marzo',
  'Abril',
  'Mayo',
  'Junio',
  'Julio',
  'Agosto',
  'Septiembre',
  'Octubre',
  'Noviembre',
  'Diciembre',
]

type DetailRow = {
  creditorId: string
  creditorCode: string
  creditorName: string
  conceptCode: string
  amount: string
  payrollId: string
  payrollName: string
  periodStart: string
  periodEnd: string
  employeeId: string
  employeeCode: string
  firstName: string
  lastName: string
}
type CreditorBucket = {
  creditorId: string
  creditorCode: string
  creditorName: string
  total: string
  employeeCount: number
  installmentCount: number
  details: DetailRow[]
}
type ReportData = {
  year: number
  month: number
  rangeFrom: string
  rangeTo: string
  grandTotal: string
  creditorCount: number
  installmentCount: number
  creditors: CreditorBucket[]
}

let report: ReportData | null = null
let error = ''
let payrollReportMode: 'on_demand' | 'file_storage' | 'local_storage' = 'on_demand'
let extraDefs: CreditorsCustomFieldDef[] = []
let cfByEmployee: Map<string, Record<string, unknown>> = new Map()

try {
  const [res, companyRes, extras] = await Promise.all([
    fetch(`${API_URL}/reports/creditors?year=${year}&month=${month}`, { headers }),
    fetch(`${API_URL}/company`, { headers }),
    loadCreditorsExtras(API_URL, headers),
  ])
  extraDefs = extras.defs
  cfByEmployee = extras.customFieldsByEmployee
  if (companyRes.ok) {
    const cj = (await companyRes.json()) as {
      data: { payrollReportMode?: string | null } | null
    }
    const mode = cj.data?.payrollReportMode
    if (mode === 'file_storage') payrollReportMode = 'file_storage'
    else if (mode === 'local_storage') payrollReportMode = 'local_storage'
  }
  if (res.status === 401) return Astro.redirect('/login')
  if (res.ok) {
    const json = (await res.json()) as { data: ReportData }
    report = json.data
  } else {
    let detail = `HTTP ${res.status}`
    try {
      const body = (await res.json()) as { error?: string; message?: string }
      detail = body.message ?? body.error ?? detail
    } catch {
      // best-effort
    }
    error = `No se pudo cargar el reporte: ${detail}`
  }
} catch (err) {
  error = err instanceof Error ? err.message : 'No se pudo conectar con el servidor.'
}

function fmt(v: string | number) {
  const n = Number(v)
  if (!Number.isFinite(n)) return String(v)
  return n.toLocaleString('es-PA', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
}
function fmtDate(iso: string) {
  if (!iso) return '—'
  const d = new Date(`${iso}T00:00:00`)
  if (Number.isNaN(d.getTime())) return iso
  return d.toLocaleDateString('es-PA', { day: '2-digit', month: '2-digit', year: 'numeric' })
}

const monthLabel = monthLabels[month - 1] ?? ''
---

<AppLayout title={`Acreedores · ${monthLabel} ${year}`}>
  <div class="mx-auto w-full max-w-7xl p-8 lg:w-3/4">
    <div class="mb-6">
      <div class="flex items-center gap-2 flex-wrap">
        <h1 class="text-xl font-semibold text-gray-900 tracking-tight">Reporte de acreedores</h1>
        <span
          class={`inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium border ${
            payrollReportMode === 'on_demand'
              ? 'bg-amber-50 text-amber-700 border-amber-200'
              : payrollReportMode === 'local_storage'
                ? 'bg-violet-50 text-violet-700 border-violet-200'
                : 'bg-blue-50 text-blue-700 border-blue-200'
          }`}
          title="Modo de almacenamiento del PDF — configurable en Configuración → Empresa"
        >
          {payrollReportMode === 'on_demand' && 'Bajo demanda'}
          {payrollReportMode === 'local_storage' && 'Disco local'}
          {payrollReportMode === 'file_storage' && 'Nube (S3/R2)'}
        </span>
      </div>
      <p class="text-sm text-gray-500 mt-0.5">
        Total a transferir o emitir cheque por acreedor en el mes seleccionado.
        Suma todas las planillas <span class="font-mono">closed</span> cuyo período cierra dentro del mes.
      </p>
    </div>

    <!-- Filtros -->
    <form method="GET" action="/reports/creditors" class="mb-5">
      <div class="grid grid-cols-1 sm:grid-cols-[auto_auto_auto_1fr] gap-2 items-end">
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Mes</label>
          <select name="month" class="px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent">
            {monthLabels.map((label, i) => (
              <option value={i + 1} selected={i + 1 === month}>{label}</option>
            ))}
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Año</label>
          <select name="year" class="px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent">
            {yearOptions.map((y) => (
              <option value={y} selected={y === year}>{y}</option>
            ))}
          </select>
        </div>
        <button
          type="submit"
          class="inline-flex items-center justify-center gap-1.5 px-3.5 py-2 rounded-md bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 transition-colors"
        >
          Ver
        </button>
        {report && report.installmentCount > 0 && can(identity, 'reports:loans.view') && (
          <div class="justify-self-end flex items-center gap-2">
            <button
              type="button"
              data-export="pdf"
              data-export-url={`/api/reports/creditors/pdf?year=${year}&month=${month}`}
              data-export-filename={`acreedores-${year}-${String(month).padStart(2, '0')}.pdf`}
              class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <path d="M9 13h6M9 17h6M9 9h2"/>
              </svg>
              {payrollReportMode === 'on_demand' ? 'Generar PDF' : 'Descargar PDF'}
            </button>
            <button
              type="button"
              data-export="xlsx"
              data-export-url={`/api/reports/creditors/xlsx?year=${year}&month=${month}`}
              data-export-filename={`acreedores-${year}-${String(month).padStart(2, '0')}.xlsx`}
              class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="7 10 12 15 17 10"/>
                <line x1="12" y1="15" x2="12" y2="3"/>
              </svg>
              Exportar Excel
            </button>
          </div>
        )}
      </div>
    </form>

    {error && (
      <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
    )}

    {report && (
      <>
        <!-- Totales -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-5">
          <div class="bg-white border border-gray-200 rounded-lg p-4">
            <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Total a transferir</p>
            <p class="text-2xl font-bold text-gray-900 tabular-nums">B/. {fmt(report.grandTotal)}</p>
            <p class="text-xs text-gray-400 mt-1 font-mono">{report.rangeFrom} → {report.rangeTo}</p>
          </div>
          <div class="bg-white border border-gray-200 rounded-lg p-4">
            <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Acreedores</p>
            <p class="text-2xl font-bold text-gray-900 tabular-nums">{report.creditorCount}</p>
          </div>
          <div class="bg-white border border-gray-200 rounded-lg p-4">
            <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Cuotas / descuentos</p>
            <p class="text-2xl font-bold text-gray-900 tabular-nums">{report.installmentCount}</p>
          </div>
        </div>

        {report.creditors.length === 0 ? (
          <div class="bg-white border border-gray-200 rounded-lg py-16 text-center">
            <p class="text-sm text-gray-500">No hay descuentos a acreedores en {monthLabel} {year}.</p>
            <p class="text-xs text-gray-400 mt-1">Solo se incluyen planillas cerradas cuyo período termina dentro del mes.</p>
          </div>
        ) : (
          <div class="space-y-3">
            {report.creditors.map((c) => (
              <details class="bg-white border border-gray-200 rounded-lg overflow-hidden">
                <summary class="cursor-pointer px-4 py-3 hover:bg-gray-50 transition-colors flex items-center justify-between gap-3">
                  <div class="min-w-0 flex-1">
                    <div class="flex items-center gap-2">
                      <span class="font-mono text-xs text-gray-500">{c.creditorCode}</span>
                      <span class="font-medium text-gray-900">{c.creditorName}</span>
                    </div>
                    <p class="text-xs text-gray-500 mt-0.5">
                      {c.employeeCount} {c.employeeCount === 1 ? 'empleado' : 'empleados'}
                      <span class="mx-1.5 text-gray-300">·</span>
                      {c.installmentCount} {c.installmentCount === 1 ? 'cuota' : 'cuotas'}
                    </p>
                  </div>
                  <div class="text-right">
                    <p class="text-lg font-bold text-gray-900 tabular-nums">B/. {fmt(c.total)}</p>
                  </div>
                  <svg class="w-4 h-4 text-gray-400 transition-transform [details[open]_&]:rotate-180" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M4 6l4 4 4-4"/></svg>
                </summary>
                <div class="border-t border-gray-100 overflow-x-auto">
                  <table class="w-full text-sm">
                    <thead>
                      <tr class="border-b border-gray-200 bg-gray-50">
                        <th class="text-left px-4 py-2.5 text-xs font-medium text-gray-500 uppercase tracking-wide">Empleado</th>
                        <th class="text-left px-4 py-2.5 text-xs font-medium text-gray-500 uppercase tracking-wide">Planilla</th>
                        <th class="text-left px-4 py-2.5 text-xs font-medium text-gray-500 uppercase tracking-wide">Período</th>
                        <th class="text-left px-4 py-2.5 text-xs font-medium text-gray-500 uppercase tracking-wide">Concepto</th>
                        {extraDefs.map((def) => (
                          <th class="text-left px-4 py-2.5 text-xs font-medium text-gray-500 uppercase tracking-wide" title={def.code}>
                            {def.name}
                          </th>
                        ))}
                        <th class="text-right px-4 py-2.5 text-xs font-medium text-gray-500 uppercase tracking-wide">Monto</th>
                      </tr>
                    </thead>
                    <tbody>
                      {c.details.map((d) => {
                        const cf = cfByEmployee.get(d.employeeId) ?? {}
                        return (
                          <tr class="border-b border-gray-100 last:border-0 hover:bg-gray-50 transition-colors">
                            <td class="px-4 py-2.5">
                              <div class="text-gray-900">{d.lastName}, {d.firstName}</div>
                              <div class="text-xs text-gray-400 font-mono">{d.employeeCode}</div>
                            </td>
                            <td class="px-4 py-2.5">
                              <a href={`/payroll/${d.payrollId}`} class="text-gray-700 hover:text-blue-600 transition-colors">{d.payrollName}</a>
                            </td>
                            <td class="px-4 py-2.5 font-mono text-xs text-gray-500">
                              {fmtDate(d.periodStart)} → {fmtDate(d.periodEnd)}
                            </td>
                            <td class="px-4 py-2.5 font-mono text-xs text-gray-700">{d.conceptCode}</td>
                            {extraDefs.map((def) => (
                              <td class="px-4 py-2.5 text-xs text-gray-700">
                                {String(formatCustomFieldValue(def, cf[def.code]) ?? '') || '—'}
                              </td>
                            ))}
                            <td class="px-4 py-2.5 text-right tabular-nums text-red-600 font-medium">−B/. {fmt(d.amount)}</td>
                          </tr>
                        )
                      })}
                    </tbody>
                  </table>
                </div>
              </details>
            ))}
          </div>
        )}
      </>
    )}
  </div>

  <script is:inline>
    /**
     * Orquesta el flujo confirmación → espera → resultado para los
     * botones de exportación. El servidor genera el archivo y lo
     * devuelve como binario; aquí lo bajamos como Blob y disparamos
     * la descarga programáticamente para mantener el modal de espera
     * arriba mientras dura la generación. Si el endpoint responde con
     * un error, lo surface en el modal de error con el mensaje del API.
     */
    ;(function () {
      const FORMAT_LABELS = {
        pdf: { label: 'PDF', kind: 'PDF', mime: 'application/pdf' },
        xlsx: {
          label: 'Excel',
          kind: 'Excel',
          mime: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',
        },
      }

      function filenameFromHeader(header, fallback) {
        if (!header) return fallback
        const m = header.match(/filename\*?=(?:UTF-8'')?"?([^";]+)"?/i)
        return m ? decodeURIComponent(m[1]) : fallback
      }

      async function runExport(btn) {
        const format = btn.dataset.export
        const url = btn.dataset.exportUrl
        const fallbackName = btn.dataset.exportFilename || `reporte.${format}`
        const meta = FORMAT_LABELS[format] || { label: format, kind: format, mime: 'application/octet-stream' }
        if (!url || !window.saModal) {
          window.location.href = url
          return
        }

        const ok = await window.saModal.confirm({
          title: `Generar reporte ${meta.kind}`,
          message:
            `Vamos a armar el reporte de acreedores en formato ${meta.kind} con las planillas cerradas del mes seleccionado. ` +
            `Puede tardar unos segundos si hay muchos descuentos.`,
          confirmLabel: `Generar ${meta.kind}`,
        })
        if (!ok) return

        window.saModal.loading({
          title: `Generando ${meta.kind}…`,
          message: 'Compilando la información del mes y armando el archivo. Por favor espera.',
        })

        let res
        try {
          res = await fetch(url, {
            method: 'GET',
            credentials: 'same-origin',
            headers: { Accept: meta.mime },
          })
        } catch (err) {
          await window.saModal.error({
            title: 'No se pudo conectar con el servidor',
            message: 'Revisa tu conexión y vuelve a intentar.',
            detail: err && err.message ? err.message : String(err),
          })
          return
        }

        if (!res.ok) {
          let detail = `HTTP ${res.status}`
          try {
            const txt = await res.text()
            if (txt) detail = txt.slice(0, 500)
          } catch {
            /* best-effort */
          }
          await window.saModal.error({
            title: `No se pudo generar el ${meta.kind}`,
            message: 'El servidor rechazó la solicitud. Revisa el detalle.',
            detail,
          })
          return
        }

        let blob
        try {
          blob = await res.blob()
        } catch (err) {
          await window.saModal.error({
            title: `No se pudo leer el ${meta.kind}`,
            message: 'El archivo llegó pero no se pudo procesar.',
            detail: err && err.message ? err.message : String(err),
          })
          return
        }

        const filename = filenameFromHeader(
          res.headers.get('content-disposition'),
          fallbackName
        )

        const objectUrl = URL.createObjectURL(blob)
        const a = document.createElement('a')
        a.href = objectUrl
        a.download = filename
        document.body.appendChild(a)
        a.click()
        a.remove()
        // Liberar el blob después del click; algunos navegadores
        // necesitan el handle vivo durante el descenso del evento.
        setTimeout(() => URL.revokeObjectURL(objectUrl), 1500)

        await window.saModal.success({
          title: `${meta.kind} generado`,
          message: `Se descargó "${filename}".`,
        })
      }

      document.querySelectorAll('button[data-export]').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.preventDefault()
          runExport(btn)
        })
      })
    })()
  </script>
</AppLayout>

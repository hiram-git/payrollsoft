---
import AppLayout from '../../layouts/AppLayout.astro'
import { PAYROLL_REPORTS } from '../../lib/reports/registry'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')

type Payroll = {
  id: string
  name: string
  type: string
  frequency: string
  periodStart: string
  periodEnd: string
  paymentDate: string | null
  status: string
  totalGross: string
  totalDeductions: string
  totalNet: string
}

const PAGE_SIZE = 25
const page = Math.max(1, Number(Astro.url.searchParams.get('page') ?? '1'))
const search = Astro.url.searchParams.get('search') ?? ''

let payrolls: Payroll[] = []
let total = 0
let totalPages = 1
let error = ''

try {
  // Ask the API for a generous slice and filter client-side. The payroll list
  // endpoint does not yet support multi-status filtering, so we page through
  // the filtered result ourselves — fine for the typical volume of payrolls
  // per tenant (dozens, not thousands).
  const params = new URLSearchParams({ page: '1', limit: '500' })
  const res = await fetch(`${API_URL}/payroll?${params}`, {
    headers: { Cookie: `auth=${authCookie}`, 'X-Tenant': 'demo' },
  })
  if (res.status === 401) return Astro.redirect('/login')
  if (res.ok) {
    const json = (await res.json()) as { data: Payroll[] }
    const all = json.data ?? []
    const matching = all.filter((p) => {
      if (p.status !== 'generated' && p.status !== 'closed') return false
      if (!search) return true
      return p.name.toLowerCase().includes(search.toLowerCase())
    })
    total = matching.length
    totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE))
    const from = (page - 1) * PAGE_SIZE
    payrolls = matching.slice(from, from + PAGE_SIZE)
  } else {
    error = 'Error al cargar las planillas'
  }
} catch {
  error = 'No se pudo conectar con el servidor'
}

function pageUrl(p: number) {
  const u = new URL(Astro.url)
  u.searchParams.set('page', String(p))
  return u.pathname + u.search
}

const showingFrom = total === 0 ? 0 : (page - 1) * PAGE_SIZE + 1
const showingTo = Math.min(page * PAGE_SIZE, total)

const statusLabel: Record<string, string> = { generated: 'Generada', closed: 'Cerrada' }
const statusStyle: Record<string, string> = {
  generated: 'bg-blue-50 text-blue-700',
  closed: 'bg-emerald-50 text-emerald-700',
}
const typeLabel: Record<string, string> = {
  regular: 'Regular',
  thirteenth: 'XIII Mes',
  special: 'Especial',
}
const freqLabel: Record<string, string> = {
  biweekly: 'Quincenal',
  monthly: 'Mensual',
  weekly: 'Semanal',
}

function fmt(v: string) {
  return Number(v).toLocaleString('es-PA', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
}
---

<AppLayout title="Reportes de Planilla">
  <div class="p-8">

    <!-- Page header -->
    <div class="flex items-center justify-between mb-2">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Reportes de Planilla</h1>
        <p class="text-sm text-gray-500 mt-0.5">
          Genera reportes PDF, Excel y comprobantes para planillas generadas o cerradas.
        </p>
      </div>
    </div>

    <!-- Filter bar -->
    <div class="flex items-center justify-between gap-4 mb-4 mt-6">
      <form method="GET" action="" class="flex items-center gap-2">
        <input
          type="search"
          name="search"
          value={search}
          placeholder="Buscar planilla…"
          class="w-64 px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-white text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
        />
        <button type="submit" class="px-3 py-1.5 text-sm rounded-md bg-blue-600 text-white hover:bg-blue-700 transition-colors">
          Buscar
        </button>
        {search && (
          <a href="/reports/payroll" class="text-xs text-gray-500 hover:text-gray-700 ml-2">Limpiar</a>
        )}
      </form>
      <span class="text-sm text-gray-500">{total} {total === 1 ? 'planilla' : 'planillas'}</span>
    </div>

    {error && (
      <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
    )}

    <!-- Table -->
    <div class="bg-white rounded-xl border border-gray-200 overflow-visible">
      {payrolls.length === 0 ? (
        <div class="py-16 text-center">
          <p class="text-sm text-gray-400 mb-1">
            {search
              ? 'No hay planillas que coincidan con la búsqueda.'
              : 'No hay planillas generadas o cerradas todavía.'}
          </p>
          {!search && (
            <a href="/payroll" class="text-sm text-gray-900 underline underline-offset-2 hover:text-gray-600">
              Ir al módulo de planillas
            </a>
          )}
        </div>
      ) : (
        <table class="w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Planilla</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Tipo</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Período</th>
              <th class="text-right px-4 py-3 font-medium text-gray-600">Bruto</th>
              <th class="text-right px-4 py-3 font-medium text-gray-600">Deduc.</th>
              <th class="text-right px-4 py-3 font-medium text-gray-600">Neto</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Estado</th>
              <th class="px-4 py-3 text-right font-medium text-gray-600">Reporte</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {payrolls.map((p) => (
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-4 py-3.5">
                  <a href={`/payroll/${p.id}`} class="font-medium text-gray-900 hover:text-gray-600">
                    {p.name}
                  </a>
                </td>
                <td class="px-4 py-3.5 text-gray-600">
                  {typeLabel[p.type] ?? p.type}
                  <span class="text-gray-400 text-xs ml-1">· {freqLabel[p.frequency] ?? p.frequency}</span>
                </td>
                <td class="px-4 py-3.5 text-gray-500 font-mono text-xs">
                  {p.periodStart} → {p.periodEnd}
                </td>
                <td class="px-4 py-3.5 text-right text-gray-700 tabular-nums">{fmt(p.totalGross)}</td>
                <td class="px-4 py-3.5 text-right text-red-600 tabular-nums">{fmt(p.totalDeductions)}</td>
                <td class="px-4 py-3.5 text-right font-semibold text-gray-900 tabular-nums">{fmt(p.totalNet)}</td>
                <td class="px-4 py-3.5">
                  <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${statusStyle[p.status] ?? 'bg-gray-100 text-gray-500'}`}>
                    {statusLabel[p.status] ?? p.status}
                  </span>
                </td>
                <td class="px-4 py-3.5 text-right">
                  <div class="relative inline-block text-left" data-report-menu>
                    <button
                      type="button"
                      class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md border border-gray-300 bg-white text-gray-700 text-xs font-medium hover:bg-gray-50 transition-colors"
                      data-report-trigger
                      aria-haspopup="menu"
                      aria-expanded="false"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                      Reportes
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <div
                      class="hidden absolute right-0 mt-1 w-72 origin-top-right rounded-lg border border-gray-200 bg-white shadow-lg z-20"
                      data-report-panel
                      role="menu"
                    >
                      <ul class="py-1">
                        {PAYROLL_REPORTS.map((r) => {
                          const isAvailable = r.status === 'available'
                          const href = r.href(p.id)
                          return (
                            <li role="none">
                              {isAvailable ? (
                                <a
                                  href={href}
                                  target={r.opensInNewTab ? '_blank' : undefined}
                                  rel={r.opensInNewTab ? 'noopener' : undefined}
                                  class="flex items-start gap-3 px-3 py-2 text-left text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-700 transition-colors"
                                  role="menuitem"
                                >
                                  <span class="mt-0.5 inline-flex items-center justify-center w-9 h-5 rounded bg-blue-50 text-blue-700 text-[10px] font-bold tracking-wide">{r.code}</span>
                                  <span class="flex-1">
                                    <span class="block font-medium leading-tight">{r.label}</span>
                                    <span class="block text-xs text-gray-500 leading-snug mt-0.5">{r.description}</span>
                                  </span>
                                </a>
                              ) : (
                                <button
                                  type="button"
                                  disabled
                                  aria-disabled="true"
                                  title="Próximamente — en desarrollo"
                                  class="w-full flex items-start gap-3 px-3 py-2 text-left text-sm text-gray-400 cursor-not-allowed"
                                  role="menuitem"
                                >
                                  <span class="mt-0.5 inline-flex items-center justify-center w-9 h-5 rounded bg-gray-100 text-gray-400 text-[10px] font-bold tracking-wide">{r.code}</span>
                                  <span class="flex-1">
                                    <span class="flex items-center gap-1.5 font-medium leading-tight">
                                      {r.label}
                                      <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[9px] font-semibold uppercase tracking-wide bg-amber-50 text-amber-700">
                                        Próximamente
                                      </span>
                                    </span>
                                    <span class="block text-xs text-gray-400 leading-snug mt-0.5">{r.description}</span>
                                  </span>
                                </button>
                              )}
                            </li>
                          )
                        })}
                      </ul>
                    </div>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>

    <!-- Pagination -->
    {totalPages > 1 && (
      <div class="mt-4 flex items-center justify-between text-sm text-gray-500">
        <span>Mostrando {showingFrom}–{showingTo} de {total}</span>
        <div class="flex items-center gap-1">
          {page > 1 ? (
            <a href={pageUrl(page - 1)} class="px-3 py-1.5 rounded-md border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 transition-colors text-xs font-medium">
              ← Anterior
            </a>
          ) : (
            <span class="px-3 py-1.5 rounded-md border border-gray-200 bg-gray-50 text-gray-300 text-xs font-medium cursor-not-allowed">← Anterior</span>
          )}
          <span class="px-3 py-1.5 text-xs text-gray-600">Pág. {page} / {totalPages}</span>
          {page < totalPages ? (
            <a href={pageUrl(page + 1)} class="px-3 py-1.5 rounded-md border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 transition-colors text-xs font-medium">
              Siguiente →
            </a>
          ) : (
            <span class="px-3 py-1.5 rounded-md border border-gray-200 bg-gray-50 text-gray-300 text-xs font-medium cursor-not-allowed">Siguiente →</span>
          )}
        </div>
      </div>
    )}
  </div>
</AppLayout>

<script>
  // Lightweight dropdown toggle for the "Reportes" menus. Only one can be open
  // at a time; clicking outside or pressing Escape closes the active menu.
  (function () {
    const menus = Array.from(document.querySelectorAll<HTMLElement>('[data-report-menu]'))

    function closeAll() {
      for (const m of menus) {
        const panel = m.querySelector<HTMLElement>('[data-report-panel]')
        const trigger = m.querySelector<HTMLElement>('[data-report-trigger]')
        if (panel) panel.classList.add('hidden')
        if (trigger) trigger.setAttribute('aria-expanded', 'false')
      }
    }

    for (const menu of menus) {
      const trigger = menu.querySelector<HTMLElement>('[data-report-trigger]')
      const panel = menu.querySelector<HTMLElement>('[data-report-panel]')
      if (!trigger || !panel) continue
      trigger.addEventListener('click', (e) => {
        e.stopPropagation()
        const open = !panel.classList.contains('hidden')
        closeAll()
        if (!open) {
          panel.classList.remove('hidden')
          trigger.setAttribute('aria-expanded', 'true')
        }
      })
      panel.addEventListener('click', (e) => e.stopPropagation())
    }

    document.addEventListener('click', closeAll)
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeAll()
    })
  })()
</script>

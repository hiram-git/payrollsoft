---
import AppLayout from '../../layouts/AppLayout.astro'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')

// The navbar's payroll-type selector persists its choice in this cookie.
// Using it as a server-side filter means the listing reacts automatically
// to whatever type the user has active — no page-local selector needed.
const activeTypeId = Astro.cookies.get('payroll.activeTypeId')?.value ?? ''

type Payroll = {
  id: string
  name: string
  type: string
  frequency: string
  periodStart: string
  periodEnd: string
  paymentDate: string | null
  status: string
  totalGross: string
  totalDeductions: string
  totalNet: string
}

const PAGE_SIZE = 25
const page = Math.max(1, Number(Astro.url.searchParams.get('page') ?? '1'))
const search = Astro.url.searchParams.get('search') ?? ''

let payrolls: Payroll[] = []
let total = 0
let totalPages = 1
let error = ''

try {
  const params = new URLSearchParams({ page: '1', limit: '500' })
  if (activeTypeId) params.set('payrollTypeId', activeTypeId)
  const res = await fetch(`${API_URL}/payroll?${params}`, {
    headers: { Cookie: `auth=${authCookie}`, 'X-Tenant': 'demo' },
  })
  if (res.status === 401) return Astro.redirect('/login')
  if (res.ok) {
    const json = (await res.json()) as { data: Payroll[] }
    const all = json.data ?? []
    const matching = all.filter((p) => {
      if (p.status !== 'generated' && p.status !== 'closed') return false
      if (!search) return true
      return p.name.toLowerCase().includes(search.toLowerCase())
    })
    total = matching.length
    totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE))
    const from = (page - 1) * PAGE_SIZE
    payrolls = matching.slice(from, from + PAGE_SIZE)
  } else {
    error = 'Error al cargar las planillas'
  }
} catch {
  error = 'No se pudo conectar con el servidor'
}

function pageUrl(p: number) {
  const u = new URL(Astro.url)
  u.searchParams.set('page', String(p))
  return u.pathname + u.search
}

const showingFrom = total === 0 ? 0 : (page - 1) * PAGE_SIZE + 1
const showingTo = Math.min(page * PAGE_SIZE, total)

const statusLabel: Record<string, string> = { generated: 'Generada', closed: 'Cerrada' }
const statusStyle: Record<string, string> = {
  generated: 'bg-blue-50 text-blue-700',
  closed: 'bg-emerald-50 text-emerald-700',
}
const typeLabel: Record<string, string> = {
  regular: 'Regular',
  thirteenth: 'XIII Mes',
  special: 'Especial',
}
const freqLabel: Record<string, string> = {
  biweekly: 'Quincenal',
  monthly: 'Mensual',
  weekly: 'Semanal',
}

function fmt(v: string) {
  return Number(v).toLocaleString('es-PA', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
}
---

<AppLayout title="Reportes de Planilla">
  <div class="p-8">

    <div class="flex items-start justify-between mb-2">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Reportes de Planilla</h1>
        <p class="text-sm text-gray-500 mt-0.5">
          Genera, descarga o regenera la Planilla PDF por cada planilla cerrada o generada.
          El filtro por tipo se hereda del selector superior.
        </p>
      </div>
    </div>

    <div class="flex items-center justify-between gap-4 mb-4 mt-6">
      <form method="GET" action="" class="flex items-center gap-2">
        <input
          type="search"
          name="search"
          value={search}
          placeholder="Buscar planilla…"
          class="w-64 px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-white text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
        />
        <button type="submit" class="px-3 py-1.5 text-sm rounded-md bg-blue-600 text-white hover:bg-blue-700 transition-colors">
          Buscar
        </button>
        {search && (
          <a href="/reports/payroll" class="text-xs text-gray-500 hover:text-gray-700 ml-2">Limpiar</a>
        )}
      </form>
      <span class="text-sm text-gray-500">{total} {total === 1 ? 'planilla' : 'planillas'}</span>
    </div>

    {error && (
      <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
    )}

    <div class="bg-white rounded-xl border border-gray-200 overflow-visible">
      {payrolls.length === 0 ? (
        <div class="py-16 text-center">
          <p class="text-sm text-gray-400 mb-1">
            {search
              ? 'No hay planillas que coincidan con la búsqueda.'
              : 'No se encontraron registros para el tipo de planilla seleccionado.'}
          </p>
          {!search && (
            <a href="/payroll" class="text-sm text-gray-900 underline underline-offset-2 hover:text-gray-600">
              Ir al módulo de planillas
            </a>
          )}
        </div>
      ) : (
        <table class="w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Planilla</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Tipo</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Período</th>
              <th class="text-right px-4 py-3 font-medium text-gray-600">Neto</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Estado</th>
              <th class="px-4 py-3 text-right font-medium text-gray-600">Acciones</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {payrolls.map((p) => (
              <tr class="hover:bg-gray-50 transition-colors" data-report-row data-payroll-id={p.id}>
                <td class="px-4 py-3.5">
                  <a href={`/payroll/${p.id}`} class="font-medium text-gray-900 hover:text-gray-600">
                    {p.name}
                  </a>
                </td>
                <td class="px-4 py-3.5 text-gray-600">
                  {typeLabel[p.type] ?? p.type}
                  <span class="text-gray-400 text-xs ml-1">· {freqLabel[p.frequency] ?? p.frequency}</span>
                </td>
                <td class="px-4 py-3.5 text-gray-500 font-mono text-xs">
                  {p.periodStart} → {p.periodEnd}
                </td>
                <td class="px-4 py-3.5 text-right font-semibold text-gray-900 tabular-nums">{fmt(p.totalNet)}</td>
                <td class="px-4 py-3.5">
                  <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${statusStyle[p.status] ?? 'bg-gray-100 text-gray-500'}`}>
                    {statusLabel[p.status] ?? p.status}
                  </span>
                </td>
                <td class="px-4 py-3.5">
                  <div class="flex items-center gap-1.5 justify-end" data-report-actions>
                    <!-- Loading skeleton / status dot — replaced on subscribe -->
                    <span class="text-[11px] text-gray-400" data-report-status>…</span>
                    <button
                      type="button"
                      data-report-action="generate"
                      class="hidden inline-flex items-center gap-1 px-2.5 py-1 rounded-md bg-blue-600 text-white text-xs font-medium hover:bg-blue-700 disabled:opacity-60 disabled:cursor-wait transition-colors"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="14 2 14 8 20 8"/><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>
                      <span data-report-label>Generar</span>
                    </button>
                    <button
                      type="button"
                      data-report-action="download"
                      class="hidden inline-flex items-center gap-1 px-2.5 py-1 rounded-md bg-blue-600 text-white text-xs font-medium hover:bg-blue-700 disabled:opacity-60 disabled:cursor-wait transition-colors"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                      Descargar
                    </button>
                    <button
                      type="button"
                      data-report-action="regenerate"
                      class="hidden inline-flex items-center gap-1 px-2.5 py-1 rounded-md border border-gray-300 bg-white text-gray-700 text-xs font-medium hover:bg-gray-50 disabled:opacity-60 disabled:cursor-wait transition-colors"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
                      <span data-report-label>Regenerar</span>
                    </button>
                    <span
                      class="hidden text-[11px] text-red-600"
                      data-report-error
                      title=""
                    >Error</span>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>

    {totalPages > 1 && (
      <div class="mt-4 flex items-center justify-between text-sm text-gray-500">
        <span>Mostrando {showingFrom}–{showingTo} de {total}</span>
        <div class="flex items-center gap-1">
          {page > 1 ? (
            <a href={pageUrl(page - 1)} class="px-3 py-1.5 rounded-md border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 transition-colors text-xs font-medium">
              ← Anterior
            </a>
          ) : (
            <span class="px-3 py-1.5 rounded-md border border-gray-200 bg-gray-50 text-gray-300 text-xs font-medium cursor-not-allowed">← Anterior</span>
          )}
          <span class="px-3 py-1.5 text-xs text-gray-600">Pág. {page} / {totalPages}</span>
          {page < totalPages ? (
            <a href={pageUrl(page + 1)} class="px-3 py-1.5 rounded-md border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 transition-colors text-xs font-medium">
              Siguiente →
            </a>
          ) : (
            <span class="px-3 py-1.5 rounded-md border border-gray-200 bg-gray-50 text-gray-300 text-xs font-medium cursor-not-allowed">Siguiente →</span>
          )}
        </div>
      </div>
    )}
  </div>
</AppLayout>

<script>
  import { payrollReportUrls, usePayrollReport } from '../../lib/reports/use-payroll-report'
  import type { ReportState } from '../../lib/reports/use-payroll-report'

  // Each row owns its own controller + subscribe, so a busy regeneration on
  // one row never blocks the others or freezes the whole table.
  for (const row of document.querySelectorAll<HTMLElement>('[data-report-row]')) {
    const payrollId = row.dataset.payrollId
    if (!payrollId) continue

    const statusEl = row.querySelector<HTMLElement>('[data-report-status]')
    const errorEl = row.querySelector<HTMLElement>('[data-report-error]')
    const btnGenerate = row.querySelector<HTMLButtonElement>('[data-report-action="generate"]')
    const btnDownload = row.querySelector<HTMLButtonElement>('[data-report-action="download"]')
    const btnRegenerate = row.querySelector<HTMLButtonElement>('[data-report-action="regenerate"]')
    const labelGenerate = btnGenerate?.querySelector<HTMLElement>('[data-report-label]') ?? null
    const labelRegenerate = btnRegenerate?.querySelector<HTMLElement>('[data-report-label]') ?? null

    const controller = usePayrollReport({
      payrollId,
      ...payrollReportUrls(payrollId),
    })

    function applyState(state: ReportState) {
      // Status dot / hint
      if (statusEl) {
        if (state.kind === 'loading') statusEl.textContent = '…'
        else if (state.kind === 'busy') statusEl.textContent = '…'
        else if (state.kind === 'error') statusEl.textContent = ''
        else statusEl.textContent = state.snapshot.status === 'generated' ? '✓' : '—'
      }

      const snapshot = state.kind === 'idle'
        ? state.snapshot
        : state.kind === 'busy' || state.kind === 'error'
          ? state.lastSnapshot
          : null

      const isGenerated = snapshot?.status === 'generated'
      const showGenerate = snapshot != null && !isGenerated
      const showDownload = snapshot != null && isGenerated
      const showRegenerate = snapshot != null && isGenerated

      btnGenerate?.classList.toggle('hidden', !showGenerate)
      btnDownload?.classList.toggle('hidden', !showDownload)
      btnRegenerate?.classList.toggle('hidden', !showRegenerate)

      const isBusy = state.kind === 'busy'
      if (btnGenerate) btnGenerate.disabled = isBusy
      if (btnDownload) btnDownload.disabled = isBusy
      if (btnRegenerate) btnRegenerate.disabled = isBusy

      if (labelGenerate) labelGenerate.textContent = isBusy && state.action === 'generate' ? 'Generando…' : 'Generar'
      if (labelRegenerate) labelRegenerate.textContent = isBusy && state.action === 'regenerate' ? 'Regenerando…' : 'Regenerar'

      if (errorEl) {
        if (state.kind === 'error') {
          errorEl.classList.remove('hidden')
          errorEl.textContent = 'Error'
          errorEl.title = state.message
        } else {
          errorEl.classList.add('hidden')
          errorEl.textContent = ''
          errorEl.title = ''
        }
      }
    }

    controller.subscribe(applyState)
    btnGenerate?.addEventListener('click', () => controller.generate())
    btnDownload?.addEventListener('click', () => controller.download())
    btnRegenerate?.addEventListener('click', () => controller.regenerate())

    void controller.refresh()
  }
</script>

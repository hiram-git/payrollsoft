---
import AppLayout from '../../layouts/AppLayout.astro'
import { resolveTenantSlugFromCookie } from '../../lib/tenant-slug'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')
const tenantSlug = resolveTenantSlugFromCookie(authCookie)

// Mandatory global filter — same cookie used by the topbar selector
// and every other module in the app. The PDF endpoint reads the cookie
// directly, so the URL doesn't need any query-string scoping.
const activeTypeId = Astro.cookies.get('payroll.activeTypeId')?.value ?? ''

type CustomFieldDef = {
  code: string
  name: string
  fieldType: 'text' | 'integer' | 'float' | 'date'
  isActive: boolean
}
type PayrollType = { id: string; code: string; name: string; sortOrder: number }
type ApiEmployee = {
  id: string
  code: string
  firstName: string
  lastName: string
  idNumber: string | null
  position: string | null
  department: string | null
  baseSalary: string | null
  payFrequency: string | null
  hireDate: string | null
  contractType: string | null
  contractEndDate: string | null
  birthDate: string | null
  isActive: boolean
}

const headers = { Cookie: `auth=${authCookie}`, 'X-Tenant': tenantSlug }

// Cargar el catálogo de campos adicionales activos para que el usuario
// pueda elegir cuáles incluir como columnas en el .xlsx. La API filtra
// por readPermission, así que aquí ya viene depurado.
let customFieldDefs: CustomFieldDef[] = []
try {
  const res = await fetch(`${API_URL}/custom-fields`, { headers })
  if (res.ok) {
    customFieldDefs = (((await res.json()) as { data: CustomFieldDef[] }).data ?? []).filter(
      (d) => d.isActive
    )
  }
} catch {
  /* la página sigue funcionando sin la lista */
}

// Modo de almacenamiento del PDF, idéntico al usado por la planilla.
// Cambia el texto del botón principal y el badge del header.
let payrollReportMode: 'on_demand' | 'file_storage' | 'local_storage' = 'on_demand'
try {
  const res = await fetch(`${API_URL}/company`, { headers })
  if (res.ok) {
    const json = (await res.json()) as {
      data: { payrollReportMode?: string | null } | null
    }
    const mode = json.data?.payrollReportMode
    if (mode === 'file_storage') payrollReportMode = 'file_storage'
    else if (mode === 'local_storage') payrollReportMode = 'local_storage'
  }
} catch {
  /* defaults to on_demand */
}

// Cargar todos los tipos de planilla para el dropdown del filtro.
let payrollTypes: PayrollType[] = []
try {
  const res = await fetch(`${API_URL}/concepts/config`, { headers })
  if (res.ok) {
    const json = (await res.json()) as { data?: { payrollTypes?: PayrollType[] } }
    payrollTypes = (json.data?.payrollTypes ?? []).sort((a, b) => a.sortOrder - b.sortOrder)
  }
} catch {
  /* ignore */
}

// ── Filtros (query string; el tipo cae al cookie del navbar si no se pasa) ──
const sp = Astro.url.searchParams
const filterTypeId = sp.get('typeId') ?? activeTypeId
const situacion: 'active' | 'inactive' | 'all' =
  sp.get('situacion') === 'inactive' ? 'inactive' : sp.get('situacion') === 'all' ? 'all' : 'active'
const filterOwnDisability = sp.get('ownDisability') === 'true'
const filterFamilyDisability = sp.get('familyDisability') === 'true'
const filterIncludeDependents = sp.get('dependents') === 'true'

const activePayrollType = payrollTypes.find((t) => t.id === filterTypeId) ?? null

// Walk every page (the API caps `limit` at 100) so totals on screen
// match the totals printed in the PDF. 50 pages × 100 ≈ 5,000 rows
// is plenty for a single payroll type.
const PAGE_SIZE = 100
const MAX_PAGES = 50

const employees: ApiEmployee[] = []
let error = ''
let unauthorized = false
try {
  for (let page = 1; page <= MAX_PAGES; page++) {
    const params = new URLSearchParams({
      page: String(page),
      limit: String(PAGE_SIZE),
    })
    if (situacion === 'active') params.set('isActive', 'true')
    else if (situacion === 'inactive') params.set('isActive', 'false')
    if (filterTypeId) params.set('payrollTypeId', filterTypeId)
    if (filterOwnDisability) params.set('hasOwnDisability', 'true')
    if (filterFamilyDisability) params.set('hasFamilyDisability', 'true')
    const res = await fetch(`${API_URL}/employees?${params}`, { headers })
    if (res.status === 401) {
      unauthorized = true
      break
    }
    if (!res.ok) {
      error = 'Error al cargar el listado de personal'
      break
    }
    const json = (await res.json()) as { data: ApiEmployee[] }
    const batch = json.data ?? []
    employees.push(...batch)
    if (batch.length < PAGE_SIZE) break
  }
} catch {
  error = 'No se pudo conectar con el servidor'
}
if (unauthorized) return Astro.redirect('/login')

const total = employees.length
const activeCount = employees.filter((e) => e.isActive).length
const totalSalary = employees.reduce((acc, e) => acc + (Number(e.baseSalary) || 0), 0)
const preview = employees.slice(0, 20)

function fmtMoney(v: number) {
  return v.toLocaleString('es-PA', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
}

const downloadParams = new URLSearchParams()
if (filterTypeId) downloadParams.set('payrollTypeId', filterTypeId)
if (activePayrollType?.name) downloadParams.set('payrollTypeName', activePayrollType.name)
downloadParams.set('situacion', situacion)
if (filterOwnDisability) downloadParams.set('hasOwnDisability', 'true')
if (filterFamilyDisability) downloadParams.set('hasFamilyDisability', 'true')
if (filterIncludeDependents) downloadParams.set('dependents', 'true')
const downloadUrl = `/api/reports/personnel/download?${downloadParams.toString()}`

const MESES = [
  'Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio',
  'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre',
]
const currentMonth = new Date().getUTCMonth() + 1

const CONTRACT_LABELS: Record<string, string> = {
  permanent: 'Permanente',
  transitory: 'Transitorio',
  contingent: 'Contingente',
  professional_services: 'Servicios profesionales',
  deputy: 'Diputado',
  interim: 'Interino',
}

// ── Contratos por vencer ────────────────────────────────────────────────────
// Se listan los empleados con "Fin de contrato" dentro de los próximos 30 días.
type ContractRow = {
  code: string
  name: string
  department: string | null
  position: string | null
  contractType: string | null
  hireDate: string
  expires: string
  daysLeft: number
}
const todayUtc = new Date()
const today0 = Date.UTC(todayUtc.getUTCFullYear(), todayUtc.getUTCMonth(), todayUtc.getUTCDate())
const DAY_MS = 86_400_000

const contractsExpiring: ContractRow[] = []
const activeVacations: {
  code: string
  name: string
  department: string | null
  position: string | null
  startDate: string
  endDate: string
  requestType: string
  days: number
}[] = []

try {
  // Empleados activos (independiente de los filtros de "Por planilla").
  const active: ApiEmployee[] = []
  for (let page = 1; page <= MAX_PAGES; page++) {
    const params = new URLSearchParams({ page: String(page), limit: String(PAGE_SIZE), isActive: 'true' })
    const res = await fetch(`${API_URL}/employees?${params}`, { headers })
    if (!res.ok) break
    const json = (await res.json()) as { data: ApiEmployee[] }
    const batch = json.data ?? []
    active.push(...batch)
    if (batch.length < PAGE_SIZE) break
  }
  for (const e of active) {
    const ced = e.contractEndDate ? String(e.contractEndDate).slice(0, 10) : ''
    if (!/^\d{4}-\d{2}-\d{2}$/.test(ced)) continue
    const expiresMs = Date.parse(`${ced}T00:00:00Z`)
    if (Number.isNaN(expiresMs)) continue
    const daysLeft = Math.round((expiresMs - today0) / DAY_MS)
    if (daysLeft < 0 || daysLeft > 30) continue
    contractsExpiring.push({
      code: e.code,
      name: `${e.firstName} ${e.lastName}`,
      department: e.department,
      position: e.position,
      contractType: e.contractType,
      hireDate: e.hireDate ? String(e.hireDate).slice(0, 10) : '—',
      expires: ced,
      daysLeft,
    })
  }
  contractsExpiring.sort((a, b) => a.daysLeft - b.daysLeft)
} catch {
  /* la pestaña de contratos queda vacía si falla */
}

try {
  const res = await fetch(`${API_URL}/vacations/active`, { headers })
  if (res.ok) {
    type VacApi = {
      employee_code: string
      employee_first_name: string
      employee_last_name: string
      employee_department: string | null
      employee_position: string | null
      start_date: string
      end_date: string
      request_type: string
    }
    const data = ((await res.json()) as { data: VacApi[] }).data ?? []
    for (const v of data) {
      const sd = String(v.start_date).slice(0, 10)
      const ed = String(v.end_date).slice(0, 10)
      const days =
        Math.round((Date.parse(`${ed}T00:00:00Z`) - Date.parse(`${sd}T00:00:00Z`)) / DAY_MS) + 1
      activeVacations.push({
        code: v.employee_code,
        name: `${v.employee_first_name} ${v.employee_last_name}`,
        department: v.employee_department,
        position: v.employee_position,
        startDate: sd,
        endDate: ed,
        requestType: v.request_type,
        days,
      })
    }
  }
} catch {
  /* la pestaña de vacaciones queda vacía si falla */
}

const REQ_TYPE_LABELS: Record<string, string> = {
  enjoy: 'Disfrute',
  pay: 'Pago',
  mixed: 'Mixto',
}
---

<AppLayout title="Reporte de Personal">
  <div class="mx-auto w-full max-w-7xl p-8 lg:w-3/4">

    <div class="mb-4">
      <div class="flex items-center gap-2 flex-wrap">
        <h1 class="text-2xl font-bold text-gray-900">Reporte de Personal</h1>
        {activePayrollType && (
          <span
            class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700"
            title="La lista se filtra por el tipo de planilla activo en el navbar"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
            {activePayrollType.name}
          </span>
        )}
      </div>
      <p class="text-sm text-gray-500 mt-0.5">
        Listados de personal: por planilla, cumpleaños, contratos por vencer y vacaciones.
      </p>
    </div>

    <!-- Tabs -->
    <div class="flex gap-0 border-b-2 border-gray-200 mb-6 flex-wrap">
      <button type="button" data-rptab="planilla" class="rp-tab px-4 py-2.5 text-sm font-medium border-b-2 -mb-0.5 border-blue-600 text-blue-700">Por planilla</button>
      <button type="button" data-rptab="cumpleanos" class="rp-tab px-4 py-2.5 text-sm font-medium border-b-2 -mb-0.5 border-transparent text-gray-500 hover:text-gray-700">Cumpleaños</button>
      <button type="button" data-rptab="contratos" class="rp-tab px-4 py-2.5 text-sm font-medium border-b-2 -mb-0.5 border-transparent text-gray-500 hover:text-gray-700">Contratos por vencer</button>
      <button type="button" data-rptab="vacaciones" class="rp-tab px-4 py-2.5 text-sm font-medium border-b-2 -mb-0.5 border-transparent text-gray-500 hover:text-gray-700">Vacaciones</button>
    </div>

    <!-- ════════════ TAB: Por planilla ════════════ -->
    <div data-rppanel="planilla">

    <div class="flex items-center justify-between gap-2 mb-4 flex-wrap">
      <span
        class={`inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium border ${
          payrollReportMode === 'on_demand'
            ? 'bg-amber-50 text-amber-700 border-amber-200'
            : payrollReportMode === 'local_storage'
              ? 'bg-violet-50 text-violet-700 border-violet-200'
              : 'bg-blue-50 text-blue-700 border-blue-200'
        }`}
        title="Modo de almacenamiento del PDF — configurable en Configuración → Empresa"
      >
        {payrollReportMode === 'on_demand' && 'Bajo demanda'}
        {payrollReportMode === 'local_storage' && 'Disco local'}
        {payrollReportMode === 'file_storage' && 'Nube (S3/R2)'}
      </span>
      <div class="flex items-center gap-2">
        <a
          id="personnelXlsx"
          href={`/api/reports/personnel/xlsx${filterTypeId ? `?payrollTypeId=${filterTypeId}` : ''}`}
          class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors"
          title="Descargar listado en Excel (incluye campos adicionales seleccionados)"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Excel
        </a>
        <a
          data-personnel-pdf
          href={downloadUrl}
          class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 transition-colors disabled:opacity-60"
          title={
            payrollReportMode === 'on_demand'
              ? 'Generar el reporte de personal en PDF al vuelo'
              : 'Descargar la última versión persistida del reporte (regenera si no existe)'
          }
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><polyline points="7 15 12 20 17 15"/><line x1="12" y1="20" x2="12" y2="12"/></svg>
          {payrollReportMode === 'on_demand' ? 'Generar PDF' : 'Descargar PDF'}
        </a>
      </div>
    </div>

    <!-- Filtros: separados por tipo (combobox / checkbox) en dos paneles -->
    <form method="GET" action="/reports/personal" class="mb-5">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        <!-- Panel: comboboxes -->
        <div class="bg-white border border-gray-200 rounded-lg p-4">
          <h2 class="text-sm font-semibold text-gray-800 mb-3">Selección</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <div>
              <label class="block text-xs font-medium text-gray-500 mb-1" for="typeId">Tipo de planilla</label>
              <select id="typeId" name="typeId" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md bg-white">
                <option value="">Todos</option>
                {payrollTypes.map((t) => (
                  <option value={t.id} selected={t.id === filterTypeId}>{t.name}</option>
                ))}
              </select>
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-500 mb-1" for="situacion">Situación</label>
              <select id="situacion" name="situacion" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md bg-white">
                <option value="active" selected={situacion === 'active'}>Activos</option>
                <option value="inactive" selected={situacion === 'inactive'}>De baja</option>
                <option value="all" selected={situacion === 'all'}>Todas</option>
              </select>
            </div>
          </div>
        </div>
        <!-- Panel: checkboxes -->
        <div class="bg-white border border-gray-200 rounded-lg p-4">
          <h2 class="text-sm font-semibold text-gray-800 mb-3">Opciones</h2>
          <div class="space-y-2.5">
            <label class="flex items-center gap-2 text-sm text-gray-700">
              <input type="checkbox" name="ownDisability" value="true" checked={filterOwnDisability} class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
              Con discapacidad propia
            </label>
            <label class="flex items-center gap-2 text-sm text-gray-700">
              <input type="checkbox" name="familyDisability" value="true" checked={filterFamilyDisability} class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
              Con familiares discapacitados
            </label>
            <label class="flex items-center gap-2 text-sm text-gray-700">
              <input type="checkbox" name="dependents" value="true" checked={filterIncludeDependents} class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
              Incluir familiares dependientes
            </label>
          </div>
        </div>
      </div>
      <div class="flex items-center gap-2 mt-4">
        <button type="submit" class="px-3.5 py-2 text-sm rounded-md bg-blue-600 text-white font-medium hover:bg-blue-700 transition-colors">Aplicar filtros</button>
        <a href="/reports/personal" class="px-3.5 py-2 text-sm rounded-md border border-gray-300 bg-white text-gray-700 font-medium hover:bg-gray-50 transition-colors">Limpiar</a>
      </div>
    </form>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-5 mt-6">
      <div class="border border-gray-200 rounded-lg bg-white p-4">
        <p class="text-[11px] uppercase tracking-wider text-gray-500 mb-1">Empleados</p>
        <p class="text-xl font-semibold text-gray-900 tabular-nums">{total}</p>
      </div>
      <div class="border border-gray-200 rounded-lg bg-white p-4">
        <p class="text-[11px] uppercase tracking-wider text-gray-500 mb-1">Activos</p>
        <p class="text-xl font-semibold text-emerald-700 tabular-nums">{activeCount}</p>
      </div>
      <div class="border border-gray-200 rounded-lg bg-white p-4">
        <p class="text-[11px] uppercase tracking-wider text-gray-500 mb-1">Total Salarios</p>
        <p class="text-xl font-semibold text-gray-900 tabular-nums">{fmtMoney(totalSalary)}</p>
      </div>
    </div>

    {customFieldDefs.length > 0 && (
      <div class="mb-5 rounded-xl border border-gray-200 bg-white p-4">
        <div class="flex items-center justify-between gap-3">
          <div>
            <h2 class="text-sm font-semibold text-gray-800">Campos adicionales en el Excel</h2>
            <p class="text-xs text-gray-500">
              Selecciona qué campos del catálogo se incluyen como columnas extra al descargar el .xlsx.
              El PDF mantiene siempre las columnas estándar.
            </p>
          </div>
          <div class="text-xs text-gray-400">
            <span id="cfCount">0</span> de {customFieldDefs.length} seleccionados
          </div>
        </div>
        <div class="mt-3 flex flex-wrap gap-2">
          {customFieldDefs.map((cf) => (
            <label class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md border border-gray-200 bg-gray-50 text-xs hover:bg-gray-100 cursor-pointer">
              <input type="checkbox" data-cf-pick value={cf.code} class="h-3.5 w-3.5 rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
              <span class="font-medium text-gray-700">{cf.name}</span>
              <span class="font-mono text-gray-400">{cf.code}</span>
            </label>
          ))}
        </div>
      </div>
    )}

    {error && (
      <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
    )}

    <div class="bg-white rounded-xl border border-gray-200 overflow-visible">
      <div class="px-5 py-3 border-b border-gray-100 flex items-center justify-between">
        <h2 class="text-sm font-semibold text-gray-800">Vista previa</h2>
        <span class="text-xs text-gray-400">
          {preview.length === 0 ? '0' : `1–${preview.length}`} de {total}
        </span>
      </div>
      {preview.length === 0 ? (
        <div class="py-14 text-center">
          <p class="text-sm text-gray-400">
            No hay empleados activos para el tipo de planilla seleccionado.
          </p>
        </div>
      ) : (
        <table class="w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="text-left px-4 py-2.5 font-medium text-gray-600">Código</th>
              <th class="text-left px-4 py-2.5 font-medium text-gray-600">Nombre</th>
              <th class="text-left px-4 py-2.5 font-medium text-gray-600">Cédula</th>
              <th class="text-left px-4 py-2.5 font-medium text-gray-600">Departamento</th>
              <th class="text-left px-4 py-2.5 font-medium text-gray-600">Cargo</th>
              <th class="text-right px-4 py-2.5 font-medium text-gray-600">Salario</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {preview.map((e) => (
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-4 py-2.5 font-mono text-xs text-gray-500">{e.code}</td>
                <td class="px-4 py-2.5 font-medium text-gray-900">{e.firstName} {e.lastName}</td>
                <td class="px-4 py-2.5 text-gray-500 font-mono text-xs">{e.idNumber ?? '—'}</td>
                <td class="px-4 py-2.5 text-gray-600">{e.department ?? '—'}</td>
                <td class="px-4 py-2.5 text-gray-600">{e.position ?? '—'}</td>
                <td class="px-4 py-2.5 text-right text-gray-900 tabular-nums">
                  {fmtMoney(Number(e.baseSalary) || 0)}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>

    {total > preview.length && (
      <p class="text-xs text-gray-500 mt-3">
        El PDF incluye los {total} empleados completos, no solo la vista previa.
      </p>
    )}

    </div>
    <!-- ════════════ /TAB: Por planilla ════════════ -->

    <!-- ════════════ TAB: Cumpleaños ════════════ -->
    <div data-rppanel="cumpleanos" style="display:none">
      <form method="GET" action="/api/reports/personnel/birthdays" class="bg-white border border-gray-200 rounded-lg p-4">
        <div class="flex flex-wrap items-end gap-4 justify-between">
          <div>
            <h2 class="text-sm font-semibold text-gray-800">Cumpleañeros del mes 🎂</h2>
            <p class="text-xs text-gray-500 mt-0.5 max-w-xl">
              Genera el listado en Excel de los empleados que cumplen años en el mes elegido,
              según el tipo de planilla y la situación seleccionados en la pestaña «Por planilla».
            </p>
          </div>
          <div class="flex items-end gap-3">
            <div>
              <label class="block text-xs font-medium text-gray-500 mb-1" for="bmonth">Mes</label>
              <select id="bmonth" name="month" class="px-3 py-2 text-sm border border-gray-300 rounded-md bg-white">
                {MESES.map((m, i) => (
                  <option value={i + 1} selected={i + 1 === currentMonth}>{m}</option>
                ))}
              </select>
            </div>
            <input type="hidden" id="bTypeId" name="payrollTypeId" value={filterTypeId} />
            <input type="hidden" id="bSituacion" name="situacion" value={situacion} />
            <button type="submit" class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              Generar cumpleañeros
            </button>
          </div>
        </div>
      </form>
    </div>

    <!-- ════════════ TAB: Contratos por vencer ════════════ -->
    <div data-rppanel="contratos" style="display:none">
      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        <div class="px-5 py-3 border-b border-gray-100 flex items-center justify-between">
          <h2 class="text-sm font-semibold text-gray-800">Contratos por vencer (≤ 30 días)</h2>
          <span class="text-xs text-gray-400">
            {contractsExpiring.length} {contractsExpiring.length === 1 ? 'contrato' : 'contratos'}
          </span>
        </div>
        {contractsExpiring.length === 0 ? (
          <div class="py-14 text-center">
            <p class="text-sm text-gray-400">No hay contratos por vencer en los próximos 30 días.</p>
          </div>
        ) : (
          <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-200">
              <tr>
                <th class="text-left px-4 py-2.5 font-medium text-gray-600">Código</th>
                <th class="text-left px-4 py-2.5 font-medium text-gray-600">Nombre</th>
                <th class="text-left px-4 py-2.5 font-medium text-gray-600">Departamento</th>
                <th class="text-left px-4 py-2.5 font-medium text-gray-600">Cargo</th>
                <th class="text-left px-4 py-2.5 font-medium text-gray-600">Tipo de contrato</th>
                <th class="text-left px-4 py-2.5 font-medium text-gray-600">Ingreso</th>
                <th class="text-left px-4 py-2.5 font-medium text-gray-600">Vence</th>
                <th class="text-right px-4 py-2.5 font-medium text-gray-600">Días</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {contractsExpiring.map((r) => (
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-4 py-2.5 font-mono text-xs text-gray-500">{r.code}</td>
                  <td class="px-4 py-2.5 font-medium text-gray-900">{r.name}</td>
                  <td class="px-4 py-2.5 text-gray-600">{r.department ?? '—'}</td>
                  <td class="px-4 py-2.5 text-gray-600">{r.position ?? '—'}</td>
                  <td class="px-4 py-2.5 text-gray-600">{r.contractType ? (CONTRACT_LABELS[r.contractType] ?? r.contractType) : '—'}</td>
                  <td class="px-4 py-2.5 text-gray-500 font-mono text-xs">{r.hireDate}</td>
                  <td class="px-4 py-2.5 text-gray-500 font-mono text-xs">{r.expires}</td>
                  <td class="px-4 py-2.5 text-right">
                    <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${
                      r.daysLeft <= 7 ? 'bg-red-100 text-red-700' : r.daysLeft <= 15 ? 'bg-amber-100 text-amber-700' : 'bg-gray-100 text-gray-600'
                    }`}>{r.daysLeft} d</span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </div>
      <p class="text-xs text-gray-500 mt-3">
        Basado en el campo «Fin de contrato» del empleado. Se listan los que vencen en los próximos 30 días.
      </p>
    </div>

    <!-- ════════════ TAB: Vacaciones ════════════ -->
    <div data-rppanel="vacaciones" style="display:none">
      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        <div class="px-5 py-3 border-b border-gray-100 flex items-center justify-between">
          <h2 class="text-sm font-semibold text-gray-800">Personal en vacaciones (hoy)</h2>
          <span class="text-xs text-gray-400">
            {activeVacations.length} {activeVacations.length === 1 ? 'persona' : 'personas'}
          </span>
        </div>
        {activeVacations.length === 0 ? (
          <div class="py-14 text-center">
            <p class="text-sm text-gray-400">No hay personal en vacaciones hoy.</p>
          </div>
        ) : (
          <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-200">
              <tr>
                <th class="text-left px-4 py-2.5 font-medium text-gray-600">Código</th>
                <th class="text-left px-4 py-2.5 font-medium text-gray-600">Nombre</th>
                <th class="text-left px-4 py-2.5 font-medium text-gray-600">Departamento</th>
                <th class="text-left px-4 py-2.5 font-medium text-gray-600">Cargo</th>
                <th class="text-left px-4 py-2.5 font-medium text-gray-600">Tipo</th>
                <th class="text-left px-4 py-2.5 font-medium text-gray-600">Desde</th>
                <th class="text-left px-4 py-2.5 font-medium text-gray-600">Hasta</th>
                <th class="text-right px-4 py-2.5 font-medium text-gray-600">Días</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {activeVacations.map((v) => (
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-4 py-2.5 font-mono text-xs text-gray-500">{v.code}</td>
                  <td class="px-4 py-2.5 font-medium text-gray-900">{v.name}</td>
                  <td class="px-4 py-2.5 text-gray-600">{v.department ?? '—'}</td>
                  <td class="px-4 py-2.5 text-gray-600">{v.position ?? '—'}</td>
                  <td class="px-4 py-2.5 text-gray-600">{REQ_TYPE_LABELS[v.requestType] ?? v.requestType}</td>
                  <td class="px-4 py-2.5 text-gray-500 font-mono text-xs">{v.startDate}</td>
                  <td class="px-4 py-2.5 text-gray-500 font-mono text-xs">{v.endDate}</td>
                  <td class="px-4 py-2.5 text-right text-gray-900 tabular-nums">{v.days}</td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </div>
    </div>

  </div>
</AppLayout>

<script>
  import { downloadPdfWithModal } from '../../lib/reports/pdf-download-modal'

  // ── Tabs ─────────────────────────────────────────────────────────────────
  {
    const ACTIVE = ['border-blue-600', 'text-blue-700']
    const INACTIVE = ['border-transparent', 'text-gray-500', 'hover:text-gray-700']
    const tabs = document.querySelectorAll<HTMLButtonElement>('[data-rptab]')
    const panels = document.querySelectorAll<HTMLElement>('[data-rppanel]')
    function show(key: string) {
      for (const p of panels) p.style.display = p.dataset.rppanel === key ? '' : 'none'
      for (const t of tabs) {
        const on = t.dataset.rptab === key
        t.classList.remove(...ACTIVE, ...INACTIVE)
        t.classList.add(...(on ? ACTIVE : INACTIVE))
      }
      if (history.replaceState) history.replaceState(null, '', `#${key}`)
    }
    for (const t of tabs) t.addEventListener('click', () => show(t.dataset.rptab || 'planilla'))
    const initial = (location.hash || '').replace('#', '')
    if (initial && document.querySelector(`[data-rppanel="${initial}"]`)) show(initial)
  }

  for (const a of document.querySelectorAll<HTMLAnchorElement>('[data-personnel-pdf]')) {
    a.addEventListener('click', (e) => {
      e.preventDefault()
      void downloadPdfWithModal(a.href, {
        title: 'Generando reporte de personal',
        filenameHint: 'personal.pdf',
      })
    })
  }

  // Mantener el href del Excel sincronizado con los checkboxes elegidos.
  const xlsxLink = document.getElementById('personnelXlsx') as HTMLAnchorElement | null
  const counter = document.getElementById('cfCount')
  const picks = document.querySelectorAll<HTMLInputElement>('[data-cf-pick]')

  function syncLink() {
    if (!xlsxLink) return
    const url = new URL(xlsxLink.href, window.location.origin)
    const selected = Array.from(picks)
      .filter((c) => c.checked)
      .map((c) => c.value)
    if (selected.length > 0) url.searchParams.set('fields', selected.join(','))
    else url.searchParams.delete('fields')
    xlsxLink.href = url.pathname + (url.search ? url.search : '')
    if (counter) counter.textContent = String(selected.length)
  }

  for (const c of picks) c.addEventListener('change', syncLink)
  syncLink()

  // Reflejar el tipo/situación elegidos en el formulario de cumpleañeros,
  // aunque aún no se haya aplicado el filtro principal.
  const typeSel = document.getElementById('typeId') as HTMLSelectElement | null
  const sitSel = document.getElementById('situacion') as HTMLSelectElement | null
  const bType = document.getElementById('bTypeId') as HTMLInputElement | null
  const bSit = document.getElementById('bSituacion') as HTMLInputElement | null
  if (typeSel && bType) typeSel.addEventListener('change', () => { bType.value = typeSel.value })
  if (sitSel && bSit) sitSel.addEventListener('change', () => { bSit.value = sitSel.value })
</script>

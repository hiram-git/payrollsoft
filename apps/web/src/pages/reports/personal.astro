---
import AppLayout from '../../layouts/AppLayout.astro'
import { resolveTenantSlugFromCookie } from '../../lib/tenant-slug'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')
const tenantSlug = resolveTenantSlugFromCookie(authCookie)

// Mandatory global filter — same cookie used by the topbar selector
// and every other module in the app. The PDF endpoint reads the cookie
// directly, so the URL doesn't need any query-string scoping.
const activeTypeId = Astro.cookies.get('payroll.activeTypeId')?.value ?? ''

type CustomFieldDef = {
  code: string
  name: string
  fieldType: 'text' | 'integer' | 'float' | 'date'
  isActive: boolean
}
type PayrollType = { id: string; code: string; name: string; sortOrder: number }
type ApiEmployee = {
  id: string
  code: string
  firstName: string
  lastName: string
  idNumber: string | null
  position: string | null
  department: string | null
  baseSalary: string | null
  payFrequency: string | null
  isActive: boolean
}

const headers = { Cookie: `auth=${authCookie}`, 'X-Tenant': tenantSlug }

// Cargar el catálogo de campos adicionales activos para que el usuario
// pueda elegir cuáles incluir como columnas en el .xlsx. La API filtra
// por readPermission, así que aquí ya viene depurado.
let customFieldDefs: CustomFieldDef[] = []
try {
  const res = await fetch(`${API_URL}/custom-fields`, { headers })
  if (res.ok) {
    customFieldDefs = (((await res.json()) as { data: CustomFieldDef[] }).data ?? []).filter(
      (d) => d.isActive
    )
  }
} catch {
  /* la página sigue funcionando sin la lista */
}

// Resolve the active type's display name (best-effort; the page still
// works without it — we just won't show the chip).
let activePayrollType: PayrollType | null = null
if (activeTypeId) {
  try {
    const res = await fetch(`${API_URL}/concepts/config`, { headers })
    if (res.ok) {
      const json = (await res.json()) as { data?: { payrollTypes?: PayrollType[] } }
      activePayrollType = json.data?.payrollTypes?.find((t) => t.id === activeTypeId) ?? null
    }
  } catch {
    /* ignore */
  }
}

// Walk every page (the API caps `limit` at 100) so totals on screen
// match the totals printed in the PDF. 50 pages × 100 ≈ 5,000 rows
// is plenty for a single payroll type.
const PAGE_SIZE = 100
const MAX_PAGES = 50

const employees: ApiEmployee[] = []
let error = ''
let unauthorized = false
try {
  for (let page = 1; page <= MAX_PAGES; page++) {
    const params = new URLSearchParams({
      page: String(page),
      limit: String(PAGE_SIZE),
      isActive: 'true',
    })
    if (activeTypeId) params.set('payrollTypeId', activeTypeId)
    const res = await fetch(`${API_URL}/employees?${params}`, { headers })
    if (res.status === 401) {
      unauthorized = true
      break
    }
    if (!res.ok) {
      error = 'Error al cargar el listado de personal'
      break
    }
    const json = (await res.json()) as { data: ApiEmployee[] }
    const batch = json.data ?? []
    employees.push(...batch)
    if (batch.length < PAGE_SIZE) break
  }
} catch {
  error = 'No se pudo conectar con el servidor'
}
if (unauthorized) return Astro.redirect('/login')

const total = employees.length
const activeCount = employees.filter((e) => e.isActive).length
const totalSalary = employees.reduce((acc, e) => acc + (Number(e.baseSalary) || 0), 0)
const preview = employees.slice(0, 20)

function fmtMoney(v: number) {
  return v.toLocaleString('es-PA', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
}

const downloadParams = new URLSearchParams()
if (activeTypeId) downloadParams.set('payrollTypeId', activeTypeId)
if (activePayrollType?.name) downloadParams.set('payrollTypeName', activePayrollType.name)
const downloadUrl = `/api/reports/personnel/download${
  downloadParams.toString() ? `?${downloadParams.toString()}` : ''
}`
---

<AppLayout title="Reporte de Personal">
  <div class="mx-auto w-full max-w-7xl p-8 lg:w-3/4">

    <div class="flex items-start justify-between mb-2 gap-4 flex-wrap">
      <div>
        <div class="flex items-center gap-2">
          <h1 class="text-2xl font-bold text-gray-900">Reporte de Personal</h1>
          {activePayrollType && (
            <span
              class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700"
              title="La lista se filtra por el tipo de planilla activo en el navbar"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
              {activePayrollType.name}
            </span>
          )}
        </div>
        <p class="text-sm text-gray-500 mt-0.5">
          Genera el PDF con todos los empleados activos asociados al tipo de planilla seleccionado en la barra superior.
        </p>
      </div>
      <div class="flex items-center gap-2">
        <a
          id="personnelXlsx"
          href={`/api/reports/personnel/xlsx${activeTypeId ? `?payrollTypeId=${activeTypeId}` : ''}`}
          class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors"
          title="Descargar listado en Excel (incluye campos adicionales seleccionados)"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Excel
        </a>
        <a
          data-personnel-pdf
          href={downloadUrl}
          class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 transition-colors disabled:opacity-60"
          title="Descargar reporte de personal en PDF"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><polyline points="7 15 12 20 17 15"/><line x1="12" y1="20" x2="12" y2="12"/></svg>
          Personal PDF
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-5 mt-6">
      <div class="border border-gray-200 rounded-lg bg-white p-4">
        <p class="text-[11px] uppercase tracking-wider text-gray-500 mb-1">Empleados</p>
        <p class="text-xl font-semibold text-gray-900 tabular-nums">{total}</p>
      </div>
      <div class="border border-gray-200 rounded-lg bg-white p-4">
        <p class="text-[11px] uppercase tracking-wider text-gray-500 mb-1">Activos</p>
        <p class="text-xl font-semibold text-emerald-700 tabular-nums">{activeCount}</p>
      </div>
      <div class="border border-gray-200 rounded-lg bg-white p-4">
        <p class="text-[11px] uppercase tracking-wider text-gray-500 mb-1">Total Salarios</p>
        <p class="text-xl font-semibold text-gray-900 tabular-nums">{fmtMoney(totalSalary)}</p>
      </div>
    </div>

    {customFieldDefs.length > 0 && (
      <div class="mb-5 rounded-xl border border-gray-200 bg-white p-4">
        <div class="flex items-center justify-between gap-3">
          <div>
            <h2 class="text-sm font-semibold text-gray-800">Campos adicionales en el Excel</h2>
            <p class="text-xs text-gray-500">
              Selecciona qué campos del catálogo se incluyen como columnas extra al descargar el .xlsx.
              El PDF mantiene siempre las columnas estándar.
            </p>
          </div>
          <div class="text-xs text-gray-400">
            <span id="cfCount">0</span> de {customFieldDefs.length} seleccionados
          </div>
        </div>
        <div class="mt-3 flex flex-wrap gap-2">
          {customFieldDefs.map((cf) => (
            <label class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md border border-gray-200 bg-gray-50 text-xs hover:bg-gray-100 cursor-pointer">
              <input type="checkbox" data-cf-pick value={cf.code} class="h-3.5 w-3.5 rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
              <span class="font-medium text-gray-700">{cf.name}</span>
              <span class="font-mono text-gray-400">{cf.code}</span>
            </label>
          ))}
        </div>
      </div>
    )}

    {error && (
      <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
    )}

    <div class="bg-white rounded-xl border border-gray-200 overflow-visible">
      <div class="px-5 py-3 border-b border-gray-100 flex items-center justify-between">
        <h2 class="text-sm font-semibold text-gray-800">Vista previa</h2>
        <span class="text-xs text-gray-400">
          {preview.length === 0 ? '0' : `1–${preview.length}`} de {total}
        </span>
      </div>
      {preview.length === 0 ? (
        <div class="py-14 text-center">
          <p class="text-sm text-gray-400">
            No hay empleados activos para el tipo de planilla seleccionado.
          </p>
        </div>
      ) : (
        <table class="w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="text-left px-4 py-2.5 font-medium text-gray-600">Código</th>
              <th class="text-left px-4 py-2.5 font-medium text-gray-600">Nombre</th>
              <th class="text-left px-4 py-2.5 font-medium text-gray-600">Cédula</th>
              <th class="text-left px-4 py-2.5 font-medium text-gray-600">Departamento</th>
              <th class="text-left px-4 py-2.5 font-medium text-gray-600">Cargo</th>
              <th class="text-right px-4 py-2.5 font-medium text-gray-600">Salario</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {preview.map((e) => (
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-4 py-2.5 font-mono text-xs text-gray-500">{e.code}</td>
                <td class="px-4 py-2.5 font-medium text-gray-900">{e.firstName} {e.lastName}</td>
                <td class="px-4 py-2.5 text-gray-500 font-mono text-xs">{e.idNumber ?? '—'}</td>
                <td class="px-4 py-2.5 text-gray-600">{e.department ?? '—'}</td>
                <td class="px-4 py-2.5 text-gray-600">{e.position ?? '—'}</td>
                <td class="px-4 py-2.5 text-right text-gray-900 tabular-nums">
                  {fmtMoney(Number(e.baseSalary) || 0)}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>

    {total > preview.length && (
      <p class="text-xs text-gray-500 mt-3">
        El PDF incluye los {total} empleados completos, no solo la vista previa.
      </p>
    )}
  </div>
</AppLayout>

<script>
  import { downloadPdfWithModal } from '../../lib/reports/pdf-download-modal'

  for (const a of document.querySelectorAll<HTMLAnchorElement>('[data-personnel-pdf]')) {
    a.addEventListener('click', (e) => {
      e.preventDefault()
      void downloadPdfWithModal(a.href, {
        title: 'Generando reporte de personal',
        filenameHint: 'personal.pdf',
      })
    })
  }

  // Mantener el href del Excel sincronizado con los checkboxes elegidos.
  const xlsxLink = document.getElementById('personnelXlsx') as HTMLAnchorElement | null
  const counter = document.getElementById('cfCount')
  const picks = document.querySelectorAll<HTMLInputElement>('[data-cf-pick]')

  function syncLink() {
    if (!xlsxLink) return
    const url = new URL(xlsxLink.href, window.location.origin)
    const selected = Array.from(picks)
      .filter((c) => c.checked)
      .map((c) => c.value)
    if (selected.length > 0) url.searchParams.set('fields', selected.join(','))
    else url.searchParams.delete('fields')
    xlsxLink.href = url.pathname + (url.search ? url.search : '')
    if (counter) counter.textContent = String(selected.length)
  }

  for (const c of picks) c.addEventListener('change', syncLink)
  syncLink()
</script>

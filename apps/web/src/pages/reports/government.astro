---
import AppLayout from '../../layouts/AppLayout.astro'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')

const activeTypeId = Astro.cookies.get('payroll.activeTypeId')?.value ?? ''

type Payroll = {
  id: string
  name: string
  type: string
  frequency: string
  periodStart: string
  periodEnd: string
  paymentDate: string | null
  status: string
  totalGross: string
  totalDeductions: string
  totalNet: string
}

const PAGE_SIZE = 25
const page = Math.max(1, Number(Astro.url.searchParams.get('page') ?? '1'))
const search = Astro.url.searchParams.get('search') ?? ''

let payrolls: Payroll[] = []
let total = 0
let totalPages = 1
let error = ''
let payrollReportMode: 'on_demand' | 'file_storage' = 'on_demand'

try {
  const headers = { Cookie: `auth=${authCookie}`, 'X-Tenant': 'demo' }
  const params = new URLSearchParams({ page: '1', limit: '500' })
  if (activeTypeId) params.set('payrollTypeId', activeTypeId)

  const [res, companyRes] = await Promise.all([
    fetch(`${API_URL}/payroll?${params}`, { headers }),
    fetch(`${API_URL}/company`, { headers }),
  ])
  if (res.status === 401) return Astro.redirect('/login')
  if (res.ok) {
    const json = (await res.json()) as { data: Payroll[] }
    const all = (json.data ?? []).filter((p) => p.status === 'generated' || p.status === 'closed')
    const matching = search
      ? all.filter((p) => p.name.toLowerCase().includes(search.toLowerCase()))
      : all
    total = matching.length
    totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE))
    const from = (page - 1) * PAGE_SIZE
    payrolls = matching.slice(from, from + PAGE_SIZE)
  } else {
    error = 'Error al cargar las planillas'
  }
  if (companyRes.ok) {
    const json = (await companyRes.json()) as {
      data: { payrollReportMode?: string | null } | null
    }
    if (json.data?.payrollReportMode === 'file_storage') {
      payrollReportMode = 'file_storage'
    }
  }
} catch {
  error = 'No se pudo conectar con el servidor'
}

function pageUrl(p: number) {
  const u = new URL(Astro.url)
  u.searchParams.set('page', String(p))
  return u.pathname + u.search
}

const showingFrom = total === 0 ? 0 : (page - 1) * PAGE_SIZE + 1
const showingTo = Math.min(page * PAGE_SIZE, total)

const statusLabel: Record<string, string> = { generated: 'Generada', closed: 'Cerrada' }
const statusStyle: Record<string, string> = {
  generated: 'bg-blue-50 text-blue-700',
  closed: 'bg-emerald-50 text-emerald-700',
}
const typeLabel: Record<string, string> = {
  regular: 'Regular',
  thirteenth: 'XIII Mes',
  special: 'Especial',
}
const freqLabel: Record<string, string> = {
  biweekly: 'Quincenal',
  monthly: 'Mensual',
  weekly: 'Semanal',
}

function fmt(v: string) {
  return Number(v).toLocaleString('es-PA', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
}

const reportTypes = [
  { key: 'transferencias', label: 'Transferencias', desc: 'Imputación a partidas' },
  { key: 'recapitulacion', label: 'Recapitulación', desc: 'Resumen del período' },
  { key: 'siacap', label: 'SIACAP', desc: 'Aportes mensuales' },
]

const isOnDemand = payrollReportMode === 'on_demand'
---

<AppLayout title="Reportes de Gobierno">
  <div class="p-8">

    <div class="flex items-start justify-between mb-2">
      <div>
        <div class="flex items-center gap-2">
          <h1 class="text-2xl font-bold text-gray-900">Reportes de Gobierno</h1>
          {activeTypeId && (
            <span
              class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700"
              title="Filtrado por tipo de planilla"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
              Filtrado por tipo de planilla
            </span>
          )}
        </div>
        <p class="text-sm text-gray-500 mt-0.5">
          Transferencias, Recapitulación y SIACAP agrupados por partida presupuestaria.
        </p>
      </div>
    </div>

    <div class="flex items-center justify-between gap-4 mb-4 mt-6">
      <form method="GET" action="" class="flex items-center gap-2">
        <input
          type="search"
          name="search"
          value={search}
          placeholder="Buscar planilla…"
          class="w-64 px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-white text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
        />
        <button type="submit" class="px-3 py-1.5 text-sm rounded-md bg-blue-600 text-white hover:bg-blue-700 transition-colors">
          Buscar
        </button>
        {search && (
          <a href="/reports/government" class="text-xs text-gray-500 hover:text-gray-700 ml-2">Limpiar</a>
        )}
      </form>
      <span class="text-sm text-gray-500">{total} {total === 1 ? 'planilla' : 'planillas'}</span>
    </div>

    {error && (
      <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
    )}

    <div class="bg-white rounded-xl border border-gray-200 overflow-visible">
      {payrolls.length === 0 ? (
        <div class="py-16 text-center">
          <p class="text-sm text-gray-400 mb-1">
            {search
              ? 'No hay planillas que coincidan con la búsqueda.'
              : 'No se encontraron planillas generadas para el tipo seleccionado.'}
          </p>
        </div>
      ) : (
        <table class="w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Planilla</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Tipo</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Período</th>
              <th class="text-right px-4 py-3 font-medium text-gray-600">Neto</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Estado</th>
              <th class="px-4 py-3 text-right font-medium text-gray-600">Reportes</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {payrolls.map((p) => (
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-4 py-3.5">
                  <a href={`/payroll/${p.id}`} class="font-medium text-gray-900 hover:text-gray-600">
                    {p.name}
                  </a>
                </td>
                <td class="px-4 py-3.5 text-gray-600">
                  {typeLabel[p.type] ?? p.type}
                  <span class="text-gray-400 text-xs ml-1">· {freqLabel[p.frequency] ?? p.frequency}</span>
                </td>
                <td class="px-4 py-3.5 text-gray-500 font-mono text-xs">
                  {p.periodStart} → {p.periodEnd}
                </td>
                <td class="px-4 py-3.5 text-right font-semibold text-gray-900 tabular-nums">{fmt(p.totalNet)}</td>
                <td class="px-4 py-3.5">
                  <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${statusStyle[p.status] ?? 'bg-gray-100 text-gray-500'}`}>
                    {statusLabel[p.status] ?? p.status}
                  </span>
                </td>
                <td class="px-4 py-3.5">
                  <div class="relative inline-block text-left float-right" data-gov-dropdown>
                    <button
                      type="button"
                      data-gov-trigger
                      class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-blue-600 text-white text-xs font-medium hover:bg-blue-700 transition-colors"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                      Reportes
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <div
                      data-gov-panel
                      class="hidden absolute right-0 mt-1 w-56 origin-top-right rounded-lg border border-gray-200 bg-white shadow-lg z-20"
                      role="menu"
                    >
                      <ul class="py-1 text-xs">
                        {reportTypes.map((r) => (
                          <li role="none">
                            <button
                              type="button"
                              role="menuitem"
                              data-gov-report={r.key}
                              data-payroll-id={p.id}
                              data-mode={isOnDemand ? 'preview' : 'download'}
                              class="w-full text-left px-3 py-2 text-gray-700 hover:bg-blue-50 hover:text-blue-700 flex items-start gap-2"
                            >
                              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 mt-0.5 shrink-0 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                              <span class="flex-1">
                                <span class="block font-medium">{r.label}</span>
                                <span class="block text-[11px] text-gray-500 leading-snug mt-0.5">{r.desc}</span>
                              </span>
                            </button>
                          </li>
                        ))}
                      </ul>
                    </div>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>

    {totalPages > 1 && (
      <div class="mt-4 flex items-center justify-between text-sm text-gray-500">
        <span>Mostrando {showingFrom}–{showingTo} de {total}</span>
        <div class="flex items-center gap-1">
          {page > 1 ? (
            <a href={pageUrl(page - 1)} class="px-3 py-1.5 rounded-md border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 transition-colors text-xs font-medium">
              ← Anterior
            </a>
          ) : (
            <span class="px-3 py-1.5 rounded-md border border-gray-200 bg-gray-50 text-gray-300 text-xs font-medium cursor-not-allowed">← Anterior</span>
          )}
          <span class="px-3 py-1.5 text-xs text-gray-600">Pág. {page} / {totalPages}</span>
          {page < totalPages ? (
            <a href={pageUrl(page + 1)} class="px-3 py-1.5 rounded-md border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 transition-colors text-xs font-medium">
              Siguiente →
            </a>
          ) : (
            <span class="px-3 py-1.5 rounded-md border border-gray-200 bg-gray-50 text-gray-300 text-xs font-medium cursor-not-allowed">Siguiente →</span>
          )}
        </div>
      </div>
    )}
  </div>
</AppLayout>

<script>
  import { downloadPdfWithModal } from '../../lib/reports/pdf-download-modal'
  import { previewPdfInModal } from '../../lib/reports/pdf-preview-modal'

  const titles: Record<string, string> = {
    transferencias: 'Transferencias',
    recapitulacion: 'Recapitulación',
    siacap: 'SIACAP',
  }

  // Per-row dropdown toggle
  for (const dd of document.querySelectorAll<HTMLElement>('[data-gov-dropdown]')) {
    const trigger = dd.querySelector<HTMLButtonElement>('[data-gov-trigger]')
    const panel = dd.querySelector<HTMLElement>('[data-gov-panel]')
    if (!trigger || !panel) continue

    trigger.addEventListener('click', (e) => {
      e.stopPropagation()
      // Close other open dropdowns first
      for (const other of document.querySelectorAll<HTMLElement>('[data-gov-panel]')) {
        if (other !== panel) other.classList.add('hidden')
      }
      panel.classList.toggle('hidden')
    })
  }
  document.addEventListener('click', () => {
    for (const p of document.querySelectorAll<HTMLElement>('[data-gov-panel]')) {
      p.classList.add('hidden')
    }
  })

  // Report buttons
  for (const btn of document.querySelectorAll<HTMLButtonElement>('[data-gov-report]')) {
    btn.addEventListener('click', (e) => {
      e.stopPropagation()
      const report = btn.dataset.govReport ?? ''
      const payrollId = btn.dataset.payrollId ?? ''
      const mode = btn.dataset.mode ?? 'download'
      if (!report || !payrollId) return

      // Close dropdown
      btn.closest('[data-gov-dropdown]')?.querySelector<HTMLElement>('[data-gov-panel]')?.classList.add('hidden')

      const url = `/api/reports/government/${report}?payrollId=${encodeURIComponent(payrollId)}`
      const title = titles[report] ?? 'Reporte'
      const filename = `${report}-${payrollId.slice(0, 8)}.pdf`

      if (mode === 'preview') {
        void previewPdfInModal(url, { title, filenameHint: filename })
      } else {
        void downloadPdfWithModal(url, {
          title: `Generando ${title}`,
          successTitle: `${title} descargada`,
          filenameHint: filename,
        })
      }
    })
  }
</script>

---
import AppLayout from '../../layouts/AppLayout.astro'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')

const { id } = Astro.params

type LineConceptEntry = {
  code: string
  name: string
  type: string
  amount: number
  formulaError?: string
}
type PayrollLine = {
  line: {
    id: string
    grossAmount: string
    deductions: string
    netAmount: string
    concepts: LineConceptEntry[]
  }
  employee: {
    id: string
    code: string
    firstName: string
    lastName: string
    department: string | null
    position: string | null
  }
}
type Payroll = {
  id: string
  name: string
  type: string
  frequency: string
  periodStart: string
  periodEnd: string
  paymentDate: string | null
  status: string
  totalGross: string
  totalDeductions: string
  totalNet: string
}

let payroll: Payroll | null = null
let lines: PayrollLine[] = []

try {
  const res = await fetch(`${API_URL}/payroll/${id}`, {
    headers: { Cookie: `auth=${authCookie}`, 'X-Tenant': 'demo' },
  })
  if (res.status === 401) return Astro.redirect('/login')
  if (res.status === 404) return Astro.redirect('/payroll')
  if (res.ok) {
    const json = (await res.json()) as { data: { payroll: Payroll; lines: PayrollLine[] } }
    payroll = json.data.payroll
    lines = json.data.lines
  }
} catch {
  return Astro.redirect('/payroll')
}

if (!payroll) return Astro.redirect('/payroll')

const msgSuccess = Astro.url.searchParams.get('success') ?? ''
const msgError = Astro.url.searchParams.get('error') ?? ''

const statusLabel: Record<string, string> = {
  created: 'Creada',
  processing: 'Procesando…',
  generated: 'Generada',
  closed: 'Cerrada',
  draft: 'Borrador',
  processed: 'Procesada',
  paid: 'Pagada',
}
const statusStyle: Record<string, string> = {
  created: 'bg-zinc-100 text-zinc-600',
  processing: 'bg-amber-50 text-amber-700',
  generated: 'bg-blue-50 text-blue-700',
  closed: 'bg-emerald-50 text-emerald-700',
}
const typeLabel: Record<string, string> = {
  regular: 'Regular',
  thirteenth: 'XIII Mes',
  special: 'Especial',
}
const freqLabel: Record<string, string> = {
  biweekly: 'Quincenal',
  monthly: 'Mensual',
  weekly: 'Semanal',
}

function fmt(v: string | number) {
  return Number(v).toLocaleString('es-PA', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
}

const s = payroll.status
const isCreated = s === 'created' || s === 'draft'
const isGenerated = s === 'generated' || s === 'processed'
const isClosed = s === 'closed' || s === 'paid'
const isProcessing = s === 'processing'

// Stepper steps
const steps = [
  { key: 'created', label: 'Creada' },
  { key: 'generated', label: 'Generada' },
  { key: 'closed', label: 'Cerrada' },
]
const stepIndex = isClosed ? 2 : isGenerated ? 1 : 0
---

<AppLayout title={payroll.name}>
  <div class="px-6 py-8 max-w-6xl mx-auto">

    <!-- Back + Title -->
    <div class="mb-6">
      <a href="/payroll" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 mb-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        Planillas
      </a>
      <div class="flex items-start justify-between gap-4">
        <div>
          <div class="flex items-center gap-2.5">
            <h1 class="text-xl font-semibold text-gray-900 tracking-tight">{payroll.name}</h1>
            <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${statusStyle[payroll.status] ?? 'bg-gray-100 text-gray-500'}`}>
              {statusLabel[payroll.status] ?? payroll.status}
            </span>
          </div>
          <p class="text-sm text-gray-500 mt-1">
            {typeLabel[payroll.type] ?? payroll.type} ·
            {freqLabel[payroll.frequency] ?? payroll.frequency} ·
            <span class="font-mono">{payroll.periodStart} → {payroll.periodEnd}</span>
            {payroll.paymentDate && <span> · Pago: <span class="font-mono">{payroll.paymentDate}</span></span>}
          </p>
        </div>

        <!-- Action buttons -->
        <div class="flex items-center gap-2 flex-shrink-0">
          {(isGenerated || isClosed) && (
            <a
              href={`/api/payroll/${id}/pdf`}
              target="_blank"
              class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors"
              title="Descargar PDF"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              PDF
            </a>
            <a
              href={`/api/payroll/${id}/xlsx`}
              class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors"
              title="Descargar Excel"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="16" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
              Excel
            </a>
          )}
          {isCreated && !isProcessing && (
            <form method="POST" action={`/api/payroll/${id}`}>
              <input type="hidden" name="_method" value="GENERATE" />
              <button
                type="submit"
                class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md bg-gray-900 text-white text-sm font-medium hover:bg-gray-700 transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                Generar planilla
              </button>
            </form>
          )}
          {isGenerated && (
            <form method="POST" action={`/api/payroll/${id}`}>
              <input type="hidden" name="_method" value="REGENERATE" />
              <button
                type="submit"
                class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
                Regenerar
              </button>
            </form>
          )}
          {isGenerated && (
            <form
              method="POST"
              action={`/api/payroll/${id}`}
              onsubmit="return confirm('¿Cerrar esta planilla? Quedará registrada como definitiva.')"
            >
              <input type="hidden" name="_method" value="CLOSE" />
              <button
                type="submit"
                class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md bg-emerald-600 text-white text-sm font-medium hover:bg-emerald-700 transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                Cerrar planilla
              </button>
            </form>
          )}
          {isClosed && (
            <form
              method="POST"
              action={`/api/payroll/${id}`}
              onsubmit="return confirm('¿Reabrir esta planilla? Volverá al estado Generada.')"
            >
              <input type="hidden" name="_method" value="REOPEN" />
              <button
                type="submit"
                class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.32"/></svg>
                Reabrir
              </button>
            </form>
          )}
          {isCreated && (
            <form
              method="POST"
              action={`/api/payroll/${id}`}
              onsubmit="return confirm('¿Eliminar esta planilla? Esta acción es irreversible.')"
            >
              <input type="hidden" name="_method" value="DELETE" />
              <button
                type="submit"
                class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md border border-red-200 text-red-600 text-sm font-medium hover:bg-red-50 transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                Eliminar
              </button>
            </form>
          )}
        </div>
      </div>
    </div>

    <!-- Status stepper -->
    <div class="mb-6 flex items-center gap-0">
      {steps.map((step, i) => (
        <div class="flex items-center">
          <div class={`flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium transition-colors ${
            i === stepIndex
              ? 'bg-gray-900 text-white'
              : i < stepIndex
                ? 'bg-gray-200 text-gray-700'
                : 'bg-transparent text-gray-400'
          }`}>
            <span class={`inline-flex items-center justify-center w-4 h-4 rounded-full text-[10px] font-bold ${
              i === stepIndex ? 'bg-white text-gray-900' : i < stepIndex ? 'bg-gray-500 text-white' : 'border border-gray-300 text-gray-400'
            }`}>{i + 1}</span>
            {step.label}
          </div>
          {i < steps.length - 1 && (
            <div class={`w-8 h-px mx-1 ${i < stepIndex ? 'bg-gray-400' : 'bg-gray-200'}`} />
          )}
        </div>
      ))}
    </div>

    <!-- Alerts -->
    {msgSuccess === '1' && (
      <div class="mb-5 flex items-center gap-2 rounded-md bg-emerald-50 border border-emerald-200 px-4 py-3 text-sm text-emerald-800">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        Planilla procesada correctamente.
      </div>
    )}
    {msgError && (
      <div class="mb-5 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
        Error: {decodeURIComponent(msgError)}
      </div>
    )}

    <!-- Totals row -->
    <div class="grid grid-cols-3 gap-4 mb-6">
      <div class="border border-gray-200 rounded-lg bg-white p-5">
        <p class="text-xs text-gray-500 mb-1 font-medium uppercase tracking-wide">Total Bruto</p>
        <p class="text-2xl font-semibold text-gray-900 tabular-nums">{fmt(payroll.totalGross)}</p>
      </div>
      <div class="border border-gray-200 rounded-lg bg-white p-5">
        <p class="text-xs text-gray-500 mb-1 font-medium uppercase tracking-wide">Deducciones</p>
        <p class="text-2xl font-semibold text-red-600 tabular-nums">{fmt(payroll.totalDeductions)}</p>
      </div>
      <div class="border border-gray-200 rounded-lg bg-white p-5">
        <p class="text-xs text-gray-500 mb-1 font-medium uppercase tracking-wide">Neto a Pagar</p>
        <p class="text-2xl font-semibold text-emerald-700 tabular-nums">{fmt(payroll.totalNet)}</p>
      </div>
    </div>

    <!-- Lines table -->
    <div class="border border-gray-200 rounded-lg bg-white overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
        <h2 class="text-sm font-semibold text-gray-800">Detalle por empleado</h2>
        <span class="text-xs text-gray-400">{lines.length} {lines.length === 1 ? 'empleado' : 'empleados'}</span>
      </div>

      {lines.length === 0 ? (
        <div class="py-14 text-center">
          <p class="text-sm text-gray-400">
            {isCreated
              ? 'Haz clic en "Generar planilla" para calcular los pagos.'
              : 'Sin líneas de planilla.'}
          </p>
        </div>
      ) : (
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-100 bg-gray-50">
              <th class="text-left px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Empleado</th>
              <th class="text-left px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Dpto / Puesto</th>
              <th class="text-right px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Bruto</th>
              <th class="text-right px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Deduc.</th>
              <th class="text-right px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Neto</th>
              <th class="px-4 py-3"></th>
            </tr>
          </thead>
          <tbody>
            {lines.map((l) => (
              <tr class="border-b border-gray-100 last:border-0 hover:bg-gray-50 transition-colors">
                <td class="px-4 py-3.5">
                  <p class="font-medium text-gray-900">{l.employee.firstName} {l.employee.lastName}</p>
                  <p class="text-xs text-gray-400 font-mono mt-0.5">{l.employee.code}</p>
                </td>
                <td class="px-4 py-3.5 text-gray-500 text-xs">
                  {l.employee.department ?? '—'}
                  {l.employee.position && <span class="text-gray-400"> / {l.employee.position}</span>}
                </td>
                <td class="px-4 py-3.5 text-right text-gray-700 tabular-nums">{fmt(l.line.grossAmount)}</td>
                <td class="px-4 py-3.5 text-right text-red-600 tabular-nums">{fmt(l.line.deductions)}</td>
                <td class="px-4 py-3.5 text-right font-semibold text-gray-900 tabular-nums">{fmt(l.line.netAmount)}</td>
                <td class="px-4 py-3.5">
                  <div class="flex items-center gap-1 justify-end">
                    {isGenerated && (
                      <form method="POST" action={`/api/payroll/${id}/line/${l.line.id}`}>
                        <input type="hidden" name="_method" value="REGENERATE" />
                        <button type="submit" class="p-1.5 rounded text-gray-400 hover:text-amber-600 hover:bg-amber-50 transition-colors" title="Regenerar empleado">
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
                        </button>
                      </form>
                    )}
                    <a href={`/payroll/${id}/${l.line.id}`} class="p-1.5 rounded text-gray-400 hover:text-blue-600 hover:bg-blue-50 transition-colors" title="Ver detalle del empleado">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                    </a>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
  </div>
</AppLayout>


---
import AppLayout from '../../layouts/AppLayout.astro'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')

const { id } = Astro.params

type LineConceptEntry = {
  code: string
  name: string
  type: string
  amount: number
  formulaError?: string
}
type PayrollLine = {
  line: {
    id: string
    grossAmount: string
    deductions: string
    netAmount: string
    concepts: LineConceptEntry[]
  }
  employee: {
    id: string
    code: string
    firstName: string
    lastName: string
    department: string | null
    position: string | null
  }
}
type Payroll = {
  id: string
  name: string
  type: string
  frequency: string
  periodStart: string
  periodEnd: string
  paymentDate: string | null
  status: string
  totalGross: string
  totalDeductions: string
  totalNet: string
}

const LINES_PER_PAGE = 50
const linesPage = Math.max(1, Number(Astro.url.searchParams.get('linesPage') ?? '1'))
const linesSearch = Astro.url.searchParams.get('search') ?? ''

let payroll: Payroll | null = null
let lines: PayrollLine[] = []
let linesTotal = 0
let linesTotalPages = 1

try {
  const params = new URLSearchParams({
    linesPage: String(linesPage),
    linesLimit: String(LINES_PER_PAGE),
  })
  if (linesSearch) params.set('search', linesSearch)
  const res = await fetch(`${API_URL}/payroll/${id}?${params}`, {
    headers: { Cookie: `auth=${authCookie}`, 'X-Tenant': 'demo' },
  })
  if (res.status === 401) return Astro.redirect('/login')
  if (res.status === 404) return Astro.redirect('/payroll')
  if (res.ok) {
    const json = (await res.json()) as {
      data: {
        payroll: Payroll
        lines: PayrollLine[]
        linesTotal: number
        linesPage: number
        linesTotalPages: number
      }
    }
    payroll = json.data.payroll
    lines = json.data.lines
    linesTotal = json.data.linesTotal ?? 0
    linesTotalPages = json.data.linesTotalPages ?? 1
  }
} catch {
  return Astro.redirect('/payroll')
}

if (!payroll) return Astro.redirect('/payroll')

function linesPageUrl(p: number) {
  const u = new URL(Astro.url)
  u.searchParams.set('linesPage', String(p))
  return u.pathname + u.search
}

const linesFrom = linesTotal === 0 ? 0 : (linesPage - 1) * LINES_PER_PAGE + 1
const linesTo = Math.min(linesPage * LINES_PER_PAGE, linesTotal)

const msgSuccess = Astro.url.searchParams.get('success') ?? ''
const msgError = Astro.url.searchParams.get('error') ?? ''

const statusLabel: Record<string, string> = {
  created: 'Creada',
  processing: 'Procesando…',
  generated: 'Generada',
  closed: 'Cerrada',
  draft: 'Borrador',
  processed: 'Procesada',
  paid: 'Pagada',
}
const statusStyle: Record<string, string> = {
  created: 'bg-zinc-100 text-zinc-600',
  processing: 'bg-amber-50 text-amber-700',
  generated: 'bg-blue-50 text-blue-700',
  closed: 'bg-emerald-50 text-emerald-700',
}
const typeLabel: Record<string, string> = {
  regular: 'Regular',
  thirteenth: 'XIII Mes',
  special: 'Especial',
}
const freqLabel: Record<string, string> = {
  biweekly: 'Quincenal',
  monthly: 'Mensual',
  weekly: 'Semanal',
}

function fmt(v: string | number) {
  return Number(v).toLocaleString('es-PA', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
}

const s = payroll.status
const isCreated = s === 'created' || s === 'draft'
const isGenerated = s === 'generated' || s === 'processed'
const isClosed = s === 'closed' || s === 'paid'
const isProcessing = s === 'processing'

// Stepper steps
const steps = [
  { key: 'created', label: 'Creada' },
  { key: 'generated', label: 'Generada' },
  { key: 'closed', label: 'Cerrada' },
]
const stepIndex = isClosed ? 2 : isGenerated ? 1 : 0
---

<AppLayout title={payroll.name}>
  <div class="p-8">

    <!-- Back + Title -->
    <div class="mb-6">
      <a href="/payroll" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 mb-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        Planillas
      </a>
      <div class="flex items-start justify-between gap-4">
        <div>
          <div class="flex items-center gap-2.5">
            <h1 class="text-xl font-semibold text-gray-900 tracking-tight">{payroll.name}</h1>
            <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${statusStyle[payroll.status] ?? 'bg-gray-100 text-gray-500'}`}>
              {statusLabel[payroll.status] ?? payroll.status}
            </span>
          </div>
          <p class="text-sm text-gray-500 mt-1">
            {typeLabel[payroll.type] ?? payroll.type} ·
            {freqLabel[payroll.frequency] ?? payroll.frequency} ·
            <span class="font-mono">{payroll.periodStart} → {payroll.periodEnd}</span>
            {payroll.paymentDate && <span> · Pago: <span class="font-mono">{payroll.paymentDate}</span></span>}
          </p>
        </div>

        <!-- Action buttons -->
        <div class="flex items-center gap-2 flex-shrink-0">
          {(isGenerated || isClosed) && (
            <div id="report-dropdown" class="relative inline-block text-left" data-payroll-id={id}>
              <button
                id="btn-report-dropdown"
                type="button"
                class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 transition-colors disabled:opacity-70 disabled:cursor-wait"
                aria-haspopup="menu"
                aria-expanded="false"
                title="Acciones del reporte de Planilla PDF"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                <span id="btn-report-dropdown-label">Reportes</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div
                id="report-dropdown-panel"
                class="hidden absolute right-0 mt-1 w-72 origin-top-right rounded-lg border border-gray-200 bg-white shadow-lg z-20"
                role="menu"
              >
                <ul class="py-1 text-sm">
                  <li role="none">
                    <button
                      type="button"
                      data-report-action="generate"
                      class="w-full text-left px-3 py-2 text-gray-700 hover:bg-blue-50 hover:text-blue-700 disabled:text-gray-400 disabled:hover:bg-transparent disabled:cursor-not-allowed flex items-start gap-2"
                      role="menuitem"
                    >
                      <span class="w-4 h-4 mt-0.5 shrink-0">
                        <svg data-icon-static xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><polyline points="7 15 12 20 17 15"/><line x1="12" y1="20" x2="12" y2="12"/></svg>
                        <svg data-icon-busy class="hidden w-4 h-4 animate-spin text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/></svg>
                      </span>
                      <span class="flex-1">
                        <span class="block font-medium" data-label>Generar</span>
                        <span class="block text-xs text-gray-500 leading-snug mt-0.5">Renderiza el PDF y lo guarda en disco.</span>
                        <span class="hidden text-[11px] text-red-600 mt-0.5 leading-snug" data-row-error></span>
                      </span>
                    </button>
                  </li>
                  <li role="none">
                    <button
                      type="button"
                      data-report-action="download"
                      class="w-full text-left px-3 py-2 text-gray-700 hover:bg-blue-50 hover:text-blue-700 disabled:text-gray-400 disabled:hover:bg-transparent disabled:cursor-not-allowed flex items-start gap-2"
                      role="menuitem"
                    >
                      <span class="w-4 h-4 mt-0.5 shrink-0">
                        <svg data-icon-static xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                        <svg data-icon-busy class="hidden w-4 h-4 animate-spin text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/></svg>
                      </span>
                      <span class="flex-1">
                        <span class="block font-medium" data-label>Descargar</span>
                        <span class="block text-xs text-gray-500 leading-snug mt-0.5">Baja la última versión persistida del PDF.</span>
                      </span>
                    </button>
                  </li>
                  <li role="none">
                    <button
                      type="button"
                      data-report-action="regenerate"
                      class="w-full text-left px-3 py-2 text-gray-700 hover:bg-blue-50 hover:text-blue-700 disabled:text-gray-400 disabled:hover:bg-transparent disabled:cursor-not-allowed flex items-start gap-2"
                      role="menuitem"
                    >
                      <span class="w-4 h-4 mt-0.5 shrink-0">
                        <svg data-icon-static xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
                        <svg data-icon-busy class="hidden w-4 h-4 animate-spin text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/></svg>
                      </span>
                      <span class="flex-1">
                        <span class="block font-medium" data-label>Regenerar</span>
                        <span class="block text-xs text-gray-500 leading-snug mt-0.5">Renderiza y sobrescribe el PDF actual. No re-calcula la planilla.</span>
                        <span class="hidden text-[11px] text-red-600 mt-0.5 leading-snug" data-row-error></span>
                      </span>
                    </button>
                  </li>
                </ul>
              </div>
            </div>
            <a
              href={`/api/payroll/${id}/xlsx`}
              class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors"
              title="Descargar Excel"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="16" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
              Excel
            </a>
            <a
              href="/reports/payroll"
              class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors"
              title="Ver todos los reportes de planilla"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
              Más reportes
            </a>
          )}
          {isCreated && !isProcessing && (
            <form id="form-generate" method="POST" action={`/api/payroll/${id}`}>
              <input type="hidden" name="_method" value="GENERATE" />
              <button
                type="button"
                data-confirm
                data-form="form-generate"
                data-title="Generar planilla"
                data-body="¿Calcular los conceptos para todos los empleados activos? El proceso puede tardar varios segundos."
                data-confirm-label="Generar"
                data-confirm-style="primary"
                data-show-loading="true"
                class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                Generar planilla
              </button>
            </form>
          )}
          {isGenerated && (
            <form id="form-regenerate" method="POST" action={`/api/payroll/${id}`}>
              <input type="hidden" name="_method" value="REGENERATE" />
              <button
                type="button"
                data-confirm
                data-form="form-regenerate"
                data-title="Regenerar planilla"
                data-body="¿Volver a calcular todas las líneas? Los valores actuales serán reemplazados con los cálculos más recientes."
                data-confirm-label="Regenerar"
                data-confirm-style="warning"
                data-show-loading="true"
                class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
                Regenerar
              </button>
            </form>
          )}
          {isGenerated && (
            <form id="form-revert" method="POST" action={`/api/payroll/${id}`}>
              <input type="hidden" name="_method" value="REVERT" />
              <button
                type="button"
                data-confirm
                data-form="form-revert"
                data-title="Revertir planilla"
                data-body="¿Devolver al estado Creada? Se eliminarán las líneas generadas y los cálculos deberán rehacerse."
                data-confirm-label="Revertir"
                data-confirm-style="warning"
                class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 14 4 9 9 4"/><path d="M20 20v-7a4 4 0 0 0-4-4H4"/></svg>
                Revertir
              </button>
            </form>
          )}
          {isGenerated && (
            <form id="form-close" method="POST" action={`/api/payroll/${id}`}>
              <input type="hidden" name="_method" value="CLOSE" />
              <button
                type="button"
                data-confirm
                data-form="form-close"
                data-title="Cerrar planilla"
                data-body="¿Cerrar esta planilla? Quedará registrada como definitiva y se guardarán los acumulados de cada empleado."
                data-confirm-label="Cerrar planilla"
                data-confirm-style="success"
                data-show-loading="true"
                class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md bg-emerald-600 text-white text-sm font-medium hover:bg-emerald-700 transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                Cerrar planilla
              </button>
            </form>
          )}
          {isClosed && (
            <form id="form-reopen" method="POST" action={`/api/payroll/${id}`}>
              <input type="hidden" name="_method" value="REOPEN" />
              <button
                type="button"
                data-confirm
                data-form="form-reopen"
                data-title="Reabrir planilla"
                data-body="¿Reabrir esta planilla? Volverá al estado Generada y los acumulados registrados serán eliminados para poder recalcularse al volver a cerrarla."
                data-confirm-label="Reabrir"
                data-confirm-style="primary"
                data-show-loading="true"
                class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.32"/></svg>
                Reabrir
              </button>
            </form>
          )}
          {isCreated && (
            <form id="form-delete" method="POST" action={`/api/payroll/${id}`}>
              <input type="hidden" name="_method" value="DELETE" />
              <button
                type="button"
                data-confirm
                data-form="form-delete"
                data-title="Eliminar planilla"
                data-body="¿Eliminar esta planilla? Esta acción es irreversible y no podrá deshacerse."
                data-confirm-label="Eliminar"
                data-confirm-style="danger"
                class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md border border-red-200 text-red-600 text-sm font-medium hover:bg-red-50 transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                Eliminar
              </button>
            </form>
          )}
        </div>
      </div>
    </div>

    <!-- Status stepper -->
    <div class="mb-6 flex items-center gap-0">
      {steps.map((step, i) => (
        <div class="flex items-center">
          <div
            class="flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium"
            style={i === stepIndex
              ? 'background: var(--navy); color: #fff'
              : i < stepIndex
                ? 'background: var(--rule-hi); color: var(--fore-dim)'
                : 'color: var(--mute)'}
          >
            <span
              class="inline-flex items-center justify-center w-4 h-4 rounded-full text-[10px] font-bold"
              style={i === stepIndex
                ? 'background: rgba(255,255,255,0.2); color: #fff'
                : i < stepIndex
                  ? 'background: var(--mute); color: var(--ink-2)'
                  : 'border: 1px solid var(--rule-hi); color: var(--mute)'}
            >{i + 1}</span>
            {step.label}
          </div>
          {i < steps.length - 1 && (
            <div
              class="w-8 h-px mx-1"
              style={i < stepIndex ? 'background: var(--rule-hi)' : 'background: var(--rule)'}
            />
          )}
        </div>
      ))}
    </div>

    <!-- Alerts -->
    {msgSuccess === '1' && (
      <div class="mb-5 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">
        Planilla procesada correctamente.
      </div>
    )}
    {msgError && (
      <div class="mb-5 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
        Error: {decodeURIComponent(msgError)}
      </div>
    )}

    <!-- Totals row -->
    <div class="grid grid-cols-3 gap-4 mb-6">
      <div class="border border-gray-200 rounded-lg bg-white p-5">
        <p class="text-xs text-gray-500 mb-1 font-medium uppercase tracking-wide">Total Bruto</p>
        <p class="text-2xl font-semibold text-gray-900 tabular-nums">{fmt(payroll.totalGross)}</p>
      </div>
      <div class="border border-gray-200 rounded-lg bg-white p-5">
        <p class="text-xs text-gray-500 mb-1 font-medium uppercase tracking-wide">Deducciones</p>
        <p class="text-2xl font-semibold text-red-600 tabular-nums">{fmt(payroll.totalDeductions)}</p>
      </div>
      <div class="border border-gray-200 rounded-lg bg-white p-5">
        <p class="text-xs text-gray-500 mb-1 font-medium uppercase tracking-wide">Neto a Pagar</p>
        <p class="text-2xl font-semibold text-emerald-700 tabular-nums">{fmt(payroll.totalNet)}</p>
      </div>
    </div>

    <!-- Lines table -->
    <div class="border border-gray-200 rounded-lg bg-white overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between gap-4">
        <h2 class="text-sm font-semibold text-gray-800 shrink-0">Detalle por empleado</h2>
        <form method="GET" action="" class="flex items-center gap-2 flex-1 max-w-xs ml-auto">
          <input
            type="search"
            name="search"
            value={linesSearch}
            placeholder="Buscar empleado…"
            class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-white text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
          />
          <button type="submit" class="px-3 py-1.5 text-sm rounded-md bg-blue-600 text-white hover:bg-blue-700 transition-colors shrink-0">Buscar</button>
        </form>
        <span class="text-xs text-gray-400 shrink-0">{linesTotal} {linesTotal === 1 ? 'empleado' : 'empleados'}</span>
      </div>

      {lines.length === 0 ? (
        <div class="py-14 text-center">
          <p class="text-sm text-gray-400">
            {isCreated
              ? 'Haz clic en "Generar planilla" para calcular los pagos.'
              : 'Sin líneas de planilla.'}
          </p>
        </div>
      ) : (
        <table class="w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Empleado</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Dpto / Puesto</th>
              <th class="text-right px-4 py-3 font-medium text-gray-600">Bruto</th>
              <th class="text-right px-4 py-3 font-medium text-gray-600">Deduc.</th>
              <th class="text-right px-4 py-3 font-medium text-gray-600">Neto</th>
              <th class="px-4 py-3"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {lines.map((l) => (
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-4 py-3.5">
                  <p class="font-medium text-gray-900">{l.employee.firstName} {l.employee.lastName}</p>
                  <p class="text-xs text-gray-400 font-mono mt-0.5">{l.employee.code}</p>
                </td>
                <td class="px-4 py-3.5 text-gray-500 text-xs">
                  {l.employee.department ?? '—'}
                  {l.employee.position && <span class="text-gray-400"> / {l.employee.position}</span>}
                </td>
                <td class="px-4 py-3.5 text-right text-gray-700 tabular-nums">{fmt(l.line.grossAmount)}</td>
                <td class="px-4 py-3.5 text-right text-red-600 tabular-nums">{fmt(l.line.deductions)}</td>
                <td class="px-4 py-3.5 text-right font-semibold text-gray-900 tabular-nums">{fmt(l.line.netAmount)}</td>
                <td class="px-4 py-3.5">
                  <div class="flex items-center gap-1 justify-end">
                    {isGenerated && (
                      <form id={`form-regen-line-${l.line.id}`} method="POST" action={`/api/payroll/${id}/line/${l.line.id}`}>
                        <input type="hidden" name="_method" value="REGENERATE" />
                        <button
                          type="button"
                          data-confirm
                          data-form={`form-regen-line-${l.line.id}`}
                          data-title="Regenerar empleado"
                          data-body={`¿Recalcular la línea de ${l.employee.firstName} ${l.employee.lastName}? Los valores actuales serán reemplazados.`}
                          data-confirm-label="Regenerar"
                          data-confirm-style="warning"
                          class="p-1.5 rounded-lg text-gray-400 hover:text-amber-600 hover:bg-amber-50 transition-colors"
                          title="Regenerar empleado"
                        >
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
                        </button>
                      </form>
                    )}
                    <a href={`/payroll/${id}/${l.line.id}${linesPage > 1 ? `?fromPage=${linesPage}` : ''}`} class="p-1.5 rounded-lg text-gray-400 hover:text-blue-600 hover:bg-blue-50 transition-colors" title="Ver detalle del empleado">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                    </a>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>

    <!-- Lines pagination -->
    {linesTotalPages > 1 && (
      <div class="mt-4 flex items-center justify-between text-sm text-gray-500">
        <span>Mostrando {linesFrom}–{linesTo} de {linesTotal} empleados</span>
        <div class="flex items-center gap-1">
          {linesPage > 1 ? (
            <a href={linesPageUrl(linesPage - 1)} class="px-3 py-1.5 rounded-md border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 transition-colors text-xs font-medium">
              ← Anterior
            </a>
          ) : (
            <span class="px-3 py-1.5 rounded-md border border-gray-200 bg-gray-50 text-gray-300 text-xs font-medium cursor-not-allowed">← Anterior</span>
          )}
          <span class="px-3 py-1.5 text-xs text-gray-600">Pág. {linesPage} / {linesTotalPages}</span>
          {linesPage < linesTotalPages ? (
            <a href={linesPageUrl(linesPage + 1)} class="px-3 py-1.5 rounded-md border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 transition-colors text-xs font-medium">
              Siguiente →
            </a>
          ) : (
            <span class="px-3 py-1.5 rounded-md border border-gray-200 bg-gray-50 text-gray-300 text-xs font-medium cursor-not-allowed">Siguiente →</span>
          )}
        </div>
      </div>
    )}
  </div>

  <!-- Confirmation modal -->
  <div id="confirm-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4" role="dialog" aria-modal="true">
    <div id="modal-backdrop" class="absolute inset-0 bg-black/40 backdrop-blur-sm"></div>
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-md p-6 animate-in fade-in zoom-in-95 duration-150">
      <div id="modal-icon" class="w-10 h-10 rounded-full flex items-center justify-center mb-4"></div>
      <h3 id="modal-title" class="text-base font-semibold text-gray-900 mb-1.5"></h3>
      <p id="modal-body" class="text-sm text-gray-500 leading-relaxed mb-4"></p>
      <!-- Loading bar — shown during long-running operations (generate/regenerate) -->
      <div id="modal-loading" class="hidden mb-5">
        <div class="flex items-center gap-2 mb-2">
          <svg class="w-4 h-4 text-amber-500 animate-spin flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/></svg>
          <span class="text-xs text-gray-500">Procesando planilla… esto puede tomar unos segundos.</span>
        </div>
        <div class="w-full bg-gray-100 rounded-full h-1.5 overflow-hidden">
          <div class="h-1.5 rounded-full bg-amber-400 animate-[indeterminate_1.5s_ease-in-out_infinite]" style="width:40%"></div>
        </div>
      </div>
      <div id="modal-actions" class="flex justify-end gap-2.5">
        <button
          id="modal-cancel"
          type="button"
          class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors"
        >
          Cancelar
        </button>
        <button
          id="modal-confirm"
          type="button"
          class="px-4 py-2 text-sm font-medium rounded-lg transition-colors"
        >
          Confirmar
        </button>
      </div>
    </div>
  </div>
</AppLayout>

<style>
  @keyframes indeterminate {
    0%   { transform: translateX(-100%); width: 40%; }
    50%  { width: 70%; }
    100% { transform: translateX(300%); width: 40%; }
  }
</style>

<script>
  const modal = document.getElementById('confirm-modal') as HTMLElement
  const modalBackdrop = document.getElementById('modal-backdrop') as HTMLElement
  const modalIcon = document.getElementById('modal-icon') as HTMLElement
  const modalTitle = document.getElementById('modal-title') as HTMLElement
  const modalBody = document.getElementById('modal-body') as HTMLElement
  const modalLoading = document.getElementById('modal-loading') as HTMLElement
  const modalActions = document.getElementById('modal-actions') as HTMLElement
  const modalConfirm = document.getElementById('modal-confirm') as HTMLButtonElement
  const modalCancel = document.getElementById('modal-cancel') as HTMLButtonElement

  const styleMap: Record<string, { btn: string; icon: string; svg: string }> = {
    danger: {
      btn: 'bg-red-600 hover:bg-red-700 text-white',
      icon: 'bg-red-100',
      svg: '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-red-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>',
    },
    warning: {
      btn: 'bg-amber-500 hover:bg-amber-600 text-white',
      icon: 'bg-amber-100',
      svg: '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-amber-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>',
    },
    success: {
      btn: 'bg-emerald-600 hover:bg-emerald-700 text-white',
      icon: 'bg-emerald-100',
      svg: '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>',
    },
    primary: {
      btn: 'bg-blue-600 hover:bg-blue-700 text-white',
      icon: 'bg-blue-100',
      svg: '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.32"/></svg>',
    },
  }

  let pendingFormId: string | null = null
  let pendingShowLoading = false

  function openModal(btn: HTMLElement) {
    pendingFormId = btn.getAttribute('data-form')
    pendingShowLoading = btn.getAttribute('data-show-loading') === 'true'
    const title = btn.getAttribute('data-title') ?? ''
    const body = btn.getAttribute('data-body') ?? ''
    const label = btn.getAttribute('data-confirm-label') ?? 'Confirmar'
    const style = btn.getAttribute('data-confirm-style') ?? 'primary'
    const s = styleMap[style] ?? styleMap.primary

    modalTitle.textContent = title
    modalBody.textContent = body
    modalLoading.classList.add('hidden')
    modalActions.classList.remove('hidden')
    modalConfirm.textContent = label
    modalConfirm.className = `px-4 py-2 text-sm font-medium rounded-lg transition-colors ${s.btn}`
    modalIcon.className = `w-10 h-10 rounded-full flex items-center justify-center mb-4 ${s.icon}`
    modalIcon.innerHTML = s.svg

    modal.classList.remove('hidden')
    modalConfirm.focus()
  }

  function showLoadingState() {
    modalLoading.classList.remove('hidden')
    modalActions.classList.add('hidden')
    modalBackdrop.removeEventListener('click', closeModal)
  }

  function closeModal() {
    modal.classList.add('hidden')
    pendingFormId = null
    pendingShowLoading = false
    modalLoading.classList.add('hidden')
    modalActions.classList.remove('hidden')
    modalBackdrop.addEventListener('click', closeModal)
  }

  document.querySelectorAll<HTMLElement>('[data-confirm]').forEach((btn) => {
    btn.addEventListener('click', () => openModal(btn))
  })

  modalCancel.addEventListener('click', closeModal)
  modalBackdrop.addEventListener('click', closeModal)

  modalConfirm.addEventListener('click', () => {
    if (pendingFormId) {
      const form = document.getElementById(pendingFormId) as HTMLFormElement | null
      if (form) {
        if (pendingShowLoading) showLoadingState()
        form.submit()
      }
    } else {
      closeModal()
    }
  })

  // Generate form — show loading inline on the button itself
  const generateForm = document.getElementById('form-generate') as HTMLFormElement | null
  const generateBtn = document.getElementById('btn-generate') as HTMLButtonElement | null
  generateForm?.addEventListener('submit', () => {
    if (generateBtn) {
      generateBtn.disabled = true
      generateBtn.innerHTML = `<svg class="w-4 h-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/></svg> Generando…`
    }
  })

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden') && modalLoading.classList.contains('hidden')) closeModal()
  })
</script>

<script>
  import { payrollReportUrls, usePayrollReport } from '../../lib/reports/use-payroll-report'
  import type { ReportState } from '../../lib/reports/use-payroll-report'

  // "Reportes" dropdown — Generar / Descargar / Regenerar share the same
  // usePayrollReport state machine, but each menu item owns its own busy
  // and error feedback so a long-running Regenerar never disables Generar
  // (or any other action elsewhere on the page).
  const container = document.getElementById('report-dropdown') as HTMLElement | null
  if (container) {
    const payrollId = container.dataset.payrollId
    const trigger = document.getElementById('btn-report-dropdown') as HTMLButtonElement | null
    const panel = document.getElementById('report-dropdown-panel') as HTMLElement | null

    if (payrollId && trigger && panel) {
      const controller = usePayrollReport({
        payrollId,
        ...payrollReportUrls(payrollId),
      })

      function openPanel() {
        panel!.classList.remove('hidden')
        trigger!.setAttribute('aria-expanded', 'true')
      }
      function closePanel() {
        panel!.classList.add('hidden')
        trigger!.setAttribute('aria-expanded', 'false')
      }

      trigger.addEventListener('click', (e) => {
        e.stopPropagation()
        if (panel.classList.contains('hidden')) openPanel()
        else closePanel()
      })
      document.addEventListener('click', (e) => {
        if (!container.contains(e.target as Node)) closePanel()
      })
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closePanel()
      })

      // Per-action UI controllers — each tracks its own busy/disabled/label
      // independently so they can be reused, reasoned about and tested in
      // isolation.
      type Action = 'generate' | 'download' | 'regenerate'

      function controllerFor(action: Action, defaultLabel: string, busyLabel: string) {
        const btn = container!.querySelector<HTMLButtonElement>(`[data-report-action="${action}"]`)
        if (!btn) return null
        const labelEl = btn.querySelector<HTMLElement>('[data-label]')
        const errorEl = btn.querySelector<HTMLElement>('[data-row-error]')
        const iconStatic = btn.querySelector<HTMLElement>('[data-icon-static]')
        const iconBusy = btn.querySelector<HTMLElement>('[data-icon-busy]')

        return {
          setVisible(visible: boolean) {
            btn.classList.toggle('hidden', !visible)
          },
          setBusy(busy: boolean) {
            btn.disabled = busy
            btn.setAttribute('aria-busy', busy ? 'true' : 'false')
            iconStatic?.classList.toggle('hidden', busy)
            iconBusy?.classList.toggle('hidden', !busy)
            if (labelEl) labelEl.textContent = busy ? busyLabel : defaultLabel
          },
          setEnabled(enabled: boolean) {
            // Only flip enabled state when not in a busy phase — busy wins
            if (btn.getAttribute('aria-busy') === 'true') return
            btn.disabled = !enabled
          },
          showError(message: string | null) {
            if (!errorEl) return
            if (message) {
              errorEl.classList.remove('hidden')
              errorEl.textContent = message
              errorEl.title = message
            } else {
              errorEl.classList.add('hidden')
              errorEl.textContent = ''
              errorEl.title = ''
            }
          },
          element: btn,
        }
      }

      const generateUi = controllerFor('generate', 'Generar', 'Generando…')
      const downloadUi = controllerFor('download', 'Descargar', 'Descargando…')
      const regenerateUi = controllerFor('regenerate', 'Regenerar', 'Regenerando…')

      function applyState(state: ReportState) {
        const snapshot = state.kind === 'idle'
          ? state.snapshot
          : state.kind === 'busy' || state.kind === 'error'
            ? state.lastSnapshot
            : null

        const isGenerated = snapshot?.status === 'generated'

        // Visibility follows the state machine: Generar appears only while
        // there is no PDF yet; Descargar / Regenerar only once one exists.
        // While the snapshot is still unknown (initial loading), keep the
        // Generar option visible as a safe default.
        generateUi?.setVisible(snapshot == null || !isGenerated)
        downloadUi?.setVisible(isGenerated === true)
        regenerateUi?.setVisible(isGenerated === true)

        const action = state.kind === 'busy' ? state.action : null
        // Per-button busy state — the others stay enabled.
        generateUi?.setBusy(action === 'generate')
        regenerateUi?.setBusy(action === 'regenerate')
        // Download has no async backend call; surface a brief visual only
        // when explicitly clicked (handled in its own listener below).

        // Errors get attached to the action that caused them so the user
        // sees feedback exactly where they clicked.
        if (state.kind === 'error') {
          if (action === 'generate' || (action == null && !isGenerated)) {
            generateUi?.showError(state.message)
          } else if (action === 'regenerate' || (action == null && isGenerated)) {
            regenerateUi?.showError(state.message)
          }
        } else {
          generateUi?.showError(null)
          regenerateUi?.showError(null)
        }
      }

      controller.subscribe(applyState)

      generateUi?.element.addEventListener('click', (e) => {
        e.stopPropagation()
        void controller.generate()
      })
      regenerateUi?.element.addEventListener('click', (e) => {
        e.stopPropagation()
        void controller.regenerate()
      })
      downloadUi?.element.addEventListener('click', (e) => {
        e.stopPropagation()
        // Cosmetic feedback while the browser starts the download — flips
        // back automatically since navigation either succeeds or surfaces
        // its own error.
        downloadUi.setBusy(true)
        controller.download()
        setTimeout(() => downloadUi.setBusy(false), 1500)
        closePanel()
      })

      void controller.refresh()
    }
  }
</script>


---
import AppLayout from '../../layouts/AppLayout.astro'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')

type Payroll = {
  id: string
  name: string
  type: string
  frequency: string
  periodStart: string
  periodEnd: string
  paymentDate: string | null
  status: string
  totalGross: string
  totalDeductions: string
  totalNet: string
}

let payrolls: Payroll[] = []
let error = ''

try {
  const res = await fetch(`${API_URL}/payroll`, {
    headers: { Cookie: `auth=${authCookie}`, 'X-Tenant': 'demo' },
  })
  if (res.status === 401) return Astro.redirect('/login')
  if (res.ok) payrolls = ((await res.json()) as { data: Payroll[] }).data ?? []
  else error = 'Error al cargar las planillas'
} catch {
  error = 'No se pudo conectar con el servidor'
}

const success = Astro.url.searchParams.get('success') === '1'

const statusLabel: Record<string, string> = {
  created: 'Creada',
  processing: 'Procesando…',
  generated: 'Generada',
  closed: 'Cerrada',
  // legacy
  draft: 'Borrador',
  processed: 'Procesada',
  paid: 'Pagada',
}
const statusStyle: Record<string, string> = {
  created: 'bg-zinc-100 text-zinc-600',
  processing: 'bg-amber-50 text-amber-700',
  generated: 'bg-blue-50 text-blue-700',
  closed: 'bg-emerald-50 text-emerald-700',
  draft: 'bg-zinc-100 text-zinc-500',
  processed: 'bg-blue-50 text-blue-700',
  paid: 'bg-emerald-50 text-emerald-700',
}
const typeLabel: Record<string, string> = {
  regular: 'Regular',
  thirteenth: 'XIII Mes',
  special: 'Especial',
}
const freqLabel: Record<string, string> = {
  biweekly: 'Quincenal',
  monthly: 'Mensual',
  weekly: 'Semanal',
}

function fmt(v: string) {
  return Number(v).toLocaleString('es-PA', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
}
---

<AppLayout title="Planillas">
  <div class="px-6 py-8 max-w-6xl mx-auto">

    <!-- Page header -->
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-xl font-semibold text-gray-900 tracking-tight">Planillas</h1>
        <p class="text-sm text-gray-500 mt-0.5">{payrolls.length} {payrolls.length === 1 ? 'planilla' : 'planillas'}</p>
      </div>
      <a
        href="/payroll/new"
        class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md bg-gray-900 text-white text-sm font-medium hover:bg-gray-700 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Nueva planilla
      </a>
    </div>

    {success && (
      <div class="mb-5 flex items-center gap-2 rounded-md bg-emerald-50 border border-emerald-200 px-4 py-3 text-sm text-emerald-800">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        Planilla guardada correctamente.
      </div>
    )}
    {error && (
      <div class="mb-5 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
    )}

    <!-- Table -->
    <div class="border border-gray-200 rounded-lg overflow-hidden bg-white">
      {payrolls.length === 0 ? (
        <div class="py-16 text-center">
          <p class="text-sm text-gray-400 mb-1">No hay planillas registradas</p>
          <a href="/payroll/new" class="text-sm text-gray-900 underline underline-offset-2 hover:text-gray-600">
            Crear la primera planilla
          </a>
        </div>
      ) : (
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200 bg-gray-50">
              <th class="text-left px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Nombre</th>
              <th class="text-left px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Tipo</th>
              <th class="text-left px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Período</th>
              <th class="text-right px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Bruto</th>
              <th class="text-right px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Deduc.</th>
              <th class="text-right px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Neto</th>
              <th class="text-left px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Estado</th>
              <th class="px-4 py-3"></th>
            </tr>
          </thead>
          <tbody>
            {payrolls.map((p) => {
              const isGen = p.status === 'generated' || p.status === 'processed'
              return (
              <tr class="border-b border-gray-100 last:border-0 hover:bg-gray-50 transition-colors">
                <td class="px-4 py-3.5">
                  <a href={`/payroll/${p.id}`} class="font-medium text-gray-900 hover:text-gray-600">
                    {p.name}
                  </a>
                </td>
                <td class="px-4 py-3.5 text-gray-600">
                  {typeLabel[p.type] ?? p.type}
                  <span class="text-gray-400 text-xs ml-1">· {freqLabel[p.frequency] ?? p.frequency}</span>
                </td>
                <td class="px-4 py-3.5 text-gray-500 font-mono text-xs">
                  {p.periodStart} → {p.periodEnd}
                </td>
                <td class="px-4 py-3.5 text-right text-gray-700 tabular-nums">{fmt(p.totalGross)}</td>
                <td class="px-4 py-3.5 text-right text-red-600 tabular-nums">{fmt(p.totalDeductions)}</td>
                <td class="px-4 py-3.5 text-right font-semibold text-gray-900 tabular-nums">{fmt(p.totalNet)}</td>
                <td class="px-4 py-3.5">
                  <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${statusStyle[p.status] ?? 'bg-gray-100 text-gray-500'}`}>
                    {statusLabel[p.status] ?? p.status}
                  </span>
                </td>
                <td class="px-4 py-3.5">
                  <div class="flex items-center gap-1 justify-end">
                    {isGen && (
                      <form method="POST" action={`/api/payroll/${p.id}`}>
                        <input type="hidden" name="_method" value="REGENERATE" />
                        <button type="submit" class="p-1.5 rounded text-gray-400 hover:text-amber-600 hover:bg-amber-50 transition-colors" title="Regenerar planilla">
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
                        </button>
                      </form>
                    )}
                    {isGen && (
                      <form method="POST" action={`/api/payroll/${p.id}`} onsubmit="return confirm('¿Cerrar esta planilla?')">
                        <input type="hidden" name="_method" value="CLOSE" />
                        <button type="submit" class="p-1.5 rounded text-gray-400 hover:text-emerald-600 hover:bg-emerald-50 transition-colors" title="Cerrar planilla">
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        </button>
                      </form>
                    )}
                    <a href={`/payroll/${p.id}`} class="p-1.5 rounded text-gray-400 hover:text-gray-700 hover:bg-gray-100 transition-colors" title="Ver detalle">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                    </a>
                  </div>
                </td>
              </tr>
            )})}

          </tbody>
        </table>
      )}
    </div>
  </div>
</AppLayout>

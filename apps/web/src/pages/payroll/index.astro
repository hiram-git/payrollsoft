---
import AppLayout from '../../layouts/AppLayout.astro'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')

type Payroll = {
  id: string
  name: string
  type: string
  frequency: string
  periodStart: string
  periodEnd: string
  paymentDate: string | null
  status: string
  totalGross: string
  totalDeductions: string
  totalNet: string
}

let payrolls: Payroll[] = []
let error = ''

try {
  const res = await fetch(`${API_URL}/payroll`, {
    headers: { Cookie: `auth=${authCookie}`, 'X-Tenant': 'demo' },
  })
  if (res.status === 401) return Astro.redirect('/login')
  if (res.ok) payrolls = ((await res.json()) as { data: Payroll[] }).data ?? []
  else error = 'Error al cargar las planillas'
} catch {
  error = 'No se pudo conectar con el servidor'
}

const success = Astro.url.searchParams.get('success') === '1'

const statusLabel: Record<string, string> = {
  draft: 'Borrador',
  processing: 'Procesando',
  processed: 'Procesada',
  paid: 'Pagada',
}
const statusClass: Record<string, string> = {
  draft: 'bg-gray-100 text-gray-600',
  processing: 'bg-yellow-100 text-yellow-700',
  processed: 'bg-blue-100 text-blue-700',
  paid: 'bg-green-100 text-green-700',
}
const typeLabel: Record<string, string> = {
  regular: 'Regular',
  thirteenth: 'XIII Mes',
  special: 'Especial',
}
const freqLabel: Record<string, string> = {
  biweekly: 'Quincenal',
  monthly: 'Mensual',
  weekly: 'Semanal',
}
---

<AppLayout title="Planillas">
  <div class="p-8">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Planillas</h1>
        <p class="text-sm text-gray-500 mt-0.5">{payrolls.length} planillas</p>
      </div>
      <a href="/payroll/new" class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
        + Nueva planilla
      </a>
    </div>

    {success && (
      <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">
        Planilla guardada correctamente.
      </div>
    )}
    {error && (
      <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
        {error}
      </div>
    )}

    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
      {payrolls.length === 0 ? (
        <div class="p-12 text-center text-gray-400 text-sm">
          No hay planillas registradas.{' '}
          <a href="/payroll/new" class="text-blue-600 hover:underline">Crear la primera</a>.
        </div>
      ) : (
        <table class="w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Nombre</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Tipo / Frec.</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Período</th>
              <th class="text-right px-4 py-3 font-medium text-gray-600">Bruto</th>
              <th class="text-right px-4 py-3 font-medium text-gray-600">Deduc.</th>
              <th class="text-right px-4 py-3 font-medium text-gray-600">Neto</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Estado</th>
              <th class="px-4 py-3"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {payrolls.map((p) => (
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-4 py-3 font-medium text-gray-900">{p.name}</td>
                <td class="px-4 py-3 text-gray-600">
                  {typeLabel[p.type] ?? p.type}
                  <span class="text-gray-400 text-xs ml-1">· {freqLabel[p.frequency] ?? p.frequency}</span>
                </td>
                <td class="px-4 py-3 text-gray-600 text-xs font-mono">{p.periodStart} → {p.periodEnd}</td>
                <td class="px-4 py-3 text-right text-gray-700">${Number(p.totalGross).toFixed(2)}</td>
                <td class="px-4 py-3 text-right text-red-600">${Number(p.totalDeductions).toFixed(2)}</td>
                <td class="px-4 py-3 text-right font-semibold text-gray-900">${Number(p.totalNet).toFixed(2)}</td>
                <td class="px-4 py-3">
                  <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${statusClass[p.status] ?? 'bg-gray-100 text-gray-500'}`}>
                    {statusLabel[p.status] ?? p.status}
                  </span>
                </td>
                <td class="px-4 py-3">
                  <a href={`/payroll/${p.id}`} class="p-1.5 rounded-lg text-gray-400 hover:text-blue-600 hover:bg-blue-50 transition-colors inline-flex">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                    </svg>
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
  </div>
</AppLayout>

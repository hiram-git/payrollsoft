---
import AppLayout from '../../layouts/AppLayout.astro'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')

// Mandatory global filter — the topbar guarantees the cookie is set to a
// valid type id before any list module renders.
const activeTypeId = Astro.cookies.get('payroll.activeTypeId')?.value ?? ''

type Payroll = {
  id: string
  name: string
  type: string
  frequency: string
  periodStart: string
  periodEnd: string
  paymentDate: string | null
  status: string
  totalGross: string
  totalDeductions: string
  totalNet: string
}

let payrolls: Payroll[] = []
let total = 0
let totalPages = 1
let error = ''

const page = Math.max(1, Number(Astro.url.searchParams.get('page') ?? '1'))
const PAGE_SIZE = 25

try {
  const params = new URLSearchParams({ page: String(page) })
  if (activeTypeId) params.set('payrollTypeId', activeTypeId)
  const res = await fetch(`${API_URL}/payroll?${params}`, {
    headers: { Cookie: `auth=${authCookie}`, 'X-Tenant': 'demo' },
  })
  if (res.status === 401) return Astro.redirect('/login')
  if (res.ok) {
    const json = (await res.json()) as { data: Payroll[]; total: number; totalPages: number }
    payrolls = json.data ?? []
    total = json.total ?? 0
    totalPages = json.totalPages ?? 1
  } else {
    error = 'Error al cargar las planillas'
  }
} catch {
  error = 'No se pudo conectar con el servidor'
}

const success = Astro.url.searchParams.get('success') === '1'

function pageUrl(p: number) {
  const u = new URL(Astro.url)
  u.searchParams.set('page', String(p))
  return u.pathname + u.search
}

const showingFrom = total === 0 ? 0 : (page - 1) * PAGE_SIZE + 1
const showingTo = Math.min(page * PAGE_SIZE, total)

const statusLabel: Record<string, string> = {
  created: 'Creada',
  processing: 'Procesando…',
  generated: 'Generada',
  closed: 'Cerrada',
  // legacy
  draft: 'Borrador',
  processed: 'Procesada',
  paid: 'Pagada',
}
const statusStyle: Record<string, string> = {
  created: 'bg-zinc-100 text-zinc-600',
  processing: 'bg-amber-50 text-amber-700',
  generated: 'bg-blue-50 text-blue-700',
  closed: 'bg-emerald-50 text-emerald-700',
  draft: 'bg-zinc-100 text-zinc-500',
  processed: 'bg-blue-50 text-blue-700',
  paid: 'bg-emerald-50 text-emerald-700',
}
const typeLabel: Record<string, string> = {
  regular: 'Regular',
  thirteenth: 'XIII Mes',
  special: 'Especial',
}
const freqLabel: Record<string, string> = {
  biweekly: 'Quincenal',
  monthly: 'Mensual',
  weekly: 'Semanal',
}

function fmt(v: string) {
  return Number(v).toLocaleString('es-PA', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
}
---

<AppLayout title="Planillas">
  <div class="p-8">

    <!-- Page header -->
    <div class="flex items-center justify-between mb-6">
      <div>
        <div class="flex items-center gap-2">
          <h1 class="text-2xl font-bold text-gray-900">Planillas</h1>
          {activeTypeId && (
            <span
              class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700"
              title="La lista se está filtrando por el tipo de planilla activo en el navbar"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
              Filtrado por tipo de planilla
            </span>
          )}
        </div>
        <p class="text-sm text-gray-500 mt-0.5">{total} {total === 1 ? 'planilla' : 'planillas'}</p>
      </div>
      <a
        href="/payroll/new"
        class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors"
      >
        + Nueva planilla
      </a>
    </div>

    {success && (
      <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">
        Planilla guardada correctamente.
      </div>
    )}
    {error && (
      <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
    )}

    <!-- Table -->
    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
      {payrolls.length === 0 ? (
        <div class="py-16 text-center">
          <p class="text-sm text-gray-400 mb-1">
            No se encontraron registros para el tipo de planilla seleccionado.
          </p>
          <a href="/payroll/new" class="text-sm text-gray-900 underline underline-offset-2 hover:text-gray-600">
            Crear una planilla nueva
          </a>
        </div>
      ) : (
        <table class="w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Nombre</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Tipo</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Período</th>
              <th class="text-right px-4 py-3 font-medium text-gray-600">Bruto</th>
              <th class="text-right px-4 py-3 font-medium text-gray-600">Deduc.</th>
              <th class="text-right px-4 py-3 font-medium text-gray-600">Neto</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Estado</th>
              <th class="px-4 py-3"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {payrolls.map((p) => {
              const isCreated = p.status === 'created' || p.status === 'draft'
              const isGen = p.status === 'generated' || p.status === 'processed'
              const isClosed = p.status === 'closed' || p.status === 'paid'
              return (
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-4 py-3.5">
                  <a href={`/payroll/${p.id}`} class="font-medium text-gray-900 hover:text-gray-600">
                    {p.name}
                  </a>
                </td>
                <td class="px-4 py-3.5 text-gray-600">
                  {typeLabel[p.type] ?? p.type}
                  <span class="text-gray-400 text-xs ml-1">· {freqLabel[p.frequency] ?? p.frequency}</span>
                </td>
                <td class="px-4 py-3.5 text-gray-500 font-mono text-xs">
                  {p.periodStart} → {p.periodEnd}
                </td>
                <td class="px-4 py-3.5 text-right text-gray-700 tabular-nums">{fmt(p.totalGross)}</td>
                <td class="px-4 py-3.5 text-right text-red-600 tabular-nums">{fmt(p.totalDeductions)}</td>
                <td class="px-4 py-3.5 text-right font-semibold text-gray-900 tabular-nums">{fmt(p.totalNet)}</td>
                <td class="px-4 py-3.5">
                  <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${statusStyle[p.status] ?? 'bg-gray-100 text-gray-500'}`}>
                    {statusLabel[p.status] ?? p.status}
                  </span>
                </td>
                <td class="px-4 py-3.5">
                  <div class="flex items-center gap-1 justify-end">

                    {/* Generate (created → no modal, direct submit) */}
                    {isCreated && (
                      <form data-generate method="POST" action={`/api/payroll/${p.id}`}>
                        <input type="hidden" name="_method" value="GENERATE" />
                        <button type="submit" class="p-1.5 rounded-lg text-gray-400 hover:text-gray-900 hover:bg-gray-100 transition-colors" title="Generar planilla">
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                        </button>
                      </form>
                    )}

                    {/* Regenerate */}
                    {isGen && (
                      <form id={`form-regenerate-${p.id}`} method="POST" action={`/api/payroll/${p.id}`}>
                        <input type="hidden" name="_method" value="REGENERATE" />
                        <button
                          type="button"
                          data-confirm
                          data-form={`form-regenerate-${p.id}`}
                          data-title="Regenerar planilla"
                          data-body="¿Volver a calcular todas las líneas? Los valores actuales serán reemplazados con los cálculos más recientes."
                          data-confirm-label="Regenerar"
                          data-confirm-style="warning"
                          data-show-loading="true"
                          class="p-1.5 rounded-lg text-gray-400 hover:text-amber-600 hover:bg-amber-50 transition-colors"
                          title="Regenerar planilla"
                        >
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
                        </button>
                      </form>
                    )}

                    {/* Revert */}
                    {isGen && (
                      <form id={`form-revert-${p.id}`} method="POST" action={`/api/payroll/${p.id}`}>
                        <input type="hidden" name="_method" value="REVERT" />
                        <button
                          type="button"
                          data-confirm
                          data-form={`form-revert-${p.id}`}
                          data-title="Revertir planilla"
                          data-body="¿Devolver al estado Creada? Se eliminarán las líneas generadas y los cálculos deberán rehacerse."
                          data-confirm-label="Revertir"
                          data-confirm-style="warning"
                          class="p-1.5 rounded-lg text-gray-400 hover:text-orange-600 hover:bg-orange-50 transition-colors"
                          title="Revertir a Creada"
                        >
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 14 4 9 9 4"/><path d="M20 20v-7a4 4 0 0 0-4-4H4"/></svg>
                        </button>
                      </form>
                    )}

                    {/* Close */}
                    {isGen && (
                      <form id={`form-close-${p.id}`} method="POST" action={`/api/payroll/${p.id}`}>
                        <input type="hidden" name="_method" value="CLOSE" />
                        <button
                          type="button"
                          data-confirm
                          data-form={`form-close-${p.id}`}
                          data-title="Cerrar planilla"
                          data-body="¿Cerrar esta planilla? Quedará registrada como definitiva y se guardarán los acumulados de cada empleado."
                          data-confirm-label="Cerrar planilla"
                          data-confirm-style="success"
                          class="p-1.5 rounded-lg text-gray-400 hover:text-emerald-600 hover:bg-emerald-50 transition-colors"
                          title="Cerrar planilla"
                        >
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        </button>
                      </form>
                    )}

                    {/* Reopen */}
                    {isClosed && (
                      <form id={`form-reopen-${p.id}`} method="POST" action={`/api/payroll/${p.id}`}>
                        <input type="hidden" name="_method" value="REOPEN" />
                        <button
                          type="button"
                          data-confirm
                          data-form={`form-reopen-${p.id}`}
                          data-title="Reabrir planilla"
                          data-body="¿Reabrir esta planilla? Volverá al estado Generada y los acumulados registrados serán eliminados para poder recalcularse al volver a cerrarla."
                          data-confirm-label="Reabrir"
                          data-confirm-style="primary"
                          class="p-1.5 rounded-lg text-gray-400 hover:text-blue-600 hover:bg-blue-50 transition-colors"
                          title="Reabrir planilla"
                        >
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.32"/></svg>
                        </button>
                      </form>
                    )}

                    {/* Delete */}
                    {isCreated && (
                      <form id={`form-delete-${p.id}`} method="POST" action={`/api/payroll/${p.id}`}>
                        <input type="hidden" name="_method" value="DELETE" />
                        <button
                          type="button"
                          data-confirm
                          data-form={`form-delete-${p.id}`}
                          data-title="Eliminar planilla"
                          data-body="¿Eliminar esta planilla? Esta acción es irreversible y no podrá deshacerse."
                          data-confirm-label="Eliminar"
                          data-confirm-style="danger"
                          class="p-1.5 rounded-lg text-gray-400 hover:text-red-600 hover:bg-red-50 transition-colors"
                          title="Eliminar planilla"
                        >
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                        </button>
                      </form>
                    )}

                    <a href={`/payroll/${p.id}`} class="p-1.5 rounded-lg text-gray-400 hover:text-gray-700 hover:bg-gray-100 transition-colors" title="Ver detalle">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                    </a>
                  </div>
                </td>
              </tr>
            )})}

          </tbody>
        </table>
      )}
    </div>

    <!-- Pagination -->
    {totalPages > 1 && (
      <div class="mt-4 flex items-center justify-between text-sm text-gray-500">
        <span>Mostrando {showingFrom}–{showingTo} de {total}</span>
        <div class="flex items-center gap-1">
          {page > 1 ? (
            <a href={pageUrl(page - 1)} class="px-3 py-1.5 rounded-md border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 transition-colors text-xs font-medium">
              ← Anterior
            </a>
          ) : (
            <span class="px-3 py-1.5 rounded-md border border-gray-200 bg-gray-50 text-gray-300 text-xs font-medium cursor-not-allowed">← Anterior</span>
          )}
          <span class="px-3 py-1.5 text-xs text-gray-600">Pág. {page} / {totalPages}</span>
          {page < totalPages ? (
            <a href={pageUrl(page + 1)} class="px-3 py-1.5 rounded-md border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 transition-colors text-xs font-medium">
              Siguiente →
            </a>
          ) : (
            <span class="px-3 py-1.5 rounded-md border border-gray-200 bg-gray-50 text-gray-300 text-xs font-medium cursor-not-allowed">Siguiente →</span>
          )}
        </div>
      </div>
    )}
  </div>

  <!-- Confirmation modal -->
  <div id="confirm-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4" role="dialog" aria-modal="true">
    <div id="modal-backdrop" class="absolute inset-0 bg-black/40 backdrop-blur-sm"></div>
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-md p-6">
      <div id="modal-icon" class="w-10 h-10 rounded-full flex items-center justify-center mb-4"></div>
      <h3 id="modal-title" class="text-base font-semibold text-gray-900 mb-1.5"></h3>
      <p id="modal-body" class="text-sm text-gray-500 leading-relaxed mb-4"></p>
      <div id="modal-loading" class="hidden mb-5">
        <div class="flex items-center gap-2 mb-2">
          <svg class="w-4 h-4 text-amber-500 animate-spin flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/></svg>
          <span class="text-xs text-gray-500">Procesando planilla… esto puede tomar unos segundos.</span>
        </div>
        <div class="w-full bg-gray-100 rounded-full h-1.5 overflow-hidden">
          <div class="h-1.5 rounded-full bg-amber-400 animate-[indeterminate_1.5s_ease-in-out_infinite]" style="width:40%"></div>
        </div>
      </div>
      <div id="modal-actions" class="flex justify-end gap-2.5">
        <button id="modal-cancel" type="button" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
          Cancelar
        </button>
        <button id="modal-confirm" type="button" class="px-4 py-2 text-sm font-medium rounded-lg transition-colors">
          Confirmar
        </button>
      </div>
    </div>
  </div>
</AppLayout>

<style>
  @keyframes indeterminate {
    0%   { transform: translateX(-100%); width: 40%; }
    50%  { width: 70%; }
    100% { transform: translateX(300%); width: 40%; }
  }
</style>

<script>
  const modal = document.getElementById('confirm-modal') as HTMLElement
  const modalBackdrop = document.getElementById('modal-backdrop') as HTMLElement
  const modalIcon = document.getElementById('modal-icon') as HTMLElement
  const modalTitle = document.getElementById('modal-title') as HTMLElement
  const modalBody = document.getElementById('modal-body') as HTMLElement
  const modalLoading = document.getElementById('modal-loading') as HTMLElement
  const modalActions = document.getElementById('modal-actions') as HTMLElement
  const modalConfirm = document.getElementById('modal-confirm') as HTMLButtonElement
  const modalCancel = document.getElementById('modal-cancel') as HTMLButtonElement

  const styleMap: Record<string, { btn: string; icon: string; svg: string }> = {
    danger: {
      btn: 'bg-red-600 hover:bg-red-700 text-white',
      icon: 'bg-red-100',
      svg: '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-red-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>',
    },
    warning: {
      btn: 'bg-amber-500 hover:bg-amber-600 text-white',
      icon: 'bg-amber-100',
      svg: '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-amber-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>',
    },
    success: {
      btn: 'bg-emerald-600 hover:bg-emerald-700 text-white',
      icon: 'bg-emerald-100',
      svg: '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>',
    },
    primary: {
      btn: 'bg-blue-600 hover:bg-blue-700 text-white',
      icon: 'bg-blue-100',
      svg: '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.32"/></svg>',
    },
  }

  let pendingFormId: string | null = null
  let pendingShowLoading = false

  function openModal(btn: HTMLElement) {
    pendingFormId = btn.getAttribute('data-form')
    pendingShowLoading = btn.getAttribute('data-show-loading') === 'true'
    const title = btn.getAttribute('data-title') ?? ''
    const body = btn.getAttribute('data-body') ?? ''
    const label = btn.getAttribute('data-confirm-label') ?? 'Confirmar'
    const style = btn.getAttribute('data-confirm-style') ?? 'primary'
    const s = styleMap[style] ?? styleMap.primary

    modalTitle.textContent = title
    modalBody.textContent = body
    modalLoading.classList.add('hidden')
    modalActions.classList.remove('hidden')
    modalConfirm.textContent = label
    modalConfirm.className = `px-4 py-2 text-sm font-medium rounded-lg transition-colors ${s.btn}`
    modalIcon.className = `w-10 h-10 rounded-full flex items-center justify-center mb-4 ${s.icon}`
    modalIcon.innerHTML = s.svg

    modal.classList.remove('hidden')
    modalConfirm.focus()
  }

  function showLoadingState() {
    modalLoading.classList.remove('hidden')
    modalActions.classList.add('hidden')
    modalBackdrop.removeEventListener('click', closeModal)
  }

  function closeModal() {
    modal.classList.add('hidden')
    pendingFormId = null
    pendingShowLoading = false
    modalLoading.classList.add('hidden')
    modalActions.classList.remove('hidden')
    modalBackdrop.addEventListener('click', closeModal)
  }

  document.querySelectorAll<HTMLElement>('[data-confirm]').forEach((btn) => {
    btn.addEventListener('click', () => openModal(btn))
  })

  // Generate buttons (direct submit) — show spinner on the button itself
  document.querySelectorAll<HTMLFormElement>('form[data-generate]').forEach((form) => {
    form.addEventListener('submit', () => {
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null
      if (btn) {
        btn.disabled = true
        btn.innerHTML = `<svg class="w-3.5 h-3.5 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/></svg>`
      }
    })
  })

  modalCancel.addEventListener('click', closeModal)
  modalBackdrop.addEventListener('click', closeModal)

  modalConfirm.addEventListener('click', () => {
    if (pendingFormId) {
      const form = document.getElementById(pendingFormId) as HTMLFormElement | null
      if (form) {
        if (pendingShowLoading) showLoadingState()
        form.submit()
      }
    } else {
      closeModal()
    }
  })

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden') && modalLoading.classList.contains('hidden')) closeModal()
  })
</script>

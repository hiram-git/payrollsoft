---
import ServerToastBridge from '../../../components/ServerToastBridge.astro'
import AppLayout from '../../../layouts/AppLayout.astro'
import { resolveTenantSlugFromCookie } from '../../../lib/tenant-slug'

const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')
const tenantSlug = resolveTenantSlugFromCookie(authCookie)

const { id, lineId } = Astro.params
const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const headers = { Cookie: `auth=${authCookie}`, 'X-Tenant': tenantSlug }
type LineConceptEntry = {
  code: string
  name: string
  type: string
  amount: number
  formulaError?: string
  manual?: boolean
}
type CatalogConcept = {
  id: string
  code: string
  name: string
  type: 'income' | 'deduction' | 'patronal'
  unit?: string | null
  isActive?: boolean
}
type PayrollLine = {
  line: {
    id: string
    grossAmount: string
    deductions: string
    netAmount: string
    concepts: LineConceptEntry[]
  }
  employee: {
    id: string
    code: string
    firstName: string
    lastName: string
    department: string | null
    position: string | null
  }
}
type Payroll = {
  id: string
  name: string
  type: string
  frequency: string
  periodStart: string
  periodEnd: string
  paymentDate: string | null
  status: string
  totalGross: string
  totalDeductions: string
  totalNet: string
}

const fromPage = Astro.url.searchParams.get('fromPage') ?? '1'
const fromSearch = Astro.url.searchParams.get('fromSearch') ?? ''

let payroll: Payroll | null = null
let currentLine: PayrollLine | null = null

try {
  const res = await fetch(`${API_URL}/payroll/${id}/line/${lineId}`, { headers })
  if (res.status === 401) return Astro.redirect('/login')
  if (res.status === 404) return Astro.redirect('/payroll')
  if (res.ok) {
    const json = (await res.json()) as { data: { payroll: Payroll; line: PayrollLine } }
    payroll = json.data.payroll
    currentLine = json.data.line
  }
} catch {
  return Astro.redirect(`/payroll/${id}`)
}

if (!payroll || !currentLine) return Astro.redirect(`/payroll/${id}`)

const isGenerated = payroll.status === 'generated' || payroll.status === 'processed'
const canEditManualConcepts =
  payroll.status === 'generated' ||
  payroll.status === 'processed' ||
  payroll.status === 'processing'

// Catálogo para el combobox: solo conceptos activos tipo income/deduction.
let manualCatalog: CatalogConcept[] = []
if (canEditManualConcepts) {
  try {
    const cRes = await fetch(`${API_URL}/concepts`, { headers })
    if (cRes.ok) {
      const cJson = (await cRes.json()) as { data: CatalogConcept[] }
      manualCatalog = (cJson.data ?? []).filter(
        (c) => (c.isActive ?? true) && (c.type === 'income' || c.type === 'deduction')
      )
    }
  } catch {
    /* fallback: combobox sin opciones */
  }
}
const msgSuccess = Astro.url.searchParams.get('success') ?? ''
const msgError = Astro.url.searchParams.get('error') ?? ''

const concepts = currentLine.line.concepts as LineConceptEntry[]
const asignaciones = concepts.filter((c) => c.type === 'income')
const deducciones = concepts.filter((c) => c.type === 'deduction')
const patronales = concepts.filter((c) => c.type === 'patronal')

function fmt(v: string | number) {
  return Number(v).toLocaleString('es-PA', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
}

const employeeName = `${currentLine.employee.firstName} ${currentLine.employee.lastName}`
---

<AppLayout title={employeeName}>
  <div class="p-8">

    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-sm text-gray-500 mb-6">
      <a href="/payroll" class="hover:text-gray-700 transition-colors">Planillas</a>
      <span class="text-gray-300">/</span>
      <a href={`/payroll/${id}?linesPage=${fromPage}${fromSearch ? `&search=${fromSearch}` : ''}`} class="hover:text-gray-700 transition-colors">{payroll.name}</a>
      <span class="text-gray-300">/</span>
      <span class="text-gray-900 font-medium">{employeeName}</span>
    </div>

    <!-- Action bar -->
    <div class="flex items-start justify-between gap-4 mb-6">
      <div>
        <h1 class="text-xl font-semibold text-gray-900">{employeeName}</h1>
        <p class="text-sm text-gray-500 mt-0.5">
          {currentLine.employee.code}
          {currentLine.employee.department && ` · ${currentLine.employee.department}`}
          {currentLine.employee.position && ` / ${currentLine.employee.position}`}
        </p>
      </div>
      <div class="flex items-center gap-2 flex-shrink-0">
        {canEditManualConcepts && (
          <button
            type="button"
            id="btn-open-manual-concept"
            class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors"
            title="Agregar un concepto del catálogo a esta línea"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Concepto
          </button>
        )}
        {isGenerated && (
          <form
            method="POST"
            action={`/api/payroll/${id}/line/${lineId}`}
            data-saconfirm
            data-sa-title="Regenerar empleado"
            data-sa-message={`¿Recalcular los conceptos de ${employeeName}? Los valores actuales serán reemplazados.`}
            data-sa-confirm-label="Regenerar"
            data-sa-tone="warning"
            data-sa-loading-title="Regenerando línea"
            data-sa-loading-message="Recalculando conceptos del empleado…"
            data-sa-success-title="Línea regenerada"
            data-sa-success-message="Los conceptos se recalcularon correctamente."
            data-sa-error-title="No se pudo regenerar"
          >
            <input type="hidden" name="_method" value="REGENERATE" />
            <button
              type="submit"
              class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
              Regenerar
            </button>
          </form>
        )}
        <a
          href={`/api/payroll/${id}/line/${lineId}/comprobante`}
          class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors"
          title="Descargar comprobante de pago en PDF"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Comprobante
        </a>
        <button
          type="button"
          data-send-comprobante
          data-payroll-id={id}
          data-line-id={lineId}
          class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 transition-colors disabled:opacity-60 disabled:cursor-wait"
          title="Enviar el comprobante de pago al correo del empleado"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          Enviar por correo
        </button>
      </div>
    </div>

    {msgSuccess === '1' && (
      <div class="mb-5 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700" data-server-toast="success">
        Línea regenerada correctamente.
      </div>
    )}
    {msgError && (
      <div class="mb-5 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700" data-server-toast="error">
        Error: {decodeURIComponent(msgError)}
      </div>
    )}

    <!-- Totals summary -->
    <div class="grid grid-cols-3 gap-4 mb-6">
      <div class="border border-gray-200 rounded-lg bg-white p-4">
        <p class="text-xs text-gray-500 mb-1 font-medium uppercase tracking-wide">Total Bruto</p>
        <p class="text-xl font-semibold text-gray-900 tabular-nums">{fmt(currentLine.line.grossAmount)}</p>
      </div>
      <div class="border border-gray-200 rounded-lg bg-white p-4">
        <p class="text-xs text-gray-500 mb-1 font-medium uppercase tracking-wide">Deducciones</p>
        <p class="text-xl font-semibold text-red-600 tabular-nums">{fmt(currentLine.line.deductions)}</p>
      </div>
      <div class="border border-gray-200 rounded-lg bg-white p-4">
        <p class="text-xs text-gray-500 mb-1 font-medium uppercase tracking-wide">Neto a Pagar</p>
        <p class="text-xl font-semibold text-emerald-700 tabular-nums">{fmt(currentLine.line.netAmount)}</p>
      </div>
    </div>

    <!-- ── Asignaciones ─────────────────────────────────────────────────────── -->
    {asignaciones.length > 0 && (
      <div class="border border-gray-200 rounded-lg bg-white overflow-hidden mb-4">
        <div class="px-4 py-3 bg-gray-50 border-b border-gray-200">
          <h3 class="text-sm font-semibold text-blue-700">Asignaciones</h3>
        </div>
        <table class="w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="text-left px-4 py-2 font-medium text-gray-600 w-32">Código</th>
              <th class="text-left px-4 py-2 font-medium text-gray-600">Concepto</th>
              <th class="text-right px-4 py-2 font-medium text-gray-600">Monto</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {asignaciones.map((c) => (
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-4 py-2.5 font-mono text-xs text-gray-500">{c.code}</td>
                <td class="px-4 py-2.5 text-gray-800">
                  {c.name}
                  {c.manual && <span class="ml-2 inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-amber-50 text-amber-700 border border-amber-200">Manual</span>}
                  {c.formulaError && <span class="ml-1 text-red-500 text-xs" title={c.formulaError}>⚠</span>}
                </td>
                <td class="px-4 py-2.5 text-right tabular-nums text-gray-900 font-medium">
                  <div class="flex items-center justify-end gap-2">
                    <span>{fmt(c.amount)}</span>
                    {c.manual && canEditManualConcepts && (
                      <form
                        method="POST"
                        action={`/api/payroll/${id}/line/${lineId}`}
                        data-saconfirm
                        data-sa-title="Quitar concepto manual"
                        data-sa-message={`Vas a eliminar el concepto "${c.code}" de esta línea. Los totales se recalcularán.`}
                        data-sa-confirm-label="Quitar"
                        data-sa-tone="warning"
                        data-sa-loading-title="Eliminando concepto"
                        data-sa-success-title="Concepto eliminado"
                        data-sa-error-title="No se pudo eliminar el concepto"
                      >
                        <input type="hidden" name="_method" value="DELETE_MANUAL" />
                        <input type="hidden" name="code" value={c.code} />
                        <button type="submit" class="text-red-500 hover:text-red-700 text-xs leading-none" title="Quitar concepto">✕</button>
                      </form>
                    )}
                  </div>
                </td>
              </tr>
            ))}
            <tr class="bg-gray-50 border-t border-gray-100">
              <td colspan="2" class="px-4 py-2 text-xs font-medium text-gray-500 text-right">Subtotal Asignaciones</td>
              <td class="px-4 py-2 text-right tabular-nums font-semibold text-gray-900">
                {fmt(asignaciones.reduce((s, c) => s + Number(c.amount), 0))}
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    )}

    <!-- ── Deducciones ──────────────────────────────────────────────────────── -->
    {deducciones.length > 0 && (
      <div class="border border-gray-200 rounded-lg bg-white overflow-hidden mb-4">
        <div class="px-4 py-3 bg-gray-50 border-b border-gray-200">
          <h3 class="text-sm font-semibold text-red-700">Deducciones</h3>
        </div>
        <table class="w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="text-left px-4 py-2 font-medium text-gray-600 w-32">Código</th>
              <th class="text-left px-4 py-2 font-medium text-gray-600">Concepto</th>
              <th class="text-right px-4 py-2 font-medium text-gray-600">Monto</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {deducciones.map((c) => (
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-4 py-2.5 font-mono text-xs text-gray-500">{c.code}</td>
                <td class="px-4 py-2.5 text-gray-800">
                  {c.name}
                  {c.manual && <span class="ml-2 inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-amber-50 text-amber-700 border border-amber-200">Manual</span>}
                  {c.formulaError && <span class="ml-1 text-red-500 text-xs" title={c.formulaError}>⚠</span>}
                </td>
                <td class="px-4 py-2.5 text-right tabular-nums text-red-600">
                  <div class="flex items-center justify-end gap-2">
                    <span>{fmt(c.amount)}</span>
                    {c.manual && canEditManualConcepts && (
                      <form
                        method="POST"
                        action={`/api/payroll/${id}/line/${lineId}`}
                        data-saconfirm
                        data-sa-title="Quitar concepto manual"
                        data-sa-message={`Vas a eliminar el concepto "${c.code}" de esta línea. Los totales se recalcularán.`}
                        data-sa-confirm-label="Quitar"
                        data-sa-tone="warning"
                        data-sa-loading-title="Eliminando concepto"
                        data-sa-success-title="Concepto eliminado"
                        data-sa-error-title="No se pudo eliminar el concepto"
                      >
                        <input type="hidden" name="_method" value="DELETE_MANUAL" />
                        <input type="hidden" name="code" value={c.code} />
                        <button type="submit" class="text-red-500 hover:text-red-700 text-xs leading-none" title="Quitar concepto">✕</button>
                      </form>
                    )}
                  </div>
                </td>
              </tr>
            ))}
            <tr class="bg-gray-50 border-t border-gray-100">
              <td colspan="2" class="px-4 py-2 text-xs font-medium text-gray-500 text-right">Subtotal Deducciones</td>
              <td class="px-4 py-2 text-right tabular-nums font-semibold text-red-600">
                {fmt(deducciones.reduce((s, c) => s + Number(c.amount), 0))}
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    )}

    <!-- ── Patronales ───────────────────────────────────────────────────────── -->
    {patronales.length > 0 && (
      <div class="border border-gray-200 rounded-lg bg-white overflow-hidden mb-4">
        <div class="px-4 py-3 bg-gray-50 border-b border-gray-200">
          <h3 class="text-sm font-semibold text-amber-700">Patronales</h3>
        </div>
        <table class="w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="text-left px-4 py-2 font-medium text-gray-600 w-32">Código</th>
              <th class="text-left px-4 py-2 font-medium text-gray-600">Concepto</th>
              <th class="text-right px-4 py-2 font-medium text-gray-600">Monto</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {patronales.map((c) => (
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-4 py-2.5 font-mono text-xs text-gray-500">{c.code}</td>
                <td class="px-4 py-2.5 text-gray-800">
                  {c.name}
                  {c.formulaError && <span class="ml-1 text-red-500 text-xs" title={c.formulaError}>⚠</span>}
                </td>
                <td class="px-4 py-2.5 text-right tabular-nums text-amber-700">{fmt(c.amount)}</td>
              </tr>
            ))}
            <tr class="bg-gray-50 border-t border-gray-100">
              <td colspan="2" class="px-4 py-2 text-xs font-medium text-gray-500 text-right">Subtotal Patronales</td>
              <td class="px-4 py-2 text-right tabular-nums font-semibold text-amber-700">
                {fmt(patronales.reduce((s, c) => s + Number(c.amount), 0))}
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    )}

  </div>

  <!-- Confirmation modal -->
  <div id="confirm-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4" role="dialog" aria-modal="true">
    <div id="modal-backdrop" class="absolute inset-0 bg-black/40 backdrop-blur-sm"></div>
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-md p-6">
      <div id="modal-icon" class="w-10 h-10 rounded-full flex items-center justify-center mb-4"></div>
      <h3 id="modal-title" class="text-base font-semibold text-gray-900 mb-1.5"></h3>
      <p id="modal-body" class="text-sm text-gray-500 leading-relaxed mb-4"></p>
      <div id="modal-loading" class="hidden mb-5">
        <div class="flex items-center gap-2 mb-2">
          <svg class="w-4 h-4 text-amber-500 animate-spin flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/></svg>
          <span class="text-xs text-gray-500">Procesando… esto puede tomar unos segundos.</span>
        </div>
        <div class="w-full bg-gray-100 rounded-full h-1.5 overflow-hidden">
          <div class="h-1.5 rounded-full bg-amber-400 animate-[indeterminate_1.5s_ease-in-out_infinite]" style="width:40%"></div>
        </div>
      </div>
      <div id="modal-actions" class="flex justify-end gap-2.5">
        <button id="modal-cancel" type="button" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Cancelar</button>
        <button id="modal-confirm" type="button" class="px-4 py-2 text-sm font-medium rounded-lg transition-colors">Confirmar</button>
      </div>
    </div>
  </div>

  <!-- ── Modal "Agregar concepto manual" ──────────────────────────────────────
       El contenido del card es idéntico al panel inline anterior. Vive
       en un <dialog> para no contaminar el layout principal y se abre
       desde el botón de la action bar. La form sigue usando
       data-saconfirm para el flujo confirmación → espera → resultado. -->
  {canEditManualConcepts && (
    <dialog
      id="manual-concept-dialog"
      class="manual-concept-dialog rounded-lg border border-gray-200 bg-white p-0 shadow-2xl backdrop:bg-black/40 max-w-2xl w-full"
    >
      <div class="rounded-lg bg-white border border-gray-200">
        <div class="px-4 py-3 bg-gray-50 border-b border-gray-200 flex items-center justify-between rounded-t-lg">
          <h3 class="text-sm font-semibold text-gray-800">Agregar concepto manual</h3>
          <div class="flex items-center gap-3">
            <span class="text-xs text-gray-500 font-mono">{manualCatalog.length} conceptos disponibles</span>
            <button
              type="button"
              id="btn-close-manual-concept"
              class="text-gray-400 hover:text-gray-600 transition-colors"
              aria-label="Cerrar"
              title="Cerrar"
            >
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M3 3l10 10M13 3L3 13"/></svg>
            </button>
          </div>
        </div>
        <form
          method="POST"
          action={`/api/payroll/${id}/line/${lineId}`}
          class="p-4"
          data-saconfirm
          data-sa-title="Agregar concepto manual"
          data-sa-message="Vamos a agregar el concepto seleccionado a esta línea con el monto fijo indicado. Los totales de la planilla se recalcularán."
          data-sa-confirm-label="Agregar concepto"
          data-sa-tone="primary"
          data-sa-loading-title="Agregando concepto"
          data-sa-success-title="Concepto agregado"
          data-sa-success-message="La línea fue actualizada con el concepto manual."
          data-sa-error-title="No se pudo agregar el concepto"
        >
          <input type="hidden" name="_method" value="ADD_MANUAL" />
          <!-- Fila inputs: alineados horizontalmente.
               Las metas/labels viven en su columna sin empujar el input. -->
          <div class="grid grid-cols-1 sm:grid-cols-[2fr_1fr_auto] gap-3 items-start">
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Concepto</label>
              <input type="hidden" name="conceptId" id="manual-concept-id" value="" />
              <div class="relative">
                <input
                  type="text"
                  id="manual-concept-search"
                  placeholder="Buscar por código o nombre…"
                  autocomplete="off"
                  required
                  class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent"
                />
                <ul
                  id="manual-concept-dropdown"
                  class="hidden absolute z-50 left-0 right-0 mt-1 bg-white border border-gray-200 rounded-md shadow-xl max-h-56 overflow-y-auto text-sm"
                  role="listbox"
                ></ul>
              </div>
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Monto</label>
              <input
                type="number"
                name="amount"
                step="0.01"
                min="0.01"
                required
                placeholder="0.00"
                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent text-right tabular-nums"
              />
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">&nbsp;</label>
              <button
                type="submit"
                class="inline-flex items-center justify-center gap-1.5 px-3.5 py-2 rounded-md bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 transition-colors"
              >
                Agregar
              </button>
            </div>
          </div>
          <p id="manual-concept-meta" class="mt-2 text-xs text-gray-400 font-mono">Selecciona un concepto del catálogo.</p>
        </form>
        <p class="px-4 pb-3 text-xs text-gray-400">
          Por ahora solo se admite monto fijo y unidad por defecto del catálogo. El tipo (asignación o deducción) lo toma automáticamente del concepto seleccionado.
        </p>
      </div>
    </dialog>

    <style is:global>
      .manual-concept-dialog {
        padding: 0;
        border: none;
        background: transparent;
        /* Sin scroll interno: dejamos que el dropdown del combobox
           se superponga si hace falta. */
        overflow: visible;
      }
      /* Alto fijo del card: ajustado al contenido real (header + form +
         meta + footer) más el dropdown del combobox (max-h-56 = 14rem)
         que vive en posición absoluta debajo del input. Suficiente para
         que la lista quepa sin disparar overflow del dialog. */
      .manual-concept-dialog > div {
        min-height: 26rem;
      }
      .manual-concept-dialog::backdrop { background: rgba(0, 0, 0, 0.4); }
    </style>

    <script is:inline>
      ;(function () {
        const dialog = document.getElementById('manual-concept-dialog')
        const open = document.getElementById('btn-open-manual-concept')
        const close = document.getElementById('btn-close-manual-concept')
        if (!dialog || !open) return

        function openDialog() {
          if (typeof dialog.showModal === 'function') {
            dialog.showModal()
          } else {
            dialog.setAttribute('open', '')
          }
          // Reset del formulario al abrir para evitar arrastrar valores
          // de un intento anterior fallido.
          const form = dialog.querySelector('form')
          form?.reset()
          const idInput = document.getElementById('manual-concept-id')
          const meta = document.getElementById('manual-concept-meta')
          if (idInput) idInput.value = ''
          if (meta) {
            meta.textContent = 'Selecciona un concepto del catálogo.'
            meta.classList.remove('text-red-600')
          }
          setTimeout(() => {
            const search = document.getElementById('manual-concept-search')
            if (search) search.focus()
          }, 50)
        }
        function closeDialog() {
          if (typeof dialog.close === 'function') dialog.close()
          else dialog.removeAttribute('open')
        }

        open.addEventListener('click', openDialog)
        close?.addEventListener('click', closeDialog)
        // Click en el backdrop cierra el dialog (sólo cuando el target
        // es el dialog mismo y no un descendiente).
        dialog.addEventListener('click', (e) => {
          if (e.target === dialog) closeDialog()
        })

        // Al disparar submit en el form interno (data-saconfirm), el
        // helper saModal abre su propio modal de confirmación. Si este
        // dialog sigue abierto se ven solapados — cerramos el dialog
        // en fase de captura para que saModal quede limpio en pantalla.
        const innerForm = dialog.querySelector('form[data-saconfirm]')
        innerForm?.addEventListener(
          'submit',
          () => {
            closeDialog()
          },
          { capture: true }
        )
      })()
    </script>
  )}

  <!-- Combobox de búsqueda para "Agregar concepto manual" -->
  <script type="application/json" id="manual-concept-data" is:inline set:html={JSON.stringify(manualCatalog).replace(/</g, '\\u003c')} />
  <script is:inline>
    ;(function () {
      const dataEl = document.getElementById('manual-concept-data')
      if (!dataEl) return
      const idInput = document.getElementById('manual-concept-id')
      const textInput = document.getElementById('manual-concept-search')
      const dropdown = document.getElementById('manual-concept-dropdown')
      const meta = document.getElementById('manual-concept-meta')
      if (!idInput || !textInput || !dropdown || !meta) return

      let conceptList = []
      try {
        conceptList = JSON.parse(dataEl.textContent || '[]')
      } catch {
        conceptList = []
      }

      const TYPE_LABEL = { income: 'Asignación', deduction: 'Deducción' }

      function filterConcepts(q) {
        const lq = q.toLowerCase().trim()
        if (!lq) return conceptList.slice(0, 50)
        return conceptList
          .filter(
            (c) =>
              c.code.toLowerCase().includes(lq) ||
              c.name.toLowerCase().includes(lq)
          )
          .slice(0, 50)
      }

      function renderDropdown(items) {
        if (items.length === 0) {
          dropdown.classList.add('hidden')
          return
        }
        dropdown.innerHTML = items
          .map((c) => {
            const tone = c.type === 'income' ? 'text-blue-700 bg-blue-50' : 'text-red-700 bg-red-50'
            return `
              <li class="px-3 py-2 cursor-pointer hover:bg-gray-50 transition-colors flex items-center justify-between gap-2"
                  role="option"
                  data-id="${c.id}"
                  data-code="${c.code}"
                  data-name="${c.name.replace(/"/g, '&quot;')}"
                  data-type="${c.type}"
                  data-unit="${c.unit ?? ''}">
                <div class="min-w-0">
                  <div class="font-mono text-xs text-gray-500">${c.code}</div>
                  <div class="text-sm text-gray-800 truncate">${c.name}</div>
                </div>
                <span class="text-[10px] px-1.5 py-0.5 rounded ${tone} font-medium flex-shrink-0">
                  ${TYPE_LABEL[c.type] || c.type}
                </span>
              </li>`
          })
          .join('')
        dropdown.classList.remove('hidden')
      }

      function pickConcept(li) {
        idInput.value = li.dataset.id
        textInput.value = `${li.dataset.code} — ${li.dataset.name}`
        const typeLabel = TYPE_LABEL[li.dataset.type] || li.dataset.type
        meta.textContent = `Tipo: ${typeLabel} · Unidad: ${li.dataset.unit || 'monto'}`
        dropdown.classList.add('hidden')
      }

      dropdown.addEventListener('mousedown', (e) => e.preventDefault())
      dropdown.addEventListener('click', (e) => {
        const li = e.target.closest('li[data-id]')
        if (li) pickConcept(li)
      })
      textInput.addEventListener('input', () => {
        idInput.value = ''
        meta.textContent = 'Selecciona un concepto del catálogo.'
        renderDropdown(filterConcepts(textInput.value))
      })
      textInput.addEventListener('focus', () => {
        renderDropdown(filterConcepts(textInput.value))
      })
      textInput.addEventListener('blur', () => {
        setTimeout(() => dropdown.classList.add('hidden'), 100)
      })

      // Si el usuario submitea sin haber elegido del dropdown, intentamos
      // resolver por código exacto (case-insensitive) antes de bloquear.
      const form = textInput.closest('form')
      form?.addEventListener('submit', (e) => {
        if (idInput.value) return
        const raw = textInput.value.trim().toLowerCase()
        const codeOnly = raw.split('—')[0].trim()
        const match = conceptList.find(
          (c) => c.code.toLowerCase() === codeOnly || c.name.toLowerCase() === raw
        )
        if (match) {
          idInput.value = match.id
          return
        }
        e.preventDefault()
        e.stopPropagation()
        textInput.focus()
        meta.textContent = 'Selecciona un concepto válido del catálogo antes de continuar.'
        meta.classList.add('text-red-600')
      })
    })()
  </script>
  <ServerToastBridge />
</AppLayout>


---
import AppLayout from '../../../layouts/AppLayout.astro'

const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')

const { id, lineId } = Astro.params
const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const headers = { Cookie: `auth=${authCookie}`, 'X-Tenant': 'demo' }

type LineConceptEntry = {
  code: string
  name: string
  type: string
  amount: number
  formulaError?: string
}
type PayrollLine = {
  line: {
    id: string
    grossAmount: string
    deductions: string
    netAmount: string
    concepts: LineConceptEntry[]
  }
  employee: {
    id: string
    code: string
    firstName: string
    lastName: string
    department: string | null
    position: string | null
  }
}
type Payroll = {
  id: string
  name: string
  type: string
  frequency: string
  periodStart: string
  periodEnd: string
  paymentDate: string | null
  status: string
  totalGross: string
  totalDeductions: string
  totalNet: string
}

let payroll: Payroll | null = null
let currentLine: PayrollLine | null = null

try {
  const res = await fetch(`${API_URL}/payroll/${id}`, { headers })
  if (res.status === 401) return Astro.redirect('/login')
  if (res.status === 404) return Astro.redirect('/payroll')
  if (res.ok) {
    const json = (await res.json()) as { data: { payroll: Payroll; lines: PayrollLine[] } }
    payroll = json.data.payroll
    currentLine = json.data.lines.find((l) => l.line.id === lineId) ?? null
  }
} catch {
  return Astro.redirect(`/payroll/${id}`)
}

if (!payroll || !currentLine) return Astro.redirect(`/payroll/${id}`)

const isGenerated = payroll.status === 'generated' || payroll.status === 'processed'
const msgSuccess = Astro.url.searchParams.get('success') ?? ''
const msgError = Astro.url.searchParams.get('error') ?? ''

const concepts = currentLine.line.concepts as LineConceptEntry[]
const asignaciones = concepts.filter((c) => c.type === 'income')
const deducciones = concepts.filter((c) => c.type === 'deduction')
const patronales = concepts.filter((c) => c.type === 'patronal')

function fmt(v: string | number) {
  return Number(v).toLocaleString('es-PA', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
}

const employeeName = `${currentLine.employee.firstName} ${currentLine.employee.lastName}`
---

<AppLayout title={employeeName}>
  <div class="px-6 py-8 max-w-4xl mx-auto">

    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-sm text-gray-500 mb-6">
      <a href="/payroll" class="hover:text-gray-700 transition-colors">Planillas</a>
      <span class="text-gray-300">/</span>
      <a href={`/payroll/${id}`} class="hover:text-gray-700 transition-colors">{payroll.name}</a>
      <span class="text-gray-300">/</span>
      <span class="text-gray-900 font-medium">{employeeName}</span>
    </div>

    <!-- Action bar -->
    <div class="flex items-start justify-between gap-4 mb-6">
      <div>
        <h1 class="text-xl font-semibold text-gray-900">{employeeName}</h1>
        <p class="text-sm text-gray-500 mt-0.5">
          {currentLine.employee.code}
          {currentLine.employee.department && ` · ${currentLine.employee.department}`}
          {currentLine.employee.position && ` / ${currentLine.employee.position}`}
        </p>
      </div>
      <div class="flex items-center gap-2 flex-shrink-0">
        {isGenerated && (
          <form method="POST" action={`/api/payroll/${id}/line/${lineId}`}>
            <input type="hidden" name="_method" value="REGENERATE" />
            <button
              type="submit"
              class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
              Regenerar
            </button>
          </form>
        )}
        <a
          href={`/api/payroll/${id}/line/${lineId}/comprobante`}
          class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors"
          title="Descargar comprobante de pago en PDF"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Comprobante
        </a>
      </div>
    </div>

    {msgSuccess === '1' && (
      <div class="mb-5 rounded-md bg-emerald-50 border border-emerald-200 px-4 py-3 text-sm text-emerald-800">
        Línea regenerada correctamente.
      </div>
    )}
    {msgError && (
      <div class="mb-5 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
        Error: {decodeURIComponent(msgError)}
      </div>
    )}

    <!-- Totals summary -->
    <div class="grid grid-cols-3 gap-4 mb-6">
      <div class="border border-gray-200 rounded-lg bg-white p-4">
        <p class="text-xs text-gray-500 mb-1 font-medium uppercase tracking-wide">Total Bruto</p>
        <p class="text-xl font-semibold text-gray-900 tabular-nums">{fmt(currentLine.line.grossAmount)}</p>
      </div>
      <div class="border border-gray-200 rounded-lg bg-white p-4">
        <p class="text-xs text-gray-500 mb-1 font-medium uppercase tracking-wide">Deducciones</p>
        <p class="text-xl font-semibold text-red-600 tabular-nums">{fmt(currentLine.line.deductions)}</p>
      </div>
      <div class="border border-gray-200 rounded-lg bg-white p-4">
        <p class="text-xs text-gray-500 mb-1 font-medium uppercase tracking-wide">Neto a Pagar</p>
        <p class="text-xl font-semibold text-emerald-700 tabular-nums">{fmt(currentLine.line.netAmount)}</p>
      </div>
    </div>

    <!-- ── Asignaciones ─────────────────────────────────────────────────────── -->
    {asignaciones.length > 0 && (
      <div class="border border-gray-200 rounded-lg bg-white overflow-hidden mb-4">
        <div class="px-4 py-3 border-b border-gray-100 bg-blue-50">
          <h3 class="text-sm font-semibold text-blue-800">Asignaciones</h3>
        </div>
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-100">
              <th class="text-left px-4 py-2 text-xs font-medium text-gray-500 w-32">Código</th>
              <th class="text-left px-4 py-2 text-xs font-medium text-gray-500">Concepto</th>
              <th class="text-right px-4 py-2 text-xs font-medium text-gray-500">Monto</th>
            </tr>
          </thead>
          <tbody>
            {asignaciones.map((c) => (
              <tr class="border-b border-gray-50 last:border-0">
                <td class="px-4 py-2.5 font-mono text-xs text-gray-500">{c.code}</td>
                <td class="px-4 py-2.5 text-gray-800">
                  {c.name}
                  {c.formulaError && <span class="ml-1 text-red-500 text-xs" title={c.formulaError}>⚠</span>}
                </td>
                <td class="px-4 py-2.5 text-right tabular-nums text-gray-900 font-medium">{fmt(c.amount)}</td>
              </tr>
            ))}
            <tr class="border-t border-blue-100 bg-blue-50/50">
              <td colspan="2" class="px-4 py-2 text-xs font-semibold text-blue-700 text-right">Subtotal Asignaciones</td>
              <td class="px-4 py-2 text-right tabular-nums font-semibold text-blue-700">
                {fmt(asignaciones.reduce((s, c) => s + Number(c.amount), 0))}
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    )}

    <!-- ── Deducciones ──────────────────────────────────────────────────────── -->
    {deducciones.length > 0 && (
      <div class="border border-gray-200 rounded-lg bg-white overflow-hidden mb-4">
        <div class="px-4 py-3 border-b border-gray-100 bg-red-50">
          <h3 class="text-sm font-semibold text-red-800">Deducciones</h3>
        </div>
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-100">
              <th class="text-left px-4 py-2 text-xs font-medium text-gray-500 w-32">Código</th>
              <th class="text-left px-4 py-2 text-xs font-medium text-gray-500">Concepto</th>
              <th class="text-right px-4 py-2 text-xs font-medium text-gray-500">Monto</th>
            </tr>
          </thead>
          <tbody>
            {deducciones.map((c) => (
              <tr class="border-b border-gray-50 last:border-0">
                <td class="px-4 py-2.5 font-mono text-xs text-gray-500">{c.code}</td>
                <td class="px-4 py-2.5 text-gray-800">
                  {c.name}
                  {c.formulaError && <span class="ml-1 text-red-500 text-xs" title={c.formulaError}>⚠</span>}
                </td>
                <td class="px-4 py-2.5 text-right tabular-nums text-red-600">{fmt(c.amount)}</td>
              </tr>
            ))}
            <tr class="border-t border-red-100 bg-red-50/50">
              <td colspan="2" class="px-4 py-2 text-xs font-semibold text-red-700 text-right">Subtotal Deducciones</td>
              <td class="px-4 py-2 text-right tabular-nums font-semibold text-red-700">
                {fmt(deducciones.reduce((s, c) => s + Number(c.amount), 0))}
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    )}

    <!-- ── Patronales ───────────────────────────────────────────────────────── -->
    {patronales.length > 0 && (
      <div class="border border-gray-200 rounded-lg bg-white overflow-hidden mb-4">
        <div class="px-4 py-3 border-b border-gray-100 bg-amber-50">
          <h3 class="text-sm font-semibold text-amber-800">Patronales</h3>
        </div>
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-100">
              <th class="text-left px-4 py-2 text-xs font-medium text-gray-500 w-32">Código</th>
              <th class="text-left px-4 py-2 text-xs font-medium text-gray-500">Concepto</th>
              <th class="text-right px-4 py-2 text-xs font-medium text-gray-500">Monto</th>
            </tr>
          </thead>
          <tbody>
            {patronales.map((c) => (
              <tr class="border-b border-gray-50 last:border-0">
                <td class="px-4 py-2.5 font-mono text-xs text-gray-500">{c.code}</td>
                <td class="px-4 py-2.5 text-gray-800">
                  {c.name}
                  {c.formulaError && <span class="ml-1 text-red-500 text-xs" title={c.formulaError}>⚠</span>}
                </td>
                <td class="px-4 py-2.5 text-right tabular-nums text-amber-700">{fmt(c.amount)}</td>
              </tr>
            ))}
            <tr class="border-t border-amber-100 bg-amber-50/50">
              <td colspan="2" class="px-4 py-2 text-xs font-semibold text-amber-700 text-right">Subtotal Patronales</td>
              <td class="px-4 py-2 text-right tabular-nums font-semibold text-amber-700">
                {fmt(patronales.reduce((s, c) => s + Number(c.amount), 0))}
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    )}

  </div>
</AppLayout>



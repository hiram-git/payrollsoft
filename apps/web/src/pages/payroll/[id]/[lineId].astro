---
import AppLayout from '../../../layouts/AppLayout.astro'

const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')

const { id, lineId } = Astro.params
const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const headers = { Cookie: `auth=${authCookie}`, 'X-Tenant': 'demo' }

type LineConceptEntry = {
  code: string
  name: string
  type: string
  amount: number
  formulaError?: string
}
type PayrollLine = {
  line: {
    id: string
    grossAmount: string
    deductions: string
    netAmount: string
    concepts: LineConceptEntry[]
  }
  employee: {
    id: string
    code: string
    firstName: string
    lastName: string
    department: string | null
    position: string | null
  }
}
type Payroll = {
  id: string
  name: string
  type: string
  frequency: string
  periodStart: string
  periodEnd: string
  paymentDate: string | null
  status: string
  totalGross: string
  totalDeductions: string
  totalNet: string
}

const fromPage = Astro.url.searchParams.get('fromPage') ?? '1'
const fromSearch = Astro.url.searchParams.get('fromSearch') ?? ''

let payroll: Payroll | null = null
let currentLine: PayrollLine | null = null

try {
  const res = await fetch(`${API_URL}/payroll/${id}/line/${lineId}`, { headers })
  if (res.status === 401) return Astro.redirect('/login')
  if (res.status === 404) return Astro.redirect('/payroll')
  if (res.ok) {
    const json = (await res.json()) as { data: { payroll: Payroll; line: PayrollLine } }
    payroll = json.data.payroll
    currentLine = json.data.line
  }
} catch {
  return Astro.redirect(`/payroll/${id}`)
}

if (!payroll || !currentLine) return Astro.redirect(`/payroll/${id}`)

const isGenerated = payroll.status === 'generated' || payroll.status === 'processed'
const msgSuccess = Astro.url.searchParams.get('success') ?? ''
const msgError = Astro.url.searchParams.get('error') ?? ''

const concepts = currentLine.line.concepts as LineConceptEntry[]
const asignaciones = concepts.filter((c) => c.type === 'income')
const deducciones = concepts.filter((c) => c.type === 'deduction')
const patronales = concepts.filter((c) => c.type === 'patronal')

function fmt(v: string | number) {
  return Number(v).toLocaleString('es-PA', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
}

const employeeName = `${currentLine.employee.firstName} ${currentLine.employee.lastName}`
---

<AppLayout title={employeeName}>
  <div class="px-6 py-8 max-w-4xl mx-auto">

    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-sm text-gray-500 mb-6">
      <a href="/payroll" class="hover:text-gray-700 transition-colors">Planillas</a>
      <span class="text-gray-300">/</span>
      <a href={`/payroll/${id}?linesPage=${fromPage}${fromSearch ? `&search=${encodeURIComponent(fromSearch)}` : ''}`} class="hover:text-gray-700 transition-colors">{payroll.name}</a>
      <span class="text-gray-300">/</span>
      <span class="text-gray-900 font-medium">{employeeName}</span>
    </div>

    <!-- Action bar -->
    <div class="flex items-start justify-between gap-4 mb-6">
      <div>
        <h1 class="text-xl font-semibold text-gray-900">{employeeName}</h1>
        <p class="text-sm text-gray-500 mt-0.5">
          {currentLine.employee.code}
          {currentLine.employee.department && ` · ${currentLine.employee.department}`}
          {currentLine.employee.position && ` / ${currentLine.employee.position}`}
        </p>
      </div>
      <div class="flex items-center gap-2 flex-shrink-0">
        {isGenerated && (
          <form id="form-regenerate" method="POST" action={`/api/payroll/${id}/line/${lineId}`}>
            <input type="hidden" name="_method" value="REGENERATE" />
            <button
              type="button"
              data-confirm
              data-form="form-regenerate"
              data-title="Regenerar empleado"
              data-body={`¿Recalcular los conceptos de ${employeeName}? Los valores actuales serán reemplazados.`}
              data-confirm-label="Regenerar"
              data-confirm-style="warning"
              data-show-loading="true"
              class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
              Regenerar
            </button>
          </form>
        )}
        <a
          href={`/api/payroll/${id}/line/${lineId}/comprobante`}
          class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-md border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors"
          title="Descargar comprobante de pago en PDF"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Comprobante
        </a>
      </div>
    </div>

    {msgSuccess === '1' && (
      <div class="mb-5 rounded-md bg-emerald-50 border border-emerald-200 px-4 py-3 text-sm text-emerald-800">
        Línea regenerada correctamente.
      </div>
    )}
    {msgError && (
      <div class="mb-5 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
        Error: {decodeURIComponent(msgError)}
      </div>
    )}

    <!-- Totals summary -->
    <div class="grid grid-cols-3 gap-4 mb-6">
      <div class="border border-gray-200 rounded-lg bg-white p-4">
        <p class="text-xs text-gray-500 mb-1 font-medium uppercase tracking-wide">Total Bruto</p>
        <p class="text-xl font-semibold text-gray-900 tabular-nums">{fmt(currentLine.line.grossAmount)}</p>
      </div>
      <div class="border border-gray-200 rounded-lg bg-white p-4">
        <p class="text-xs text-gray-500 mb-1 font-medium uppercase tracking-wide">Deducciones</p>
        <p class="text-xl font-semibold text-red-600 tabular-nums">{fmt(currentLine.line.deductions)}</p>
      </div>
      <div class="border border-gray-200 rounded-lg bg-white p-4">
        <p class="text-xs text-gray-500 mb-1 font-medium uppercase tracking-wide">Neto a Pagar</p>
        <p class="text-xl font-semibold text-emerald-700 tabular-nums">{fmt(currentLine.line.netAmount)}</p>
      </div>
    </div>

    <!-- ── Asignaciones ─────────────────────────────────────────────────────── -->
    {asignaciones.length > 0 && (
      <div class="border border-gray-200 rounded-lg bg-white overflow-hidden mb-4">
        <div class="px-4 py-3 border-b border-gray-100 bg-blue-50">
          <h3 class="text-sm font-semibold text-blue-800">Asignaciones</h3>
        </div>
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-100">
              <th class="text-left px-4 py-2 text-xs font-medium text-gray-500 w-32">Código</th>
              <th class="text-left px-4 py-2 text-xs font-medium text-gray-500">Concepto</th>
              <th class="text-right px-4 py-2 text-xs font-medium text-gray-500">Monto</th>
            </tr>
          </thead>
          <tbody>
            {asignaciones.map((c) => (
              <tr class="border-b border-gray-50 last:border-0">
                <td class="px-4 py-2.5 font-mono text-xs text-gray-500">{c.code}</td>
                <td class="px-4 py-2.5 text-gray-800">
                  {c.name}
                  {c.formulaError && <span class="ml-1 text-red-500 text-xs" title={c.formulaError}>⚠</span>}
                </td>
                <td class="px-4 py-2.5 text-right tabular-nums text-gray-900 font-medium">{fmt(c.amount)}</td>
              </tr>
            ))}
            <tr class="border-t border-blue-100 bg-blue-50/50">
              <td colspan="2" class="px-4 py-2 text-xs font-semibold text-blue-700 text-right">Subtotal Asignaciones</td>
              <td class="px-4 py-2 text-right tabular-nums font-semibold text-blue-700">
                {fmt(asignaciones.reduce((s, c) => s + Number(c.amount), 0))}
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    )}

    <!-- ── Deducciones ──────────────────────────────────────────────────────── -->
    {deducciones.length > 0 && (
      <div class="border border-gray-200 rounded-lg bg-white overflow-hidden mb-4">
        <div class="px-4 py-3 border-b border-gray-100 bg-red-50">
          <h3 class="text-sm font-semibold text-red-800">Deducciones</h3>
        </div>
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-100">
              <th class="text-left px-4 py-2 text-xs font-medium text-gray-500 w-32">Código</th>
              <th class="text-left px-4 py-2 text-xs font-medium text-gray-500">Concepto</th>
              <th class="text-right px-4 py-2 text-xs font-medium text-gray-500">Monto</th>
            </tr>
          </thead>
          <tbody>
            {deducciones.map((c) => (
              <tr class="border-b border-gray-50 last:border-0">
                <td class="px-4 py-2.5 font-mono text-xs text-gray-500">{c.code}</td>
                <td class="px-4 py-2.5 text-gray-800">
                  {c.name}
                  {c.formulaError && <span class="ml-1 text-red-500 text-xs" title={c.formulaError}>⚠</span>}
                </td>
                <td class="px-4 py-2.5 text-right tabular-nums text-red-600">{fmt(c.amount)}</td>
              </tr>
            ))}
            <tr class="border-t border-red-100 bg-red-50/50">
              <td colspan="2" class="px-4 py-2 text-xs font-semibold text-red-700 text-right">Subtotal Deducciones</td>
              <td class="px-4 py-2 text-right tabular-nums font-semibold text-red-700">
                {fmt(deducciones.reduce((s, c) => s + Number(c.amount), 0))}
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    )}

    <!-- ── Patronales ───────────────────────────────────────────────────────── -->
    {patronales.length > 0 && (
      <div class="border border-gray-200 rounded-lg bg-white overflow-hidden mb-4">
        <div class="px-4 py-3 border-b border-gray-100 bg-amber-50">
          <h3 class="text-sm font-semibold text-amber-800">Patronales</h3>
        </div>
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-100">
              <th class="text-left px-4 py-2 text-xs font-medium text-gray-500 w-32">Código</th>
              <th class="text-left px-4 py-2 text-xs font-medium text-gray-500">Concepto</th>
              <th class="text-right px-4 py-2 text-xs font-medium text-gray-500">Monto</th>
            </tr>
          </thead>
          <tbody>
            {patronales.map((c) => (
              <tr class="border-b border-gray-50 last:border-0">
                <td class="px-4 py-2.5 font-mono text-xs text-gray-500">{c.code}</td>
                <td class="px-4 py-2.5 text-gray-800">
                  {c.name}
                  {c.formulaError && <span class="ml-1 text-red-500 text-xs" title={c.formulaError}>⚠</span>}
                </td>
                <td class="px-4 py-2.5 text-right tabular-nums text-amber-700">{fmt(c.amount)}</td>
              </tr>
            ))}
            <tr class="border-t border-amber-100 bg-amber-50/50">
              <td colspan="2" class="px-4 py-2 text-xs font-semibold text-amber-700 text-right">Subtotal Patronales</td>
              <td class="px-4 py-2 text-right tabular-nums font-semibold text-amber-700">
                {fmt(patronales.reduce((s, c) => s + Number(c.amount), 0))}
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    )}

  </div>

  <!-- Confirmation modal -->
  <div id="confirm-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4" role="dialog" aria-modal="true">
    <div id="modal-backdrop" class="absolute inset-0 bg-black/40 backdrop-blur-sm"></div>
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-md p-6">
      <div id="modal-icon" class="w-10 h-10 rounded-full flex items-center justify-center mb-4"></div>
      <h3 id="modal-title" class="text-base font-semibold text-gray-900 mb-1.5"></h3>
      <p id="modal-body" class="text-sm text-gray-500 leading-relaxed mb-4"></p>
      <div id="modal-loading" class="hidden mb-5">
        <div class="flex items-center gap-2 mb-2">
          <svg class="w-4 h-4 text-amber-500 animate-spin flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/></svg>
          <span class="text-xs text-gray-500">Procesando… esto puede tomar unos segundos.</span>
        </div>
        <div class="w-full bg-gray-100 rounded-full h-1.5 overflow-hidden">
          <div class="h-1.5 rounded-full bg-amber-400 animate-[indeterminate_1.5s_ease-in-out_infinite]" style="width:40%"></div>
        </div>
      </div>
      <div id="modal-actions" class="flex justify-end gap-2.5">
        <button id="modal-cancel" type="button" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Cancelar</button>
        <button id="modal-confirm" type="button" class="px-4 py-2 text-sm font-medium rounded-lg transition-colors">Confirmar</button>
      </div>
    </div>
  </div>
</AppLayout>

<style>
  @keyframes indeterminate {
    0%   { transform: translateX(-100%); width: 40%; }
    50%  { width: 70%; }
    100% { transform: translateX(300%); width: 40%; }
  }
</style>

<script>
  const modal = document.getElementById('confirm-modal') as HTMLElement
  const modalBackdrop = document.getElementById('modal-backdrop') as HTMLElement
  const modalIcon = document.getElementById('modal-icon') as HTMLElement
  const modalTitle = document.getElementById('modal-title') as HTMLElement
  const modalBody = document.getElementById('modal-body') as HTMLElement
  const modalLoading = document.getElementById('modal-loading') as HTMLElement
  const modalActions = document.getElementById('modal-actions') as HTMLElement
  const modalConfirm = document.getElementById('modal-confirm') as HTMLButtonElement
  const modalCancel = document.getElementById('modal-cancel') as HTMLButtonElement

  const styleMap: Record<string, { btn: string; icon: string; svg: string }> = {
    warning: {
      btn: 'bg-amber-500 hover:bg-amber-600 text-white',
      icon: 'bg-amber-100',
      svg: '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-amber-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>',
    },
  }

  let pendingFormId: string | null = null
  let pendingShowLoading = false

  function openModal(btn: HTMLElement) {
    pendingFormId = btn.getAttribute('data-form')
    pendingShowLoading = btn.getAttribute('data-show-loading') === 'true'
    const title = btn.getAttribute('data-title') ?? ''
    const body = btn.getAttribute('data-body') ?? ''
    const label = btn.getAttribute('data-confirm-label') ?? 'Confirmar'
    const style = btn.getAttribute('data-confirm-style') ?? 'warning'
    const s = styleMap[style] ?? styleMap.warning

    modalTitle.textContent = title
    modalBody.textContent = body
    modalLoading.classList.add('hidden')
    modalActions.classList.remove('hidden')
    modalConfirm.textContent = label
    modalConfirm.className = `px-4 py-2 text-sm font-medium rounded-lg transition-colors ${s.btn}`
    modalIcon.className = `w-10 h-10 rounded-full flex items-center justify-center mb-4 ${s.icon}`
    modalIcon.innerHTML = s.svg

    modal.classList.remove('hidden')
    modalConfirm.focus()
  }

  function showLoadingState() {
    modalLoading.classList.remove('hidden')
    modalActions.classList.add('hidden')
    modalBackdrop.removeEventListener('click', closeModal)
  }

  function closeModal() {
    modal.classList.add('hidden')
    pendingFormId = null
    pendingShowLoading = false
    modalLoading.classList.add('hidden')
    modalActions.classList.remove('hidden')
    modalBackdrop.addEventListener('click', closeModal)
  }

  document.querySelectorAll<HTMLElement>('[data-confirm]').forEach((btn) => {
    btn.addEventListener('click', () => openModal(btn))
  })

  modalCancel.addEventListener('click', closeModal)
  modalBackdrop.addEventListener('click', closeModal)

  modalConfirm.addEventListener('click', () => {
    if (pendingFormId) {
      const form = document.getElementById(pendingFormId) as HTMLFormElement | null
      if (form) {
        if (pendingShowLoading) showLoadingState()
        form.submit()
      }
    } else {
      closeModal()
    }
  })

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden') && modalLoading.classList.contains('hidden')) closeModal()
  })
</script>

---
import PortalLayout from '../../layouts/PortalLayout.astro'
import { getPortalIdentity } from '../../lib/portal-auth'

const identity = getPortalIdentity(Astro.cookies)
if (!identity) return Astro.redirect('/portal/login')
---

<PortalLayout title="Tardanzas">
  <div class="pr-wrap">
    <div class="pr-header">
      <a href="/portal" class="pr-back">← Volver al portal</a>
      <h1 class="pr-title">Justificación de tardanza</h1>
      <p class="pr-subtitle">Justifica una tardanza para que se descuente del tiempo compensatorio.</p>
    </div>

    <div class="pr-banner pr-banner-err" id="err-banner" style="display:none;">
      <svg width="11" height="11" viewBox="0 0 11 11" fill="none" stroke="currentColor" stroke-width="1.3"><circle cx="5.5" cy="5.5" r="4.5"/><path d="M5.5 3v3M5.5 7.8v.2"/></svg>
      <span id="err-text"></span>
    </div>
    <div class="pr-banner pr-banner-ok" id="ok-banner" style="display:none;">
      <svg width="11" height="11" viewBox="0 0 11 11" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 5.8 4.5 8.2 9 3.4"/></svg>
      <span id="ok-text"></span>
    </div>

    <form id="pf-form" enctype="multipart/form-data" novalidate>
      <section class="pt-card pr-section">
        <h2 class="pr-section-title">Motivo de la tardanza</h2>
        <div class="pr-grid-2">
          <div>
            <label class="pr-label">Motivo *</label>
            <select id="pf-subtype" name="subtypeCode" class="pr-input pr-select-field" required>
              <option value="">Selecciona...</option>
              <option value="fuertes_lluvias">Fuertes lluvias</option>
              <option value="huelga">Huelga</option>
              <option value="cita_medica">Asistencia a cita médica</option>
              <option value="otros">Otros</option>
            </select>
          </div>
          <div>
            <label class="pr-label">Fecha del documento</label>
            <input type="date" name="documentDate" class="pr-input" required />
          </div>
        </div>
      </section>

      <section class="pt-card pr-section">
        <h2 class="pr-section-title">Período de tardanza</h2>
        <div class="pr-grid-3">
          <div>
            <label class="pr-label">Hora programada de entrada *</label>
            <input type="datetime-local" id="pf-start" name="extra_scheduled_entry" class="pr-input" required />
          </div>
          <div>
            <label class="pr-label">Hora real de llegada *</label>
            <input type="datetime-local" id="pf-end" name="extra_actual_arrival" class="pr-input" required />
          </div>
          <div>
            <label class="pr-label">Minutos de tardanza</label>
            <div class="pr-calc-result">
              <span class="pr-calc-value" id="pf-calc-mins">0</span>
              <span>minutos</span>
            </div>
            <input type="hidden" id="pf-minutes" name="extra_minutes_late" value="0" />
          </div>
        </div>
      </section>

      <section class="pt-card pr-section" id="dyn-section" style="display:none;">
        <h2 class="pr-section-title">Datos adicionales</h2>
        <div id="dyn-fields" class="pr-grid-2"></div>
      </section>

      <section class="pt-card pr-section">
        <h2 class="pr-section-title">Motivo detallado</h2>
        <textarea name="extra_reason_detail" rows="3" placeholder="Describe el motivo de la tardanza..." class="pr-input pr-textarea" required></textarea>
      </section>

      <section class="pt-card pr-section">
        <h2 class="pr-section-title">Observaciones</h2>
        <textarea name="observations" rows="2" placeholder="Notas adicionales (opcional)" class="pr-input pr-textarea"></textarea>
      </section>

      <div class="pr-actions">
        <a href="/portal" class="pr-btn-cancel">Cancelar</a>
        <button type="submit" id="pf-submit" class="pr-btn-submit">
          <span class="btn-text">Enviar solicitud</span>
          <span class="pr-spinner"></span>
        </button>
      </div>
    </form>
  </div>

  <script is:inline>
    ;(function() {
      var FILE_TYPE_CODE = 'tardanzas';
      var form = document.getElementById('pf-form');
      var subtypeEl = document.getElementById('pf-subtype');
      var dynSection = document.getElementById('dyn-section');
      var dynFields = document.getElementById('dyn-fields');
      var submitBtn = document.getElementById('pf-submit');
      var errBanner = document.getElementById('err-banner');
      var errText = document.getElementById('err-text');
      var okBanner = document.getElementById('ok-banner');
      var okText = document.getElementById('ok-text');
      var startEl = document.getElementById('pf-start');
      var endEl = document.getElementById('pf-end');
      var calcEl = document.getElementById('pf-calc-mins');
      var minsHidden = document.getElementById('pf-minutes');
      var FILE_ACCEPT = 'application/pdf,image/jpeg,image/png,image/gif';
      var typeId = null; var subtypeMap = {}; var fieldsCache = {};

      function showErr(m) { errText.textContent = m; errBanner.style.display = 'flex'; okBanner.style.display = 'none'; }
      function showOk(m) { okText.textContent = m; okBanner.style.display = 'flex'; errBanner.style.display = 'none'; }
      function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;'); }
      function proxyGet(p) { return fetch('/api/portal/proxy?path=' + encodeURIComponent(p)).then(function(r) { return r.json(); }); }

      function calcMinutes() {
        var s = startEl.value, e = endEl.value;
        if (!s || !e) { calcEl.textContent = '0'; minsHidden.value = '0'; return; }
        var diff = (new Date(e).getTime() - new Date(s).getTime()) / 60000;
        if (diff < 0) diff = 0;
        var rounded = Math.round(diff);
        calcEl.textContent = String(rounded);
        minsHidden.value = String(rounded);
      }
      startEl.addEventListener('change', calcMinutes);
      endEl.addEventListener('change', calcMinutes);

      proxyGet('file-types').then(function(res) {
        var types = (res && res.data) || [];
        for (var i = 0; i < types.length; i++) { if (types[i].code === FILE_TYPE_CODE) { typeId = types[i].id; break; } }
        if (!typeId) return;
        return proxyGet('file-types/' + typeId + '/subtypes');
      }).then(function(res) {
        if (!res) return;
        var subs = (res && res.data) || [];
        for (var j = 0; j < subs.length; j++) subtypeMap[subs[j].code] = subs[j].id;
      });

      subtypeEl.addEventListener('change', function() {
        var code = subtypeEl.value;
        if (!code || !typeId) { dynSection.style.display = 'none'; dynFields.innerHTML = ''; return; }
        var subtypeId = subtypeMap[code];
        if (!subtypeId) { dynSection.style.display = 'none'; return; }
        var key = typeId + '/' + subtypeId;
        if (fieldsCache[key]) { renderFields(fieldsCache[key]); return; }
        proxyGet('file-fields?typeId=' + typeId + '&subtypeId=' + subtypeId).then(function(res) {
          var fields = (res && res.data && res.data.fields) || [];
          fields = fields.filter(function(f) { return f.name !== 'tardiness_date' && f.name !== 'minutes_late' && f.name !== 'reason_detail'; });
          fieldsCache[key] = fields;
          renderFields(fields);
        });
      });

      function renderFields(fields) {
        if (fields.length === 0) { dynSection.style.display = 'none'; dynFields.innerHTML = ''; return; }
        dynFields.innerHTML = fields.map(function(def) {
          var id = 'dyn-' + def.name; var name = (def.type === 'file' ? 'file' : 'extra') + '_' + def.name;
          var req = def.required ? ' required' : ''; var ph = def.placeholder ? ' placeholder="' + esc(def.placeholder) + '"' : '';
          var val = def.default != null ? esc(String(def.default)) : ''; var full = def.type === 'textarea' || def.type === 'file';
          var label = '<label class="pr-label" for="' + id + '">' + esc(def.label) + (def.required ? ' <span style="color:var(--err)">*</span>' : '') + '</label>';
          var inner = '';
          if (def.type === 'textarea') inner = '<textarea id="' + id + '" name="' + name + '" rows="3"' + req + ph + ' class="pr-input pr-textarea">' + val + '</textarea>';
          else if (def.type === 'file') inner = '<input id="' + id + '" type="file" name="' + name + '"' + req + ' accept="' + FILE_ACCEPT + '" class="pr-file-input" />';
          else if (def.type === 'number') inner = '<input id="' + id + '" type="number" name="' + name + '"' + req + (def.step != null ? ' step="' + def.step + '"' : '') + ph + ' value="' + val + '" class="pr-input" />';
          else if (def.type === 'date') inner = '<input id="' + id + '" type="date" name="' + name + '"' + req + ' value="' + val + '" class="pr-input" />';
          else inner = '<input id="' + id + '" type="text" name="' + name + '"' + req + ph + ' value="' + val + '" class="pr-input" />';
          return '<div' + (full ? ' class="pr-full"' : '') + '>' + label + inner + '</div>';
        }).join('');
        dynSection.style.display = 'block';
      }

      form.addEventListener('submit', function(e) {
        e.preventDefault(); errBanner.style.display = 'none';
        var code = subtypeEl.value;
        if (!code || !typeId) { showErr('Selecciona un motivo.'); return; }
        var subtypeId = subtypeMap[code];
        if (!subtypeId) { showErr('Subtipo no encontrado.'); return; }
        var mins = Number(minsHidden.value);
        if (!startEl.value || !endEl.value || mins <= 0) { showErr('Selecciona las horas de entrada programada y real.'); return; }
        submitBtn.classList.add('loading'); submitBtn.disabled = true;
        var fd = new FormData(form);
        fd.set('typeId', String(typeId));
        fd.set('subtypeId', String(subtypeId));
        fetch('/api/portal/requests', { method: 'POST', body: fd })
          .then(function(r) { return r.json(); })
          .then(function(r) {
            if (r.success) {
              showOk('Solicitud creada. N° ' + (r.data && r.data.documentNumber ? r.data.documentNumber : ''));
              form.reset(); dynSection.style.display = 'none'; dynFields.innerHTML = '';
              calcEl.textContent = '0'; minsHidden.value = '0';
            } else showErr(r.error || 'Error.');
            submitBtn.classList.remove('loading'); submitBtn.disabled = false;
          })
          .catch(function() { showErr('Error de conexión.'); submitBtn.classList.remove('loading'); submitBtn.disabled = false; });
      });
    })();
  </script>
</PortalLayout>

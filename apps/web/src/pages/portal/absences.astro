---
import PortalLayout from '../../layouts/PortalLayout.astro'
import { getPortalIdentity } from '../../lib/portal-auth'

const identity = getPortalIdentity(Astro.cookies)
if (!identity) return Astro.redirect('/portal/login')
---

<PortalLayout title="Ausencias">
  <div class="pf-wrap">
    <div class="pf-header">
      <h1 class="pf-title">Solicitud de ausencia</h1>
      <p class="pf-sub">Justifica una ausencia para que se descuente del tiempo compensatorio.</p>
    </div>

    <div class="pf-banner pf-banner-err" id="err-banner" style="display:none;">
      <span id="err-text"></span>
    </div>
    <div class="pf-banner pf-banner-ok" id="ok-banner" style="display:none;">
      <span id="ok-text"></span>
    </div>

    <form id="pf-form" enctype="multipart/form-data" novalidate>
      <section class="pt-card pf-section">
        <h2 class="pf-section-title">Tipo de ausencia</h2>
        <div class="pf-grid-2">
          <div>
            <label class="ds-label">Motivo *</label>
            <select id="pf-subtype" name="subtypeCode" class="ds-input" required>
              <option value="">Selecciona...</option>
              <option value="enfermedad">Enfermedad</option>
              <option value="duelo">Duelo</option>
              <option value="matrimonio">Matrimonio</option>
              <option value="nacimiento_hijo">Nacimiento de hijo</option>
              <option value="enfermedad_pariente">Enfermedad de pariente cercano</option>
              <option value="eventos_academicos">Eventos académicos</option>
              <option value="asuntos_personales">Asuntos personales</option>
            </select>
          </div>
          <div>
            <label class="ds-label">Fecha del documento</label>
            <input type="date" name="documentDate" class="ds-input" required />
          </div>
        </div>
      </section>

      <section class="pt-card pf-section" id="dyn-section" style="display:none;">
        <h2 class="pf-section-title">Datos de la ausencia</h2>
        <div id="dyn-fields" class="pf-grid-2"></div>
      </section>

      <section class="pt-card pf-section">
        <h2 class="pf-section-title">Observaciones</h2>
        <textarea name="observations" rows="2" placeholder="Notas adicionales (opcional)" class="ds-input" style="resize:vertical;min-height:56px;"></textarea>
      </section>

      <div class="pf-actions">
        <a href="/portal" class="ds-btn-ghost">Cancelar</a>
        <button type="submit" id="pf-submit" class="ds-btn-primary">
          <span class="btn-text">Enviar solicitud</span>
          <span class="pf-spinner"></span>
        </button>
      </div>
    </form>
  </div>

  <style is:global>
    .pf-wrap { max-width:800px; margin:0 auto; padding:32px 24px; }
    .pf-header { margin-bottom:24px; }
    .pf-title { font-family:var(--f-display); font-weight:300; font-size:24px; letter-spacing:-0.02em; margin:0 0 4px; color:var(--fore); }
    .pf-sub { font-size:13px; color:var(--mute-2); margin:0; }
    .pf-banner { font-family:var(--f-mono); font-size:11.5px; padding:10px 12px; border-radius:3px; margin-bottom:16px; letter-spacing:.04em; display:flex; align-items:center; gap:10px; }
    .pf-banner-err { color:var(--err); border:1px solid rgba(224,107,92,0.35); background:rgba(224,107,92,0.06); }
    .pf-banner-ok { color:var(--ok); border:1px solid rgba(111,181,140,0.35); background:rgba(111,181,140,0.06); }
    .pf-section { padding:24px; margin-bottom:16px; border-radius:10px; }
    .pf-section-title { font-family:var(--f-sans); font-weight:600; font-size:15px; color:var(--fore); margin:0 0 18px; }
    .pf-grid-2 { display:grid; grid-template-columns:repeat(2,1fr); gap:16px; }
    .pf-full { grid-column:1/-1; }
    @media (max-width:640px) { .pf-grid-2 { grid-template-columns:1fr; } }
    .pf-actions { display:flex; align-items:center; justify-content:flex-end; gap:12px; padding-top:16px; border-top:1px solid var(--rule); }
    .pf-spinner { width:14px; height:14px; border:2px solid rgba(255,255,255,.3); border-top-color:#fff; border-radius:50%; animation:pf-spin .6s linear infinite; display:none; }
    .ds-btn-primary.loading .btn-text { display:none; }
    .ds-btn-primary.loading .pf-spinner { display:block; }
    @keyframes pf-spin { to { transform:rotate(360deg); } }
  </style>

  <script is:inline>
    ;(function() {
      var FILE_TYPE_CODE = 'ausencias';
      var form = document.getElementById('pf-form');
      var subtypeEl = document.getElementById('pf-subtype');
      var dynSection = document.getElementById('dyn-section');
      var dynFields = document.getElementById('dyn-fields');
      var submitBtn = document.getElementById('pf-submit');
      var errBanner = document.getElementById('err-banner');
      var errText = document.getElementById('err-text');
      var okBanner = document.getElementById('ok-banner');
      var okText = document.getElementById('ok-text');
      var FILE_ACCEPT = 'application/pdf,image/jpeg,image/png,image/gif';
      var typeId = null;
      var subtypeMap = {};
      var fieldsCache = {};

      function showErr(m) { errText.textContent = m; errBanner.style.display = 'flex'; okBanner.style.display = 'none'; }
      function showOk(m) { okText.textContent = m; okBanner.style.display = 'flex'; errBanner.style.display = 'none'; }
      function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;'); }

      function proxyGet(p) {
        return fetch('/api/portal/proxy?path=' + encodeURIComponent(p)).then(function(r) { return r.json(); });
      }

      // Resolve type id and subtypes
      proxyGet('file-types').then(function(res) {
        var types = (res && res.data) || [];
        for (var i = 0; i < types.length; i++) {
          if (types[i].code === FILE_TYPE_CODE) { typeId = types[i].id; break; }
        }
        if (!typeId) return;
        return proxyGet('file-types/' + typeId + '/subtypes');
      }).then(function(res) {
        if (!res) return;
        var subs = (res && res.data) || [];
        for (var j = 0; j < subs.length; j++) subtypeMap[subs[j].code] = subs[j].id;
      });

      subtypeEl.addEventListener('change', function() {
        var code = subtypeEl.value;
        if (!code || !typeId) { dynSection.style.display = 'none'; dynFields.innerHTML = ''; return; }
        var subtypeId = subtypeMap[code];
        if (!subtypeId) { dynSection.style.display = 'none'; return; }
        var key = typeId + '/' + subtypeId;
        if (fieldsCache[key]) { renderFields(fieldsCache[key]); return; }
        proxyGet('file-fields?typeId=' + typeId + '&subtypeId=' + subtypeId).then(function(res) {
          var fields = (res && res.data && res.data.fields) || [];
          fieldsCache[key] = fields;
          renderFields(fields);
        });
      });

      function renderFields(fields) {
        if (fields.length === 0) { dynSection.style.display = 'none'; dynFields.innerHTML = ''; return; }
        dynFields.innerHTML = fields.map(function(def) {
          var id = 'dyn-' + def.name;
          var name = (def.type === 'file' ? 'file' : 'extra') + '_' + def.name;
          var req = def.required ? ' required' : '';
          var ph = def.placeholder ? ' placeholder="' + esc(def.placeholder) + '"' : '';
          var val = def.default != null ? esc(String(def.default)) : '';
          var full = def.type === 'textarea' || def.type === 'file';
          var label = '<label class="ds-label" for="' + id + '">' + esc(def.label) + (def.required ? ' <span style="color:var(--err)">*</span>' : '') + '</label>';
          var inner = '';
          if (def.type === 'textarea') inner = '<textarea id="' + id + '" name="' + name + '" rows="3"' + req + ph + ' class="ds-input" style="resize:vertical;min-height:56px;">' + val + '</textarea>';
          else if (def.type === 'select') {
            var opts = (def.options || []).map(function(o) { return '<option value="' + esc(o.value) + '">' + esc(o.label) + '</option>'; }).join('');
            inner = '<select id="' + id + '" name="' + name + '"' + req + ' class="ds-input"><option value="">Selecciona…</option>' + opts + '</select>';
          } else if (def.type === 'file') inner = '<input id="' + id + '" type="file" name="' + name + '"' + req + ' accept="' + FILE_ACCEPT + '" class="ds-input" style="padding:8px;" />';
          else if (def.type === 'number') inner = '<input id="' + id + '" type="number" name="' + name + '"' + req + (def.step != null ? ' step="' + def.step + '"' : '') + ph + ' value="' + val + '" class="ds-input" />';
          else if (def.type === 'date') inner = '<input id="' + id + '" type="date" name="' + name + '"' + req + ' value="' + val + '" class="ds-input" />';
          else if (def.type === 'datetime') inner = '<input id="' + id + '" type="datetime-local" name="' + name + '"' + req + ' value="' + val + '" class="ds-input" />';
          else inner = '<input id="' + id + '" type="text" name="' + name + '"' + req + ph + ' value="' + val + '" class="ds-input" />';
          return '<div' + (full ? ' class="pf-full"' : '') + '>' + label + inner + '</div>';
        }).join('');
        dynSection.style.display = 'block';
      }

      form.addEventListener('submit', function(e) {
        e.preventDefault();
        errBanner.style.display = 'none';
        var code = subtypeEl.value;
        if (!code || !typeId) { showErr('Selecciona un motivo.'); return; }
        var subtypeId = subtypeMap[code];
        if (!subtypeId) { showErr('Subtipo no encontrado.'); return; }
        submitBtn.classList.add('loading'); submitBtn.disabled = true;
        var fd = new FormData(form);
        fd.set('typeId', String(typeId));
        fd.set('subtypeId', String(subtypeId));
        fetch('/api/portal/requests', { method: 'POST', body: fd })
          .then(function(r) { return r.json(); })
          .then(function(r) {
            if (r.success) {
              showOk('Solicitud creada exitosamente. N° ' + (r.data && r.data.documentNumber ? r.data.documentNumber : ''));
              form.reset(); dynSection.style.display = 'none'; dynFields.innerHTML = '';
            } else showErr(r.error || 'Error al crear la solicitud.');
            submitBtn.classList.remove('loading'); submitBtn.disabled = false;
          })
          .catch(function() { showErr('Error de conexión.'); submitBtn.classList.remove('loading'); submitBtn.disabled = false; });
      });
    })();
  </script>
</PortalLayout>

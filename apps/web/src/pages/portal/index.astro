---
import PortalLayout from '../../layouts/PortalLayout.astro'
import { getPortalIdentity } from '../../lib/portal-auth'

const identity = getPortalIdentity(Astro.cookies)
if (!identity) return Astro.redirect('/portal/login')

const firstName = identity.name?.split(' ')[0] ?? 'Colaborador'
---

<PortalLayout title="Inicio">
  <div style="max-width:900px; margin:0 auto; padding:32px 24px;">
    <h1 style="font-family:var(--f-display); font-weight:300; font-size:28px; letter-spacing:-0.02em; margin:0 0 6px;">
      Hola, {firstName}.
    </h1>
    <p style="color:var(--mute-2); font-size:14px; margin:0 0 32px;">
      Bienvenido al portal de colaboradores.
    </p>

    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(260px, 1fr)); gap:16px;">
      <a href="/portal/requests" class="pt-card" style="text-decoration:none; transition:border-color 140ms ease;" onmouseover="this.style.borderColor='var(--rule-hi)'" onmouseout="this.style.borderColor='var(--rule)'">
        <div style="display:flex; align-items:center; gap:12px; margin-bottom:12px;">
          <div style="width:36px; height:36px; border-radius:6px; background:var(--navy-soft); display:grid; place-items:center;">
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="var(--navy-hi)" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
              <path d="M13 2H3a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V3a1 1 0 0 0-1-1z"/>
              <path d="M5 6h6M5 9h4"/>
            </svg>
          </div>
          <h2 class="pt-card-title" style="margin:0;">Solicitudes</h2>
        </div>
        <p style="color:var(--mute-2); font-size:13px; margin:0; line-height:1.5;">
          Crea solicitudes de vacaciones, permisos y otros documentos.
        </p>
      </a>

      <a href="/portal/attendance" class="pt-card" style="text-decoration:none; transition:border-color 140ms ease;" onmouseover="this.style.borderColor='var(--rule-hi)'" onmouseout="this.style.borderColor='var(--rule)'">
        <div style="display:flex; align-items:center; gap:12px; margin-bottom:12px;">
          <div style="width:36px; height:36px; border-radius:6px; background:var(--navy-soft); display:grid; place-items:center;">
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="var(--navy-hi)" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="8" cy="8" r="6"/>
              <path d="M8 4.5V8l2.5 1.5"/>
            </svg>
          </div>
          <h2 class="pt-card-title" style="margin:0;">Mis marcaciones</h2>
        </div>
        <p style="color:var(--mute-2); font-size:13px; margin:0; line-height:1.5;">
          Consulta tu historial de entradas, salidas y asistencia.
        </p>
      </a>

      <a href="/portal/approvals" class="pt-card" style="text-decoration:none; transition:border-color 140ms ease;" onmouseover="this.style.borderColor='var(--rule-hi)'" onmouseout="this.style.borderColor='var(--rule)'">
        <div style="display:flex; align-items:center; gap:12px; margin-bottom:12px;">
          <div style="width:36px; height:36px; border-radius:6px; background:var(--navy-soft); display:grid; place-items:center;">
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="var(--navy-hi)" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2l-8.5 8.5L2 7"/>
            </svg>
          </div>
          <h2 class="pt-card-title" style="margin:0;">Aprobaciones</h2>
        </div>
        <p style="color:var(--mute-2); font-size:13px; margin:0; line-height:1.5;">
          Revisa y aprueba solicitudes de tu departamento.
        </p>
      </a>
    </div>
  </div>
</PortalLayout>

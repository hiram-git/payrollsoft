---
const token = Astro.url.searchParams.get('token') ?? ''
if (!token) return Astro.redirect('/portal/login')
---

<!doctype html>
<html lang="es" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nueva contraseña — Portal del Colaborador</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400&family=Inter+Tight:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <script is:inline>
    try { document.documentElement.dataset.theme = localStorage.getItem('payroll.theme') || 'dark'; } catch(e) {}
  </script>
  <style>
    :root, [data-theme="dark"] {
      --ink:#07101F; --ink-2:#0A1628; --ink-3:#101E33; --ink-4:#16263F;
      --navy:#003087; --navy-hi:#1E4BA8; --navy-lo:#00205A;
      --rule:#1A2740; --rule-hi:#243555; --mute:#6A7690; --mute-2:#8B97AE;
      --fore:#EDEEF2; --fore-dim:#C9CEDB; --err:#E06B5C; --ok:#6FB58C;
      --f-display:'Fraunces','Times New Roman',serif;
      --f-sans:'Inter Tight',-apple-system,system-ui,sans-serif;
      --f-mono:'JetBrains Mono',ui-monospace,monospace;
    }
    [data-theme="light"] {
      --ink:#F4F5F7; --ink-2:#FFFFFF; --ink-3:#FFFFFF; --ink-4:#EFF1F5;
      --rule:#E4E7EE; --rule-hi:#D2D7E0; --mute:#7A8499; --mute-2:#5B6478;
      --fore:#0C1424; --fore-dim:#2A3346; --err:#B53A2B; --ok:#2E7A56;
    }
    *,*::before,*::after{box-sizing:border-box;}
    html,body{height:100%;margin:0;}
    body{background:var(--ink);color:var(--fore);font-family:var(--f-sans);font-size:15px;line-height:1.5;-webkit-font-smoothing:antialiased;display:flex;align-items:center;justify-content:center;padding:24px;}
    .wrap{width:100%;max-width:420px;}
    .eyebrow{font-family:var(--f-mono);font-size:11px;color:var(--mute);letter-spacing:.14em;text-transform:uppercase;margin-bottom:14px;display:flex;align-items:center;gap:10px;}
    .eyebrow-dot{width:5px;height:5px;border-radius:50%;background:var(--navy);display:inline-block;}
    .title{font-family:var(--f-display);font-weight:300;font-size:32px;line-height:1.1;letter-spacing:-0.02em;margin:0 0 8px;color:var(--fore);}
    .sub{font-size:14px;color:var(--mute-2);margin:0 0 32px;}
    .field{margin-bottom:20px;}
    .label{font-family:var(--f-mono);font-size:11px;color:var(--mute-2);letter-spacing:.1em;text-transform:uppercase;margin-bottom:8px;display:block;}
    .input-wrap{border-bottom:1px solid var(--rule);transition:border-color 160ms ease;position:relative;}
    .input-wrap:focus-within{border-bottom-color:var(--fore);}
    .input{width:100%;background:transparent;border:none;outline:none;padding:12px 0;padding-right:36px;color:var(--fore);font-family:var(--f-sans);font-size:16px;caret-color:var(--fore);}
    .input::placeholder{color:var(--mute);}
    .banner{font-family:var(--f-mono);font-size:11.5px;padding:10px 12px;border-radius:3px;margin-bottom:22px;letter-spacing:.04em;display:none;align-items:center;gap:10px;}
    .banner.visible{display:flex;}
    .banner-err{color:var(--err);border:1px solid rgba(224,107,92,0.35);background:rgba(224,107,92,0.06);}
    .banner-ok{color:var(--ok);border:1px solid rgba(111,181,140,0.35);background:rgba(111,181,140,0.06);}
    .btn{width:100%;height:52px;background:var(--navy);color:#fff;border:none;border-radius:3px;font-family:var(--f-sans);font-weight:500;font-size:14.5px;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:10px;transition:background 160ms ease;margin-bottom:24px;}
    .btn:hover{background:var(--navy-hi);}
    .btn:disabled{opacity:.6;cursor:not-allowed;}
    .btn.loading .btn-text{display:none;}
    .btn.loading .spinner{display:block;}
    .spinner{width:16px;height:16px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .6s linear infinite;display:none;}
    @keyframes spin{to{transform:rotate(360deg);}}
    .link-row{text-align:center;}
    .link{font-family:var(--f-mono);font-size:11px;color:var(--fore-dim);letter-spacing:.08em;text-transform:uppercase;text-decoration:none;border-bottom:1px dashed var(--rule-hi);padding-bottom:1px;}
    .link:hover{color:var(--fore);border-bottom-color:var(--fore);}
    .eye-btn{position:absolute;right:0;top:50%;transform:translateY(-50%);background:transparent;border:none;cursor:pointer;color:var(--mute);padding:6px;display:grid;place-items:center;transition:color 140ms ease;}
    .eye-btn:hover{color:var(--fore-dim);}
    .hint{font-size:11px;color:var(--mute);margin-top:6px;font-family:var(--f-mono);letter-spacing:.04em;}
  </style>
</head>
<body>
  <div class="wrap">
    <div class="eyebrow"><span class="eyebrow-dot"></span> Portal del Colaborador</div>
    <h1 class="title">Nueva contraseña</h1>
    <p class="sub">Ingresa tu nueva contraseña y el código de empresa.</p>

    <div class="banner banner-err" id="err-banner">
      <svg width="11" height="11" viewBox="0 0 11 11" fill="none" stroke="currentColor" stroke-width="1.3"><circle cx="5.5" cy="5.5" r="4.5"/><path d="M5.5 3v3M5.5 7.8v.2"/></svg>
      <span id="err-text"></span>
    </div>
    <div class="banner banner-ok" id="ok-banner">
      <svg width="11" height="11" viewBox="0 0 11 11" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 5.8 4.5 8.2 9 3.4"/></svg>
      <span id="ok-text"></span>
    </div>

    <form id="rp-form" novalidate>
      <div class="field">
        <span class="label">Nueva contraseña</span>
        <div class="input-wrap">
          <input id="password" type="password" placeholder="••••••••" autocomplete="new-password" class="input" />
          <button type="button" class="eye-btn" id="eye-btn" aria-label="Mostrar contraseña">
            <svg id="eye-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3">
              <path d="M1.5 8C3 4.5 5.4 3 8 3s5 1.5 6.5 5c-1.5 3.5-3.9 5-6.5 5S3 11.5 1.5 8Z"/><circle cx="8" cy="8" r="2"/>
            </svg>
          </button>
        </div>
        <div class="hint">Mínimo 6 caracteres</div>
      </div>
      <div class="field" style="margin-bottom:28px;">
        <span class="label">Confirmar contraseña</span>
        <div class="input-wrap"><input id="password2" type="password" placeholder="••••••••" autocomplete="new-password" class="input" /></div>
      </div>
      <button type="submit" class="btn" id="submit-btn">
        <span class="btn-text">Guardar nueva contraseña</span>
        <span class="spinner"></span>
      </button>
      <p class="link-row">
        <a href="/portal/login" class="link">Volver al inicio de sesión</a>
      </p>
    </form>
  </div>

  <script is:inline define:vars={{ resetToken: token }}>
    (function() {
      var form = document.getElementById('rp-form');
      var errBanner = document.getElementById('err-banner');
      var errText = document.getElementById('err-text');
      var okBanner = document.getElementById('ok-banner');
      var okText = document.getElementById('ok-text');
      var submitBtn = document.getElementById('submit-btn');

      var pwInput = document.getElementById('password');
      var eyeBtn = document.getElementById('eye-btn');
      var eyeIcon = document.getElementById('eye-icon');
      var eyeOn = '<path d="M1.5 8C3 4.5 5.4 3 8 3s5 1.5 6.5 5c-1.5 3.5-3.9 5-6.5 5S3 11.5 1.5 8Z"/><circle cx="8" cy="8" r="2"/>';
      var eyeOff = '<path d="M2 8C3.5 5 5.6 3.5 8 3.5M14 8c-.5 1.1-1.1 2-1.8 2.7M9.5 12.3c-.5.1-1 .2-1.5.2-2.4 0-4.5-1.5-6-4.5"/><path d="M2 2l12 12"/>';
      var shown = false;
      eyeBtn.addEventListener('click', function() {
        shown = !shown;
        pwInput.type = shown ? 'text' : 'password';
        eyeIcon.innerHTML = shown ? eyeOff : eyeOn;
      });

      form.addEventListener('submit', function(e) {
        e.preventDefault();
        errBanner.classList.remove('visible');
        okBanner.classList.remove('visible');

        var password = document.getElementById('password').value;
        var password2 = document.getElementById('password2').value;

        if (!password || !password2) {
          errText.textContent = 'Completa todos los campos.';
          errBanner.classList.add('visible');
          return;
        }
        if (password.length < 6) {
          errText.textContent = 'La contraseña debe tener al menos 6 caracteres.';
          errBanner.classList.add('visible');
          return;
        }
        if (password !== password2) {
          errText.textContent = 'Las contraseñas no coinciden.';
          errBanner.classList.add('visible');
          return;
        }

        submitBtn.classList.add('loading');
        submitBtn.disabled = true;

        fetch('/api/portal/reset-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token: resetToken, password: password }),
        })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          submitBtn.classList.remove('loading');
          submitBtn.disabled = false;
          if (d.success) {
            okText.textContent = d.message || 'Contraseña actualizada.';
            okBanner.classList.add('visible');
            form.style.display = 'none';
            setTimeout(function() { window.location.href = '/portal/login'; }, 3000);
          } else {
            errText.textContent = d.error || 'Error al cambiar la contraseña.';
            errBanner.classList.add('visible');
          }
        })
        .catch(function() {
          submitBtn.classList.remove('loading');
          submitBtn.disabled = false;
          errText.textContent = 'Error de conexión. Intenta de nuevo.';
          errBanner.classList.add('visible');
        });
      });
    })();
  </script>
</body>
</html>

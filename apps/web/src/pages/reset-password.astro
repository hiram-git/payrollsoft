---
import AuthLayout from '../layouts/AuthLayout.astro'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'

const token = Astro.url.searchParams.get('token') ?? ''
const tenant = (Astro.url.searchParams.get('tenant') ?? '').toLowerCase()
const errorKey = Astro.url.searchParams.get('error') ?? ''

// Server-side pre-flight: if the link is busted (missing pieces, expired,
// already used) we render a dedicated error state instead of a usable form.
type TokenState =
  | { kind: 'ok' }
  | { kind: 'invalid-link' }
  | { kind: 'expired' | 'used' | 'invalid' | 'user_missing' }
  | { kind: 'server-error' }

let tokenState: TokenState
if (!token || !tenant) {
  tokenState = { kind: 'invalid-link' }
} else {
  try {
    const res = await fetch(`${API_URL}/auth/reset-password/${encodeURIComponent(token)}`, {
      headers: { 'X-Tenant': tenant },
    })
    if (res.ok) {
      tokenState = { kind: 'ok' }
    } else {
      const body = (await res.json().catch(() => null)) as { error?: string } | null
      const apiError = body?.error
      if (
        apiError === 'expired' ||
        apiError === 'used' ||
        apiError === 'invalid' ||
        apiError === 'user_missing'
      ) {
        tokenState = { kind: apiError }
      } else {
        tokenState = { kind: 'server-error' }
      }
    }
  } catch {
    tokenState = { kind: 'server-error' }
  }
}

// Form-level errors that come back via redirect (mismatch, too-short, etc.)
const formErrorMessages: Record<string, string> = {
  'missing-fields': 'Completa todos los campos.',
  mismatch: 'Las contraseñas no coinciden.',
  'too-short': 'La contraseña debe tener al menos 8 caracteres.',
  'server-error': 'Error de servidor. Intenta de nuevo.',
}

const tokenErrorMessages: Record<string, string> = {
  'invalid-link': 'El enlace de recuperación no es válido. Solicita uno nuevo.',
  expired: 'Este enlace expiró. Solicita uno nuevo para continuar.',
  used: 'Este enlace ya fue utilizado. Solicita uno nuevo si quieres cambiar tu contraseña otra vez.',
  invalid: 'Este enlace no es válido. Solicita uno nuevo.',
  user_missing: 'La cuenta asociada al enlace ya no está activa.',
  'server-error': 'No se pudo verificar el enlace. Intenta de nuevo en unos minutos.',
}

// Form-level errors override only when the token itself is still valid.
const blockingError =
  tokenState.kind !== 'ok' ? (tokenErrorMessages[tokenState.kind] ?? null) : null
const formError =
  tokenState.kind === 'ok' && errorKey ? (formErrorMessages[errorKey] ?? null) : null
---
<AuthLayout title="Restablecer contraseña">
  <form class="form-wrap" method="POST" action="/api/auth/reset-password" novalidate>
    <div class="eyebrow">
      <span class="eyebrow-dot"></span>
      Portal de empresa · Restablecer contraseña
    </div>
    <h1 class="form-h1">Crea tu nueva contraseña.</h1>
    <p class="form-sub">
      Elige una contraseña con al menos 8 caracteres. Después podrás iniciar sesión normalmente.
    </p>

    {blockingError ? (
      <>
        <div class="err-banner">
          <svg width="11" height="11" viewBox="0 0 11 11" fill="none" stroke="currentColor" stroke-width="1.3">
            <circle cx="5.5" cy="5.5" r="4.5"/>
            <path d="M5.5 3v3M5.5 7.8v.2"/>
          </svg>
          {blockingError}
        </div>
        <a href="/forgot-password" class="submit-btn" style="text-decoration:none">
          Solicitar nuevo enlace
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="square">
            <path d="M2 7h10M8.5 3.5L12 7l-3.5 3.5"/>
          </svg>
        </a>
        <p class="auth-aside">
          <a href="/login" class="auth-link">← Volver a iniciar sesión</a>
        </p>
      </>
    ) : (
      <>
        {formError && (
          <div class="err-banner">
            <svg width="11" height="11" viewBox="0 0 11 11" fill="none" stroke="currentColor" stroke-width="1.3">
              <circle cx="5.5" cy="5.5" r="4.5"/>
              <path d="M5.5 3v3M5.5 7.8v.2"/>
            </svg>
            {formError}
          </div>
        )}

        <input type="hidden" name="token" value={token} />
        <input type="hidden" name="tenant" value={tenant} />

        <div class="field">
          <div class="label-row"><span class="field-label">Nueva contraseña</span></div>
          <div class="input-wrap">
            <input
              id="password"
              name="password"
              type="password"
              required
              minlength="8"
              autocomplete="new-password"
              placeholder="••••••••"
              class="field-input"
            />
            <button type="button" class="eye-btn" id="eye-btn-1" aria-label="Mostrar contraseña" data-target="password">
              <svg id="eye-icon-1" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3">
                <path d="M1.5 8C3 4.5 5.4 3 8 3s5 1.5 6.5 5c-1.5 3.5-3.9 5-6.5 5S3 11.5 1.5 8Z"/>
                <circle cx="8" cy="8" r="2"/>
              </svg>
            </button>
          </div>
          <p class="field-help">Mínimo 8 caracteres. Combina letras, números y símbolos.</p>
        </div>

        <div class="field" style="margin-bottom:28px">
          <div class="label-row"><span class="field-label">Confirmar contraseña</span></div>
          <div class="input-wrap">
            <input
              id="confirm"
              name="confirm"
              type="password"
              required
              minlength="8"
              autocomplete="new-password"
              placeholder="••••••••"
              class="field-input"
            />
            <button type="button" class="eye-btn" id="eye-btn-2" aria-label="Mostrar contraseña" data-target="confirm">
              <svg id="eye-icon-2" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3">
                <path d="M1.5 8C3 4.5 5.4 3 8 3s5 1.5 6.5 5c-1.5 3.5-3.9 5-6.5 5S3 11.5 1.5 8Z"/>
                <circle cx="8" cy="8" r="2"/>
              </svg>
            </button>
          </div>
        </div>

        <button type="submit" class="submit-btn">
          Cambiar contraseña
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="square">
            <path d="M2 7h10M8.5 3.5L12 7l-3.5 3.5"/>
          </svg>
        </button>

        <p class="auth-aside">
          <a href="/login" class="auth-link">← Volver a iniciar sesión</a>
        </p>
      </>
    )}
  </form>
</AuthLayout>

<script is:inline>
  (function () {
    const eyeOn  = '<path d="M1.5 8C3 4.5 5.4 3 8 3s5 1.5 6.5 5c-1.5 3.5-3.9 5-6.5 5S3 11.5 1.5 8Z"/><circle cx="8" cy="8" r="2"/>';
    const eyeOff = '<path d="M2 8C3.5 5 5.6 3.5 8 3.5M14 8c-.5 1.1-1.1 2-1.8 2.7M9.5 12.3c-.5.1-1 .2-1.5.2-2.4 0-4.5-1.5-6-4.5"/><path d="M2 2l12 12"/>';

    function wireEyeToggle(btnId, iconId) {
      const btn = document.getElementById(btnId);
      const icon = document.getElementById(iconId);
      if (!btn || !icon) return;
      const targetId = btn.getAttribute('data-target');
      const input = targetId ? document.getElementById(targetId) : null;
      if (!input) return;
      let shown = false;
      btn.addEventListener('click', () => {
        shown = !shown;
        input.type = shown ? 'text' : 'password';
        icon.innerHTML = shown ? eyeOff : eyeOn;
        btn.setAttribute('aria-label', shown ? 'Ocultar contraseña' : 'Mostrar contraseña');
      });
    }

    wireEyeToggle('eye-btn-1', 'eye-icon-1');
    wireEyeToggle('eye-btn-2', 'eye-icon-2');
  })();
</script>

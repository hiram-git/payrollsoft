---
import AppLayout from '../../layouts/AppLayout.astro'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')

const headers = { Cookie: `auth=${authCookie}`, 'X-Tenant': 'demo' }

type Employee = {
  id: string
  code: string
  firstName: string
  lastName: string
  isActive: boolean
}

let employees: Employee[] = []

try {
  const res = await fetch(`${API_URL}/employees?limit=100`, { headers })
  if (res.status === 401) return Astro.redirect('/login')
  if (res.ok) {
    const json = (await res.json()) as { data: Employee[] }
    employees = (json.data ?? []).filter((e) => e.isActive)
  }
} catch {
  // proceed with empty list
}

const preselectedEmployeeId = Astro.url.searchParams.get('employeeId') ?? ''

const error = Astro.url.searchParams.get('error') ?? ''
const errorMessages: Record<string, string> = {
  'missing-fields': 'Completa todos los campos requeridos y genera la tabla de cuotas.',
  'employee-not-found': 'El empleado seleccionado no existe.',
  'server-error': 'Error del servidor. Intenta de nuevo.',
}

const loanTypes = [
  { value: 'PERSONAL', label: 'Préstamo Personal' },
  { value: 'VEHICULAR', label: 'Préstamo Vehicular' },
  { value: 'HIPOTECARIO', label: 'Crédito Hipotecario' },
  { value: 'EMBARGO', label: 'Embargo de Sueldo' },
  { value: 'JUDICIAL', label: 'Retención Judicial' },
  { value: 'PENSION', label: 'Pensión Alimenticia' },
  { value: 'SEGURO', label: 'Seguro/Prima' },
  { value: 'COOPERATIVA', label: 'Cooperativa' },
  { value: 'OTRO', label: 'Otro' },
]
---

<AppLayout title="Nuevo Préstamo">
  <div class="p-8 max-w-5xl">
    <div class="flex items-center gap-3 mb-6">
      <a href="/loans" class="text-sm text-gray-500 hover:text-gray-700">← Préstamos</a>
      <span class="text-gray-300">/</span>
      <h1 class="text-2xl font-bold text-gray-900">Nuevo Préstamo</h1>
    </div>

    {error && (
      <div class="mb-6 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
        {errorMessages[error] ?? 'Ocurrió un error inesperado.'}
      </div>
    )}

    <form method="POST" action="/api/loans" id="loanForm">
      <!-- Hidden computed fields (filled by the calculator before submit) -->
      <input type="hidden" name="installment" id="hiddenInstallment" />
      <input type="hidden" name="endDate" id="hiddenEndDate" />

      <!-- Section 1: Loan info -->
      <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4 space-y-4">
        <h2 class="font-semibold text-gray-800">Información del Préstamo</h2>

        <div class="grid grid-cols-2 gap-4">
          <!-- Employee -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Empleado *</label>
            <select name="employeeId" id="employeeId" class="input" required>
              <option value="">Seleccione empleado...</option>
              {employees.map((emp) => (
                <option value={emp.id} selected={emp.id === preselectedEmployeeId}>
                  {emp.code} — {emp.firstName} {emp.lastName}
                </option>
              ))}
            </select>
          </div>

          <!-- Creditor -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Acreedor</label>
            <input type="text" name="creditor" class="input" placeholder="Nombre del banco o institución" maxlength="255" />
          </div>

          <!-- Loan type -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Tipo de Préstamo *</label>
            <select name="loanType" class="input" required>
              <option value="">Seleccione tipo...</option>
              {loanTypes.map((t) => (
                <option value={t.value}>{t.label}</option>
              ))}
            </select>
          </div>

          <!-- Frequency -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Frecuencia de Descuento *</label>
            <select name="frequency" id="frequency" class="input" required>
              <option value="semanal">Semanal (cada 7 días)</option>
              <option value="quincenal">Quincenal (cada 15 días)</option>
              <option value="mensual" selected>Mensual (cada mes)</option>
            </select>
          </div>
        </div>
      </div>

      <!-- Section 2: Calculation inputs -->
      <div class="bg-white rounded-xl border border-gray-200 p-6 mb-4 space-y-4">
        <h2 class="font-semibold text-gray-800">Cálculo del Préstamo</h2>

        <div class="grid grid-cols-3 gap-4">
          <!-- Total amount -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Monto Total (USD) *</label>
            <input type="number" step="0.01" min="0.01" name="totalAmount" id="totalAmount"
              class="input" placeholder="0.00" required />
            <p class="text-xs text-gray-400 mt-1">Monto total a financiar</p>
          </div>

          <!-- Installments count -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Cantidad de Cuotas *</label>
            <input type="number" min="1" name="installmentsCount" id="installmentsCount"
              class="input" placeholder="12" required />
            <p class="text-xs text-gray-400 mt-1">Número de pagos</p>
          </div>

          <!-- Start date -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Primer Descuento *</label>
            <input type="date" name="startDate" id="startDate" class="input" required />
            <p class="text-xs text-gray-400 mt-1">Fecha de la 1ra cuota</p>
          </div>
        </div>

        <!-- Allow December toggle -->
        <div class="flex items-center gap-3 pt-1">
          <input type="checkbox" name="allowDecember" id="allowDecember"
            class="w-4 h-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500"
            checked />
          <label for="allowDecember" class="text-sm text-gray-700">
            Descontar en diciembre
            <span class="text-gray-400 font-normal">(si está desactivado, las cuotas de diciembre pasan a enero)</span>
          </label>
        </div>

        <!-- Generate button -->
        <div class="flex items-center justify-between pt-2 border-t border-gray-100">
          <span class="text-xs text-gray-400">Complete los campos y genere la tabla antes de guardar</span>
          <button type="button" id="btnGenerate"
            class="inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold text-white bg-gray-700 hover:bg-gray-800 rounded-lg transition-colors">
            Generar tabla de cuotas
          </button>
        </div>
      </div>

      <!-- Error from calculator -->
      <div id="calcError" class="mb-4 rounded-lg bg-amber-50 border border-amber-200 px-4 py-3 text-sm text-amber-700 hidden"></div>

      <!-- Section 3: Installments table (hidden until generated) -->
      <div id="tableSection" class="hidden">
        <div class="bg-white rounded-xl border border-gray-200 overflow-hidden mb-4">
          <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
            <h2 class="font-semibold text-gray-800">Tabla de Cuotas</h2>
            <span class="text-xs text-gray-400" id="tableSubtitle"></span>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="bg-gray-50 border-b border-gray-200">
                <tr>
                  <th class="text-center px-4 py-3 font-medium text-gray-600">#</th>
                  <th class="text-center px-4 py-3 font-medium text-gray-600">Fecha</th>
                  <th class="text-right px-4 py-3 font-medium text-gray-600">Cuota</th>
                  <th class="text-right px-4 py-3 font-medium text-gray-600">Saldo Inicial</th>
                  <th class="text-right px-4 py-3 font-medium text-gray-600">Amortización</th>
                  <th class="text-right px-4 py-3 font-medium text-gray-600">Saldo Final</th>
                </tr>
              </thead>
              <tbody id="tableBody" class="divide-y divide-gray-100"></tbody>
            </table>
          </div>
          <!-- Summary -->
          <div class="px-6 py-4 bg-gray-50 border-t border-gray-100">
            <div class="grid grid-cols-3 gap-4 text-center">
              <div>
                <p class="text-xs text-gray-500 mb-1">Cuota fija</p>
                <p class="text-lg font-bold text-emerald-600" id="summaryInstallment"></p>
              </div>
              <div>
                <p class="text-xs text-gray-500 mb-1">Total amortizado</p>
                <p class="text-lg font-bold text-blue-600" id="summaryTotal"></p>
              </div>
              <div>
                <p class="text-xs text-gray-500 mb-1">Último descuento</p>
                <p class="text-lg font-bold text-gray-700" id="summaryLastDate"></p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Actions -->
      <div class="flex justify-between mt-2">
        <a href="/loans" class="px-4 py-2 text-sm text-gray-600 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
          Cancelar
        </a>
        <button type="submit" id="btnSubmit" disabled
          class="px-4 py-2 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
          Guardar Préstamo
        </button>
      </div>
    </form>
  </div>
</AppLayout>

<style>
  .input {
    @apply w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent;
  }
</style>

<script is:inline>
;(function () {
  const btnGenerate = document.getElementById('btnGenerate')
  const btnSubmit = document.getElementById('btnSubmit')
  const calcError = document.getElementById('calcError')
  const tableSection = document.getElementById('tableSection')
  const tableBody = document.getElementById('tableBody')
  const tableSubtitle = document.getElementById('tableSubtitle')
  const summaryInstallment = document.getElementById('summaryInstallment')
  const summaryTotal = document.getElementById('summaryTotal')
  const summaryLastDate = document.getElementById('summaryLastDate')
  const hiddenInstallment = document.getElementById('hiddenInstallment')
  const hiddenEndDate = document.getElementById('hiddenEndDate')

  const form = document.getElementById('loanForm')
  const totalAmountInput = form.querySelector('[name="totalAmount"]')
  const installmentsInput = form.querySelector('[name="installmentsCount"]')
  const frequencySelect = form.querySelector('[name="frequency"]')
  const startDateInput = form.querySelector('[name="startDate"]')
  const allowDecemberInput = form.querySelector('[name="allowDecember"]')

  function formatMoney(cents) {
    return '$' + (cents / 100).toFixed(2)
  }

  function formatDateDisplay(d) {
    const day = String(d.getDate()).padStart(2, '0')
    const month = String(d.getMonth() + 1).padStart(2, '0')
    return day + '/' + month + '/' + d.getFullYear()
  }

  function toInputDate(d) {
    const y = d.getFullYear()
    const m = String(d.getMonth() + 1).padStart(2, '0')
    const day = String(d.getDate()).padStart(2, '0')
    return y + '-' + m + '-' + day
  }

  function parseDate(value) {
    if (!value) return null
    const p = new Date(value + 'T00:00:00')
    return Number.isNaN(p.getTime()) ? null : p
  }

  function addFrequency(date, frequency) {
    const next = new Date(date.getTime())
    if (frequency === 'semanal') { next.setDate(next.getDate() + 7); return next }
    if (frequency === 'quincenal') { next.setDate(next.getDate() + 15); return next }
    // mensual — preserve day-of-month, clamp to month end
    const day = next.getDate()
    next.setMonth(next.getMonth() + 1)
    if (next.getDate() !== day) next.setDate(0)
    return next
  }

  function showError(msg) {
    calcError.textContent = msg
    calcError.classList.remove('hidden')
  }

  function clearError() {
    calcError.textContent = ''
    calcError.classList.add('hidden')
  }

  btnGenerate.addEventListener('click', function () {
    clearError()

    const totalAmount = parseFloat(totalAmountInput.value)
    const count = parseInt(installmentsInput.value, 10)
    const frequency = frequencySelect.value
    const startDate = parseDate(startDateInput.value)
    const allowDecember = allowDecemberInput ? allowDecemberInput.checked : true

    if (!totalAmount || totalAmount <= 0 || !count || count <= 0 || !startDate) {
      showError('Completa el monto total, cantidad de cuotas y fecha del primer descuento.')
      return
    }

    const totalCents = Math.round(totalAmount * 100)
    const baseCents = Math.round(totalCents / count)
    let remaining = totalCents
    let current = new Date(startDate.getTime())
    let lastDueDate = null

    tableBody.innerHTML = ''

    for (let i = 1; i <= count; i++) {
      const dueDate = new Date(current.getTime())

      // Skip December if not allowed — move to Jan 1 of next year
      if (!allowDecember && dueDate.getMonth() === 11) {
        dueDate.setFullYear(dueDate.getFullYear() + 1)
        dueDate.setMonth(0)
        dueDate.setDate(1)
      }

      const amountCents = i < count ? baseCents : remaining
      const initialCents = remaining
      remaining -= amountCents
      const finalCents = remaining

      const tr = document.createElement('tr')
      tr.className = 'hover:bg-gray-50'
      tr.innerHTML =
        '<td class="text-center px-4 py-2.5 text-gray-600">' + i + '</td>' +
        '<td class="text-center px-4 py-2.5 text-gray-700">' + formatDateDisplay(dueDate) + '</td>' +
        '<td class="text-right px-4 py-2.5 font-semibold text-emerald-600">' + formatMoney(amountCents) + '</td>' +
        '<td class="text-right px-4 py-2.5 text-gray-600">' + formatMoney(initialCents) + '</td>' +
        '<td class="text-right px-4 py-2.5 text-blue-600">' + formatMoney(amountCents) + '</td>' +
        '<td class="text-right px-4 py-2.5 font-semibold text-gray-800">' + formatMoney(finalCents) + '</td>'
      tableBody.appendChild(tr)

      lastDueDate = dueDate
      current = addFrequency(current, frequency)
    }

    // Fill hidden fields for form submission
    hiddenInstallment.value = (baseCents / 100).toFixed(2)
    hiddenEndDate.value = lastDueDate ? toInputDate(lastDueDate) : ''

    // Update summary
    summaryInstallment.textContent = formatMoney(baseCents)
    summaryTotal.textContent = formatMoney(totalCents)
    summaryLastDate.textContent = lastDueDate ? formatDateDisplay(lastDueDate) : ''
    tableSubtitle.textContent = count + ' cuota' + (count !== 1 ? 's' : '') + ' · ' + (frequencySelect.options[frequencySelect.selectedIndex]?.text ?? '')

    tableSection.classList.remove('hidden')
    btnSubmit.disabled = false
    tableSection.scrollIntoView({ behavior: 'smooth', block: 'nearest' })
  })

  // Re-lock submit if any key input changes after table was generated
  ;[totalAmountInput, installmentsInput, frequencySelect, startDateInput, allowDecemberInput].forEach(function (el) {
    el.addEventListener('change', function () {
      btnSubmit.disabled = true
      tableSection.classList.add('hidden')
      hiddenInstallment.value = ''
      hiddenEndDate.value = ''
    })
  })
})()
</script>

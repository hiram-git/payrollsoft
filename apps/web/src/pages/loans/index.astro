---
import AppLayout from '../../layouts/AppLayout.astro'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')

const headers = { Cookie: `auth=${authCookie}`, 'X-Tenant': 'demo' }

type LoanRow = {
  id: string
  employeeId: string
  amount: string
  balance: string
  installment: string
  startDate: string
  endDate: string | null
  isActive: boolean
  loanType: string | null
  frequency: string | null
  creditor: string | null
  allowDecember: boolean
  createdAt: string
  employeeCode: string
  employeeFirstName: string
  employeeLastName: string
}

let loans: LoanRow[] = []

try {
  const res = await fetch(`${API_URL}/loans`, { headers })
  if (res.status === 401) return Astro.redirect('/login')
  if (res.ok) loans = ((await res.json()) as { data: LoanRow[] }).data ?? []
} catch {
  // show empty list on error
}

const success = Astro.url.searchParams.get('success') === '1'

const freqLabel: Record<string, string> = {
  semanal: 'Semanal',
  quincenal: 'Quincenal',
  mensual: 'Mensual',
}

const loanTypeLabel: Record<string, string> = {
  PERSONAL: 'Personal',
  VEHICULAR: 'Vehicular',
  HIPOTECARIO: 'Hipotecario',
  EMBARGO: 'Embargo',
  JUDICIAL: 'Judicial',
  PENSION: 'Pensión',
  SEGURO: 'Seguro/Prima',
  COOPERATIVA: 'Cooperativa',
  OTRO: 'Otro',
}
---

<AppLayout title="Préstamos">
  <div class="p-8">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Préstamos</h1>
        <p class="text-sm text-gray-500 mt-0.5">{loans.length} registro{loans.length !== 1 ? 's' : ''}</p>
      </div>
      <a href="/loans/new" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors">
        + Nuevo préstamo
      </a>
    </div>

    {success && (
      <div class="mb-6 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">
        Préstamo registrado correctamente.
      </div>
    )}

    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
      {loans.length === 0 ? (
        <div class="p-16 text-center text-gray-400 text-sm">
          No hay préstamos registrados.
        </div>
      ) : (
        <table class="w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Empleado</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Tipo</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Acreedor</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Monto</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Saldo</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Cuota</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Frecuencia</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Inicio</th>
              <th class="text-left px-4 py-3 font-medium text-gray-600">Estado</th>
              <th class="px-4 py-3"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {loans.map((loan) => (
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-4 py-3">
                  <a href={`/employees/${loan.employeeId}?tab=prestamos`} class="font-medium text-gray-900 hover:text-blue-600">
                    {loan.employeeFirstName} {loan.employeeLastName}
                  </a>
                  <div class="text-xs text-gray-400">{loan.employeeCode}</div>
                </td>
                <td class="px-4 py-3 text-gray-600">
                  {loan.loanType ? (loanTypeLabel[loan.loanType] ?? loan.loanType) : '—'}
                </td>
                <td class="px-4 py-3 text-gray-600">{loan.creditor ?? '—'}</td>
                <td class="px-4 py-3 text-gray-900">${loan.amount}</td>
                <td class="px-4 py-3 text-gray-700">${loan.balance}</td>
                <td class="px-4 py-3 text-gray-700">${loan.installment}</td>
                <td class="px-4 py-3 text-gray-600">
                  {loan.frequency ? (freqLabel[loan.frequency] ?? loan.frequency) : '—'}
                </td>
                <td class="px-4 py-3 text-gray-600">{loan.startDate}</td>
                <td class="px-4 py-3">
                  <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${loan.isActive ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500'}`}>
                    {loan.isActive ? 'Activo' : 'Cerrado'}
                  </span>
                </td>
                <td class="px-4 py-3">
                  <div class="flex items-center justify-end gap-1">
                    <a href={`/employees/${loan.employeeId}/loans/${loan.id}`} title="Editar" class="p-1.5 rounded-lg text-gray-400 hover:text-blue-600 hover:bg-blue-50 transition-colors">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                      </svg>
                    </a>
                    {loan.isActive && (
                      <form method="POST" action={`/api/employees/${loan.employeeId}/loans/${loan.id}`}
                        onsubmit="return confirm('¿Cerrar este préstamo?')"
                      >
                        <input type="hidden" name="_method" value="DELETE" />
                        <button type="submit" title="Cerrar préstamo" class="p-1.5 rounded-lg text-gray-400 hover:text-red-600 hover:bg-red-50 transition-colors">
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
                          </svg>
                        </button>
                      </form>
                    )}
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
  </div>
</AppLayout>

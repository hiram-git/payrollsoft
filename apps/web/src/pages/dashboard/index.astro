---
import AppLayout from '../../layouts/AppLayout.astro'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')

const TENANT = 'demo'
const headers = { Cookie: `auth=${authCookie}`, 'X-Tenant': TENANT }

type RecentPayroll = {
  id: string
  name: string
  type: string
  status: string
  totalNet: string
  periodStart: string
  periodEnd: string
}

type Stats = {
  activeEmployees: number
  activeConcepts: number
  activeLoans: number
  payrollsThisMonth: number
  netThisMonth: number
  recentPayrolls: RecentPayroll[]
}

let stats: Stats = {
  activeEmployees: 0,
  activeConcepts: 0,
  activeLoans: 0,
  payrollsThisMonth: 0,
  netThisMonth: 0,
  recentPayrolls: [],
}

try {
  const res = await fetch(`${API_URL}/dashboard/stats`, { headers })
  if (res.status === 401) return Astro.redirect('/login')
  if (res.ok) {
    const json = (await res.json()) as { data: Stats }
    stats = json.data
  }
} catch {
  // mostrar stats en cero si falla
}

const now = new Date()
const monthName = now.toLocaleString('es-PA', { month: 'long', year: 'numeric' })

function fmt(v: number) {
  return v.toLocaleString('es-PA', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
}

const statusLabel: Record<string, string> = {
  created: 'Creada',
  processing: 'Procesando',
  generated: 'Generada',
  closed: 'Cerrada',
  draft: 'Borrador',
  processed: 'Procesada',
  paid: 'Pagada',
}
const statusColor: Record<string, string> = {
  created: 'var(--mute-2)',
  processing: 'var(--warn)',
  generated: 'var(--navy-hi)',
  closed: 'var(--ok)',
}
const statusBg: Record<string, string> = {
  created: 'rgba(106,118,144,0.12)',
  processing: 'rgba(227,178,90,0.12)',
  generated: 'rgba(30,75,168,0.12)',
  closed: 'rgba(111,181,140,0.12)',
}
const typeLabel: Record<string, string> = {
  regular: 'Regular',
  thirteenth: 'XIII Mes',
  special: 'Especial',
}
---

<AppLayout title="Dashboard">
  <style>
    .dash { padding: 32px 28px; max-width: 1100px; }
    .dash-header { margin-bottom: 28px; }
    .dash-title {
      font-size: 18px;
      font-weight: 500;
      color: var(--fore);
      letter-spacing: -0.02em;
    }
    .dash-sub {
      font-family: var(--f-mono);
      font-size: 11px;
      color: var(--mute);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-top: 4px;
    }

    /* KPI cards */
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      margin-bottom: 24px;
    }
    @media (max-width: 900px) { .kpi-grid { grid-template-columns: repeat(2, 1fr); } }
    .kpi-card {
      background: var(--ink-3);
      border: 1px solid var(--rule);
      border-radius: 6px;
      padding: 18px 20px;
      box-shadow: var(--shadow);
    }
    .kpi-label {
      font-family: var(--f-mono);
      font-size: 10px;
      color: var(--mute);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 10px;
    }
    .kpi-value {
      font-size: 26px;
      font-weight: 600;
      color: var(--fore);
      letter-spacing: -0.02em;
      font-variant-numeric: tabular-nums;
      line-height: 1;
      margin-bottom: 6px;
    }
    .kpi-link {
      font-size: 12px;
      color: var(--mute);
      text-decoration: none;
      transition: color 140ms ease;
    }
    .kpi-link:hover { color: var(--fore-dim); }
    .kpi-value-green { color: var(--pos); }

    /* Recent payrolls table */
    .table-card {
      background: var(--ink-3);
      border: 1px solid var(--rule);
      border-radius: 6px;
      overflow: hidden;
      box-shadow: var(--shadow);
      margin-bottom: 20px;
    }
    .table-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 20px;
      border-bottom: 1px solid var(--rule);
    }
    .table-title {
      font-size: 13.5px;
      font-weight: 500;
      color: var(--fore);
    }
    .table-see-all {
      font-size: 12px;
      color: var(--mute);
      text-decoration: none;
      transition: color 140ms ease;
    }
    .table-see-all:hover { color: var(--fore-dim); }
    .data-table {
      width: 100%;
      border-collapse: collapse;
    }
    .data-table th {
      text-align: left;
      padding: 10px 20px;
      font-family: var(--f-mono);
      font-size: 10px;
      color: var(--mute);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      border-bottom: 1px solid var(--rule);
      font-weight: 400;
    }
    .data-table th:last-child { text-align: right; }
    .data-table td {
      padding: 12px 20px;
      border-bottom: 1px solid var(--rule);
      vertical-align: middle;
    }
    .data-table tr:last-child td { border-bottom: none; }
    .data-table tr:hover td { background: var(--ink-4); }
    .row-name {
      font-size: 13.5px;
      font-weight: 500;
      color: var(--fore);
      text-decoration: none;
      transition: color 140ms ease;
    }
    .row-name:hover { color: var(--navy-hi); }
    .row-type {
      font-size: 11.5px;
      color: var(--mute);
      margin-top: 2px;
    }
    .row-period {
      font-family: var(--f-mono);
      font-size: 11.5px;
      color: var(--mute-2);
    }
    .status-pill {
      display: inline-flex;
      align-items: center;
      padding: 3px 9px;
      border-radius: 99px;
      font-family: var(--f-mono);
      font-size: 10.5px;
      letter-spacing: 0.06em;
      font-weight: 500;
    }
    .row-net {
      text-align: right;
      font-size: 13.5px;
      font-weight: 600;
      color: var(--fore);
      font-variant-numeric: tabular-nums;
    }
    .empty-state {
      padding: 48px 20px;
      text-align: center;
    }
    .empty-text {
      font-size: 13.5px;
      color: var(--mute);
      margin-bottom: 16px;
    }
    .empty-action {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 16px;
      background: var(--navy);
      color: #fff;
      border-radius: 4px;
      font-size: 13px;
      text-decoration: none;
      transition: background 140ms ease;
    }
    .empty-action:hover { background: var(--navy-hi); }

    /* Quick links */
    .quick-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 10px;
    }
    @media (max-width: 900px) { .quick-grid { grid-template-columns: repeat(2, 1fr); } }
    .quick-link {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 14px;
      background: var(--ink-3);
      border: 1px solid var(--rule);
      border-radius: 6px;
      font-size: 13px;
      color: var(--fore-dim);
      text-decoration: none;
      transition: border-color 140ms ease, color 140ms ease;
      box-shadow: var(--shadow);
    }
    .quick-link:hover { border-color: var(--rule-hi); color: var(--fore); }
    .quick-icon { color: var(--mute); flex-shrink: 0; }
  </style>

  <div class="dash">
    <!-- Header -->
    <div class="dash-header">
      <h1 class="dash-title">Resumen</h1>
      <p class="dash-sub">{monthName}</p>
    </div>

    <!-- KPI cards -->
    <div class="kpi-grid">
      <div class="kpi-card">
        <p class="kpi-label">Empleados activos</p>
        <p class="kpi-value">{stats.activeEmployees}</p>
        <a href="/employees" class="kpi-link">Ver empleados →</a>
      </div>
      <div class="kpi-card">
        <p class="kpi-label">Conceptos activos</p>
        <p class="kpi-value">{stats.activeConcepts}</p>
        <a href="/config/conceptos" class="kpi-link">Ver conceptos →</a>
      </div>
      <div class="kpi-card">
        <p class="kpi-label">Planillas este mes</p>
        <p class="kpi-value">{stats.payrollsThisMonth}</p>
        <a href="/payroll" class="kpi-link">Ver planillas →</a>
      </div>
      <div class="kpi-card">
        <p class="kpi-label">Neto pagado este mes</p>
        <p class={`kpi-value kpi-value-green`}>{fmt(stats.netThisMonth)}</p>
        <p class="kpi-link">Generadas y cerradas</p>
      </div>
    </div>

    <!-- Recent payrolls -->
    <div class="table-card">
      <div class="table-header">
        <span class="table-title">Planillas recientes</span>
        <a href="/payroll" class="table-see-all">Ver todas →</a>
      </div>

      {stats.recentPayrolls.length === 0 ? (
        <div class="empty-state">
          <p class="empty-text">No hay planillas creadas aún.</p>
          <a href="/payroll/new" class="empty-action">
            Crear primera planilla
          </a>
        </div>
      ) : (
        <table class="data-table">
          <thead>
            <tr>
              <th>Planilla</th>
              <th>Período</th>
              <th>Estado</th>
              <th>Neto</th>
            </tr>
          </thead>
          <tbody>
            {stats.recentPayrolls.map((p) => (
              <tr>
                <td>
                  <a href={`/payroll/${p.id}`} class="row-name">{p.name}</a>
                  <p class="row-type">{typeLabel[p.type] ?? p.type}</p>
                </td>
                <td>
                  <span class="row-period">{p.periodStart} → {p.periodEnd}</span>
                </td>
                <td>
                  <span
                    class="status-pill"
                    style={`color:${statusColor[p.status] ?? 'var(--mute-2)'};background:${statusBg[p.status] ?? 'rgba(106,118,144,0.12)'}`}
                  >
                    {statusLabel[p.status] ?? p.status}
                  </span>
                </td>
                <td class="row-net">
                  {Number(p.totalNet) > 0 ? fmt(Number(p.totalNet)) : '—'}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>

    <!-- Quick links -->
    <div class="quick-grid">
      <a href="/payroll/new" class="quick-link">
        <svg class="quick-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
        Nueva planilla
      </a>
      <a href="/employees/new" class="quick-link">
        <svg class="quick-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><path d="M20 8v6M23 11h-6"/></svg>
        Nuevo empleado
      </a>
      <a href="/config/conceptos/new" class="quick-link">
        <svg class="quick-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
        Nuevo concepto
      </a>
      <a href="/config/conceptos" class="quick-link">
        <svg class="quick-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        Configurar conceptos
      </a>
    </div>
  </div>
</AppLayout>

---
import AppLayout from '../../layouts/AppLayout.astro'

const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')
---

<AppLayout title="Dashboard">
  <div class="p-8">
    <h1 class="text-2xl font-bold text-gray-900 mb-6">Dashboard</h1>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-white rounded-xl border border-gray-200 p-6">
        <p class="text-sm text-gray-500">Empleados activos</p>
        <p class="text-3xl font-bold text-gray-900 mt-1">—</p>
      </div>
      <div class="bg-white rounded-xl border border-gray-200 p-6">
        <p class="text-sm text-gray-500">Planillas este mes</p>
        <p class="text-3xl font-bold text-gray-900 mt-1">—</p>
      </div>
      <div class="bg-white rounded-xl border border-gray-200 p-6">
        <p class="text-sm text-gray-500">Total nómina</p>
        <p class="text-3xl font-bold text-gray-900 mt-1">—</p>
      </div>
    </div>
    <p class="mt-8 text-sm text-gray-400">Sistema en construcción — Fase 3 en progreso</p>
  </div>
</AppLayout>

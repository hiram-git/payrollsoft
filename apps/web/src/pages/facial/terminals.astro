---
import AppLayout from '../../layouts/AppLayout.astro'
import { resolveTenantSlugFromCookie } from '../../lib/tenant-slug'

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const authCookie = Astro.cookies.get('auth')?.value
if (!authCookie) return Astro.redirect('/login')
const tenantSlug = resolveTenantSlugFromCookie(authCookie)

type Terminal = {
  id: string
  code: string
  name: string
  location: string | null
  status: string
  lastSeenAt: string | null
  appVersion: string | null
  createdAt: string
}

let terminals: Terminal[] = []
let formError = ''
let formSuccess = ''
let newToken = ''

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const action = form.get('_action')
  if (action === 'create') {
    const res = await fetch(`${API_URL}/facial/terminals`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        Cookie: `auth=${authCookie}`,
        'X-Tenant': tenantSlug,
      },
      body: JSON.stringify({
        code: form.get('code'),
        name: form.get('name'),
        location: form.get('location') || undefined,
      }),
    })
    if (res.ok) {
      const j = (await res.json()) as { data: { token: string; code: string } }
      newToken = j.data.token
      formSuccess = `Terminal ${j.data.code} creada.`
    } else {
      const j = (await res.json().catch(() => ({}))) as { error?: string }
      formError = j.error ?? 'Error al crear terminal'
    }
  }
}

try {
  const res = await fetch(`${API_URL}/facial/terminals`, {
    headers: { Cookie: `auth=${authCookie}`, 'X-Tenant': tenantSlug },
  })
  if (res.ok) {
    const json = (await res.json()) as { data: Terminal[] }
    terminals = json.data ?? []
  }
} catch {}
---

<AppLayout title="Terminales de marcación">
  <div class="p-8">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Terminales (kioskos)</h1>
        <p class="text-sm text-gray-500 mt-0.5">{terminals.length} terminales registradas</p>
      </div>
      <a href="/facial" class="text-sm text-blue-600 hover:underline">← Dashboard</a>
    </div>

    {formSuccess && (
      <div class="mb-4 rounded-lg bg-emerald-50 border border-emerald-200 px-4 py-3 text-sm text-emerald-700">
        {formSuccess}
        {newToken && (
          <div class="mt-2 p-3 rounded-lg bg-white border border-emerald-200">
            <p class="text-xs text-emerald-700 mb-1 font-medium">Token de API (guárdalo, no se mostrará de nuevo):</p>
            <code class="text-xs font-mono text-gray-800 break-all">{newToken}</code>
          </div>
        )}
      </div>
    )}
    {formError && (
      <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
        {formError}
      </div>
    )}

    <!-- New terminal -->
    <form method="POST" class="bg-white rounded-xl border border-gray-200 p-5 mb-6 grid grid-cols-1 md:grid-cols-4 gap-3 items-end">
      <input type="hidden" name="_action" value="create" />
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1" for="code">Código</label>
        <input id="code" name="code" required pattern="[a-zA-Z0-9_-]{2,60}" placeholder="kiosk-recepcion"
          class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1" for="name">Nombre</label>
        <input id="name" name="name" required placeholder="Recepción Principal"
          class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1" for="location">Ubicación</label>
        <input id="location" name="location" placeholder="Edificio A, planta baja"
          class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
      </div>
      <button type="submit"
        class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
        + Registrar terminal
      </button>
    </form>

    <!-- Terminal list -->
    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="text-left px-4 py-3 font-medium text-gray-600">Código</th>
            <th class="text-left px-4 py-3 font-medium text-gray-600">Nombre</th>
            <th class="text-left px-4 py-3 font-medium text-gray-600">Ubicación</th>
            <th class="text-left px-4 py-3 font-medium text-gray-600">Estado</th>
            <th class="text-left px-4 py-3 font-medium text-gray-600">Último contacto</th>
            <th class="text-left px-4 py-3 font-medium text-gray-600">Versión</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {terminals.map((t) => (
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3 font-mono text-xs text-gray-800">{t.code}</td>
              <td class="px-4 py-3 text-gray-900">{t.name}</td>
              <td class="px-4 py-3 text-gray-600">{t.location ?? '—'}</td>
              <td class="px-4 py-3">
                {t.status === 'active'
                  ? <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-emerald-50 text-emerald-700 text-xs font-medium">Activa</span>
                  : <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-gray-100 text-gray-600 text-xs font-medium">Inactiva</span>
                }
              </td>
              <td class="px-4 py-3 text-gray-600 text-xs">
                {t.lastSeenAt ? new Date(t.lastSeenAt).toLocaleString('es-PA') : 'Nunca'}
              </td>
              <td class="px-4 py-3 text-gray-600 text-xs font-mono">{t.appVersion ?? '—'}</td>
            </tr>
          ))}
        </tbody>
      </table>
      {terminals.length === 0 && (
        <div class="py-10 text-center text-sm text-gray-400">Aún no hay terminales registradas.</div>
      )}
    </div>
  </div>
</AppLayout>

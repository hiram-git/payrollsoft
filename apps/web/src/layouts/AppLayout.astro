---
interface Props {
  title: string
}

const { title } = Astro.props
const path = Astro.url.pathname
const returnTo = Astro.url.pathname + Astro.url.search

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000'
const authCookie = Astro.cookies.get('auth')?.value ?? ''
let userName = 'Mi cuenta'
let userEmail = ''
let userInitials = 'U'
let userRole = ''

if (authCookie) {
  try {
    const jwtParts = authCookie.split('.')
    if (jwtParts.length === 3) {
      const payload = JSON.parse(
        Buffer.from(jwtParts[1].replace(/-/g, '+').replace(/_/g, '/'), 'base64').toString('utf8')
      )
      if (payload.name) userName = payload.name
      if (payload.email) userEmail = payload.email
      if (payload.role) userRole = payload.role
      if (payload.name) {
        const np = (payload.name as string).trim().split(/\s+/)
        userInitials = np.length >= 2
          ? (np[0][0] + np[np.length - 1][0]).toUpperCase()
          : (payload.name as string)[0].toUpperCase()
      } else if (payload.email) {
        userInitials = (payload.email as string)[0].toUpperCase()
      }
    }
  } catch (_) {}
}

const roleLabels: Record<string, string> = {
  SUPER_ADMIN: 'Super Admin',
  ADMIN: 'Administrador',
  HR: 'Recursos Humanos',
  ACCOUNTANT: 'Contabilidad',
  VIEWER: 'Visor',
}
const userRoleLabel = roleLabels[userRole] ?? ''

// ── Payroll type selector ──────────────────────────────────────────────────────
const activeTypeId = Astro.cookies.get('payroll.activeTypeId')?.value ?? ''
type PayrollType = { id: string; code: string; name: string; sortOrder: number }
let payrollTypes: PayrollType[] = []
if (authCookie) {
  try {
    const res = await fetch(`${API_URL}/concepts/config`, {
      headers: { Cookie: `auth=${authCookie}`, 'X-Tenant': 'demo' },
    })
    if (res.ok) {
      const json = (await res.json()) as { data?: { payrollTypes?: PayrollType[] } }
      payrollTypes = (json.data?.payrollTypes ?? []).sort((a, b) => a.sortOrder - b.sortOrder)
    }
  } catch (_) {}
}
const activeType = payrollTypes.find((t) => t.id === activeTypeId) ?? null

function isActive(href: string) {
  return path === href || (href !== '/dashboard' && path.startsWith(href))
}

type NavChild = { href: string; label: string }
type NavEntry =
  | { kind: 'item'; href: string; label: string; icon: IconKey }
  | { kind: 'group'; label: string; icon: IconKey; children: NavChild[] }

const nav: NavEntry[] = [
  { kind: 'item', href: '/dashboard', label: 'Panel', icon: 'dashboard' },
  {
    kind: 'group',
    label: 'Estructura',
    icon: 'building',
    children: [
      { href: '/config/estructura', label: 'Posición' },
      { href: '/config/cargos', label: 'Cargos' },
      { href: '/config/funciones', label: 'Funciones' },
      { href: '/config/departamentos', label: 'Departamentos' },
      { href: '/config/partidas', label: 'Partidas' },
    ],
  },
  {
    kind: 'group',
    label: 'Personal',
    icon: 'personal',
    children: [
      { href: '/employees', label: 'Empleados' },
      { href: '/personal/baja', label: 'De Baja' },
      { href: '/personal/documentos', label: 'Documentos' },
    ],
  },
  {
    kind: 'group',
    label: 'Préstamos',
    icon: 'loans',
    children: [
      { href: '/config/acreedores', label: 'Acreedores' },
      { href: '/loans', label: 'Gestión' },
    ],
  },
  {
    kind: 'group',
    label: 'Asistencia',
    icon: 'clock',
    children: [
      { href: '/attendance', label: 'Marcaciones' },
      { href: '/attendance/shifts', label: 'Horarios' },
    ],
  },
  {
    kind: 'group',
    label: 'Planilla',
    icon: 'payroll',
    children: [
      { href: '/payroll', label: 'Cálculo' },
      { href: '/config/conceptos', label: 'Conceptos' },
      { href: '/config/catalogo-conceptos', label: 'Catálogos' },
    ],
  },
  { kind: 'item', href: '/acumulados', label: 'Acumulados', icon: 'acumulados' },
  {
    kind: 'group',
    label: 'Reportes',
    icon: 'chart',
    children: [
      { href: '/reports/personal', label: 'Personal' },
      { href: '/reports/payroll', label: 'Planilla' },
      { href: '/reports/movements', label: 'Movimientos' },
    ],
  },
  { kind: 'item', href: '/vacations', label: 'Vacaciones', icon: 'calendar' },
  { kind: 'item', href: '/liquidations', label: 'Liquidaciones', icon: 'scale' },
  {
    kind: 'group',
    label: 'Configuración',
    icon: 'gear',
    children: [
      { href: '/config/company', label: 'Empresa' },
      { href: '/config/users', label: 'Usuarios' },
      { href: '/config/roles', label: 'Roles y permisos' },
      { href: '/config/calendars', label: 'Calendarios' },
    ],
  },
]

function groupActive(children: NavChild[]) {
  return children.some((c) => isActive(c.href))
}

type IconKey =
  | 'dashboard'
  | 'building'
  | 'personal'
  | 'loans'
  | 'clock'
  | 'payroll'
  | 'chart'
  | 'calendar'
  | 'scale'
  | 'gear'
  | 'acumulados'

const icons: Record<IconKey, string> = {
  dashboard:
    '<rect x="2" y="2" width="5" height="5" rx="1"/><rect x="9" y="2" width="5" height="5" rx="1"/><rect x="2" y="9" width="5" height="5" rx="1"/><rect x="9" y="9" width="5" height="5" rx="1"/>',
  building:
    '<rect x="2" y="8" width="12" height="6" rx="1"/><rect x="5" y="4" width="6" height="4"/><rect x="7" y="1.5" width="2" height="2.5"/><rect x="4" y="10" width="2" height="4"/><rect x="10" y="10" width="2" height="4"/>',
  personal:
    '<circle cx="5.5" cy="4.5" r="2"/><path d="M1.5 12c0-2.21 1.79-4 4-4s4 1.79 4 4"/><circle cx="11" cy="5.5" r="1.5"/><path d="M14.5 12c0-1.66-1.12-3-2.5-3"/>',
  loans: '<circle cx="5" cy="7" r="2"/><path d="M7 7h5.5M10 7v2M12 7v1.5"/>',
  clock: '<circle cx="8" cy="8" r="5.5"/><path d="M8 5v3.5l2 2"/>',
  payroll: '<rect x="2" y="3" width="12" height="11" rx="1"/><path d="M2 7h12M6 3v4M10 3v4"/>',
  chart:
    '<path d="M2 13V3M13 13H2"/><rect x="4" y="8" width="2" height="4"/><rect x="7" y="5" width="2" height="7"/><rect x="10" y="9" width="2" height="3"/>',
  calendar: '<rect x="2" y="3" width="12" height="11" rx="1"/><path d="M2 7h12M6 1v4M10 1v4"/>',
  scale:
    '<path d="M8 2v11M4 13h8"/><path d="M3 5l2.5 4H.5L3 5Z"/><path d="M13 5l2.5 4h-5L13 5Z"/><path d="M3 5h10"/>',
  gear: '<circle cx="8" cy="8" r="2"/><path d="M8 1.5v2M8 12.5v2M1.5 8h2M12.5 8h2M3.4 3.4l1.4 1.4M11.2 11.2l1.4 1.4M3.4 12.6l1.4-1.4M11.2 4.8l1.4-1.4"/>',
  acumulados: '<rect x="2" y="9.5" width="2.5" height="4" rx="0.5"/><rect x="6.5" y="6.5" width="2.5" height="7" rx="0.5"/><rect x="11" y="3.5" width="2.5" height="10" rx="0.5"/>',

---
interface Props {
  title: string
}

const { title } = Astro.props
const path = Astro.url.pathname

function isActive(href: string) {
  return path === href || (href !== '/dashboard' && path.startsWith(href))
}

const navWork = [
  { href: '/dashboard', label: 'Panel', icon: 'dashboard' },
  { href: '/employees', label: 'Empleados', icon: 'team' },
  { href: '/loans', label: 'Préstamos', icon: 'loans' },
  { href: '/payroll', label: 'Planillas', icon: 'payroll' },
  { href: '/acumulados', label: 'Acumulados', icon: 'chart' },
]

const navOrg = [
  { href: '/attendance', label: 'Asistencia', icon: 'clock' },
  { href: '/vacations', label: 'Vacaciones', icon: 'calendar' },
  { href: '/reports', label: 'Reportes', icon: 'reports' },
]

const configItems = [
  { href: '/config/company', label: 'Empresa' },
  { href: '/config/estructura', label: 'Estructura' },
  { href: '/config/cargos', label: 'Cargos' },
  { href: '/config/funciones', label: 'Funciones' },
  { href: '/config/departamentos', label: 'Departamentos' },
  { href: '/config/conceptos', label: 'Conceptos' },
  { href: '/config/catalogo-conceptos', label: 'Catálogos' },
  { href: '/config/acreedores', label: 'Acreedores' },
]

const isConfigActive = configItems.some(({ href }) => path.startsWith(href))

type IconKey =
  | 'dashboard'
  | 'team'
  | 'loans'
  | 'payroll'
  | 'chart'
  | 'clock'
  | 'calendar'
  | 'reports'
const icons: Record<IconKey, string> = {
  dashboard:
    '<rect x="2" y="2" width="5" height="6"/><rect x="9" y="2" width="5" height="3"/><rect x="9" y="7" width="5" height="7"/><rect x="2" y="10" width="5" height="4"/>',
  team: '<circle cx="8" cy="5" r="2.2"/><path d="M3 13c.6-2.4 2.5-3.5 5-3.5s4.4 1.1 5 3.5"/>',
  loans: '<circle cx="5" cy="7" r="2"/><path d="M7 7h5.5M10 7v2M12 7v1.5"/>',
  payroll: '<rect x="2" y="3" width="12" height="11" rx="1"/><path d="M2 7h12M6 3v4M10 3v4"/>',
  chart:
    '<path d="M2 13V3M13 13H2"/><rect x="4" y="8" width="2" height="4"/><rect x="7" y="5" width="2" height="7"/><rect x="10" y="9" width="2" height="3"/>',
  clock: '<circle cx="8" cy="8" r="5.5"/><path d="M8 5v3.5l2 2"/>',
  calendar: '<rect x="2" y="3" width="12" height="11" rx="1"/><path d="M2 7h12M6 1v4M10 1v4"/>',
  reports: '<path d="M3 2h7l3 3v9H3V2Z"/><path d="M10 2v3h3M5 8h6M5 11h6"/>',
}
---

<!doctype html>
<html lang="es" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Payroll Panamá</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400&family=Inter+Tight:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <script is:inline>
      try { document.documentElement.dataset.theme = localStorage.getItem('payroll.theme') || 'dark'; } catch(e) {}
    </script>
    <style is:global>
      :root, [data-theme="dark"] {
        --ink:       #07101F;
        --ink-2:     #0A1628;
        --ink-3:     #101E33;
        --ink-4:     #16263F;
        --navy:      #003087;
        --navy-hi:   #1E4BA8;
        --navy-soft: rgba(0,48,135,0.18);
        --rule:      #1A2740;
        --rule-hi:   #243555;
        --mute:      #6A7690;
        --mute-2:    #8B97AE;
        --fore:      #EDEEF2;
        --fore-dim:  #C9CEDB;
        --warn:      #E3B25A;
        --err:       #E06B5C;
        --ok:        #6FB58C;
        --pos:       #6FB58C;
        --neg:       #E06B5C;
        --shadow:    none;
        --f-display: 'Fraunces','Times New Roman',serif;
        --f-sans:    'Inter Tight',-apple-system,system-ui,sans-serif;
        --f-mono:    'JetBrains Mono',ui-monospace,monospace;
      }
      [data-theme="light"] {
        --ink:       #F4F5F7;
        --ink-2:     #FFFFFF;
        --ink-3:     #FFFFFF;
        --ink-4:     #EFF1F5;
        --navy:      #003087;
        --navy-hi:   #1E4BA8;
        --navy-soft: rgba(0,48,135,0.08);
        --rule:      #E4E7EE;
        --rule-hi:   #D2D7E0;
        --mute:      #7A8499;
        --mute-2:    #5B6478;
        --fore:      #0C1424;
        --fore-dim:  #2A3346;
        --warn:      #B07A17;
        --err:       #B53A2B;
        --ok:        #2E7A56;
        --pos:       #2E7A56;
        --neg:       #B53A2B;
        --shadow:    0 1px 2px rgba(12,20,36,0.04), 0 1px 1px rgba(12,20,36,0.03);
      }

      *, *::before, *::after { box-sizing: border-box; }
      html, body { height: 100%; margin: 0; }
      body {
        background: var(--ink);
        color: var(--fore);
        font-family: var(--f-sans);
        font-size: 14px;
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
        letter-spacing: -0.005em;
        transition: background 180ms ease, color 180ms ease;
      }
      ::selection { background: var(--navy); color: #fff; }
      ::-webkit-scrollbar { width: 10px; height: 10px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background: var(--rule); border-radius: 10px; border: 2px solid var(--ink); }
      ::-webkit-scrollbar-thumb:hover { background: var(--rule-hi); }

      /* ── App shell ──────────────────────────────────────── */
      .app-shell {
        display: flex;
        height: 100vh;
        width: 100vw;
        overflow: hidden;
      }

      /* ── Sidebar ────────────────────────────────────────── */
      .sidebar {
        width: 240px;
        flex-shrink: 0;
        background: var(--ink-2);
        border-right: 1px solid var(--rule);
        display: flex;
        flex-direction: column;
        padding: 20px 14px 16px;
        box-shadow: var(--shadow);
        overflow-y: auto;
        overflow-x: hidden;
      }
      .sidebar-brand {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 4px 10px 20px;
      }
      .brand-mark {
        width: 32px; height: 32px;
        border-radius: 4px;
        background: var(--navy);
        display: grid;
        place-items: center;
        color: #fff;
        font-family: var(--f-display);
        font-size: 18px;
        font-weight: 400;
        letter-spacing: -0.02em;
        flex-shrink: 0;
      }
      .brand-col { display: flex; flex-direction: column; line-height: 1.2; }
      .brand-name { font-family: var(--f-sans); font-weight: 500; font-size: 14px; color: var(--fore); }
      .brand-sub  { font-family: var(--f-mono); font-size: 9.5px; color: var(--mute); letter-spacing: 0.14em; text-transform: uppercase; margin-top: 2px; }
      .nav-section {
        font-family: var(--f-mono);
        font-size: 10px;
        color: var(--mute);
        letter-spacing: 0.16em;
        text-transform: uppercase;
        padding: 14px 12px 8px;
      }
      .nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 9px 12px;
        border-radius: 3px;
        cursor: pointer;
        color: var(--fore-dim);
        font-size: 13.5px;
        font-weight: 400;
        text-decoration: none;
        transition: background 140ms ease, color 140ms ease;
        position: relative;
      }
      .nav-item:hover:not(.nav-active) {
        background: var(--ink-4);
        color: var(--fore);
      }
      .nav-active {
        background: var(--navy-soft);
        color: var(--fore);
        font-weight: 500;
      }
      .nav-active::before {
        content: '';
        position: absolute;
        left: 0; top: 6px; bottom: 6px;
        width: 2px;
        background: var(--navy-hi);
        border-radius: 0 2px 2px 0;
      }
      .nav-icon {
        flex-shrink: 0;
        color: inherit;
        opacity: 0.85;
      }
      /* Config sub-items */
      .config-summary {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 9px 12px;
        border-radius: 3px;
        cursor: pointer;
        color: var(--fore-dim);
        font-size: 13.5px;
        font-weight: 400;
        list-style: none;
        transition: background 140ms ease, color 140ms ease;
        user-select: none;
      }
      .config-summary:hover { background: var(--ink-4); color: var(--fore); }
      .config-summary-active { color: var(--fore); font-weight: 500; }
      .config-chevron { margin-left: auto; transition: transform 200ms ease; opacity: 0.6; }
      details[open] .config-chevron { transform: rotate(180deg); }
      .config-sub {
        margin-top: 2px;
        padding-left: 24px;
      }
      .config-sub-item {
        display: flex;
        align-items: center;
        padding: 7px 12px;
        border-radius: 3px;
        font-size: 13px;
        color: var(--mute-2);
        text-decoration: none;
        transition: background 140ms ease, color 140ms ease;
      }
      .config-sub-item:hover { background: var(--ink-4); color: var(--fore); }
      .config-sub-active { color: var(--fore); font-weight: 500; background: var(--navy-soft); }
      .sidebar-footer {
        margin-top: auto;
        padding-top: 12px;
        border-top: 1px solid var(--rule);
      }
      .logout-btn {
        display: flex;
        align-items: center;
        gap: 12px;
        width: 100%;
        padding: 9px 12px;
        border-radius: 3px;
        border: none;
        background: transparent;
        color: var(--mute);
        font-size: 13.5px;
        font-family: var(--f-sans);
        cursor: pointer;
        transition: background 140ms ease, color 140ms ease;
        text-align: left;
      }
      .logout-btn:hover { background: var(--ink-4); color: var(--fore); }

      /* ── Main column ────────────────────────────────────── */
      .main-col {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-width: 0;
        overflow: hidden;
      }

      /* ── Topbar ─────────────────────────────────────────── */
      .topbar {
        height: 56px;
        flex-shrink: 0;
        background: var(--ink-2);
        border-bottom: 1px solid var(--rule);
        display: flex;
        align-items: center;
        padding: 0 20px;
        gap: 12px;
        box-shadow: var(--shadow);
      }
      .topbar-crumbs {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 6px;
        font-family: var(--f-sans);
        font-size: 13.5px;
        color: var(--mute-2);
        min-width: 0;
      }
      .topbar-crumbs .crumb-sep { opacity: 0.4; }
      .topbar-crumbs .crumb-cur { color: var(--fore); font-weight: 500; }
      .topbar-right {
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .topbar-icon-btn {
        width: 34px; height: 34px;
        display: grid;
        place-items: center;
        border: none;
        background: transparent;
        color: var(--mute);
        cursor: pointer;
        border-radius: 6px;
        transition: background 140ms ease, color 140ms ease;
        text-decoration: none;
      }
      .topbar-icon-btn:hover { background: var(--ink-4); color: var(--fore-dim); }

      /* Theme switch in topbar */
      .ts-wrap {
        display: inline-flex;
        padding: 2px;
        background: var(--ink-3);
        border: 1px solid var(--rule);
        border-radius: 999px;
        position: relative;
      }
      .ts-knob {
        position: absolute;
        top: 2px;
        width: 30px; height: 24px;
        background: var(--ink-2);
        border: 1px solid var(--rule-hi);
        border-radius: 999px;
        transition: transform 220ms cubic-bezier(.2,.7,.2,1);
        pointer-events: none;
      }
      .ts-btn {
        position: relative;
        z-index: 2;
        width: 30px; height: 24px;
        display: grid;
        place-items: center;
        border: none;
        background: transparent;
        cursor: pointer;
        border-radius: 999px;
        transition: color 160ms ease;
      }
      .ts-btn[data-active="true"]  { color: var(--fore); }
      .ts-btn[data-active="false"] { color: var(--mute); }

      /* Avatar */
      .avatar-pill {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 4px 10px 4px 4px;
        border-radius: 999px;
        border: 1px solid var(--rule);
        background: var(--ink-3);
        cursor: pointer;
        transition: border-color 140ms ease;
      }
      .avatar-pill:hover { border-color: var(--rule-hi); }
      .avatar-circle {
        width: 26px; height: 26px;
        border-radius: 50%;
        background: var(--navy);
        display: grid;
        place-items: center;
        font-size: 11px;
        font-weight: 600;
        color: #fff;
        letter-spacing: 0.02em;
        flex-shrink: 0;
      }
      .avatar-name {
        font-size: 12.5px;
        font-weight: 500;
        color: var(--fore-dim);
        white-space: nowrap;
      }

      /* ── Page content ───────────────────────────────────── */
      .page-content {
        flex: 1;
        overflow-y: auto;
        overflow-x: hidden;
        background: var(--ink);
      }
    </style>
  </head>
  <body>
    <div class="app-shell">

      <!-- Sidebar -->
      <aside class="sidebar">
        <div class="sidebar-brand">
          <div class="brand-mark">P</div>
          <div class="brand-col">
            <span class="brand-name">PayrollSoft</span>
            <span class="brand-sub">Payroll Panamá</span>
          </div>
        </div>

        <span class="nav-section">Trabajo</span>

        {navWork.map(({ href, label, icon }) => (
          <a
            href={href}
            class={`nav-item${isActive(href) ? ' nav-active' : ''}`}
          >
            <svg class="nav-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" set:html={icons[icon as IconKey]} />
            {label}
          </a>
        ))}

        <span class="nav-section">Organización</span>

        {navOrg.map(({ href, label, icon }) => (
          <a
            href={href}
            class={`nav-item${isActive(href) ? ' nav-active' : ''}`}
          >
            <svg class="nav-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" set:html={icons[icon as IconKey]} />
            {label}
          </a>
        ))}

        <span class="nav-section">Config.</span>

        <details open={isConfigActive || undefined}>
          <summary class={`config-summary${isConfigActive ? ' config-summary-active' : ''}`}>
            <svg class="nav-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3">
              <circle cx="8" cy="8" r="2"/><path d="M8 1.5v2M8 12.5v2M1.5 8h2M12.5 8h2M3.4 3.4l1.4 1.4M11.2 11.2l1.4 1.4M3.4 12.6l1.4-1.4M11.2 4.8l1.4-1.4"/>
            </svg>
            Configuración
            <svg class="config-chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="square">
              <path d="M2.5 4l2.5 2.5L7.5 4"/>
            </svg>
          </summary>
          <div class="config-sub">
            {configItems.map(({ href, label }) => (
              <a
                href={href}
                class={`config-sub-item${isActive(href) ? ' config-sub-active' : ''}`}
              >
                {label}
              </a>
            ))}
          </div>
        </details>

        <div class="sidebar-footer">
          <form method="POST" action="/api/auth/logout">
            <button type="submit" class="logout-btn">
              <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.3">
                <path d="M8 2H2.5v9H8M5.5 6.5h6M9 4.5l2 2-2 2"/>
              </svg>
              Cerrar sesión
            </button>
          </form>
        </div>
      </aside>

      <!-- Main column: topbar + content -->
      <div class="main-col">
        <header class="topbar">
          <div class="topbar-crumbs">
            <span>Payroll Panamá</span>
            <span class="crumb-sep">
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="square">
                <path d="M4 2.5 6.5 5 4 7.5"/>
              </svg>
            </span>
            <span class="crumb-cur">{title}</span>
          </div>
          <div class="topbar-right">
            <!-- Theme switch -->
            <div class="ts-wrap" role="group" aria-label="Cambiar tema" id="ts-wrap">
              <span class="ts-knob" id="ts-knob"></span>
              <button class="ts-btn" id="ts-light" data-active="false" aria-label="Tema claro" title="Tema claro">
                <svg width="13" height="13" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
                  <circle cx="7" cy="7" r="2.6"/>
                  <path d="M7 1.5v1.3M7 11.2v1.3M1.5 7h1.3M11.2 7h1.3M3 3l.9.9M10.1 10.1l.9.9M3 11l.9-.9M10.1 3.9l.9-.9"/>
                </svg>
              </button>
              <button class="ts-btn" id="ts-dark" data-active="true" aria-label="Tema oscuro" title="Tema oscuro">
                <svg width="13" height="13" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M11.5 8.5A4.8 4.8 0 0 1 5.5 2.5a5 5 0 1 0 6 6Z"/>
                </svg>
              </button>
            </div>

            <!-- Notifications -->
            <button class="topbar-icon-btn" aria-label="Notificaciones" title="Notificaciones">
              <svg width="15" height="15" viewBox="0 0 15 15" fill="none" stroke="currentColor" stroke-width="1.3">
                <path d="M3.5 11h8l-1-1V6.5a3 3 0 0 0-6 0V10l-1 1Z"/>
                <path d="M6 12.5c.2.6.8 1 1.5 1s1.3-.4 1.5-1"/>
              </svg>
            </button>

            <!-- User avatar -->
            <div class="avatar-pill">
              <div class="avatar-circle">U</div>
              <span class="avatar-name">Mi cuenta</span>
            </div>
          </div>
        </header>

        <main class="page-content">
          <slot />
        </main>
      </div>

    </div>

    <script is:inline>
      (function () {
        const html = document.documentElement;
        const knob   = document.getElementById('ts-knob');
        const btnL   = document.getElementById('ts-light');
        const btnD   = document.getElementById('ts-dark');
        if (!knob || !btnL || !btnD) return;

        function applyTheme(t) {
          html.dataset.theme = t;
          try { localStorage.setItem('payroll.theme', t); } catch(e) {}
          const isDark = t === 'dark';
          btnL.dataset.active = (!isDark).toString();
          btnD.dataset.active  = isDark.toString();
          knob.style.transform = isDark ? 'translateX(30px)' : 'translateX(0)';
        }

        applyTheme(html.dataset.theme || 'dark');
        btnL.addEventListener('click', () => applyTheme('light'));
        btnD.addEventListener('click', () => applyTheme('dark'));
      })();
    </script>
  </body>
</html>

---

<!doctype html>
<html lang="es" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Payroll Panamá</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400&family=Inter+Tight:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <script is:inline>
      try { document.documentElement.dataset.theme = localStorage.getItem('payroll.theme') || 'dark'; } catch(e) {}
    </script>
    <style is:global>
      :root, [data-theme="dark"] {
        --ink:       #07101F;
        --ink-2:     #0A1628;
        --ink-3:     #101E33;
        --ink-4:     #16263F;
        --navy:      #003087;
        --navy-hi:   #1E4BA8;
        --navy-soft: rgba(0,48,135,0.18);
        --rule:      #1A2740;
        --rule-hi:   #243555;
        --mute:      #6A7690;
        --mute-2:    #8B97AE;
        --fore:      #EDEEF2;
        --fore-dim:  #C9CEDB;
        --warn:      #E3B25A;
        --err:       #E06B5C;
        --ok:        #6FB58C;
        --pos:       #6FB58C;
        --neg:       #E06B5C;
        --shadow:    none;
        --f-display: 'Fraunces','Times New Roman',serif;
        --f-sans:    'Inter Tight',-apple-system,system-ui,sans-serif;
        --f-mono:    'JetBrains Mono',ui-monospace,monospace;
      }
      [data-theme="light"] {
        --ink:       #F4F5F7;
        --ink-2:     #FFFFFF;
        --ink-3:     #FFFFFF;
        --ink-4:     #EFF1F5;
        --navy:      #003087;
        --navy-hi:   #1E4BA8;
        --navy-soft: rgba(0,48,135,0.08);
        --rule:      #E4E7EE;
        --rule-hi:   #D2D7E0;
        --mute:      #7A8499;
        --mute-2:    #5B6478;
        --fore:      #0C1424;
        --fore-dim:  #2A3346;
        --warn:      #B07A17;
        --err:       #B53A2B;
        --ok:        #2E7A56;
        --pos:       #2E7A56;
        --neg:       #B53A2B;
        --shadow:    0 1px 2px rgba(12,20,36,0.04), 0 1px 1px rgba(12,20,36,0.03);
      }

      *, *::before, *::after { box-sizing: border-box; }
      html, body { height: 100%; margin: 0; }
      body {
        background: var(--ink);
        color: var(--fore);
        font-family: var(--f-sans);
        font-size: 14px;
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
        letter-spacing: -0.005em;
        transition: background 180ms ease, color 180ms ease;
      }
      ::selection { background: var(--navy); color: #fff; }
      ::-webkit-scrollbar { width: 10px; height: 10px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background: var(--rule); border-radius: 10px; border: 2px solid var(--ink); }
      ::-webkit-scrollbar-thumb:hover { background: var(--rule-hi); }

      /* ── App shell ──────────────────────────────────────── */
      .app-shell {
        display: flex;
        height: 100vh;
        width: 100vw;
        overflow: hidden;
      }

      /* ── Sidebar ────────────────────────────────────────── */
      .sidebar {
        width: 240px;
        flex-shrink: 0;
        background: var(--ink-2);
        border-right: 1px solid var(--rule);
        display: flex;
        flex-direction: column;
        padding: 20px 14px 16px;
        box-shadow: var(--shadow);
        overflow-y: auto;
        overflow-x: hidden;
      }
      .sidebar-brand {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 4px 10px 20px;
      }
      .brand-mark {
        width: 32px; height: 32px;
        border-radius: 4px;
        background: var(--navy);
        display: grid;
        place-items: center;
        color: #fff;
        font-family: var(--f-display);
        font-size: 18px;
        font-weight: 400;
        letter-spacing: -0.02em;
        flex-shrink: 0;
      }
      .brand-col { display: flex; flex-direction: column; line-height: 1.2; }
      .brand-name { font-family: var(--f-sans); font-weight: 500; font-size: 14px; color: var(--fore); }
      .brand-sub  { font-family: var(--f-mono); font-size: 9.5px; color: var(--mute); letter-spacing: 0.14em; text-transform: uppercase; margin-top: 2px; }
      .nav-section {
        font-family: var(--f-mono);
        font-size: 10px;
        color: var(--mute);
        letter-spacing: 0.16em;
        text-transform: uppercase;
        padding: 14px 12px 8px;
      }
      .nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 9px 12px;
        border-radius: 3px;
        cursor: pointer;
        color: var(--fore-dim);
        font-size: 13.5px;
        font-weight: 400;
        text-decoration: none;
        transition: background 140ms ease, color 140ms ease;
        position: relative;
      }
      .nav-item:hover:not(.nav-active) {
        background: var(--ink-4);
        color: var(--fore);
      }
      .nav-active {
        background: var(--navy-soft);
        color: var(--fore);
        font-weight: 500;
      }
      .nav-active::before {
        content: '';
        position: absolute;
        left: 0; top: 6px; bottom: 6px;
        width: 2px;
        background: var(--navy-hi);
        border-radius: 0 2px 2px 0;
      }
      .nav-icon {
        flex-shrink: 0;
        color: inherit;
        opacity: 0.85;
      }
      /* Group toggle (parent row) */
      .group-summary {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 9px 12px;
        border-radius: 3px;
        cursor: pointer;
        color: var(--fore-dim);
        font-size: 13.5px;
        font-weight: 400;
        list-style: none;
        transition: background 140ms ease, color 140ms ease;
        user-select: none;
      }
      .group-summary:hover { background: var(--ink-4); color: var(--fore); }
      .group-summary-active { color: var(--fore); font-weight: 500; }
      .group-chevron { margin-left: auto; transition: transform 200ms ease; opacity: 0.5; }
      details[open] .group-chevron { transform: rotate(180deg); }

      /* Children rail */
      .group-children {
        position: relative;
        margin: 2px 0 4px 24px;
        padding-left: 12px;
      }
      .group-children::before {
        content: '';
        position: absolute;
        left: 0;
        top: 4px;
        bottom: 4px;
        width: 1px;
        background: var(--rule);
        border-radius: 1px;
      }
      .child-item {
        display: flex;
        align-items: center;
        padding: 6px 10px;
        border-radius: 3px;
        font-size: 13px;
        color: var(--mute-2);
        text-decoration: none;
        transition: background 140ms ease, color 140ms ease;
        position: relative;
      }
      .child-item:hover { background: var(--ink-4); color: var(--fore); }
      .child-active {
        color: var(--fore);
        font-weight: 500;
        background: var(--navy-soft);
      }
      .child-active::before {
        content: '';
        position: absolute;
        left: -12px;
        top: 50%;
        transform: translateY(-50%);
        width: 1px;
        height: 60%;
        background: var(--navy-hi);
        border-radius: 1px;
      }
      /* ── Main column ────────────────────────────────────── */
      .main-col {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-width: 0;
        overflow: hidden;
      }

      /* ── Topbar ─────────────────────────────────────────── */
      .topbar {
        height: 56px;
        flex-shrink: 0;
        background: var(--ink-2);
        border-bottom: 1px solid var(--rule);
        display: flex;
        align-items: center;
        padding: 0 20px;
        gap: 12px;
        box-shadow: var(--shadow);
      }
      .topbar-crumbs {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 6px;
        font-family: var(--f-sans);
        font-size: 13.5px;
        color: var(--mute-2);
        min-width: 0;
      }
      .topbar-crumbs .crumb-sep { opacity: 0.4; }
      .topbar-crumbs .crumb-cur { color: var(--fore); font-weight: 500; }
      .topbar-right {
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .topbar-icon-btn {
        width: 34px; height: 34px;
        display: grid;
        place-items: center;
        border: none;
        background: transparent;
        color: var(--mute);
        cursor: pointer;
        border-radius: 6px;
        transition: background 140ms ease, color 140ms ease;
        text-decoration: none;
      }
      .topbar-icon-btn:hover { background: var(--ink-4); color: var(--fore-dim); }

      /* Theme switch in topbar */
      .ts-wrap {
        display: inline-flex;
        padding: 2px;
        background: var(--ink-3);
        border: 1px solid var(--rule);
        border-radius: 999px;
        position: relative;
      }
      .ts-knob {
        position: absolute;
        top: 2px;
        width: 30px; height: 24px;
        background: var(--ink-2);
        border: 1px solid var(--rule-hi);
        border-radius: 999px;
        transition: transform 220ms cubic-bezier(.2,.7,.2,1);
        pointer-events: none;
      }
      .ts-btn {
        position: relative;
        z-index: 2;
        width: 30px; height: 24px;
        display: grid;
        place-items: center;
        border: none;
        background: transparent;
        cursor: pointer;
        border-radius: 999px;
        transition: color 160ms ease;
      }
      .ts-btn[data-active="true"]  { color: var(--fore); }
      .ts-btn[data-active="false"] { color: var(--mute); }

      /* Payroll type selector */
      .type-selector-form { display: contents; }
      .type-selector-wrap {
        display: flex;
        align-items: center;
        gap: 5px;
        padding: 4px 10px 4px 8px;
        border: 1px solid var(--rule);
        border-radius: 999px;
        background: var(--ink-3);
        color: var(--mute);
        transition: border-color 140ms ease;
      }
      .type-selector-wrap:focus-within { border-color: var(--rule-hi); }
      .type-selector {
        background: transparent;
        border: none;
        color: var(--fore-dim);
        font-size: 12px;
        font-family: var(--f-sans);
        cursor: pointer;
        outline: none;
        padding: 0;
        max-width: 150px;
      }
      .type-selector option { background: var(--ink-2); color: var(--fore); }

      /* Avatar */
      .avatar-wrap { position: relative; }
      .avatar-pill {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 4px 10px 4px 4px;
        border-radius: 999px;
        border: 1px solid var(--rule);
        background: var(--ink-3);
        cursor: pointer;
        transition: border-color 140ms ease;
        font-family: var(--f-sans);
      }
      .avatar-pill:hover { border-color: var(--rule-hi); }
      .avatar-circle {
        width: 26px; height: 26px;
        border-radius: 50%;
        background: var(--navy);
        display: grid;
        place-items: center;
        font-size: 11px;
        font-weight: 600;
        color: #fff;
        letter-spacing: 0.02em;
        flex-shrink: 0;
      }
      .avatar-name {
        font-size: 12.5px;
        font-weight: 500;
        color: var(--fore-dim);
        white-space: nowrap;
      }
      .avatar-chevron {
        color: var(--mute);
        flex-shrink: 0;
        transition: transform 200ms ease;
        margin-left: 2px;
      }

      /* User dropdown */
      .user-dropdown {
        position: absolute;
        top: calc(100% + 8px);
        right: 0;
        width: 224px;
        background: var(--ink-2);
        border: 1px solid var(--rule);
        border-radius: 8px;
        box-shadow: 0 8px 28px rgba(0,0,0,0.35);
        z-index: 200;
        opacity: 0;
        transform: translateY(-6px);
        pointer-events: none;
        transition: opacity 160ms ease, transform 160ms ease;
        overflow: hidden;
      }
      .user-dropdown.open {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
      }
      .user-dropdown-header {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px;
      }
      .user-dropdown-avatar {
        width: 36px; height: 36px;
        border-radius: 50%;
        background: var(--navy);
        display: grid;
        place-items: center;
        font-size: 13px;
        font-weight: 600;
        color: #fff;
        flex-shrink: 0;
      }
      .user-dropdown-info {
        display: flex;
        flex-direction: column;
        min-width: 0;
      }
      .user-dropdown-name {
        font-size: 13px;
        font-weight: 600;
        color: var(--fore);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .user-dropdown-email {
        font-size: 11px;
        color: var(--mute);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin-top: 1px;
      }
      .user-dropdown-role {
        font-size: 10px;
        font-family: var(--f-mono);
        color: var(--navy-hi);
        letter-spacing: 0.06em;
        text-transform: uppercase;
        margin-top: 3px;
      }
      .user-dropdown-divider {
        height: 1px;
        background: var(--rule);
      }
      .user-dropdown-item {
        display: flex;
        align-items: center;
        gap: 10px;
        width: 100%;
        padding: 9px 14px;
        border: none;
        background: transparent;
        color: var(--fore-dim);
        font-size: 13px;
        font-family: var(--f-sans);
        text-decoration: none;
        cursor: pointer;
        transition: background 140ms ease, color 140ms ease;
        text-align: left;
      }
      .user-dropdown-item:hover { background: var(--ink-4); color: var(--fore); }
      .user-dropdown-danger { color: var(--err); }
      .user-dropdown-danger:hover { background: rgba(224,107,92,0.08); color: var(--err); }

      /* ── Page content ───────────────────────────────────── */
      .page-content {
        flex: 1;
        overflow-y: auto;
        overflow-x: hidden;
        background: var(--ink);
      }

      /* ── Dark-mode theming for page content cards/tables ── */
      [data-theme="dark"] .page-content .bg-white       { background-color: var(--ink-2); }
      [data-theme="dark"] .page-content .bg-gray-50     { background-color: var(--ink-3); }
      [data-theme="dark"] .page-content .bg-gray-100    { background-color: var(--ink-4); }

      [data-theme="dark"] .page-content .border-gray-200,
      [data-theme="dark"] .page-content .border-gray-100 { border-color: var(--rule); }
      [data-theme="dark"] .page-content .border-gray-300  { border-color: var(--rule-hi); }

      [data-theme="dark"] .page-content .divide-gray-100 > :not([hidden]) ~ :not([hidden]) { border-color: var(--rule); }

      [data-theme="dark"] .page-content .text-gray-900,
      [data-theme="dark"] .page-content .text-gray-800  { color: var(--fore); }
      [data-theme="dark"] .page-content .text-gray-700  { color: var(--fore-dim); }
      [data-theme="dark"] .page-content .text-gray-600  { color: var(--mute-2); }
      [data-theme="dark"] .page-content .text-gray-500,
      [data-theme="dark"] .page-content .text-gray-400,
      [data-theme="dark"] .page-content .text-gray-300  { color: var(--mute); }

      [data-theme="dark"] .page-content .hover\:bg-gray-50:hover,
      [data-theme="dark"] .page-content .hover\:bg-gray-100:hover { background-color: var(--ink-4); }
      [data-theme="dark"] .page-content .hover\:text-gray-700:hover { color: var(--fore); }

      /* ── Inputs / selects / textareas ────────────────────── */
      [data-theme="dark"] .page-content input:not([type="submit"]):not([type="button"]):not([type="checkbox"]):not([type="radio"]):not([type="file"]),
      [data-theme="dark"] .page-content select,
      [data-theme="dark"] .page-content textarea {
        background-color: var(--ink-3);
        border-color: var(--rule);
        color: var(--fore);
      }
      [data-theme="dark"] .page-content input::placeholder,
      [data-theme="dark"] .page-content textarea::placeholder { color: var(--mute); }
      [data-theme="dark"] .page-content input:focus,
      [data-theme="dark"] .page-content select:focus,
      [data-theme="dark"] .page-content textarea:focus {
        border-color: var(--navy-hi);
        box-shadow: 0 0 0 2px var(--navy-soft);
      }
    </style>
  </head>
  <body>
    <div class="app-shell">

      <!-- Sidebar -->
      <aside class="sidebar">
        <div class="sidebar-brand">
          <div class="brand-mark">P</div>
          <div class="brand-col">
            <span class="brand-name">PayrollSoft</span>
            <span class="brand-sub">Payroll Panamá</span>
          </div>
        </div>

        {nav.map((entry) => {
          if (entry.kind === 'item') {
            return (
              <a href={entry.href} class={`nav-item${isActive(entry.href) ? ' nav-active' : ''}`}>
                <svg class="nav-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" set:html={icons[entry.icon]} />
                {entry.label}
              </a>
            )
          }
          const active = groupActive(entry.children)
          return (
            <details open={active || undefined}>
              <summary class={`group-summary${active ? ' group-summary-active' : ''}`}>
                <svg class="nav-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" set:html={icons[entry.icon]} />
                {entry.label}
                <svg class="group-chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="square">
                  <path d="M2.5 4l2.5 2.5L7.5 4"/>
                </svg>
              </summary>
              <div class="group-children">
                {entry.children.map((child) => (
                  <a href={child.href} class={`child-item${isActive(child.href) ? ' child-active' : ''}`}>
                    {child.label}
                  </a>
                ))}
              </div>
            </details>
          )
        })}

      </aside>

      <!-- Main column: topbar + content -->
      <div class="main-col">
        <header class="topbar">
          <div class="topbar-crumbs">
            <span>Payroll Panamá</span>
            <span class="crumb-sep">
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="square">
                <path d="M4 2.5 6.5 5 4 7.5"/>
              </svg>
            </span>
            <span class="crumb-cur">{title}</span>
          </div>
          <div class="topbar-right">
            <!-- Theme switch -->
            <div class="ts-wrap" role="group" aria-label="Cambiar tema" id="ts-wrap">
              <span class="ts-knob" id="ts-knob"></span>
              <button class="ts-btn" id="ts-light" data-active="false" aria-label="Tema claro" title="Tema claro">
                <svg width="13" height="13" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
                  <circle cx="7" cy="7" r="2.6"/>
                  <path d="M7 1.5v1.3M7 11.2v1.3M1.5 7h1.3M11.2 7h1.3M3 3l.9.9M10.1 10.1l.9.9M3 11l.9-.9M10.1 3.9l.9-.9"/>
                </svg>
              </button>
              <button class="ts-btn" id="ts-dark" data-active="true" aria-label="Tema oscuro" title="Tema oscuro">
                <svg width="13" height="13" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M11.5 8.5A4.8 4.8 0 0 1 5.5 2.5a5 5 0 1 0 6 6Z"/>
                </svg>
              </button>
            </div>

            <!-- Notifications -->
            <button class="topbar-icon-btn" aria-label="Notificaciones" title="Notificaciones">
              <svg width="15" height="15" viewBox="0 0 15 15" fill="none" stroke="currentColor" stroke-width="1.3">
                <path d="M3.5 11h8l-1-1V6.5a3 3 0 0 0-6 0V10l-1 1Z"/>
                <path d="M6 12.5c.2.6.8 1 1.5 1s1.3-.4 1.5-1"/>
              </svg>
            </button>

            <!-- Payroll type filter -->
            {payrollTypes.length > 0 && (
              <form method="POST" action="/api/config/select-payroll-type" class="type-selector-form">
                <input type="hidden" name="returnTo" value={returnTo} />
                <div class="type-selector-wrap" title="Filtrar por tipo de planilla">
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
                    <path d="M1 2.5h10M3 6h6M5 9.5h2"/>
                  </svg>
                  <select
                    name="payrollTypeId"
                    class="type-selector"
                    onchange="this.closest('form').submit()"
                    aria-label="Tipo de planilla activo"
                  >
                    <option value="">Todos los tipos</option>
                    {payrollTypes.map((t) => (
                      <option value={t.id} selected={t.id === activeTypeId}>{t.name}</option>
                    ))}
                  </select>
                </div>
              </form>
            )}

            <!-- User avatar + dropdown -->
            <div class="avatar-wrap">
              <button class="avatar-pill" id="user-menu-btn" aria-haspopup="menu" aria-expanded="false">
                <div class="avatar-circle">{userInitials}</div>
                <span class="avatar-name">{userName}</span>
                <svg class="avatar-chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="square">
                  <path d="M2.5 4l2.5 2.5L7.5 4"/>
                </svg>
              </button>
              <div class="user-dropdown" id="user-dropdown" role="menu" aria-hidden="true">
                <div class="user-dropdown-header">
                  <div class="user-dropdown-avatar">{userInitials}</div>
                  <div class="user-dropdown-info">
                    <span class="user-dropdown-name">{userName}</span>
                    {userEmail && <span class="user-dropdown-email">{userEmail}</span>}
                    {userRoleLabel && <span class="user-dropdown-role">{userRoleLabel}</span>}
                  </div>
                </div>
                <div class="user-dropdown-divider"></div>
                <a href="/config/company" class="user-dropdown-item" role="menuitem">
                  <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.3">
                    <rect x="1.5" y="4" width="10" height="8" rx="1"/>
                    <path d="M4.5 4V2.5a2 2 0 0 1 4 0V4"/>
                  </svg>
                  Empresa
                </a>
                <a href="/config/users" class="user-dropdown-item" role="menuitem">
                  <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.3">
                    <circle cx="4" cy="4" r="2"/>
                    <path d="M1 11c0-1.66 1.34-3 3-3s3 1.34 3 3"/>
                    <circle cx="10" cy="5" r="1.5"/>
                    <path d="M12.5 11c0-1.38-.9-2.5-2-2.5"/>
                  </svg>
                  Usuarios
                </a>
                <div class="user-dropdown-divider"></div>
                <form method="POST" action="/api/auth/logout">
                  <button type="submit" class="user-dropdown-item user-dropdown-danger" role="menuitem">
                    <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.3">
                      <path d="M8 2H2.5v9H8M5.5 6.5h6M9 4.5l2 2-2 2"/>
                    </svg>
                    Cerrar sesión
                  </button>
                </form>
              </div>
            </div>
          </div>
        </header>

        <main class="page-content">
          <slot />
        </main>
      </div>

    </div>

    <script is:inline>
      (function () {
        const html = document.documentElement;
        const knob   = document.getElementById('ts-knob');
        const btnL   = document.getElementById('ts-light');
        const btnD   = document.getElementById('ts-dark');
        if (!knob || !btnL || !btnD) return;

        function applyTheme(t) {
          html.dataset.theme = t;
          try { localStorage.setItem('payroll.theme', t); } catch(e) {}
          const isDark = t === 'dark';
          btnL.dataset.active = (!isDark).toString();
          btnD.dataset.active  = isDark.toString();
          knob.style.transform = isDark ? 'translateX(30px)' : 'translateX(0)';
        }

        applyTheme(html.dataset.theme || 'dark');
        btnL.addEventListener('click', () => applyTheme('light'));
        btnD.addEventListener('click', () => applyTheme('dark'));
      })();

      // ── User dropdown ──────────────────────────────────────────────────────
      (function () {
        var btn      = document.getElementById('user-menu-btn');
        var dropdown = document.getElementById('user-dropdown');
        if (!btn || !dropdown) return;

        function openMenu() {
          dropdown.classList.add('open');
          btn.setAttribute('aria-expanded', 'true');
          dropdown.setAttribute('aria-hidden', 'false');
          var chevron = btn.querySelector('.avatar-chevron');
          if (chevron) chevron.style.transform = 'rotate(180deg)';
        }

        function closeMenu() {
          dropdown.classList.remove('open');
          btn.setAttribute('aria-expanded', 'false');
          dropdown.setAttribute('aria-hidden', 'true');
          var chevron = btn.querySelector('.avatar-chevron');
          if (chevron) chevron.style.transform = '';
        }

        btn.addEventListener('click', function (e) {
          e.stopPropagation();
          dropdown.classList.contains('open') ? closeMenu() : openMenu();
        });

        document.addEventListener('click', function () { closeMenu(); });
        document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeMenu(); });
        dropdown.addEventListener('click', function (e) { e.stopPropagation(); });
      })();
    </script>
  </body>
</html>

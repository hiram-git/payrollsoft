---
import { getPortalIdentity, portalInitials } from '../lib/portal-auth'

interface Props {
  title: string
}
const { title } = Astro.props
const identity = getPortalIdentity(Astro.cookies)
if (!identity) return Astro.redirect('/portal/login')
if (identity.mustChangePassword) return Astro.redirect('/portal/change-password')

const path = Astro.url.pathname

function isActive(href: string) {
  return path === href || (href !== '/portal' && path.startsWith(href))
}

const userInit = portalInitials(identity)
const userName = identity.name || 'Colaborador'
const userCode = identity.employeeCode || ''
---
<!doctype html>
<html lang="es" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Portal del Colaborador</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400&family=Inter+Tight:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <script is:inline>
    try { document.documentElement.dataset.theme = localStorage.getItem('portal.theme') || 'dark'; } catch(e) {}
  </script>
  <style is:global>
    :root, [data-theme="dark"] {
      --ink:#07101F; --ink-2:#0A1628; --ink-3:#101E33; --ink-4:#16263F;
      --navy:#003087; --navy-hi:#1E4BA8; --navy-soft:rgba(0,48,135,0.18);
      --rule:#1A2740; --rule-hi:#243555;
      --fore:#EDEEF2; --fore-dim:#C9CEDB; --mute-2:#8B97AE; --mute:#6A7690;
      --warn:#E3B25A; --err:#E06B5C; --ok:#6FB58C;
      --f-display:'Fraunces','Times New Roman',serif;
      --f-sans:'Inter Tight',-apple-system,system-ui,sans-serif;
      --f-mono:'JetBrains Mono',ui-monospace,monospace;
    }
    [data-theme="light"] {
      --ink:#F4F5F7; --ink-2:#FFFFFF; --ink-3:#FFFFFF; --ink-4:#EFF1F5;
      --navy:#003087; --navy-hi:#1E4BA8; --navy-soft:rgba(0,48,135,0.08);
      --rule:#E4E7EE; --rule-hi:#D2D7E0;
      --fore:#0C1424; --fore-dim:#2A3346; --mute-2:#5B6478; --mute:#7A8499;
      --warn:#B07A17; --err:#B53A2B; --ok:#2E7A56;
    }
    *, *::before, *::after { box-sizing: border-box; }
    html, body { height:100%; margin:0; }
    body {
      background: var(--ink); color: var(--fore);
      font-family: var(--f-sans); font-size: 14px; line-height: 1.5;
      -webkit-font-smoothing: antialiased; letter-spacing:-0.005em;
      transition: background 180ms ease, color 180ms ease;
    }
    .pt-shell { display:flex; height:100vh; width:100vw; overflow:hidden; }

    .pt-side {
      width:240px; flex-shrink:0; background:var(--ink-2);
      border-right:1px solid var(--rule);
      display:flex; flex-direction:column; padding:20px 14px;
      overflow-y:auto;
    }
    @media (max-width: 768px) {
      .pt-side { display:none; }
      .pt-mobile-toggle { display:flex !important; }
    }
    .pt-brand { display:flex; align-items:center; gap:12px; padding:4px 10px 20px; }
    .pt-brand-mark {
      width:32px; height:32px; border-radius:4px; background:var(--navy);
      display:grid; place-items:center; color:#fff;
      font-family: var(--f-display); font-size:18px;
    }
    .pt-brand-name { font-weight:500; font-size:14px; color:var(--fore); }
    .pt-brand-sub { font-family:var(--f-mono); font-size:9.5px; color:var(--mute); letter-spacing:.14em; text-transform:uppercase; margin-top:2px; }

    .pt-section { font-family:var(--f-mono); font-size:10px; color:var(--mute); letter-spacing:.16em; text-transform:uppercase; padding:14px 12px 8px; }

    .pt-item {
      display:flex; align-items:center; gap:12px; padding:9px 12px;
      border-radius:3px; color:var(--fore-dim); font-size:13.5px;
      text-decoration:none; transition:background 140ms ease, color 140ms ease;
      position:relative;
    }
    .pt-item:hover:not(.pt-active) { background:var(--ink-4); color:var(--fore); }
    .pt-active { background:var(--navy-soft); color:var(--fore); font-weight:500; }
    .pt-active::before { content:''; position:absolute; left:0; top:6px; bottom:6px; width:2px; background:var(--navy-hi); border-radius:0 2px 2px 0; }

    .pt-item svg { width:16px; height:16px; flex-shrink:0; opacity:.7; }
    .pt-active svg { opacity:1; }

    .pt-main { flex:1; display:flex; flex-direction:column; min-width:0; min-height:0; overflow:hidden; }

    .pt-top {
      height:56px; flex-shrink:0; background:var(--ink-2);
      border-bottom:1px solid var(--rule);
      display:flex; align-items:center; padding:0 24px; gap:12px;
    }
    .pt-mobile-toggle {
      display:none; align-items:center; justify-content:center;
      width:32px; height:32px; border:1px solid var(--rule); border-radius:4px;
      background:transparent; color:var(--fore-dim); cursor:pointer;
    }
    .pt-crumbs { flex:1; display:flex; align-items:center; gap:6px; font-size:13.5px; color:var(--mute-2); }
    .pt-crumbs .cur { color:var(--fore); font-weight:500; }

    .pt-user-pill {
      display:flex; align-items:center; gap:8px;
      padding:4px 10px 4px 4px; border-radius:999px;
      border:1px solid var(--rule); background:var(--ink-3);
      font-family:var(--f-sans);
    }
    .pt-circle { width:26px; height:26px; border-radius:50%; background:var(--navy); display:grid; place-items:center; font-size:11px; font-weight:600; color:#fff; }

    .pt-content { flex:1; overflow:auto; background:var(--ink); }

    /* Theme switch */
    .pt-ts-wrap {
      display: inline-flex; align-items: center; padding: 3px;
      background: var(--ink-3); border: 1px solid var(--rule);
      border-radius: 999px; position: relative;
    }
    .pt-ts-knob {
      position: absolute; top: 3px; bottom: 3px; width: 30px;
      background: var(--ink-2); border: 1px solid var(--rule-hi);
      border-radius: 999px; transition: transform 220ms cubic-bezier(.2,.7,.2,1);
      pointer-events: none;
    }
    .pt-ts-btn {
      position: relative; z-index: 2; width: 30px; height: 28px;
      display: grid; place-items: center; border: none; background: transparent;
      cursor: pointer; border-radius: 999px; transition: color 160ms ease;
    }
    .pt-ts-btn[data-active="true"]  { color: var(--fore); }
    .pt-ts-btn[data-active="false"] { color: var(--mute); }

    [data-theme="dark"] .pt-content .bg-white { background-color: var(--ink-2); }
    [data-theme="dark"] .pt-content .bg-gray-50 { background-color: var(--ink-3); }
    [data-theme="dark"] .pt-content .border-gray-200 { border-color: var(--rule); }
    [data-theme="dark"] .pt-content .border-gray-100 { border-color: var(--rule); }
    [data-theme="dark"] .pt-content .text-gray-900 { color: var(--fore); }
    [data-theme="dark"] .pt-content .text-gray-700 { color: var(--fore-dim); }
    [data-theme="dark"] .pt-content .text-gray-600 { color: var(--mute-2); }
    [data-theme="dark"] .pt-content .text-gray-500 { color: var(--mute); }
    [data-theme="dark"] .pt-content .text-gray-400 { color: var(--mute); }
    [data-theme="dark"] .pt-content .hover\:bg-gray-50:hover { background-color: var(--ink-4); }
    [data-theme="dark"] .pt-content input,
    [data-theme="dark"] .pt-content select,
    [data-theme="dark"] .pt-content textarea {
      background-color: var(--ink-3); border-color: var(--rule); color: var(--fore);
    }
    [data-theme="dark"] .pt-content input:focus,
    [data-theme="dark"] .pt-content select:focus,
    [data-theme="dark"] .pt-content textarea:focus {
      border-color: var(--navy-hi); box-shadow:0 0 0 2px var(--navy-soft);
    }

    /* ── Light mode overrides for portal content ── */
    [data-theme="light"] .pt-content { background:var(--ink); }
    [data-theme="light"] .pt-side { background:var(--ink-2); border-color:var(--rule); }
    [data-theme="light"] .pt-top { background:var(--ink-2); border-color:var(--rule); }
    [data-theme="light"] .pt-user-pill { background:var(--ink-4); border-color:var(--rule); }
    [data-theme="light"] .pt-item:hover:not(.pt-active) { background:var(--ink-4); }

    .pt-card {
      background: var(--ink-2);
      border: 1px solid var(--rule);
      border-radius: 6px;
      padding: 24px;
    }
    .pt-card-title {
      font-family: var(--f-sans);
      font-weight: 600;
      font-size: 15px;
      color: var(--fore);
      margin: 0 0 16px;
    }

    /* ── Shared design system classes for portal pages ── */

    /* Inputs / selects / textareas */
    .ds-input {
      width: 100%;
      padding: 8px 12px;
      font-size: 13px;
      font-family: var(--f-sans);
      background: var(--ink-3);
      border: 1px solid var(--rule);
      border-radius: 6px;
      color: var(--fore);
      outline: none;
      transition: border-color 140ms, box-shadow 140ms;
    }
    .ds-input:focus { border-color: var(--navy-hi); box-shadow: 0 0 0 2px var(--navy-soft); }
    .ds-input:disabled { opacity: .5; cursor: not-allowed; }
    .ds-input::placeholder { color: var(--mute); }
    select.ds-input { cursor: pointer; }

    /* Tables */
    .ds-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .ds-table thead th {
      font-family: var(--f-mono); font-size: 10px; color: var(--mute);
      letter-spacing: .1em; text-transform: uppercase; text-align: left;
      padding: 10px 14px; border-bottom: 1px solid var(--rule);
      background: var(--ink-3); position: sticky; top: 0;
    }
    .ds-table tbody td {
      padding: 10px 14px; color: var(--fore-dim);
      border-bottom: 1px solid var(--rule);
    }
    .ds-table tbody tr:last-child td { border-bottom: none; }
    .ds-table tbody tr:hover td { background: var(--ink-4); }

    /* Badges / chips */
    .ds-chip {
      display: inline-block; padding: 2px 8px; border-radius: 3px;
      font-family: var(--f-mono); font-size: 10px; letter-spacing: .06em;
      text-transform: uppercase; font-weight: 500;
    }
    .ds-chip-pending  { background: rgba(227,178,90,0.15); color: var(--warn); }
    .ds-chip-approved { background: rgba(111,181,140,0.15); color: var(--ok); }
    .ds-chip-rejected { background: rgba(224,107,92,0.15); color: var(--err); }
    .ds-chip-present  { background: rgba(111,181,140,0.15); color: var(--ok); }
    .ds-chip-late     { background: rgba(227,178,90,0.15); color: var(--warn); }
    .ds-chip-absent   { background: rgba(224,107,92,0.15); color: var(--err); }
    .ds-chip-default  { background: var(--ink-4); color: var(--mute-2); }

    /* Buttons */
    .ds-btn-primary {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 8px 16px; background: var(--navy); color: #fff;
      border: none; border-radius: 6px; font-family: var(--f-sans);
      font-weight: 500; font-size: 13px; cursor: pointer;
      transition: background 140ms;
    }
    .ds-btn-primary:hover { background: var(--navy-hi); }
    .ds-btn-ghost {
      padding: 8px 16px; border-radius: 6px;
      border: 1px solid var(--rule); background: transparent;
      color: var(--fore-dim); font-size: 13px; cursor: pointer;
      font-family: var(--f-sans); transition: border-color 140ms, background 140ms;
    }
    .ds-btn-ghost:hover { border-color: var(--rule-hi); background: var(--ink-4); }

    /* Labels */
    .ds-label {
      display: block; font-size: 12px; font-weight: 500;
      color: var(--fore-dim); margin-bottom: 6px;
    }

    /* Empty state */
    .ds-empty {
      padding: 48px 16px; text-align: center;
      color: var(--mute); font-size: 13px;
    }

    /* Mono text */
    .ds-mono { font-family: var(--f-mono); font-size: 11px; color: var(--mute-2); }

    /* Card wrapper (for tables) */
    .ds-card-table {
      background: var(--ink-2); border: 1px solid var(--rule);
      border-radius: 8px; overflow: hidden;
    }
  </style>
</head>
<body>
  <div class="pt-shell">
    <aside class="pt-side" id="pt-sidebar">
      <div class="pt-brand">
        <div class="pt-brand-mark">P</div>
        <div>
          <div class="pt-brand-name">PayrollSoft</div>
          <div class="pt-brand-sub">Portal</div>
        </div>
      </div>

      <div class="pt-section">Menú</div>

      <a href="/portal" class={`pt-item${isActive('/portal') && path === '/portal' ? ' pt-active' : ''}`}>
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
          <path d="M2 6l6-4 6 4v7a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V6z"/>
          <path d="M6 14V9h4v5"/>
        </svg>
        Inicio
      </a>

      {(identity.modules.length === 0 || identity.modules.includes('requests')) && (
        <a href="/portal/requests" class={`pt-item${isActive('/portal/requests') ? ' pt-active' : ''}`}>
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
            <path d="M13 2H3a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V3a1 1 0 0 0-1-1z"/>
            <path d="M5 6h6M5 9h4"/>
          </svg>
          Solicitudes
        </a>
      )}

      {(identity.modules.length === 0 || identity.modules.includes('attendance')) && (
        <a href="/portal/attendance" class={`pt-item${isActive('/portal/attendance') ? ' pt-active' : ''}`}>
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="8" cy="8" r="6"/>
            <path d="M8 4.5V8l2.5 1.5"/>
          </svg>
          Mis marcaciones
        </a>
      )}

      {identity.isApprover && (
        <a href="/portal/approvals" class={`pt-item${isActive('/portal/approvals') ? ' pt-active' : ''}`}>
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2l-8.5 8.5L2 7"/>
          </svg>
          Aprobaciones
        </a>
      )}

      <div style="margin-top:auto; padding:12px 0;">
        <div style="padding:8px 12px; margin-bottom:8px; border-radius:4px; background:var(--ink-3); border:1px solid var(--rule);">
          <div style="font-size:12.5px; font-weight:500; color:var(--fore-dim); margin-bottom:2px;">{userName}</div>
          <div style="font-family:var(--f-mono); font-size:10px; color:var(--mute); letter-spacing:.08em; text-transform:uppercase;">Código: {userCode}</div>
        </div>
        <button
          type="button"
          id="logout-btn"
          style="width:100%; padding:8px 12px; border-radius:4px; border:1px solid var(--rule); background:transparent; color:var(--mute-2); font-size:12px; cursor:pointer; font-family:var(--f-sans);"
        >
          Cerrar sesión
        </button>
      </div>
    </aside>

    <div class="pt-main">
      <header class="pt-top">
        <button class="pt-mobile-toggle" id="pt-menu-btn" aria-label="Menú">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
            <path d="M2 4h12M2 8h12M2 12h12"/>
          </svg>
        </button>
        <div class="pt-crumbs">
          <span>Portal</span>
          <span style="opacity:.4">/</span>
          <span class="cur">{title}</span>
        </div>
        <div class="pt-ts-wrap" role="group" aria-label="Cambiar tema" id="pt-ts-wrap">
          <span class="pt-ts-knob" id="pt-ts-knob"></span>
          <button class="pt-ts-btn" id="pt-ts-light" data-active="false" aria-label="Tema claro" title="Tema claro">
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
              <circle cx="7" cy="7" r="2.6"/>
              <path d="M7 1.5v1.3M7 11.2v1.3M1.5 7h1.3M11.2 7h1.3M3 3l.9.9M10.1 10.1l.9.9M3 11l.9-.9M10.1 3.9l.9-.9"/>
            </svg>
          </button>
          <button class="pt-ts-btn" id="pt-ts-dark" data-active="true" aria-label="Tema oscuro" title="Tema oscuro">
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
              <path d="M11.5 8.5A4.8 4.8 0 0 1 5.5 2.5a5 5 0 1 0 6 6Z"/>
            </svg>
          </button>
        </div>
        <div class="pt-user-pill" title={`${userName} · ${userCode}`}>
          <div class="pt-circle">{userInit}</div>
          <span style="font-size:12.5px; font-weight:500; color:var(--fore-dim);">{userName}</span>
        </div>
      </header>
      <main class="pt-content"><slot /></main>
    </div>
  </div>

  <script is:inline>
    (function() {
      var logoutBtn = document.getElementById('logout-btn');
      if (logoutBtn) {
        logoutBtn.addEventListener('click', function() {
          fetch('/api/portal/logout', { method: 'POST' })
            .then(function() { window.location.href = '/portal/login'; })
            .catch(function() { window.location.href = '/portal/login'; });
        });
      }

      var tsKnob = document.getElementById('pt-ts-knob');
      var tsLight = document.getElementById('pt-ts-light');
      var tsDark = document.getElementById('pt-ts-dark');
      function applyPortalTheme(t) {
        document.documentElement.dataset.theme = t;
        try { localStorage.setItem('portal.theme', t); } catch(e) {}
        var isDark = t === 'dark';
        tsLight.dataset.active = (!isDark).toString();
        tsDark.dataset.active = isDark.toString();
        tsKnob.style.transform = isDark ? 'translateX(30px)' : 'translateX(0)';
      }
      applyPortalTheme(document.documentElement.dataset.theme || 'dark');
      tsLight.addEventListener('click', function() { applyPortalTheme('light'); });
      tsDark.addEventListener('click', function() { applyPortalTheme('dark'); });

      var menuBtn = document.getElementById('pt-menu-btn');
      var sidebar = document.getElementById('pt-sidebar');
      if (menuBtn && sidebar) {
        menuBtn.addEventListener('click', function() {
          var isVisible = sidebar.style.display === 'flex';
          sidebar.style.display = isVisible ? 'none' : 'flex';
          sidebar.style.position = isVisible ? '' : 'fixed';
          sidebar.style.zIndex = isVisible ? '' : '50';
          sidebar.style.top = isVisible ? '' : '0';
          sidebar.style.left = isVisible ? '' : '0';
          sidebar.style.height = isVisible ? '' : '100vh';
        });
      }
    })();
  </script>
</body>
</html>

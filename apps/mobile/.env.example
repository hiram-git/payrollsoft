# URL base de la API Elysia (apps/api). El móvil habla DIRECTO con ella,
# sin pasar por el BFF de Astro. En emulador Android usa la IP del host
# (10.0.2.2) en vez de localhost.
VITE_API_URL=http://localhost:3000

# Slug del tenant que se envía en el header X-Tenant en cada request.
VITE_TENANT=demo

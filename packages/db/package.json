{
  "name": "@payroll/db",
  "version": "0.0.1",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:generate:public": "drizzle-kit generate --config drizzle.public.config.ts",
    "db:generate:tenant": "drizzle-kit generate --config drizzle.tenant.config.ts",
    "db:migrate:public": "bun --env-file=../../.env src/migrate.ts --public",
    "db:migrate:tenant": "bun --env-file=../../.env src/migrate.ts --tenant=demo",
    "db:migrate:all-tenants": "bun --env-file=../../.env src/migrate.ts --all-tenants",
    "migrate:prod:public": "bun src/migrate.ts --public",
    "migrate:prod:tenant": "bun src/migrate.ts --tenant=demo",
    "migrate:prod": "bun src/migrate.ts --public && bun src/migrate.ts --tenant=demo",
    "db:seed": "bun --env-file=../../.env src/seed.ts",
    "seed:prod": "bun src/seed.ts",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.3",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.7.2"
  }
}

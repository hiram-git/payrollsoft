# API
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/payroll_panama
JWT_SECRET=change-this-to-a-random-string-with-at-least-32-characters
# Public URL of the web app — used to build the absolute links embedded
# in transactional emails (e.g. password reset). Must point to the
# user-facing host, not the API.
WEB_URL=http://localhost:4321

# Web
PUBLIC_API_URL=http://localhost:3000

# ─── SMTP (used by the password recovery flow) ──────────────────────────
# SMTP credentials are configured per tenant under
# /config/company → tab "Servidor SMTP" (host, port, encryption, user,
# password, from address). No env vars required: each company can use
# its own provider (Gmail, Sendgrid, Mailgun, etc.). When the tenant
# leaves the SMTP fields empty, the password reset endpoint silently
# accepts the request but never sends mail — the operator should fill
# them in before the feature can deliver emails.

# ─── Cloudflare R2 (only used when a tenant sets payroll_report_mode = 'file_storage') ───
# Optional. If you keep every tenant on the default 'on_demand' mode,
# none of these are required and the app works locally without R2.
# Endpoint: https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Optional: public CDN URL prefix for direct-from-browser downloads
# (currently unused; reserved for a future signed-URL / CDN optimisation).
R2_PUBLIC_URL=
